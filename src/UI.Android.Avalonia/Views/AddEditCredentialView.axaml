<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PhantomVault.UI.ViewModels"
             x:Class="PhantomVault.UI.Views.AddEditCredentialView"
             x:DataType="vm:AddEditCredentialViewModel"
             Background="{DynamicResource WindowBackgroundBrush}">

  <ScrollViewer>
    <StackPanel Margin="20,20,20,24" Spacing="14">

      <TextBlock Text="New credential"
                 FontSize="{StaticResource Type.H2.Size}"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource PrimaryTextBrush}"/>

      <StackPanel Spacing="4">
        <TextBlock Text="Title"
                   FontSize="{StaticResource Type.Label.Size}"
                   Foreground="{DynamicResource SecondaryTextBrush}"/>
        <TextBox Text="{Binding Title, Mode=TwoWay}"
                 Watermark="e.g. GitHub" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Username or email"
                   FontSize="{StaticResource Type.Label.Size}"
                   Foreground="{DynamicResource SecondaryTextBrush}"/>
        <TextBox Text="{Binding Username, Mode=TwoWay}"
                 Watermark="username@example.com" />
      </StackPanel>

      <StackPanel Spacing="4">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" Text="Password"
                     FontSize="{StaticResource Type.Label.Size}"
                     Foreground="{DynamicResource SecondaryTextBrush}"/>
          <Button Grid.Column="1"
                  Content="Show/Hide"
                  FontSize="{StaticResource Type.Tiny.Size}"
                  Background="Transparent"
                  Foreground="{DynamicResource AccentBrush}"
                  Padding="6,2"
                  Command="{Binding TogglePasswordVisibilityCommand}"/>
        </Grid>
        <TextBox Text="{Binding Password, Mode=TwoWay}"
                 PasswordChar="•"
                 Watermark="Strong unique password"
                 IsVisible="{Binding !IsPasswordVisible}"/>
        <TextBox Text="{Binding Password, Mode=TwoWay}"
                 Watermark="Strong unique password"
                 IsVisible="{Binding IsPasswordVisible}"/>
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="URL"
                   FontSize="{StaticResource Type.Label.Size}"
                   Foreground="{DynamicResource SecondaryTextBrush}"/>
        <TextBox Text="{Binding Url, Mode=TwoWay}"
                 Watermark="https://github.com" />
      </StackPanel>

      <StackPanel Spacing="4">
        <TextBlock Text="Notes"
                   FontSize="{StaticResource Type.Label.Size}"
                   Foreground="{DynamicResource SecondaryTextBrush}"/>
        <TextBox Text="{Binding Notes, Mode=TwoWay}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 MinHeight="84" />
      </StackPanel>

      <TextBlock Text="{Binding Status}"
                 FontSize="{StaticResource Type.Tiny.Size}"
                 Foreground="{DynamicResource AccentBrush}"
                 TextWrapping="Wrap"
                 IsVisible="{Binding Status, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

      <Grid ColumnDefinitions="*,*" Margin="0,6,0,0">
        <Button Grid.Column="0"
                Content="Cancel"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Margin="0,0,8,0"
                Padding="0,12"
                Background="Transparent"
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Foreground="{DynamicResource PrimaryTextBrush}"
                Command="{Binding CancelCommand}"/>
        <Button Grid.Column="1"
                Content="Save"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Margin="8,0,0,0"
                Padding="0,12"
                Background="{DynamicResource AccentBrush}"
                Foreground="White"
                CornerRadius="10"
                FontWeight="SemiBold"
                Command="{Binding SaveCommand}"/>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
