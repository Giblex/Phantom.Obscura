<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PhantomVault.UI.ViewModels"
             xmlns:models="using:PhantomVault.UI.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PhantomVault.UI.Views.WelcomePage"
             x:DataType="vm:WelcomePageViewModel"
             Background="{DynamicResource WindowBackgroundBrush}">

  <!--
    Android adaptation of Views/WelcomePage.axaml from UI.Desktop.
    Layout deltas vs desktop:
      (1) Root is UserControl (Window doesn't host under SingleViewApplicationLifetime).
      (2) Redundant page-level header dropped — the AppShell already shows the
          "Phantom Obscura" title + brand icon in the top bar, so we lead with
          the welcome message + logo tile instead of repeating the title.
      (3) Logo + USB-gate cards stack vertically for phone widths; tablet form
          factors get the same layout but with more breathing room.
      (4) Pulse-ring + trace animations from desktop's 800-LOC code-behind are
          deferred to a later phase.
  -->

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://PhantomVault.UI/Assets/Themes/PreVaultTheme.axaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Button.vault-choice">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.action-pill">
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="Width" Value="116"/>
      <Setter Property="FontSize" Value="{StaticResource Type.Body.Size}"/>
      <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
  </UserControl.Styles>

  <!-- Two-row grid: scrolling body + sticky action footer. -->
  <Grid RowDefinitions="*,Auto" Background="{DynamicResource WindowBackgroundBrush}">

    <!-- ─── Main content (logo + status + gate card) ───────────────────────── -->
    <ScrollViewer Grid.Row="0"
                  Background="{DynamicResource WindowBackgroundBrush}"
                  Padding="20,16,20,16"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="16" HorizontalAlignment="Stretch" VerticalAlignment="Top">

        <!-- Welcome subtitle (single tagline, no duplicated app name). -->
        <TextBlock Text="{Binding WelcomeMessage}"
                   FontSize="{StaticResource Type.Body.Size}"
                   Foreground="{DynamicResource HeaderMutedTextBrush}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,4,0,0"/>

        <!-- Brand tile: icon stacked above wordmark — fits any phone width. -->
        <Border CornerRadius="16"
                ClipToBounds="True"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}"
                BorderThickness="1"
                HorizontalAlignment="Stretch"
                Padding="20,18">
          <StackPanel Orientation="Vertical"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="10">
            <Image Source="avares://PhantomVault.UI/Assets/Visuals/Giblex Icons/Icon Transparent background.png"
                   Stretch="Uniform" MaxHeight="110"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="Phantom Obscura"
                       FontSize="26"
                       FontFamily="{DynamicResource TitleFontFamily}"
                       FontWeight="Normal"
                       Foreground="#1A6B75"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- Version, centred under the logo. -->
        <TextBlock Text="{Binding AppVersion}"
                   FontSize="{StaticResource Type.Tiny.Size}"
                   Foreground="{DynamicResource MutedTextBrush}"
                   HorizontalAlignment="Center"/>

        <!-- Status pill: indeterminate progress + status copy. -->
        <Border Background="{DynamicResource ControlBackgroundBrush}"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="1"
                CornerRadius="999"
                Padding="14,8"
                HorizontalAlignment="Center"
                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <ProgressBar IsIndeterminate="True"
                         Width="64" Height="4"
                         Foreground="{DynamicResource AccentBrush}"
                         IsVisible="{Binding IsDeviceDetectionActive}"/>
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="{StaticResource Type.Label.Size}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- USB gate / vault discovery card — vertically stacked content. -->
        <Border Background="{DynamicResource ControlBackgroundBrush}"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="20,18"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding IsLandingVisible}">
          <StackPanel Spacing="12" HorizontalAlignment="Stretch">
            <!-- Centred indicator dot. -->
            <Border Width="22" Height="22" CornerRadius="11"
                    Background="{DynamicResource AccentBrush}"
                    HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding DeviceLinkHeadline}"
                       FontSize="{StaticResource Type.H4.Size}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding DeviceLinkDetail}"
                       FontSize="{StaticResource Type.Small.Size}"
                       Foreground="{DynamicResource MutedTextBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding DetectedVaultPathDisplay}"
                       FontSize="{StaticResource Type.Tiny.Size}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontFamily="{StaticResource MonoFontFamily}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       IsVisible="{Binding HasRecognizedVaults}"/>

            <!-- Picker for the multi-vault case. -->
            <StackPanel Spacing="6" IsVisible="{Binding ShowVaultPicker}" Margin="0,6,0,0">
              <TextBlock Text="Available vaults on this USB"
                         FontSize="{StaticResource Type.Label.Size}"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         HorizontalAlignment="Center"/>
              <ItemsControl ItemsSource="{Binding DetectedVaults}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:DetectedVaultLaunchRequest">
                    <Button Classes="vault-choice"
                            Click="DetectedVaultChoice_Click"
                            Tag="{Binding}"
                            Margin="0,0,0,8">
                      <Border Background="#121C2B"
                              CornerRadius="14"
                              Padding="14,10"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource ControlBorderBrush}">
                        <StackPanel Spacing="2">
                          <TextBlock Text="{Binding DisplayName}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     FontSize="{StaticResource Type.Body.Size}"/>
                          <TextBlock Text="{Binding VaultPath}"
                                     FontSize="{StaticResource Type.Tiny.Size}"
                                     Foreground="{DynamicResource MutedTextBrush}"
                                     FontFamily="{StaticResource MonoFontFamily}"
                                     TextWrapping="NoWrap"
                                     TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                      </Border>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ─── Setup choice (after Get Started tapped) ──────────────────── -->
        <Border Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="16"
                Padding="20,18"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding IsSetupChoiceVisible}">
          <StackPanel Spacing="14">
            <TextBlock Text="Choose Your Setup Path"
                       FontSize="{StaticResource Type.H3.Size}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>

            <!-- Two tap-target tiles stacked vertically on phone (WrapPanel
                 places them side-by-side on tablet). Each has a "?" help button
                 anchored to the top-right that opens a Flyout with the full
                 description, so the tile itself stays at-a-glance. -->
            <WrapPanel ItemSpacing="12" LineSpacing="12" HorizontalAlignment="Center">
              <Grid Width="280" Height="120">
                <Border CornerRadius="16" Background="#162235"/>
                <Button Command="{Binding ShowDefaultSetupCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="16"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Padding="0">
                  <StackPanel Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Default Setup"
                               FontSize="{StaticResource Type.H4.Size}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Recommended"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <!-- Help icon, top-right -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        Width="28" Height="28"
                        Padding="0"
                        CornerRadius="14"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1">
                  <TextBlock Text="?"
                             FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  <Button.Flyout>
                    <Flyout Placement="Bottom">
                      <StackPanel MaxWidth="280" Spacing="8">
                        <TextBlock Text="Default Setup" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Best if you just want a vault without wrestling the knobs. You choose the vault name and your authentication, and Obscura handles the rest with hardened defaults."
                                   FontSize="{StaticResource Type.Small.Size}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Includes Ghost Secured, PhantomKey, dual keyfiles, USB binding, 1 GB container, and remnant cleanup."
                                   FontSize="{StaticResource Type.Small.Size}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>
                      </StackPanel>
                    </Flyout>
                  </Button.Flyout>
                </Button>
              </Grid>

              <Grid Width="280" Height="120">
                <Border CornerRadius="16" Background="#162235"/>
                <Button Command="{Binding ShowAdvancedSetupCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="16"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Padding="0">
                  <StackPanel Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Advanced Setup"
                               FontSize="{StaticResource Type.H4.Size}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Power user"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        Width="28" Height="28"
                        Padding="0"
                        CornerRadius="14"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1">
                  <TextBlock Text="?"
                             FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  <Button.Flyout>
                    <Flyout Placement="Bottom">
                      <StackPanel MaxWidth="280" Spacing="8">
                        <TextBlock Text="Advanced Setup" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Best if you want full control over the protection tier, storage layout, keyfile flow, remnant handling, and every other vault-building decision."
                                   FontSize="{StaticResource Type.Small.Size}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="You will walk through the full wizard and choose the exact security profile and provisioning path."
                                   FontSize="{StaticResource Type.Small.Size}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>
                      </StackPanel>
                    </Flyout>
                  </Button.Flyout>
                </Button>
              </Grid>
            </WrapPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- ─── Action footer (sticky bottom row) ────────────────────────────── -->
    <Border Grid.Row="1"
            Background="{DynamicResource HeaderBackgroundBrush}"
            BorderBrush="{DynamicResource FooterBorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="14,12">
      <WrapPanel Orientation="Horizontal" ItemSpacing="8" LineSpacing="8"
                 HorizontalAlignment="Center">
        <!-- Landing-state buttons -->
        <Button Classes="action-pill"
                Command="{Binding GetStartedCommand}"
                IsVisible="{Binding IsLandingVisible}">
          <TextBlock Text="Get Started" Foreground="{DynamicResource ButtonTextBrush}"/>
        </Button>
        <Button Classes="action-pill"
                Command="{Binding OpenExistingVaultCommand}"
                IsVisible="{Binding IsLandingVisible}"
                IsEnabled="{Binding HasSelectedVault}">
          <TextBlock Text="{Binding OpenVaultButtonText}" Foreground="{DynamicResource ButtonTextBrush}"/>
        </Button>
        <Button Classes="action-pill"
                Click="About_Click"
                IsVisible="{Binding IsLandingVisible}">
          <TextBlock Text="About" Foreground="{DynamicResource ButtonTextBrush}"/>
        </Button>
        <Button Classes="action-pill"
                Click="Import_Click"
                IsVisible="{Binding IsLandingVisible}">
          <TextBlock Text="Import" Foreground="{DynamicResource ButtonTextBrush}"/>
        </Button>

        <!-- Setup-choice-state button -->
        <Button Classes="action-pill"
                Command="{Binding BackToWelcomeCommand}"
                IsVisible="{Binding IsSetupChoiceVisible}">
          <TextBlock Text="Back" Foreground="{DynamicResource ButtonTextBrush}"/>
        </Button>
      </WrapPanel>
    </Border>
  </Grid>
</UserControl>
