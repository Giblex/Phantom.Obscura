<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PhantomVault.UI.ViewModels"
             xmlns:models="using:PhantomVault.UI.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="PhantomVault.UI.Views.WelcomePage"
             x:DataType="vm:WelcomePageViewModel"
             Background="{DynamicResource WindowBackgroundBrush}">

  <!--
    Android adaptation of Views/WelcomePage.axaml from UI.Desktop.
    Content is a verbatim port of the desktop layout, with three deltas:
      (1) Root is UserControl, not ThemeAwareWindow, so it can be hosted under
          SingleViewApplicationLifetime on Android.
      (2) Window-scoped pulse-ring/trace animations were removed — they live
          in the desktop's .axaml.cs animation harness (809 LOC) which we'll
          port piecemeal in a later phase.
      (3) `Classes="liquid-glass*"` classes are commented-out until we link
          Giblex.Controls.BorderEnergyTrace + LiquidGlass.axaml (Phase 4).
    All bindings, brushes, and StaticResource type sizes match desktop exactly.
  -->

  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://PhantomVault.UI/Assets/Themes/PreVaultTheme.axaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <UserControl.Styles>
    <Style Selector="Button.vault-choice">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto"
        Margin="0"
        Background="{DynamicResource WindowBackgroundBrush}">

    <!-- ── Header (taller, more prominent — verbatim from desktop) ────────── -->
    <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" Padding="14,12">
      <StackPanel HorizontalAlignment="Center" Spacing="8">
        <TextBlock Text="{Binding AppName}"
                   FontSize="{StaticResource Type.H2.Size}"
                   FontFamily="{DynamicResource TitleFontFamily}"
                   FontWeight="Normal"
                   Foreground="{DynamicResource HeaderTextBrush}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="{Binding WelcomeMessage}"
                   FontSize="{StaticResource Type.Body.Size}"
                   Foreground="{DynamicResource HeaderTextBrush}"
                   HorizontalAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- ── Main content (centred logo tile + status + vault picker) ──────── -->
    <ScrollViewer x:Name="MainScrollViewer"
                  Grid.Row="1"
                  Background="{DynamicResource WindowBackgroundBrush}"
                  Padding="20,20,20,28"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="18" HorizontalAlignment="Center" VerticalAlignment="Center" MinHeight="300" Margin="0,0,0,112">

        <!-- Centred tile with logo. Phone-friendly: WrapPanel lets the wordmark
             stack below the icon when horizontal space is tight (typical phone
             portrait) and sit beside it on wider tablet form factors. -->
        <Border CornerRadius="16"
                ClipToBounds="True"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}"
                BorderThickness="1"
                HorizontalAlignment="Stretch" VerticalAlignment="Center"
                MaxWidth="760" MinHeight="188" MaxHeight="320" Padding="16,18">
          <StackPanel Orientation="Vertical"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Spacing="10">
            <Image Source="avares://PhantomVault.UI/Assets/Visuals/Giblex Icons/Icon Transparent background.png"
                   Stretch="Uniform" MaxHeight="110"
                   HorizontalAlignment="Center"/>
            <TextBlock Text="Phantom Obscura"
                       FontSize="26"
                       FontFamily="{DynamicResource TitleFontFamily}"
                       FontWeight="Normal"
                       Foreground="#1A6B75"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <TextBlock Text="{Binding AppVersion}"
                   FontSize="{StaticResource Type.Tiny.Size}"
                   Foreground="{DynamicResource MutedTextBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,6,0,0"/>

        <!-- Status + indeterminate progress card -->
        <Border x:Name="DetectionStatusCard"
                Background="{DynamicResource WindowBackgroundBrush}"
                CornerRadius="20"
                Padding="18,12"
                HorizontalAlignment="Center"
                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                Margin="0,10,0,0"
                BorderBrush="{DynamicResource ControlBackgroundBrush}"
                BorderThickness="4">
          <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
            <ProgressBar IsIndeterminate="True"
                         Width="72"
                         Height="4"
                         Foreground="{DynamicResource AccentBrush}"
                         IsVisible="{Binding IsDeviceDetectionActive}"/>
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="{StaticResource Type.Label.Size}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       FontWeight="Normal"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Border>

        <ProgressBar IsIndeterminate="True"
                     IsVisible="{Binding IsDeviceDetectionActive}"
                     Height="4"
                     Foreground="{DynamicResource AccentBrush}"
                     Width="260"
                     Margin="0,10,0,0"/>

        <!-- Detected vault card (USB found, vaults listed) -->
        <Border x:Name="DetectedVaultCard"
                Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource CardBackgroundBrush}"
                BorderThickness="4"
                CornerRadius="20"
                Padding="18,16"
                MaxWidth="760"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding IsLandingVisible}">
          <StackPanel Spacing="14">
            <!-- Phone-safe layout: vertical stack with the white indicator dot
                 sitting above the headline / detail text instead of beside.
                 The desktop version uses a 120dp Grid on the left which
                 over-runs phone widths. -->
            <Border Width="22" Height="22" CornerRadius="11" Background="#FFFFFF"
                    HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding DeviceLinkHeadline}"
                       FontSize="{StaticResource Type.H4.Size}"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding DeviceLinkDetail}"
                       FontSize="{StaticResource Type.Small.Size}"
                       Foreground="{DynamicResource MutedTextBrush}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding DetectedVaultPathDisplay}"
                       FontSize="{StaticResource Type.Small.Size}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       IsVisible="{Binding HasRecognizedVaults}"/>

            <StackPanel x:Name="VaultListAnchor"
                        Spacing="8"
                        IsVisible="{Binding ShowVaultPicker}">
              <TextBlock Text="Available vaults on this USB"
                         FontSize="{StaticResource Type.Label.Size}"
                         Foreground="{DynamicResource PrimaryTextBrush}"/>
              <ItemsControl ItemsSource="{Binding DetectedVaults}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:DetectedVaultLaunchRequest">
                    <Button Classes="vault-choice"
                            Click="DetectedVaultChoice_Click"
                            Tag="{Binding}"
                            Margin="0,0,0,8">
                      <Border Background="#121C2B"
                              CornerRadius="14"
                              Padding="16,10"
                              Width="336"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource ControlBorderBrush}">
                        <StackPanel Spacing="2" HorizontalAlignment="Stretch">
                          <TextBlock Text="{Binding DisplayName}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     FontSize="{StaticResource Type.Body.Size}"/>
                          <TextBlock Text="{Binding VaultPath}"
                                     FontSize="{StaticResource Type.Tiny.Size}"
                                     Foreground="{DynamicResource MutedTextBrush}"
                                     TextWrapping="NoWrap"
                                     TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                      </Border>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Setup choice card (Default vs Advanced).
             Phone-friendly: two big tap targets + a "?" help icon in the top-right
             corner of each tile. The icon opens a Flyout with the full description
             (formerly inline paragraphs), so the choice surface stays at-a-glance. -->
        <Border Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="20"
                Padding="20,18"
                MaxWidth="760"
                HorizontalAlignment="Stretch"
                IsVisible="{Binding IsSetupChoiceVisible}"
                BoxShadow="0 8 24 0 #30000000">
          <StackPanel Spacing="14">
            <TextBlock Text="Choose Your Setup Path"
                       FontSize="{StaticResource Type.H3.Size}"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       TextWrapping="Wrap"/>

            <!-- Tile group: stacks vertically on phones, side-by-side once
                 there's room. Each tile is a Grid so the help "?" can sit
                 absolutely in the top-right corner regardless of phone width. -->
            <WrapPanel ItemSpacing="12" LineSpacing="12">
              <!-- Default Setup tile -->
              <Grid Background="#162235"
                    Width="320" MinHeight="120"
                    HorizontalAlignment="Stretch">
                <Border CornerRadius="18" Background="#162235"/>
                <Button Command="{Binding ShowDefaultSetupCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="18"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Padding="20,16">
                  <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Default Setup"
                               FontSize="{StaticResource Type.H4.Size}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Recommended"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource AccentBrush}"
                               HorizontalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <!-- Help "?" pinned top-right; opens a flyout with the full description -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        Width="28" Height="28"
                        Padding="0"
                        CornerRadius="14"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        ToolTip.Tip="What's in Default Setup?">
                  <TextBlock Text="?"
                             FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  <Button.Flyout>
                    <Flyout Placement="Bottom">
                      <StackPanel MaxWidth="280" Spacing="8">
                        <TextBlock Text="Default Setup"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Best if you just want a vault without wrestling the knobs. You choose the vault name and your authentication, and Obscura handles the rest with hardened defaults."
                                   FontSize="{StaticResource Type.Small.Size}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Includes Ghost Secured, PhantomKey, dual keyfiles, USB binding, 1 GB container, and remnant cleanup."
                                   FontSize="{StaticResource Type.Small.Size}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>
                      </StackPanel>
                    </Flyout>
                  </Button.Flyout>
                </Button>
              </Grid>

              <!-- Advanced Setup tile -->
              <Grid Background="#162235"
                    Width="320" MinHeight="120"
                    HorizontalAlignment="Stretch">
                <Border CornerRadius="18" Background="#162235"/>
                <Button Command="{Binding ShowAdvancedSetupCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="18"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Padding="20,16">
                  <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Advanced Setup"
                               FontSize="{StaticResource Type.H4.Size}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Power user"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        Width="28" Height="28"
                        Padding="0"
                        CornerRadius="14"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        ToolTip.Tip="What's in Advanced Setup?">
                  <TextBlock Text="?"
                             FontSize="14" FontWeight="Bold"
                             Foreground="{DynamicResource AccentBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  <Button.Flyout>
                    <Flyout Placement="Bottom">
                      <StackPanel MaxWidth="280" Spacing="8">
                        <TextBlock Text="Advanced Setup"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Best if you want full control over the protection tier, storage layout, keyfile flow, remnant handling, and every other vault-building decision."
                                   FontSize="{StaticResource Type.Small.Size}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="You will walk through the full wizard and choose the exact security profile and provisioning path."
                                   FontSize="{StaticResource Type.Small.Size}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>
                      </StackPanel>
                    </Flyout>
                  </Button.Flyout>
                </Button>
              </Grid>
            </WrapPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- ── Action footer (Get Started, Open Vault, About, Import, ...) ──────
         Phone-friendly: ItemWidth lowered so two buttons fit per row on a
         typical 360dp phone instead of clipping off the right edge. -->
    <Border x:Name="ActionFooterCard"
            Grid.Row="2"
            Background="{DynamicResource HeaderBackgroundBrush}"
            Padding="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            MaxWidth="760"
            CornerRadius="16"
            Margin="14,8,14,16"
            BorderBrush="{DynamicResource FooterBorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">
      <WrapPanel Orientation="Horizontal" ItemWidth="128" HorizontalAlignment="Center">
        <Button Command="{Binding GetStartedCommand}" CornerRadius="10" Height="40" Width="116"
                FontSize="{StaticResource Type.Body.Size}" FontWeight="Normal"
                FontFamily="{DynamicResource MainFontFamily}"
                IsVisible="{Binding IsLandingVisible}">
          <TextBlock Text="Get Started" Foreground="{DynamicResource ButtonTextBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>

        <Button Command="{Binding OpenExistingVaultCommand}" CornerRadius="10" Height="40" Width="116"
                FontSize="{StaticResource Type.Body.Size}" FontFamily="{DynamicResource MainFontFamily}"
                IsVisible="{Binding IsLandingVisible}" IsEnabled="{Binding HasSelectedVault}">
          <TextBlock Text="{Binding OpenVaultButtonText}" Foreground="{DynamicResource ButtonTextBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>

        <Button Click="About_Click" CornerRadius="10" Height="40" Width="116"
                FontFamily="{DynamicResource MainFontFamily}" FontSize="{StaticResource Type.Body.Size}"
                ToolTip.Tip="About this app"
                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                IsVisible="{Binding IsLandingVisible}">
          <TextBlock Text="About" Foreground="{DynamicResource ButtonTextBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>

        <Button Click="Import_Click" CornerRadius="10" Height="40" Width="116"
                FontFamily="{DynamicResource MainFontFamily}" FontSize="{StaticResource Type.Body.Size}"
                ToolTip.Tip="Import data"
                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                IsVisible="{Binding IsLandingVisible}">
          <TextBlock Text="Import" Foreground="{DynamicResource ButtonTextBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>

        <Button Command="{Binding BackToWelcomeCommand}" CornerRadius="10" Height="40" Width="116"
                FontFamily="{DynamicResource MainFontFamily}" FontSize="{StaticResource Type.Body.Size}"
                IsVisible="{Binding IsSetupChoiceVisible}">
          <TextBlock Text="Back" Foreground="{DynamicResource ButtonTextBrush}"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Button>
      </WrapPanel>
    </Border>

  </Grid>
</UserControl>
