<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PhantomVault.UI.ViewModels"
             x:Class="PhantomVault.UI.Views.CredentialListView"
             x:DataType="vm:CredentialListViewModel"
             Background="{DynamicResource WindowBackgroundBrush}">

  <Grid RowDefinitions="Auto,*,Auto" Margin="20,20,20,16">

    <!-- Header -->
    <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
      <TextBlock Text="Credentials"
                 FontSize="{StaticResource Type.H2.Size}"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource PrimaryTextBrush}"/>
      <TextBox Text="{Binding FilterText, Mode=TwoWay}"
               Watermark="Search title, username, or URL…"
               FontSize="{StaticResource Type.Body.Size}"/>
    </StackPanel>

    <!-- List or empty state -->
    <Grid Grid.Row="1">
      <ScrollViewer IsVisible="{Binding HasItems}">
        <ItemsControl ItemsSource="{Binding FilteredItems}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:CredentialListItem">
              <Button HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch"
                      Background="{DynamicResource CardBackgroundBrush}"
                      BorderThickness="0"
                      CornerRadius="12"
                      Margin="0,0,0,10"
                      Padding="14"
                      Command="{Binding $parent[ItemsControl].DataContext.(vm:CredentialListViewModel.OpenDetailCommand)}"
                      CommandParameter="{Binding}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <Border Grid.Column="0"
                          Width="44" Height="44" CornerRadius="22"
                          Background="{Binding AccentBrush}"
                          VerticalAlignment="Center">
                    <TextBlock Text="{Binding Glyph}"
                               FontSize="{StaticResource Type.H3.Size}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                  </Border>
                  <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                               FontSize="{StaticResource Type.Body.Size}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Username}"
                               FontSize="{StaticResource Type.Label.Size}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                  <TextBlock Grid.Column="2"
                             Text="›"
                             FontSize="{StaticResource Type.H3.Size}"
                             Foreground="{DynamicResource MutedTextBrush}"
                             VerticalAlignment="Center"
                             Margin="8,0,0,0"/>
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <StackPanel IsVisible="{Binding !HasItems}"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="14"
                  Margin="20">
        <TextBlock Text="🔐"
                   FontSize="48"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="{Binding EmptyHint}"
                   FontSize="{StaticResource Type.Body.Size}"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="320"/>
      </StackPanel>
    </Grid>

    <!-- Floating action -->
    <Button Grid.Row="2"
            HorizontalAlignment="Right"
            Margin="0,12,0,0"
            Padding="20,12"
            CornerRadius="24"
            FontSize="{StaticResource Type.H3.Size}"
            FontWeight="SemiBold"
            Background="{DynamicResource AccentBrush}"
            Foreground="White"
            Content="+ Add credential"
            Command="{Binding AddCommand}"/>
  </Grid>
</UserControl>
