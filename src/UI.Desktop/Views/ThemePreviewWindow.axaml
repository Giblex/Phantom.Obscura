<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhantomVault.UI.ViewModels"
        x:Class="PhantomVault.UI.Views.ThemePreviewWindow"
        x:DataType="vm:ThemePreviewViewModel"
        Title="Theme Showcase - PhantomVault"
        Width="1400" Height="900"
        MinWidth="1200" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Classes="animated-window">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0"
                Padding="30,25"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                Background="{DynamicResource HeaderBackgroundBrush}">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock Text="🎨 Theme Showcase"
                               FontSize="{StaticResource Type.H2.Size}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource HeaderTextBrush}"/>
                    <TextBlock Text="Preview all available themes and color schemes for PhantomVault"
                               FontSize="{StaticResource Type.Label.Size}"
                               Foreground="{DynamicResource HeaderMutedTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="Current Theme:"
                               FontSize="{StaticResource Type.Label.Size}"
                               Foreground="{DynamicResource HeaderMutedTextBrush}"
                               VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource AccentBrush}"
                            CornerRadius="6"
                            Padding="12,6">
                        <TextBlock Text="{Binding CurrentThemeName}"
                                   FontSize="{StaticResource Type.Label.Size}"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Theme Previews ScrollViewer -->
        <ScrollViewer Grid.Row="1" Padding="30,25">
            <StackPanel Spacing="30">

                <!-- Dark Themes Section -->
                <StackPanel Spacing="20">
                    <TextBlock Text="🌙 Dark Themes"
                               FontSize="{StaticResource Type.H3.Size}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                    <!-- Phantom Dark Theme -->
                    <Border Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="0">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <!-- Theme Header -->
                            <Border Grid.Row="0"
                                    Background="#35475B"
                                    Padding="20,15"
                                    CornerRadius="12,12,0,0">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                        <Border Background="#6B8CAE"
                                                Width="40" Height="40"
                                                CornerRadius="8"/>
                                        <StackPanel Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="Phantom Dark"
                                                       FontSize="{StaticResource Type.H4.Size}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFFFFF"/>
                                            <TextBlock Text="Default dark theme • Muted blues • Calm"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="#C0C8D0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Content="Apply Theme"
                                            Background="#6B8CAE"
                                            Foreground="White"
                                            Padding="16,8"
                                            CornerRadius="6"
                                            FontSize="{StaticResource Type.Label.Size}"
                                            FontWeight="SemiBold"
                                            Command="{Binding ApplyThemeCommand}"
                                            CommandParameter="phantom-dark"/>
                                </Grid>
                            </Border>

                            <!-- Theme Preview Content -->
                            <Grid Grid.Row="1" Margin="20" ColumnDefinitions="*,*,*" ColumnSpacing="15">
                                <!-- Colors Column -->
                                <StackPanel Grid.Column="0" Spacing="12">
                                    <TextBlock Text="Color Palette"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#FFFFFF"/>
                                    <StackPanel Spacing="8">
                                        <Border Background="#6B8CAE" Height="40" CornerRadius="6" Padding="10">
                                            <TextBlock Text="Accent" Foreground="White" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Background="#35475B" Height="40" CornerRadius="6" Padding="10">
                                            <TextBlock Text="Background" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Background="#272F43" Height="40" CornerRadius="6" Padding="10">
                                            <TextBlock Text="Content" Foreground="#E0E6ED" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Typography Column -->
                                <StackPanel Grid.Column="1" Spacing="12">
                                    <TextBlock Text="Typography"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#FFFFFF"/>
                                    <Border Background="#272F43" CornerRadius="6" Padding="15">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Primary Text"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       Foreground="#FFFFFF"/>
                                            <TextBlock Text="Secondary Text"
                                                       FontSize="{StaticResource Type.Label.Size}"
                                                       Foreground="#E0E6ED"/>
                                            <TextBlock Text="Muted Text"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="#C0C8D0"/>
                                            <TextBlock Text="Disabled Text"
                                                       FontSize="{StaticResource Type.Tiny.Size}"
                                                       Foreground="#909AA4"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- UI Components Column -->
                                <StackPanel Grid.Column="2" Spacing="12">
                                    <TextBlock Text="Components"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#FFFFFF"/>
                                    <StackPanel Spacing="8">
                                        <Button Content="Primary Button"
                                                Background="#6B8CAE"
                                                Foreground="White"
                                                Padding="12,8"
                                                CornerRadius="6"
                                                HorizontalAlignment="Stretch"/>
                                        <TextBox Text="Input Field"
                                                 Background="#4A5C6E"
                                                 Foreground="#FFFFFF"
                                                 BorderBrush="#FFFFFF15"
                                                 Padding="10"
                                                 CornerRadius="6"/>
                                        <CheckBox Content="Checkbox Example"
                                                  Foreground="#E0E6ED"
                                                  IsChecked="True"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Theme Tags -->
                            <Border Grid.Row="2"
                                    BorderThickness="0,1,0,0"
                                    BorderBrush="#FFFFFF15"
                                    Padding="20,12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="#6B8CAE33" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Professional" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#6B8CAE"/>
                                    </Border>
                                    <Border Background="#6B8CAE33" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Low Contrast" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#6B8CAE"/>
                                    </Border>
                                    <Border Background="#6B8CAE33" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Accessible" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#6B8CAE"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Giblex Glass Navy Theme -->
                    <Border Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="0">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <Border Grid.Row="0"
                                    Background="#0A0F18"
                                    Padding="20,15"
                                    CornerRadius="12,12,0,0">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                        <Border Background="#2DD4BF"
                                                Width="40" Height="40"
                                                CornerRadius="8"/>
                                        <StackPanel Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="Giblex Glass Navy"
                                                       FontSize="{StaticResource Type.H4.Size}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#F8FAFC"/>
                                            <TextBlock Text="Deep navy gradients • Glass cards • Teal accents"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="#8B9CB3"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Content="Apply Theme"
                                            Background="#2DD4BF"
                                            Foreground="#0A0F18"
                                            Padding="16,8"
                                            CornerRadius="6"
                                            FontSize="{StaticResource Type.Label.Size}"
                                            FontWeight="SemiBold"
                                            Command="{Binding ApplyThemeCommand}"
                                            CommandParameter="giblex-glass-navy"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="20" ColumnDefinitions="*,*,*" ColumnSpacing="15">
                                <StackPanel Grid.Column="0" Spacing="12">
                                    <TextBlock Text="Color Palette"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#F8FAFC"/>
                                    <StackPanel Spacing="8">
                                        <Border Background="#2DD4BF" Height="40" CornerRadius="6" Padding="10">
                                            <TextBlock Text="Teal Accent" Foreground="#0A0F18" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        </Border>
                                        <Border Height="40" CornerRadius="6" Padding="10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#0A0F18" Offset="0"/>
                                                    <GradientStop Color="#0D1420" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="Gradient BG" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Background="#162235" Height="40" CornerRadius="6" Padding="10">
                                            <TextBlock Text="Card Surface" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="12">
                                    <TextBlock Text="Typography"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#F8FAFC"/>
                                    <Border Background="#162235" CornerRadius="6" Padding="15">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Primary Text"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       Foreground="#F8FAFC"/>
                                            <TextBlock Text="Secondary Text"
                                                       FontSize="{StaticResource Type.Label.Size}"
                                                       Foreground="#E0E6ED"/>
                                            <TextBlock Text="Muted Text"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="#8B9CB3"/>
                                            <TextBlock Text="Disabled Text"
                                                       FontSize="{StaticResource Type.Tiny.Size}"
                                                       Foreground="#5A6A7A"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="12">
                                    <TextBlock Text="Components"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#F8FAFC"/>
                                    <StackPanel Spacing="8">
                                        <Button Content="Primary Button"
                                                Background="#2DD4BF"
                                                Foreground="#0A0F18"
                                                Padding="12,8"
                                                CornerRadius="6"
                                                FontWeight="SemiBold"
                                                HorizontalAlignment="Stretch"/>
                                        <TextBox Text="Input Field"
                                                 Background="#162235"
                                                 Foreground="#F8FAFC"
                                                 BorderBrush="#2A3E54"
                                                 Padding="10"
                                                 CornerRadius="6"/>
                                        <CheckBox Content="Checkbox Example"
                                                  Foreground="#F8FAFC"
                                                  IsChecked="True"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="2"
                                    BorderThickness="0,1,0,0"
                                    BorderBrush="#2A3E54"
                                    Padding="20,12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="#2DD4BF33" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Modern" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#2DD4BF"/>
                                    </Border>
                                    <Border Background="#2DD4BF33" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Glass Morphism" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#2DD4BF"/>
                                    </Border>
                                    <Border Background="#2DD4BF33" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="High Contrast" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#2DD4BF"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Classic Dark Theme -->
                    <Border Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="0">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <Border Grid.Row="0"
                                    Background="#1E1E1E"
                                    Padding="20,15"
                                    CornerRadius="12,12,0,0">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                        <Border Background="#007ACC"
                                                Width="40" Height="40"
                                                CornerRadius="8"/>
                                        <StackPanel Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="Classic Dark"
                                                       FontSize="{StaticResource Type.H4.Size}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#D4D4D4"/>
                                            <TextBlock Text="VS Code inspired • Developer friendly • Sharp"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="#858585"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Content="Apply Theme"
                                            Background="#007ACC"
                                            Foreground="White"
                                            Padding="16,8"
                                            CornerRadius="6"
                                            FontSize="{StaticResource Type.Label.Size}"
                                            FontWeight="SemiBold"
                                            Command="{Binding ApplyThemeCommand}"
                                            CommandParameter="classic-dark"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="20" ColumnDefinitions="*,*,*" ColumnSpacing="15">
                                <StackPanel Grid.Column="0" Spacing="12">
                                    <TextBlock Text="Color Palette"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#D4D4D4"/>
                                    <StackPanel Spacing="8">
                                        <Border Background="#007ACC" Height="40" CornerRadius="6" Padding="10">
                                            <TextBlock Text="Accent" Foreground="White" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Background="#1E1E1E" Height="40" CornerRadius="6" Padding="10" BorderBrush="#3E3E42" BorderThickness="1">
                                            <TextBlock Text="Background" Foreground="#D4D4D4" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Background="#252526" Height="40" CornerRadius="6" Padding="10">
                                            <TextBlock Text="Content" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="12">
                                    <TextBlock Text="Typography"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#D4D4D4"/>
                                    <Border Background="#252526" CornerRadius="6" Padding="15" BorderBrush="#3E3E42" BorderThickness="1">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Primary Text"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       Foreground="#D4D4D4"/>
                                            <TextBlock Text="Secondary Text"
                                                       FontSize="{StaticResource Type.Label.Size}"
                                                       Foreground="#CCCCCC"/>
                                            <TextBlock Text="Muted Text"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="#858585"/>
                                            <TextBlock Text="Disabled Text"
                                                       FontSize="{StaticResource Type.Tiny.Size}"
                                                       Foreground="#6E6E6E"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="12">
                                    <TextBlock Text="Components"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#D4D4D4"/>
                                    <StackPanel Spacing="8">
                                        <Button Content="Primary Button"
                                                Background="#007ACC"
                                                Foreground="White"
                                                Padding="12,8"
                                                CornerRadius="6"
                                                HorizontalAlignment="Stretch"/>
                                        <TextBox Text="Input Field"
                                                 Background="#3C3C3C"
                                                 Foreground="#CCCCCC"
                                                 BorderBrush="#3E3E42"
                                                 Padding="10"
                                                 CornerRadius="6"/>
                                        <CheckBox Content="Checkbox Example"
                                                  Foreground="#CCCCCC"
                                                  IsChecked="True"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="2"
                                    BorderThickness="0,1,0,0"
                                    BorderBrush="#3E3E42"
                                    Padding="20,12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="#007ACC33" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Developer" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#007ACC"/>
                                    </Border>
                                    <Border Background="#007ACC33" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Sharp Edges" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#007ACC"/>
                                    </Border>
                                    <Border Background="#007ACC33" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Minimal" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#007ACC"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Light Themes Section -->
                <StackPanel Spacing="20">
                    <TextBlock Text="☀️ Light Themes"
                               FontSize="{StaticResource Type.H3.Size}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                    <!-- Phantom Light Theme -->
                    <Border Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="0">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <Border Grid.Row="0"
                                    Background="#FDFCF9"
                                    Padding="20,15"
                                    CornerRadius="12,12,0,0"
                                    BorderBrush="#CAD6E4"
                                    BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                        <Border Background="#5F7FA6"
                                                Width="40" Height="40"
                                                CornerRadius="8"/>
                                        <StackPanel Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="Phantom Light"
                                                       FontSize="{StaticResource Type.H4.Size}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#1A202C"/>
                                            <TextBlock Text="Clean • Soft blues • Easy on eyes"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="#64748B"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Content="Apply Theme"
                                            Background="#5F7FA6"
                                            Foreground="White"
                                            Padding="16,8"
                                            CornerRadius="6"
                                            FontSize="{StaticResource Type.Label.Size}"
                                            FontWeight="SemiBold"
                                            Command="{Binding ApplyThemeCommand}"
                                            CommandParameter="phantom-light"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="20" ColumnDefinitions="*,*,*" ColumnSpacing="15">
                                <StackPanel Grid.Column="0" Spacing="12">
                                    <TextBlock Text="Color Palette"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#1A202C"/>
                                    <StackPanel Spacing="8">
                                        <Border Background="#5F7FA6" Height="40" CornerRadius="6" Padding="10">
                                            <TextBlock Text="Accent" Foreground="White" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Background="#FDFCF9" Height="40" CornerRadius="6" Padding="10" BorderBrush="#CAD6E4" BorderThickness="1">
                                            <TextBlock Text="Background" Foreground="#1A202C" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Background="#FAFCFF" Height="40" CornerRadius="6" Padding="10" BorderBrush="#CAD6E4" BorderThickness="1">
                                            <TextBlock Text="Content" Foreground="#334155" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="12">
                                    <TextBlock Text="Typography"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#1A202C"/>
                                    <Border Background="#FAFCFF" CornerRadius="6" Padding="15" BorderBrush="#CAD6E4" BorderThickness="1">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Primary Text"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       Foreground="#1A202C"/>
                                            <TextBlock Text="Secondary Text"
                                                       FontSize="{StaticResource Type.Label.Size}"
                                                       Foreground="#334155"/>
                                            <TextBlock Text="Muted Text"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="#64748B"/>
                                            <TextBlock Text="Disabled Text"
                                                       FontSize="{StaticResource Type.Tiny.Size}"
                                                       Foreground="#94A3B8"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="12">
                                    <TextBlock Text="Components"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#1A202C"/>
                                    <StackPanel Spacing="8">
                                        <Button Content="Primary Button"
                                                Background="#5F7FA6"
                                                Foreground="White"
                                                Padding="12,8"
                                                CornerRadius="6"
                                                HorizontalAlignment="Stretch"/>
                                        <TextBox Text="Input Field"
                                                 Background="#F1F5FB"
                                                 Foreground="#1A202C"
                                                 BorderBrush="#CAD6E4"
                                                 Padding="10"
                                                 CornerRadius="6"/>
                                        <CheckBox Content="Checkbox Example"
                                                  Foreground="#334155"
                                                  IsChecked="True"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="2"
                                    BorderThickness="0,1,0,0"
                                    BorderBrush="#CAD6E4"
                                    Padding="20,12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="#5F7FA633" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Clean" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#5F7FA6"/>
                                    </Border>
                                    <Border Background="#5F7FA633" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Soft" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#5F7FA6"/>
                                    </Border>
                                    <Border Background="#5F7FA633" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Accessible" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#5F7FA6"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Classic Light Theme -->
                    <Border Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="0">
                        <Grid RowDefinitions="Auto,*,Auto">
                            <Border Grid.Row="0"
                                    Background="#FFFFFF"
                                    Padding="20,15"
                                    CornerRadius="12,12,0,0"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                        <Border Background="#0078D4"
                                                Width="40" Height="40"
                                                CornerRadius="8"/>
                                        <StackPanel Spacing="4" VerticalAlignment="Center">
                                            <TextBlock Text="Classic Light"
                                                       FontSize="{StaticResource Type.H4.Size}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#1F1F1F"/>
                                            <TextBlock Text="Windows 11 inspired • Bright • Modern"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="#737373"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Content="Apply Theme"
                                            Background="#0078D4"
                                            Foreground="White"
                                            Padding="16,8"
                                            CornerRadius="6"
                                            FontSize="{StaticResource Type.Label.Size}"
                                            FontWeight="SemiBold"
                                            Command="{Binding ApplyThemeCommand}"
                                            CommandParameter="classic-light"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1" Margin="20" ColumnDefinitions="*,*,*" ColumnSpacing="15">
                                <StackPanel Grid.Column="0" Spacing="12">
                                    <TextBlock Text="Color Palette"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#1F1F1F"/>
                                    <StackPanel Spacing="8">
                                        <Border Background="#0078D4" Height="40" CornerRadius="6" Padding="10">
                                            <TextBlock Text="Accent" Foreground="White" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Background="#FFFFFF" Height="40" CornerRadius="6" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
                                            <TextBlock Text="Background" Foreground="#1F1F1F" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Background="#F5F5F5" Height="40" CornerRadius="6" Padding="10" BorderBrush="#E0E0E0" BorderThickness="1">
                                            <TextBlock Text="Content" Foreground="#424242" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="12">
                                    <TextBlock Text="Typography"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#1F1F1F"/>
                                    <Border Background="#F5F5F5" CornerRadius="6" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Primary Text"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       Foreground="#1F1F1F"/>
                                            <TextBlock Text="Secondary Text"
                                                       FontSize="{StaticResource Type.Label.Size}"
                                                       Foreground="#424242"/>
                                            <TextBlock Text="Muted Text"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="#737373"/>
                                            <TextBlock Text="Disabled Text"
                                                       FontSize="{StaticResource Type.Tiny.Size}"
                                                       Foreground="#A6A6A6"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="12">
                                    <TextBlock Text="Components"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               FontWeight="SemiBold"
                                               Foreground="#1F1F1F"/>
                                    <StackPanel Spacing="8">
                                        <Button Content="Primary Button"
                                                Background="#0078D4"
                                                Foreground="White"
                                                Padding="12,8"
                                                CornerRadius="6"
                                                HorizontalAlignment="Stretch"/>
                                        <TextBox Text="Input Field"
                                                 Background="#FFFFFF"
                                                 Foreground="#1F1F1F"
                                                 BorderBrush="#D1D1D1"
                                                 Padding="10"
                                                 CornerRadius="6"/>
                                        <CheckBox Content="Checkbox Example"
                                                  Foreground="#424242"
                                                  IsChecked="True"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="2"
                                    BorderThickness="0,1,0,0"
                                    BorderBrush="#E0E0E0"
                                    Padding="20,12">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="#0078D433" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Modern" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#0078D4"/>
                                    </Border>
                                    <Border Background="#0078D433" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Bright" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#0078D4"/>
                                    </Border>
                                    <Border Background="#0078D433" CornerRadius="4" Padding="8,4">
                                        <TextBlock Text="Windows 11" FontSize="{StaticResource Type.Tiny.Size}" Foreground="#0078D4"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                Padding="30,20"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                Background="{DynamicResource FooterBackgroundBrush}">
            <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right">
                <TextBlock Text="💡 Pro tip: Themes can be changed anytime in Settings → Theme"
                           FontSize="{StaticResource Type.Small.Size}"
                           Foreground="{DynamicResource FooterMutedTextBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Close"
                        Command="{Binding CloseCommand}"
                        Width="120"
                        Height="36"
                        FontSize="{StaticResource Type.Label.Size}"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White"
                        CornerRadius="6"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
