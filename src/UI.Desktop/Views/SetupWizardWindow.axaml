<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhantomVault.UI.ViewModels"
        xmlns:views="clr-namespace:PhantomVault.UI.Views"
        xmlns:controls="clr-namespace:PhantomVault.UI.Desktop.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
        x:Class="PhantomVault.UI.Views.SetupWizardWindow"
        x:DataType="vm:SetupWizardViewModel"
        Title="Phantom Obscura Setup Wizard"
        Width="900" Height="780"
        MinWidth="800" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Icon="avares://PhantomVault.UI/Assets/Visuals/Giblex Icons/Parent Icon.ico"
        Background="{DynamicResource WindowBackgroundBrush}"
        FontFamily="{DynamicResource DefaultFontFamily}"
        Classes="animated-window">

    <views:ThemeAwareWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PhantomVault.UI/Assets/Themes/PreVaultTheme.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </views:ThemeAwareWindow.Resources>

    <!-- Strip default button chrome from step progress buttons -->
    <views:ThemeAwareWindow.Styles>
        <Style Selector="Button.step-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Button.nav-button">
            <Setter Property="Width" Value="156"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="{StaticResource Type.Body.Size}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#0C1620"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="#4C6170"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="BorderBrush" Value="#5C7080"/>
            <Setter Property="Background" Value="#101C28"/>
        </Style>
        <Style Selector="ComboBox:focus">
            <Setter Property="BorderBrush" Value="#5C7080"/>
            <Setter Property="Background" Value="#101C28"/>
        </Style>
        <Style Selector="ComboBox /template/ Border">
            <Setter Property="Background" Value="#0C1620"/>
            <Setter Property="BorderBrush" Value="#4C6170"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="ComboBox:pointerover /template/ Border">
            <Setter Property="Background" Value="#101C28"/>
            <Setter Property="BorderBrush" Value="#5C7080"/>
        </Style>
        <Style Selector="ComboBox:focus /template/ Border">
            <Setter Property="Background" Value="#101C28"/>
            <Setter Property="BorderBrush" Value="#5C7080"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="Background" Value="#0C1620"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        <Style Selector="ComboBoxItem /template/ ContentPresenter">
            <Setter Property="Background" Value="#0C1620"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style Selector="ComboBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#162432"/>
        </Style>
        <Style Selector="ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#1C2C3C"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#0A1420"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="#446074"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style Selector="Button.step-btn /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.step-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.step-btn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.step-btn:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <!-- Stronger control contrast -->
        <Style Selector="RadioButton:checked /template/ Ellipse#CheckGlyph">
            <Setter Property="Fill" Value="#ECF7FB"/>
        </Style>
        <Style Selector="RadioButton:checked /template/ Border#OuterBorder">
            <Setter Property="BorderBrush" Value="#55C3CF"/>
        </Style>
        <Style Selector="RadioButton:checked:pointerover /template/ Border#OuterBorder">
            <Setter Property="BorderBrush" Value="#8AD6DE"/>
        </Style>
        <Style Selector="RadioButton:checked:pointerover /template/ Ellipse#CheckGlyph">
            <Setter Property="Fill" Value="#E0E6ED"/>
        </Style>
        <Style Selector="RadioButton:pointerover /template/ Border#OuterBorder">
            <Setter Property="BorderBrush" Value="#7FA1B8"/>
        </Style>

        <!-- Override CheckBox styling for dark background visibility -->
        <Style Selector="CheckBox /template/ Border#NormalRectangle">
            <Setter Property="BorderBrush" Value="#738897"/>
            <Setter Property="Background" Value="#0A1420"/>
        </Style>
        <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="#0A1420"/>
            <Setter Property="BorderBrush" Value="#8297A5"/>
        </Style>
        <Style Selector="CheckBox:checked:pointerover /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="#0E1A27"/>
            <Setter Property="BorderBrush" Value="#8FA4B2"/>
        </Style>
        <Style Selector="CheckBox:pointerover /template/ Border#NormalRectangle">
            <Setter Property="BorderBrush" Value="#8FA4B2"/>
            <Setter Property="Background" Value="#0E1A27"/>
        </Style>
        <Style Selector="CheckBox /template/ Path#CheckGlyph">
            <Setter Property="Fill" Value="#EAF3F8"/>
        </Style>

        <!-- Accent navigation button -->
        <Style Selector="Button.solid-primary">
            <Setter Property="Background" Value="#173042"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#55C3CF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.solid-primary /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#173042"/>
            <Setter Property="BorderBrush" Value="#55C3CF"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="Button.solid-primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1E3C52"/>
            <Setter Property="BorderBrush" Value="#8AD6DE"/>
        </Style>
        <Style Selector="Button.solid-primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#102838"/>
            <Setter Property="BorderBrush" Value="#55C3CF"/>
        </Style>
        <Style Selector="Button.solid-primary:disabled /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#111B2A"/>
            <Setter Property="BorderBrush" Value="#20FFFFFF"/>
        </Style>
    </views:ThemeAwareWindow.Styles>

    <Design.DataContext>
        <vm:SetupWizardViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        
        <!-- ═══════════════════════════════════════════════════════════════════════
             HEADER - Progress indicator and step title
             ═══════════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" Padding="24,20,24,18">
            <Grid RowDefinitions="Auto,Auto,Auto">
                <!-- App Title and Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="14" Margin="0,0,0,18">
                    <Image Source="avares://PhantomVault.UI/Assets/Visuals/Giblex Icons/Icon Transparent background.png"
                           Width="74" Height="74" Stretch="Uniform" VerticalAlignment="Center"/>
                    <TextBlock Text="Phantom Obscura Setup Wizard"
                               FontSize="{StaticResource Type.H2.Size}"
                               FontFamily="{DynamicResource TitleFontFamily}"
                               FontWeight="Normal"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Step Progress Bar -->
                <Grid Grid.Row="1" Margin="8,0,8,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Step 1: Welcome -->
                    <Button Grid.Column="0" Classes="step-btn"
                            Command="{Binding GoToStepCommand}" CommandParameter="1"
                            IsEnabled="{Binding CurrentStep, Converter={x:Static views:StepClickableConverter.Instance}, ConverterParameter=1}"
                            Background="Transparent" BorderThickness="0" Padding="0"
                            HorizontalAlignment="Center" VerticalAlignment="Stretch"
                            Cursor="{Binding CurrentStep, Converter={x:Static views:StepCursorConverter.Instance}, ConverterParameter=1}">
                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                            <Border Width="44" Height="44" CornerRadius="22"
                                    Background="{Binding CurrentStep, Converter={x:Static views:StepProgressConverter.Instance}, ConverterParameter=1}"
                                    BorderBrush="#4BFFFFFF" BorderThickness="2">
                                <controls:SvgIcon Preset="Info" IconColor="White" IconSize="20"
                                                  Width="20" Height="20"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Welcome" FontSize="{StaticResource Type.Mini.Size}" 
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Step 2: Security -->
                    <Button Grid.Column="1" Classes="step-btn"
                            Command="{Binding GoToStepCommand}" CommandParameter="2"
                            IsEnabled="{Binding CurrentStep, Converter={x:Static views:StepClickableConverter.Instance}, ConverterParameter=2}"
                            Background="Transparent" BorderThickness="0" Padding="0"
                            HorizontalAlignment="Center" VerticalAlignment="Stretch"
                            Cursor="{Binding CurrentStep, Converter={x:Static views:StepCursorConverter.Instance}, ConverterParameter=2}">
                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                            <Border Width="44" Height="44" CornerRadius="22"
                                    Background="{Binding CurrentStep, Converter={x:Static views:StepProgressConverter.Instance}, ConverterParameter=2}"
                                    BorderBrush="#4BFFFFFF" BorderThickness="2">
                                <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Password Strength.svg" IconColor="White" IconSize="20"
                                                  Width="20" Height="20"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Security" FontSize="{StaticResource Type.Mini.Size}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Step 3: PhantomKey -->
                    <Button Grid.Column="2" Classes="step-btn"
                            Command="{Binding GoToStepCommand}" CommandParameter="3"
                            IsEnabled="{Binding CurrentStep, Converter={x:Static views:StepClickableConverter.Instance}, ConverterParameter=3}"
                            Background="Transparent" BorderThickness="0" Padding="0"
                            HorizontalAlignment="Center" VerticalAlignment="Stretch"
                            Cursor="{Binding CurrentStep, Converter={x:Static views:StepCursorConverter.Instance}, ConverterParameter=3}">
                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                            <Border Width="44" Height="44" CornerRadius="22"
                                    Background="{Binding CurrentStep, Converter={x:Static views:StepProgressConverter.Instance}, ConverterParameter=3}"
                                    BorderBrush="#4BFFFFFF" BorderThickness="2">
                                <controls:SvgIcon Preset="Shield" IconColor="White" IconSize="20"
                                                  Width="20" Height="20"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="PhantomKey" FontSize="{StaticResource Type.Mini.Size}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Step 4: Storage -->
                    <Button Grid.Column="3" Classes="step-btn"
                            Command="{Binding GoToStepCommand}" CommandParameter="4"
                            IsEnabled="{Binding CurrentStep, Converter={x:Static views:StepClickableConverter.Instance}, ConverterParameter=4}"
                            Background="Transparent" BorderThickness="0" Padding="0"
                            HorizontalAlignment="Center" VerticalAlignment="Stretch"
                            Cursor="{Binding CurrentStep, Converter={x:Static views:StepCursorConverter.Instance}, ConverterParameter=4}">
                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                            <Border Width="44" Height="44" CornerRadius="22"
                                    Background="{Binding CurrentStep, Converter={x:Static views:StepProgressConverter.Instance}, ConverterParameter=4}"
                                    BorderBrush="#4BFFFFFF" BorderThickness="2">
                                <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Storage Location.svg" IconColor="White" IconSize="20"
                                                  Width="20" Height="20"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Storage" FontSize="{StaticResource Type.Mini.Size}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Step 5: Keyfile -->
                    <Button Grid.Column="4" Classes="step-btn"
                            Command="{Binding GoToStepCommand}" CommandParameter="5"
                            IsEnabled="{Binding CurrentStep, Converter={x:Static views:StepClickableConverter.Instance}, ConverterParameter=5}"
                            Background="Transparent" BorderThickness="0" Padding="0"
                            HorizontalAlignment="Center" VerticalAlignment="Stretch"
                            Cursor="{Binding CurrentStep, Converter={x:Static views:StepCursorConverter.Instance}, ConverterParameter=5}">
                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                            <Border Width="44" Height="44" CornerRadius="22"
                                    Background="{Binding CurrentStep, Converter={x:Static views:StepProgressConverter.Instance}, ConverterParameter=5}"
                                    BorderBrush="#4BFFFFFF" BorderThickness="2">
                                <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Keyfile.svg" IconColor="White" IconSize="20"
                                                  Width="20" Height="20"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Keyfile" FontSize="{StaticResource Type.Mini.Size}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Step 6: Authentication -->
                    <Button Grid.Column="5" Classes="step-btn"
                            Command="{Binding GoToStepCommand}" CommandParameter="6"
                            IsEnabled="{Binding CurrentStep, Converter={x:Static views:StepClickableConverter.Instance}, ConverterParameter=6}"
                            Background="Transparent" BorderThickness="0" Padding="0"
                            HorizontalAlignment="Center" VerticalAlignment="Stretch"
                            Cursor="{Binding CurrentStep, Converter={x:Static views:StepCursorConverter.Instance}, ConverterParameter=6}">
                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                            <Border Width="44" Height="44" CornerRadius="22"
                                    Background="{Binding CurrentStep, Converter={x:Static views:StepProgressConverter.Instance}, ConverterParameter=6}"
                                    BorderBrush="#4BFFFFFF" BorderThickness="2">
                                <controls:SvgIcon Preset="Lock" IconColor="White" IconSize="20"
                                                  Width="20" Height="20"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Auth" FontSize="{StaticResource Type.Mini.Size}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Step 7: Remnants or Complete -->
                    <StackPanel Grid.Column="6" HorizontalAlignment="Center" Spacing="8"
                                IsVisible="{Binding UsesExtendedProgress}">
                        <Border Width="44" Height="44" CornerRadius="22"
                                Background="{Binding CurrentStep, Converter={x:Static views:StepProgressConverter.Instance}, ConverterParameter=7}"
                                BorderBrush="#4BFFFFFF" BorderThickness="2">
                            <controls:SvgIcon Preset="AlertTriangle" IconColor="White" IconSize="20"
                                              Width="20" Height="20"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Remnants" FontSize="{StaticResource Type.Mini.Size}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6" HorizontalAlignment="Center" Spacing="8"
                                IsVisible="{Binding !UsesExtendedProgress}">
                        <Border Width="44" Height="44" CornerRadius="22"
                                Background="{Binding CurrentStep, Converter={x:Static views:StepProgressConverter.Instance}, ConverterParameter=7}"
                                BorderBrush="#4BFFFFFF" BorderThickness="2">
                            <controls:SvgIcon Preset="Check" IconColor="White" IconSize="20"
                                              Width="20" Height="20"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Complete" FontSize="{StaticResource Type.Mini.Size}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Step 8: Final review/complete when remnants are present -->
                    <StackPanel Grid.Column="7" HorizontalAlignment="Center" Spacing="8"
                                IsVisible="{Binding UsesExtendedProgress}">
                        <Border Width="44" Height="44" CornerRadius="22"
                                Background="{Binding CurrentStep, Converter={x:Static views:StepProgressConverter.Instance}, ConverterParameter=8}"
                                BorderBrush="#4BFFFFFF" BorderThickness="2">
                            <controls:SvgIcon Preset="Check" IconColor="White" IconSize="20"
                                              Width="20" Height="20"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Complete" FontSize="{StaticResource Type.Mini.Size}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- Current Step Title -->
                <TextBlock Grid.Row="2" 
                           Text="{Binding CurrentStepTitle}"
                           FontSize="{StaticResource Type.H3.Size}"
                           FontFamily="{DynamicResource TitleFontFamily}"
                           FontWeight="Normal"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════════
             MAIN CONTENT - Step-specific content with animations
             ═══════════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" ClipToBounds="True">
            <ScrollViewer Name="MainScrollViewer"
                          VerticalScrollBarVisibility="Visible"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="40,24,40,120">
                <!-- Step 1: Welcome -->
                <Border IsVisible="{Binding CurrentStep, Converter={x:Static views:StepVisibilityConverter.Instance}, ConverterParameter=1}"
                        Classes="fade-in">
                    <StackPanel Spacing="24" MaxWidth="700" HorizontalAlignment="Center" Margin="0,0,0,40">
                        <!-- Welcome Card -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="28,22"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="16">
                                <!-- Animated Icon -->
                                <Image Source="avares://PhantomVault.UI/Assets/Visuals/Giblex Icons/Icon Transparent background.png"
                                       Width="124"
                                       Height="124"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"/>

                                <TextBlock Text="Welcome to Phantom Obscura"
                                           FontSize="{StaticResource Type.H2.Size}"
                                           FontFamily="{DynamicResource TitleFontFamily}"
                                           FontWeight="Normal"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           HorizontalAlignment="Center"/>

                                <TextBlock TextWrapping="Wrap"
                                           FontSize="{StaticResource Type.Body.Size}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextAlignment="Center"
                                           LineHeight="24">
                                    This wizard will guide you through setting up your secure vault.
                                    Phantom Obscura uses military-grade post-quantum encryption to protect your credentials.
                                </TextBlock>

                                <!-- Feature Highlights -->
                                <Border Background="#162235"
                                        CornerRadius="{StaticResource Radius.Lg}"
                                        Padding="20,16"
                                        Margin="0,12,0,0"
                                        BorderThickness="0"
                                        BoxShadow="0 4 16 0 #40000000">
                                    <StackPanel Spacing="12">
                                        <TextBlock Text="What you'll set up:"
                                                   FontSize="{StaticResource Type.Body.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        
                                        <StackPanel Spacing="8">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <controls:SvgIcon Preset="Settings" IconColor="White" IconSize="22" Width="22" Height="22" VerticalAlignment="Center"/>
                                                <TextBlock Text="Security level tailored to your needs"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Storage Location.svg" IconColor="White" IconSize="22" Width="22" Height="22" VerticalAlignment="Center"/>
                                                <TextBlock Text="USB-bound encrypted storage with device binding"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Keyfile.svg" IconColor="White" IconSize="22" Width="22" Height="22" VerticalAlignment="Center"/>
                                                <TextBlock Text="Secure keyfile generation (required)"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <controls:SvgIcon Preset="Shield" IconColor="White" IconSize="22" Width="22" Height="22" VerticalAlignment="Center"/>
                                                <TextBlock Text="PhantomKey hardware binding for maximum protection"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Password.svg" IconColor="White" IconSize="22" Width="22" Height="22" VerticalAlignment="Center"/>
                                                <TextBlock Text="Master password support, required for Phantom Secured"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="14">
                                <TextBlock Text="Vault Identity"
                                           FontSize="{StaticResource Type.H4.Size}"
                                           FontWeight="Normal"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>

                                <TextBlock Text="Give this vault a name you will recognise later. Think of it like the label on a safe rather than the secret inside it."
                                           TextWrapping="Wrap"
                                           FontSize="{StaticResource Type.Small.Size}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           LineHeight="20"/>

                                <TextBox Text="{Binding VaultName}"
                                         Watermark="Enter your vault name"
                                         MaxLength="64"/>
                            </StackPanel>
                        </Border>

                        <!-- Terms Acceptance -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Terms and Conditions"
                                           FontSize="{StaticResource Type.H4.Size}"
                                           FontWeight="Normal"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="{StaticResource Type.Small.Size}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           LineHeight="20">
                                    By using Phantom Obscura, you agree to take responsibility for the security of your master password
                                    and any keyfiles. We cannot recover your data if you lose access to your credentials.
                                    Your vault is encrypted locally and never transmitted to external servers.
                                </TextBlock>

                                <CheckBox IsChecked="{Binding AcceptedTerms}"
                                          Margin="0,8,0,0">
                                    <TextBlock Text="I understand and accept these terms"
                                               FontSize="{StaticResource Type.Body.Size}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </CheckBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step 2: Security Level -->
                <Border IsVisible="{Binding CurrentStep, Converter={x:Static views:StepVisibilityConverter.Instance}, ConverterParameter=2}"
                        Classes="fade-in">
                    <StackPanel Spacing="20" MaxWidth="750" HorizontalAlignment="Center">
                        <!-- Explanation Card -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="40" Height="40" CornerRadius="20" Background="#111B2A">
                                        <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Password Strength.svg" IconColor="White" IconSize="24"
                                                          Width="24" Height="24"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="Choose Your Protection Tier"
                                                   FontSize="{StaticResource Type.H3.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Select the storage and privacy tier that matches your threat model"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Security Options -->
                        <ItemsControl ItemsSource="{Binding SecurityLevels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundBrush}"
                                            CornerRadius="{StaticResource Radius.Xl}"
                                            Padding="20,16"
                                            Margin="0,0,0,12"
                                            BoxShadow="0 4 16 0 #40000000"
                                            Cursor="Hand"
                                            Tapped="SecurityLevelCard_Tapped">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <RadioButton Grid.Column="0"
                                                         GroupName="SecurityLevel"
                                                         IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                         VerticalAlignment="Top"
                                                         Margin="0,4,16,0"/>
                                            <StackPanel Grid.Column="1" Spacing="8">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="{StaticResource Type.H4.Size}"
                                                                   FontWeight="Normal"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                        <Border IsVisible="{Binding Name, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                                Background="#111B2A"
                                                                CornerRadius="4"
                                                                Padding="8,2"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding RecommendedFor}"
                                                                       FontSize="{StaticResource Type.Micro.Size}"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                        </Border>
                                                        <Border Background="#173042"
                                                                CornerRadius="4"
                                                                Padding="8,2"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding SecurityIncreasePercent, StringFormat='Security boost: {0}%'}"
                                                                       FontSize="{StaticResource Type.Micro.Size}"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <Border Grid.Column="1"
                                                            Width="28"
                                                            Height="28"
                                                            CornerRadius="14"
                                                            Background="#122334"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            ToolTip.Tip="{Binding SecurityHelpText}">
                                                        <TextBlock Text="?"
                                                                   FontSize="{StaticResource Type.Body.Size}"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                                
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="{StaticResource Type.Body.Size}"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           TextWrapping="Wrap"/>

                                                <Border Background="#122334"
                                                        CornerRadius="10"
                                                        Padding="12,10"
                                                        Margin="0,2,0,0">
                                                    <TextBlock Text="{Binding FriendlySummary}"
                                                               FontSize="{StaticResource Type.Small.Size}"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                </Border>

                                                <ItemsControl ItemsSource="{Binding Features}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                                                <TextBlock Text="✓" FontSize="{StaticResource Type.Small.Size}" 
                                                                           Foreground="White"/>
                                                                <TextBlock Text="{Binding}"
                                                                           FontSize="{StaticResource Type.Small.Size}"
                                                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Border>

                <!-- Step 3: PhantomKey Setup -->
                <Border IsVisible="{Binding CurrentStep, Converter={x:Static views:StepVisibilityConverter.Instance}, ConverterParameter=3}"
                        Classes="fade-in">
                    <StackPanel Spacing="20" MaxWidth="700" HorizontalAlignment="Center">
                        <!-- Enable PhantomKey -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="40" Height="40" CornerRadius="20" Background="#111B2A">
                                        <controls:SvgIcon Preset="Shield" IconColor="White" IconSize="24"
                                                          Width="24" Height="24"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="PhantomKey Bridge Binding"
                                                   FontSize="{StaticResource Type.H4.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Isolated Phantom Key workspace linked into Obscura"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <CheckBox IsChecked="{Binding EnablePhantomKey}" Margin="0,4,0,0">
                                    <TextBlock Text="Enable PhantomKey hardware binding"
                                               FontSize="{StaticResource Type.Body.Size}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <!-- What is PhantomKey -->
                        <Border Background="#162235" CornerRadius="12" Padding="20,16"
                                IsVisible="{Binding EnablePhantomKey}"
                                BorderThickness="0"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="10">
                                <TextBlock Text="What is PhantomKey?"
                                           FontSize="{StaticResource Type.H4.Size}"
                                           FontWeight="Normal"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="{StaticResource Type.Body.Size}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           LineHeight="22">
                                    Phantom Key remains in its own encrypted bridge workspace and exposes only
                                    sealed policy, continuity, and consumer-mapping records to Obscura. The vault
                                    gains hardware-backed assurance without embedding Phantom Key secrets into the
                                    Obscura container set.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000"
                                IsVisible="{Binding EnablePhantomKey}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Bridge boundary"
                                           FontSize="{StaticResource Type.H4.Size}"
                                           FontWeight="Normal"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock Text="{Binding PhantomKeyBridgeLocationDescription}"
                                           TextWrapping="Wrap"
                                           FontSize="{StaticResource Type.Body.Size}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           LineHeight="22"/>
                                <TextBlock Text="{Binding PhantomKeyTrustBoundarySummary}"
                                           TextWrapping="Wrap"
                                           FontSize="{StaticResource Type.Small.Size}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           LineHeight="20"/>
                            </StackPanel>
                        </Border>

                        <!-- How it works -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000"
                                IsVisible="{Binding EnablePhantomKey}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="How it works"
                                           FontSize="{StaticResource Type.H4.Size}"
                                           FontWeight="Normal"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>

                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1C2D42">
                                            <TextBlock Text="1" FontSize="13" FontWeight="Normal"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Provision the isolated Phantom Key bridge workspace"
                                                   FontSize="{StaticResource Type.Body.Size}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1C2D42">
                                            <TextBlock Text="2" FontSize="13" FontWeight="Normal"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Seal hardware context, policy, and consumer records without exporting secrets"
                                                   FontSize="{StaticResource Type.Body.Size}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1C2D42">
                                            <TextBlock Text="3" FontSize="13" FontWeight="Normal"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Complete passkey and additional-factor setup before first unlock"
                                                   FontSize="{StaticResource Type.Body.Size}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Note -->
                        <Border Background="#162235" CornerRadius="8" Padding="14,10"
                                IsVisible="{Binding EnablePhantomKey}"
                                BorderThickness="0"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <controls:SvgIcon Preset="Info" IconColor="{DynamicResource MutedTextBrush}" IconSize="20"
                                                  Width="20" Height="20" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="{StaticResource Type.Small.Size}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           LineHeight="20">
                                    Obscura will prepare the Phantom Key bridge during provisioning, then the
                                    passkey, TOTP, and Windows Hello factors can be completed in the dedicated
                                    authentication step before the vault goes live.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step 4: USB Storage -->
                <Border IsVisible="{Binding CurrentStep, Converter={x:Static views:StepVisibilityConverter.Instance}, ConverterParameter=4}"
                        Classes="fade-in">
                    <StackPanel Spacing="20" MaxWidth="700" HorizontalAlignment="Center">
                        <!-- Explanation -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="40" Height="40" CornerRadius="20" Background="#111B2A">
                                        <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Storage Location.svg" IconColor="White" IconSize="24"
                                                          Width="24" Height="24"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="USB Storage Configuration"
                                                   FontSize="{StaticResource Type.H3.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Configure your USB-bound encrypted vault storage"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock TextWrapping="Wrap"
                                           FontSize="{StaticResource Type.Body.Size}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           LineHeight="22"
                                           Margin="0,8,0,0">
                                    Your encrypted vault will be stored on a USB drive for maximum physical security. 
                                    The vault is only accessible when the drive is connected and cannot be decrypted 
                                    from another device.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- USB Drive Selection -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="20,16"
                                BoxShadow="0 6 20 2 #50000000">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" Background="#111B2A"
                                        VerticalAlignment="Center" Margin="0,0,16,0">
                                    <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Storage Location.svg" IconColor="White" IconSize="22"
                                                      Width="22" Height="22"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Select USB Drive"
                                               FontSize="{StaticResource Type.H4.Size}"
                                               FontWeight="Normal"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <TextBlock Text="Choose the USB drive for your encrypted vault storage"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource MutedTextBrush}"/>
                                    
                                    <Border Background="{DynamicResource ControlBackgroundBrush}"
                                            CornerRadius="{StaticResource Radius.Md}"
                                            Padding="12,8"
                                            Margin="0,8,0,0"
                                            IsVisible="{Binding UsbDetected}">
                                        <ComboBox ItemsSource="{Binding AvailableUsbDrives}"
                                                  SelectedItem="{Binding SelectedUsbPath}"
                                                  PlaceholderText="Select a USB drive..."
                                                  HorizontalAlignment="Stretch"
                                                  MinWidth="280"/>
                                    </Border>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="8"
                                                IsVisible="{Binding !UsbDetected}"
                                                Margin="0,8,0,0">
                                        <controls:SvgIcon Preset="AlertTriangle" IconColor="{DynamicResource WarningBrush}" IconSize="20"
                                                          Width="20" Height="20" VerticalAlignment="Center"/>
                                        <TextBlock Text="No USB drives detected. Please connect a USB drive."
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   Foreground="{DynamicResource WarningBrush}"/>
                                    </StackPanel>

                                    <!-- Remaining USB Space -->
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0"
                                                IsVisible="{Binding RemainingUsbSpaceDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                        <controls:SvgIcon Preset="Database" IconColor="White" IconSize="20"
                                                          Width="20" Height="20" VerticalAlignment="Center"/>
                                        <TextBlock FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource SecondaryTextBrush}">
                                            <Run Text="Available space: "/>
                                            <Run Text="{Binding RemainingUsbSpaceDisplay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Command="{Binding LoadStepDataCommand}"
                                        Content="Refresh"
                                        Classes="liquid-glass"
                                        Width="90" Height="32"
                                        VerticalAlignment="Top"/>
                            </Grid>
                        </Border>

                        <!-- USB Device Binding -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="20,16"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <controls:SvgIcon Preset="Lock" IconColor="White" IconSize="24"
                                                      Width="24" Height="24" VerticalAlignment="Center"/>
                                    <TextBlock Text="USB Device Binding"
                                               FontSize="{StaticResource Type.H4.Size}"
                                               FontWeight="Normal"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </StackPanel>
                                
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="{StaticResource Type.Small.Size}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           LineHeight="20">
                                    Device binding cryptographically ties your vault to this specific USB drive. 
                                    The vault cannot be decrypted if copied to another device.
                                </TextBlock>

                                <CheckBox IsChecked="{Binding EnableUsbBinding}" Margin="0,4,0,0">
                                    <TextBlock Text="Enable USB device binding (recommended)"
                                               FontSize="{StaticResource Type.Body.Size}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </CheckBox>

                                <Border Background="{DynamicResource ControlBackgroundBrush}"
                                        CornerRadius="{StaticResource Radius.Sm}"
                                        Padding="12,10"
                                        IsVisible="{Binding UsbDeviceId, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <controls:SvgIcon Preset="Check" IconColor="White" IconSize="20"
                                                              Width="20" Height="20" VerticalAlignment="Center"/>
                                            <TextBlock FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="White">
                                                <Run Text="Device ID: "/>
                                                <Run Text="{Binding DisplayUsbDeviceId}" FontFamily="{StaticResource MonoFontFamily}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Command="{Binding ToggleRevealUsbDeviceIdCommand}"
                                                Classes="liquid-glass"
                                                Height="32"
                                                MinWidth="78"
                                                Padding="14,0">
                                            <TextBlock Text="{Binding UsbDeviceIdToggleText}"
                                                       Foreground="{DynamicResource ButtonTextBrush}"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- GUUID Binding -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="20,16"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="36" Height="36" CornerRadius="18" Background="#111B2A">
                                        <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Link.svg" IconColor="White" IconSize="22"
                                                          Width="22" Height="22"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="GUUID Binding"
                                                   FontSize="{StaticResource Type.H4.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Globally unique identifier binding for vault identity"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <CheckBox IsChecked="{Binding EnableGuuidBinding}" Margin="0,4,0,0">
                                    <TextBlock Text="Enable GUUID binding"
                                               FontSize="{StaticResource Type.Body.Size}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </CheckBox>

                                <Border Background="#162235" CornerRadius="8" Padding="12,8"
                                        IsVisible="{Binding GuuidValue, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                        BorderThickness="0"
                                        BoxShadow="0 4 16 0 #40000000">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <controls:SvgIcon Preset="Check" IconColor="White" IconSize="20"
                                                          Width="20" Height="20" VerticalAlignment="Center"/>
                                        <TextBlock FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontFamily="{StaticResource MonoFontFamily}"
                                                   Text="{Binding GuuidValue}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Encrypted Container -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="20,16"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="36" Height="36" CornerRadius="18" Background="#111B2A">
                                        <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Encrypted Container.svg" IconColor="White" IconSize="22"
                                                          Width="22" Height="22"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="Encrypted Container"
                                                   FontSize="{StaticResource Type.H4.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Create an encrypted container for vault data isolation"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <CheckBox IsChecked="{Binding EnableEncryptedContainer}" Margin="0,4,0,0">
                                    <TextBlock Text="Enable encrypted container"
                                               FontSize="{StaticResource Type.Body.Size}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </CheckBox>

                                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0"
                                            IsVisible="{Binding EnableEncryptedContainer}">
                                    <TextBlock Text="Container size:"
                                               FontSize="{StaticResource Type.Body.Size}"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                    <ComboBox SelectedItem="{Binding EncryptedContainerSize}"
                                              Width="140">
                                        <ComboBoxItem Content="128 MB"/>
                                        <ComboBoxItem Content="256 MB"/>
                                        <ComboBoxItem Content="512 MB"/>
                                        <ComboBoxItem Content="1 GB"/>
                                        <ComboBoxItem Content="2 GB"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step 5: Keyfile & Password -->
                <Border IsVisible="{Binding CurrentStep, Converter={x:Static views:StepVisibilityConverter.Instance}, ConverterParameter=5}"
                        Classes="fade-in">
                    <StackPanel Spacing="20" MaxWidth="700" HorizontalAlignment="Center">
                        <!-- Keyfile Section (Required) -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="28,24"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="40" Height="40" CornerRadius="20" Background="#111B2A">
                                        <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Keyfile.svg" IconColor="White" IconSize="24"
                                                          Width="24" Height="24"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="{Binding KeyMaterialSectionTitle}"
                                                   FontSize="{StaticResource Type.H3.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding KeyMaterialSectionSubtitle}"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   FontWeight="Normal"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Text="{Binding KeyMaterialDescription}"
                                           TextWrapping="Wrap"
                                           FontSize="{StaticResource Type.Body.Size}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           LineHeight="22"
                                           Margin="0,8,0,0"/>

                                <!-- Keyfile Option Selection -->
                                <Border Background="{DynamicResource ControlBackgroundBrush}"
                                        CornerRadius="{StaticResource Radius.Md}"
                                        Padding="16,12"
                                        Margin="0,8,0,0"
                                        IsVisible="{Binding SupportsExternalKeyfile}">
                                    <StackPanel Spacing="12">
                                        <!-- Generate New Keyfile Option -->
                                        <RadioButton IsChecked="{Binding !UseExistingKeyfile}" GroupName="KeyfileOption">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <controls:SvgIcon Preset="Plus" IconColor="White" IconSize="20"
                                                                  Width="20" Height="20" VerticalAlignment="Center"/>
                                                <TextBlock Text="Generate a new keyfile"
                                                           FontSize="{StaticResource Type.Body.Size}"
                                                           FontWeight="Normal"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </RadioButton>
                                        
                                        <!-- Use Existing Keyfile Option -->
                                        <RadioButton IsChecked="{Binding UseExistingKeyfile}" GroupName="KeyfileOption">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <controls:SvgIcon Preset="Folder" IconColor="White" IconSize="20"
                                                                  Width="20" Height="20" VerticalAlignment="Center"/>
                                                <TextBlock Text="Use an existing keyfile"
                                                           FontSize="{StaticResource Type.Body.Size}"
                                                           FontWeight="Normal"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </RadioButton>

                                        <!-- Browse for Keyfile (shown when Use Existing is selected) -->
                                        <Border IsVisible="{Binding UseExistingKeyfile}"
                                                Background="{DynamicResource SurfaceBrush}"
                                                CornerRadius="{StaticResource Radius.Sm}"
                                                Padding="12"
                                                Margin="28,4,0,0">
                                            <StackPanel Spacing="10">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Button Command="{Binding BrowseKeyfileCommand}"
                                                            Classes="primary"
                                                            Padding="16,8"
                                                            HorizontalAlignment="Left">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="📂" FontSize="{StaticResource Type.Body.Size}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="Browse..." VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Command="{Binding ClearKeyfileCommand}"
                                                            IsVisible="{Binding KeyfileSelected}"
                                                            Classes="ghost"
                                                            Padding="8"
                                                            ToolTip.Tip="Clear selection">
                                                        <TextBlock Text="✕" FontSize="{StaticResource Type.Body.Size}" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    </Button>
                                                </StackPanel>
                                                
                                                <TextBlock Text="{Binding KeyfileStatus}"
                                                           FontSize="{StaticResource Type.Small.Size}"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           TextWrapping="Wrap"/>
                                                <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding KeyfileSelected}">
                                                    <TextBlock Text="✓" FontSize="{StaticResource Type.Body.Size}" FontWeight="Normal" Foreground="White" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Keyfile validated"
                                                               FontSize="{StaticResource Type.Small.Size}"
                                                               Foreground="White"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Keyfile Generation Info (shown when Generate is selected) -->
                                <Border IsVisible="{Binding ShowGeneratedKeyfileInfo}"
                                        Background="{DynamicResource ControlBackgroundBrush}"
                                        CornerRadius="{StaticResource Radius.Md}"
                                        Padding="16,12"
                                        Margin="0,4,0,0">
                                    <StackPanel Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <controls:SvgIcon Preset="Info" IconColor="White" IconSize="20"
                                                              Width="20" Height="20" VerticalAlignment="Center"/>
                                            <TextBlock Text="Entropy-blended keyfile generator"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock TextWrapping="Wrap"
                                                   Text="{Binding KeyfileGenerationStatus}"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>

                                        <Border Background="#102030"
                                                CornerRadius="{StaticResource Radius.Sm}"
                                                Padding="16,14">
                                            <StackPanel Spacing="12">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <ProgressBar Grid.Column="0"
                                                                 Value="{Binding EntropyProgressPercent}"
                                                                 Minimum="0"
                                                                 Maximum="100"
                                                                 Height="8"/>
                                                    <TextBlock Grid.Column="1"
                                                               Margin="12,0,0,0"
                                                               Text="{Binding EntropyCollectedBits, StringFormat='{}{0} bits'}"
                                                               FontSize="{StaticResource Type.Small.Size}"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               VerticalAlignment="Center"/>
                                                </Grid>

                                                <TextBlock FontSize="{StaticResource Type.Small.Size}"
                                                           Foreground="{DynamicResource MutedTextBrush}">
                                                    <Run Text="Samples: "/>
                                                    <Run Text="{Binding EntropySampleCount}"/>
                                                    <Run Text="  |  Threshold: "/>
                                                    <Run Text="{Binding EntropyRequiredBits}"/>
                                                    <Run Text=" bits"/>
                                                </TextBlock>

                                                <Border Name="EntropyCaptureSurface"
                                                        Background="#0B1320"
                                                        BorderBrush="#465969"
                                                        BorderThickness="1"
                                                        CornerRadius="{StaticResource Radius.Sm}"
                                                        Height="196"
                                                        ClipToBounds="True"
                                                        IsEnabled="{Binding !EntropyKeyfileSealed}"
                                                        PointerMoved="EntropyCaptureSurface_PointerMoved"
                                                        PointerPressed="EntropyCaptureSurface_PointerPressed"
                                                        PointerReleased="EntropyCaptureSurface_PointerReleased">
                                                    <Grid>
                                                        <Canvas IsHitTestVisible="False">
                                                            <Line StartPoint="0,34" EndPoint="800,34" Stroke="#12FFFFFF" StrokeThickness="1"/>
                                                            <Line StartPoint="0,68" EndPoint="800,68" Stroke="#12FFFFFF" StrokeThickness="1"/>
                                                            <Line StartPoint="0,102" EndPoint="800,102" Stroke="#12FFFFFF" StrokeThickness="1"/>
                                                            <Line StartPoint="0,136" EndPoint="800,136" Stroke="#12FFFFFF" StrokeThickness="1"/>
                                                            <Line StartPoint="80,0" EndPoint="80,170" Stroke="#12FFFFFF" StrokeThickness="1"/>
                                                            <Line StartPoint="160,0" EndPoint="160,170" Stroke="#12FFFFFF" StrokeThickness="1"/>
                                                            <Line StartPoint="240,0" EndPoint="240,170" Stroke="#12FFFFFF" StrokeThickness="1"/>
                                                            <Line StartPoint="320,0" EndPoint="320,170" Stroke="#12FFFFFF" StrokeThickness="1"/>
                                                            <Line StartPoint="400,0" EndPoint="400,170" Stroke="#12FFFFFF" StrokeThickness="1"/>
                                                            <Line StartPoint="480,0" EndPoint="480,170" Stroke="#12FFFFFF" StrokeThickness="1"/>
                                                            <Line StartPoint="560,0" EndPoint="560,170" Stroke="#12FFFFFF" StrokeThickness="1"/>
                                                            <Line StartPoint="640,0" EndPoint="640,170" Stroke="#12FFFFFF" StrokeThickness="1"/>
                                                            <Line StartPoint="720,0" EndPoint="720,170" Stroke="#12FFFFFF" StrokeThickness="1"/>
                                                        </Canvas>

                                                        <StackPanel HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Spacing="8"
                                                                    IsHitTestVisible="False">
                                                            <TextBlock Text="Move your mouse here to feed the keyfile entropy pool"
                                                                       FontSize="{StaticResource Type.Body.Size}"
                                                                       FontWeight="Normal"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       HorizontalAlignment="Center"/>
                                                            <TextBlock Text="Pointer movement, timing jitter, and button transitions are blended with CSPRNG state to produce the staged keyfile."
                                                                       TextWrapping="Wrap"
                                                                       TextAlignment="Center"
                                                                       MaxWidth="500"
                                                                       FontSize="{StaticResource Type.Small.Size}"
                                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Button Command="{Binding SealEntropyKeyfileCommand}"
                                                            Classes="liquid-glass"
                                                            IsEnabled="{Binding CanSealEntropyKeyfile}">
                                                        <TextBlock Text="Seal Entropy Keyfile"/>
                                                    </Button>
                                                    <Button Command="{Binding ResetEntropyKeyfileCommand}"
                                                            Classes="liquid-glass">
                                                        <TextBlock Text="Reset Pool"/>
                                                    </Button>
                                                    <TextBlock Text="Entropy keyfile sealed"
                                                               VerticalAlignment="Center"
                                                               FontSize="{StaticResource Type.Small.Size}"
                                                               Foreground="White"
                                                               IsVisible="{Binding EntropyKeyfileSealed}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="• Stored on your selected storage location and wrapped in place during provisioning"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="• Keep a backup copy in a secure location after creation"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="• Never share your keyfile with anyone"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Border IsVisible="{Binding IsBlackSecureSelected}"
                                        Background="{DynamicResource ControlBackgroundBrush}"
                                        CornerRadius="{StaticResource Radius.Md}"
                                        Padding="16,12"
                                        Margin="0,4,0,0">
                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <controls:SvgIcon Preset="Info" IconColor="White" IconSize="20"
                                                              Width="20" Height="20" VerticalAlignment="Center"/>
                                            <TextBlock Text="Phantom Secured authentication path"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock Text="• Physical USB device path is used instead of a browsable filesystem"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="• Master password is required"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="• External keyfile browsing is disabled for this tier"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Optional Password Section -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="16">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Password.svg" IconColor="White" IconSize="24"
                                                      Width="24" Height="24" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="{Binding PasswordSectionTitle}"
                                                   FontSize="{StaticResource Type.H4.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding PasswordSectionDescription}"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Enable Password Checkbox -->
                                <CheckBox IsChecked="{Binding UsePassword}" Margin="0,8,0,0"
                                          IsVisible="{Binding ShowPasswordToggle}">
                                    <TextBlock Text="{Binding PasswordToggleText}"
                                               FontSize="{StaticResource Type.Body.Size}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </CheckBox>

                                <!-- Password Fields (shown when enabled) -->
                                <StackPanel Spacing="12" IsVisible="{Binding UsePassword}">
                                    <!-- Master Password -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Master Password"
                                                   FontSize="{StaticResource Type.Body.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding MasterPassword}"
                                                     Watermark="Enter your master password..."
                                                     FontSize="{StaticResource Type.Body.Size}"
                                                     IsVisible="{Binding RevealMasterPassword}"/>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding MasterPassword}"
                                                     PasswordChar="●"
                                                     Watermark="Enter your master password..."
                                                     FontSize="{StaticResource Type.Body.Size}"
                                                     IsVisible="{Binding !RevealMasterPassword}"/>
                                            <Button Grid.Column="1"
                                                    Command="{Binding ToggleMasterPasswordRevealCommand}"
                                                    Classes="liquid-glass"
                                                    Width="92"
                                                    Height="42">
                                                <TextBlock Text="{Binding MasterPasswordRevealGlyph}"/>
                                            </Button>
                                        </Grid>
                                        
                                        <!-- Strength Indicator -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <ProgressBar Grid.Column="0"
                                                         Value="{Binding PasswordStrength, Converter={x:Static views:PasswordStrengthValueConverter.Instance}}"
                                                         Minimum="0" Maximum="100"
                                                         Height="6"
                                                         Foreground="{Binding PasswordStrength, Converter={x:Static views:PasswordStrengthColorConverter.Instance}}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding PasswordStrength}"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{Binding PasswordStrength, Converter={x:Static views:PasswordStrengthColorConverter.Instance}}"
                                                       Margin="12,0,0,0"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Confirm Password -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Confirm Password"
                                                   FontSize="{StaticResource Type.Body.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding ConfirmPassword}"
                                                     Watermark="Confirm your master password..."
                                                     FontSize="{StaticResource Type.Body.Size}"
                                                     IsVisible="{Binding RevealConfirmPassword}"/>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding ConfirmPassword}"
                                                     PasswordChar="●"
                                                     Watermark="Confirm your master password..."
                                                     FontSize="{StaticResource Type.Body.Size}"
                                                     IsVisible="{Binding !RevealConfirmPassword}"/>
                                            <Button Grid.Column="1"
                                                    Command="{Binding ToggleConfirmPasswordRevealCommand}"
                                                    Classes="liquid-glass"
                                                    Width="92"
                                                    Height="42">
                                                <TextBlock Text="{Binding ConfirmPasswordRevealGlyph}"/>
                                            </Button>
                                        </Grid>
                                        
                                        <!-- Match Indicator -->
                                        <StackPanel Orientation="Horizontal" Spacing="8"
                                                    IsVisible="{Binding ConfirmPassword, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                            <TextBlock Text="{Binding PasswordsMatch, Converter={x:Static views:PasswordMatchIconConverter.Instance}}"
                                                       FontSize="{StaticResource Type.Body.Size}"/>
                                            <TextBlock Text="{Binding PasswordsMatch, Converter={x:Static views:PasswordMatchTextConverter.Instance}}"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{Binding PasswordsMatch, Converter={x:Static views:PasswordMatchColorConverter.Instance}}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Generate Button -->
                                    <Button Command="{Binding GenerateStrongPasswordCommand}"
                                            Classes="liquid-glass"
                                            Height="40"
                                            HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <controls:SvgIcon IconName="Assets/Visuals/App Icons/SVG/Generate dice.svg" IconColor="White" IconSize="20"
                                                              Width="20" Height="20" VerticalAlignment="Center"/>
                                            <TextBlock Text="Generate Strong Password"
                                                       Foreground="{DynamicResource ButtonTextBrush}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step 6: Additional Authentication -->
                <Border IsVisible="{Binding IsAuthenticationStep}"
                        Classes="fade-in">
                    <StackPanel Spacing="20" MaxWidth="760" HorizontalAlignment="Center">
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="26,22"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="44" Height="44" CornerRadius="22" Background="#122334">
                                        <controls:SvgIcon Preset="Lock" IconColor="White" IconSize="24"
                                                          Width="24" Height="24"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Additional Authentication"
                                                   FontSize="{StaticResource Type.H3.Size}"
                                                   FontFamily="{DynamicResource TitleFontFamily}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="These factors are optional, but if you switch one on it must be fully enrolled before you continue."
                                                   FontSize="{StaticResource Type.Body.Size}"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="14">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Windows Hello"
                                                   FontSize="{StaticResource Type.H4.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding WindowsHelloOnboarding.StatusMessage}"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding EnableWindowsHello}"
                                              VerticalAlignment="Center">
                                        <TextBlock Text="Require this factor"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </CheckBox>
                                </Grid>

                                <Border Background="#0E1A27"
                                        CornerRadius="10"
                                        Padding="14,12"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{Binding WindowsHelloOnboarding.EnrollmentStatus}"
                                                   FontSize="{StaticResource Type.Body.Size}"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button Command="{Binding WindowsHelloOnboarding.EnrollBiometricCommand}"
                                                    Classes="liquid-glass"
                                                    Height="40"
                                                    IsVisible="{Binding !WindowsHelloOnboarding.IsBiometricEnrolled}">
                                                <TextBlock Text="Set Up Windows Hello"/>
                                            </Button>
                                            <Button Command="{Binding WindowsHelloOnboarding.TestBiometricCommand}"
                                                    Classes="liquid-glass"
                                                    Height="40"
                                                    IsVisible="{Binding WindowsHelloOnboarding.IsBiometricEnrolled}">
                                                <TextBlock Text="Test"/>
                                            </Button>
                                            <Button Command="{Binding WindowsHelloOnboarding.RemoveBiometricCommand}"
                                                    Classes="liquid-glass"
                                                    Height="40"
                                                    IsVisible="{Binding WindowsHelloOnboarding.IsBiometricEnrolled}">
                                                <TextBlock Text="Remove"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="14">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Passkey"
                                                   FontSize="{StaticResource Type.H4.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding PasskeyOnboarding.StatusMessage}"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding EnablePasskeys}"
                                              VerticalAlignment="Center">
                                        <TextBlock Text="Require this factor"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </CheckBox>
                                </Grid>

                                <Border Background="#0E1A27"
                                        CornerRadius="10"
                                        Padding="14,12"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{Binding PasskeyOnboarding.RegistrationStatus}"
                                                   FontSize="{StaticResource Type.Body.Size}"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding PasskeyOnboarding.DeviceName}"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button Command="{Binding PasskeyOnboarding.RegisterPasskeyCommand}"
                                                    Classes="liquid-glass"
                                                    Height="40"
                                                    IsVisible="{Binding !PasskeyOnboarding.HasRegisteredPasskey}">
                                                <TextBlock Text="Register on This Device"/>
                                            </Button>
                                            <Button Command="{Binding PasskeyOnboarding.TestPasskeyCommand}"
                                                    Classes="liquid-glass"
                                                    Height="40"
                                                    IsVisible="{Binding PasskeyOnboarding.HasRegisteredPasskey}">
                                                <TextBlock Text="Test"/>
                                            </Button>
                                            <Button Command="{Binding PasskeyOnboarding.RemovePasskeyCommand}"
                                                    Classes="liquid-glass"
                                                    Height="40"
                                                    IsVisible="{Binding PasskeyOnboarding.HasRegisteredPasskey}">
                                                <TextBlock Text="Remove"/>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="14">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="TOTP"
                                                   FontSize="{StaticResource Type.H4.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding TotpOnboarding.StatusMessage}"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding EnableTotp}"
                                              VerticalAlignment="Center">
                                        <TextBlock Text="Require this factor"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </CheckBox>
                                </Grid>

                                <Border Background="#0E1A27"
                                        CornerRadius="10"
                                        Padding="14,12"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="12">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Authenticator Secret"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                            <TextBox Text="{Binding TotpOnboarding.TotpSecret}"
                                                     IsReadOnly="True"
                                                     FontFamily="Consolas, Courier New"
                                                     Watermark="Generate a secret to begin"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Button Command="{Binding TotpOnboarding.GenerateTotpSecretCommand}"
                                                    Classes="liquid-glass"
                                                    Height="40">
                                                <TextBlock Text="Generate Secret"/>
                                            </Button>
                                            <Button Command="{Binding TotpOnboarding.RemoveTotpSecretCommand}"
                                                    Classes="liquid-glass"
                                                    Height="40"
                                                    IsVisible="{Binding TotpOnboarding.HasTotpSecret}">
                                                <TextBlock Text="Clear"/>
                                            </Button>
                                        </StackPanel>

                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10"
                                              IsVisible="{Binding TotpOnboarding.HasTotpSecret}">
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding TotpOnboarding.TestCode}"
                                                     Watermark="Enter the 6-digit authenticator code"/>
                                            <Button Grid.Column="1"
                                                    Command="{Binding TotpOnboarding.VerifyTotpCodeCommand}"
                                                    Classes="liquid-glass"
                                                    Height="42">
                                                <TextBlock Text="Verify"/>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Step 7 (conditional): Remnant Actions — only shown when remnants are detected on the USB drive -->
                <Border IsVisible="{Binding IsRemnantStep}"
                        Classes="fade-in">
                    <StackPanel Spacing="20" MaxWidth="700" HorizontalAlignment="Center">
                        <!-- Remnant Detection Header -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="44" Height="44" CornerRadius="22" Background="#122334">
                                        <controls:SvgIcon Preset="AlertTriangle" IconColor="{DynamicResource AccentBrush}" IconSize="24"
                                                          Width="28" Height="28"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Remnant Detection"
                                                   FontSize="{StaticResource Type.H3.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Previous vault remnants were detected on this drive"
                                                   FontSize="{StaticResource Type.Body.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Detected Remnants List -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Detected Files"
                                           FontSize="{StaticResource Type.H4.Size}"
                                           FontWeight="Normal"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>

                                <ItemsControl ItemsSource="{Binding DetectedRemnants}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0E1A27"
                                                    CornerRadius="10" Padding="14,12" Margin="0,0,0,8"
                                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                                    BorderThickness="1">
                                                <Grid ColumnDefinitions="Auto,*,Auto">
                                                    <controls:SvgIcon Grid.Column="0" Preset="File" IconColor="{DynamicResource MutedTextBrush}" IconSize="20"
                                                                      Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding FileName}"
                                                                   FontSize="{StaticResource Type.Body.Size}"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                        <TextBlock Text="{Binding FilePath}"
                                                                   FontSize="{StaticResource Type.Micro.Size}"
                                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding FileSize}"
                                                               FontSize="{StaticResource Type.Small.Size}"
                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Remnant Action Selection -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Choose an Action"
                                           FontSize="{StaticResource Type.H4.Size}"
                                           FontWeight="Normal"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>

                                <RadioButton GroupName="RemnantAction"
                                             IsChecked="{Binding WipeRemnantsSelected, Mode=TwoWay}">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Securely wipe remnants before creating vault"
                                                   FontSize="{StaticResource Type.Body.Size}"
                                                   FontWeight="Normal"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Recommended — removes old vault files to prevent conflicts"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton GroupName="RemnantAction"
                                             IsChecked="{Binding IgnoreRemnantsSelected, Mode=TwoWay}">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Ignore remnants and proceed"
                                                   FontSize="{StaticResource Type.Body.Size}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="Keep existing files — remnants will remain on the drive"
                                                   FontSize="{StaticResource Type.Small.Size}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Review and Completion (final step — step 6 or 7 depending on remnant detection) -->
                <Border IsVisible="{Binding IsReviewStep}"
                        Classes="fade-in">
                    <StackPanel Spacing="20" MaxWidth="700" HorizontalAlignment="Center">
                        <!-- Summary Header -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                                    <Border Width="44" Height="44" CornerRadius="22" Background="#111B2A">
                                        <controls:SvgIcon Preset="Check" IconColor="White" IconSize="24"
                                                          Width="24" Height="24"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Ready to Create Your Vault!"
                                               FontSize="{StaticResource Type.H2.Size}"
                                               FontFamily="{DynamicResource TitleFontFamily}"
                                               FontWeight="Normal"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Text="Review your settings below, then click 'Create Vault' to finish setup."
                                           FontSize="{StaticResource Type.Body.Size}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Configuration Summary -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Your Vault Configuration"
                                           FontSize="{StaticResource Type.H4.Size}"
                                           FontWeight="Normal"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>

                                <StackPanel Spacing="12">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <controls:SvgIcon Grid.Column="0" Preset="Settings" IconColor="White" IconSize="32"
                                                          Width="32" Height="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Protection Tier"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding SelectedSecurityLevel}"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*">
                                        <controls:SvgIcon Grid.Column="0" IconName="Assets/Visuals/App Icons/SVG/Storage Location.svg" IconColor="White" IconSize="32"
                                                          Width="32" Height="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Storage Location"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding SelectedStorageLocation}"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*">
                                        <controls:SvgIcon Grid.Column="0" IconName="Assets/Visuals/App Icons/SVG/Keyfile.svg" IconColor="White" IconSize="32"
                                                          Width="32" Height="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Keyfile"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                            <TextBlock Text="Will be generated"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*">
                                        <controls:SvgIcon Grid.Column="0" IconName="Assets/Visuals/App Icons/SVG/Password.svg" IconColor="White" IconSize="32"
                                                          Width="32" Height="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Master Password"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding UsePassword, Converter={x:Static views:BoolToEnabledConverter.Instance}}"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*">
                                        <controls:SvgIcon Grid.Column="0" Preset="Eye" IconColor="White" IconSize="32"
                                                          Width="32" Height="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Windows Hello"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding EnableWindowsHello, Converter={x:Static views:BoolToEnabledConverter.Instance}}"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*">
                                        <controls:SvgIcon Grid.Column="0" Preset="Lock" IconColor="White" IconSize="32"
                                                          Width="32" Height="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Passkey"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding EnablePasskeys, Converter={x:Static views:BoolToEnabledConverter.Instance}}"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,*">
                                        <controls:SvgIcon Grid.Column="0" Preset="Clock" IconColor="White" IconSize="32"
                                                          Width="32" Height="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="TOTP"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding EnableTotp, Converter={x:Static views:BoolToEnabledConverter.Instance}}"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- PhantomKey Hardware Binding -->
                                    <Grid ColumnDefinitions="Auto,*">
                                        <controls:SvgIcon Grid.Column="0" Preset="Shield" IconColor="White" IconSize="32"
                                                          Width="32" Height="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="PhantomKey Hardware Binding"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding EnablePhantomKey, Converter={x:Static views:BoolToEnabledConverter.Instance}}"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="{Binding PhantomKeyBridgeLocationDescription}"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="520"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- GUUID Binding -->
                                    <Grid ColumnDefinitions="Auto,*">
                                        <controls:SvgIcon Grid.Column="0" IconName="Assets/Visuals/App Icons/SVG/Link.svg" IconColor="White" IconSize="32"
                                                          Width="32" Height="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="GUUID Binding"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding EnableGuuidBinding, Converter={x:Static views:BoolToEnabledConverter.Instance}}"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Encrypted Container -->
                                    <Grid ColumnDefinitions="Auto,*">
                                        <controls:SvgIcon Grid.Column="0" IconName="Assets/Visuals/App Icons/SVG/Encrypted Container.svg" IconColor="White" IconSize="32"
                                                          Width="32" Height="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Encrypted Container"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding EnableEncryptedContainer, Converter={x:Static views:BoolToEnabledConverter.Instance}}"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Remnant Detection (only when remnants were detected) -->
                                    <Grid ColumnDefinitions="Auto,*"
                                          IsVisible="{Binding HasRemnants}">
                                        <controls:SvgIcon Grid.Column="0" Preset="AlertTriangle" IconColor="#AE8B6B" IconSize="32"
                                                          Width="32" Height="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Remnant Action"
                                                       FontSize="{StaticResource Type.Small.Size}"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                            <TextBlock Text="{Binding SelectedRemnantAction}"
                                                       FontSize="{StaticResource Type.Body.Size}"
                                                       FontWeight="Normal"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Completion Progress -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Padding="24,20"
                                BoxShadow="0 4 16 0 #40000000"
                                IsVisible="{Binding IsCompleting}">
                            <StackPanel Spacing="12" HorizontalAlignment="Center">
                                <ProgressBar IsIndeterminate="True"
                                             Height="8"
                                             Width="300"
                                             Foreground="{DynamicResource AccentBrush}"/>
                                <TextBlock Text="{Binding StatusMessage}"
                                           FontSize="{StaticResource Type.Body.Size}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════════
             FOOTER - Navigation buttons and status
             ═══════════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource FooterBackgroundBrush}"
                Padding="24,20,24,32"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Status Message -->
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           FontSize="{StaticResource Type.Small.Size}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           MaxWidth="300"
                           TextWrapping="Wrap"/>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <Button Command="{Binding PreviousStepCommand}"
                            Content="← Back"
                            Classes="liquid-glass nav-button"
                            IsVisible="{Binding CanGoBack}"/>
                    
                    <Button Command="{Binding NextStepCommand}"
                            Content="{Binding NextButtonText}"
                            Classes="liquid-glass nav-button"
                            IsEnabled="{Binding CanGoNext}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

</views:ThemeAwareWindow>
