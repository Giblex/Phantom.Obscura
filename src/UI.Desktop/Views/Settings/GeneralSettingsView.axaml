<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PhantomVault.UI.Views.Settings.GeneralSettingsView">
    <StackPanel Spacing="20" Margin="0,0,30,60">
        <TextBlock Text="General Settings" 
                   FontSize="{StaticResource Type.H3.Size}" 
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"/>
        
        <Border Classes="fade-in stagger-1"
                Background="{DynamicResource SettingsPanelBackgroundBrush}"
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="{StaticResource Radius.Lg}" 
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Vault Preferences" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <CheckBox Content="Start with Windows" 
                          IsEnabled="False"
                          ToolTip.Tip="Launch PhantomVault automatically when Windows starts"/>
                
                <CheckBox Content="Minimize to system tray" 
                          IsEnabled="False"
                          ToolTip.Tip="Keep PhantomVault running in background when minimized"/>
                
                <CheckBox Content="Check for updates automatically" 
                          IsEnabled="False"
                          ToolTip.Tip="Automatically check for new versions on startup"/>

                <TextBlock Text="Startup automation and in-app update controls are not wired in this build yet, so they are shown as unavailable instead of acting like live switches."
                           FontSize="{StaticResource Type.Small.Size}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
                
                <StackPanel Spacing="8">
                    <TextBlock Text="Default view mode:" 
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <ComboBox Width="200"
                              HorizontalAlignment="Left"
                              SelectedIndex="{Binding SelectedDefaultView, Mode=TwoWay}">
                        <ComboBoxItem Content="List View"/>
                        <ComboBoxItem Content="Grid View"/>
                    </ComboBox>
                </StackPanel>
                
                <ToggleSwitch Content="Show Dashboard on startup"
                              IsChecked="{Binding IsDashboardEnabled}"
                              HorizontalAlignment="Left"
                              ToolTip.Tip="When disabled, the app starts directly on the Passwords view and hides the Dashboard button"/>
            </StackPanel>
        </Border>

        <Border Classes="fade-in stagger-2"
                Background="{DynamicResource SettingsPanelBackgroundBrush}"
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="{StaticResource Radius.Lg}" 
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Icon Management" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <TextBlock Text="Manage custom icons, import new icons, and organize your icon library" 
                           FontSize="{StaticResource Type.Small.Size}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
                
                <Button Content="Open Icon Manager" 
                        HorizontalAlignment="Left"
                        Classes="liquid-glass"
                        Command="{Binding $parent[Window].DataContext.OpenIconManagerCommand}"
                        ToolTip.Tip="Manage custom icons and download icon packs"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
