<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PhantomVault.UI.ViewModels.Settings"
             x:Class="PhantomVault.UI.Views.Settings.BackupSettingsView"
             x:DataType="vm:BackupSettingsViewModel">
    <StackPanel Spacing="20" Margin="0,0,30,60">
        <TextBlock Text="Backup &amp; Restore" 
                   FontSize="{StaticResource Type.H3.Size}" 
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"/>
        
        <Border Classes="fade-in stagger-1"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="16" 
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Scheduled Backups" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>

                <StackPanel Spacing="8">
                    <TextBlock Text="Backup location:" 
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" 
                                 Margin="0,0,10,0"
                                 Text="{Binding BackupLocation}"
                                 IsReadOnly="True"/>
                        <Button Grid.Column="1" 
                                Content="Browse..." 
                                Command="{Binding BrowseBackupLocationCommand}"
                                Width="100"/>
                    </Grid>
                </StackPanel>

                <CheckBox Content="Enable automated backups"
                          IsChecked="{Binding EnableAutomatedBackups}"
                          Foreground="{DynamicResource PrimaryTextBrush}"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <StackPanel Grid.Column="0" Spacing="6">
                        <TextBlock Text="Frequency"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <ComboBox SelectedIndex="{Binding SelectedFrequency}">
                            <ComboBoxItem Content="Daily"/>
                            <ComboBoxItem Content="Weekly"/>
                            <ComboBoxItem Content="Monthly"/>
                            <ComboBoxItem Content="On vault close"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="6">
                        <TextBlock Text="Retention"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <ComboBox SelectedIndex="{Binding SelectedRetention}">
                            <ComboBoxItem Content="Keep 5 backups"/>
                            <ComboBoxItem Content="Keep 10 backups"/>
                            <ComboBoxItem Content="Keep 20 backups"/>
                            <ComboBoxItem Content="Keep 50 backups"/>
                            <ComboBoxItem Content="Keep all backups"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <CheckBox Content="Use signed secure backup package for manual backups"
                          IsChecked="{Binding EncryptBackups}"
                          Foreground="{DynamicResource PrimaryTextBrush}"/>

                <TextBlock Text="{Binding ScheduledBackupStatus}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>

                <TextBlock Text="{Binding VaultContextStatus}"
                           TextWrapping="Wrap"
                           FontSize="{StaticResource Type.Small.Size}"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StackPanel>
        </Border>

        <Border Classes="fade-in stagger-2"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="16" 
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Manual Backup" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Backup Now" 
                            Width="150"
                            Command="{Binding BackupNowCommand}"
                            IsEnabled="{Binding IsVaultContextAvailable}"
                            Classes="primary"
                            ToolTip.Tip="Create an immediate backup"/>
                    <Button Content="Restore from Backup" 
                            Width="150"
                            Command="{Binding RestoreFromBackupCommand}"
                            IsEnabled="{Binding IsVaultContextAvailable}"
                            Classes="liquid-glass"
                            ToolTip.Tip="Restore vault from a previous backup"/>
                </StackPanel>

                <TextBlock Text="{Binding LastBackupTime, StringFormat='Last backup: {0}'}" 
                           FontStyle="Italic"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>

                <TextBlock Text="{Binding VaultContextStatus}"
                           TextWrapping="Wrap"
                           FontSize="{StaticResource Type.Small.Size}"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StackPanel>
        </Border>

        <Border Classes="fade-in stagger-3"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="16" 
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Backup History" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <ScrollViewer Height="150" 
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding BackupHistory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" 
                                           FontStyle="Italic"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Text="{Binding BackupHistoryStatus}"
                           TextWrapping="Wrap"
                           FontSize="{StaticResource Type.Small.Size}"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>

                <Button Content="Open Backup Folder" 
                        Width="180" 
                        HorizontalAlignment="Left"
                        Command="{Binding OpenBackupFolderCommand}"
                        Classes="liquid-glass"/>
            </StackPanel>
        </Border>

        <Border Classes="fade-in stagger-4"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="16" 
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Vault Snapshots" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <TextBlock Text="Manage encrypted backup snapshots, create new restore points, and roll back from existing backup files." 
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                
                <Button Content="Manage Snapshots" 
                        Width="180" 
                        HorizontalAlignment="Left"
                        Command="{Binding ManageSnapshotsCommand}"
                        Classes="liquid-glass"/>
            </StackPanel>
        </Border>

        <!-- Recovery Vault Backup -->
        <Border Classes="fade-in stagger-5"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="16" 
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Recovery Vault Backup" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>

                <TextBlock Text="Recovery vault backup is available when the currently unlocked vault can resolve its PhantomRecovery workspace on the bound device."
                           TextWrapping="Wrap"
                           FontSize="{StaticResource Type.Small.Size}"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>

                <TextBlock Text="{Binding RecoveryVaultStatus}"
                           TextWrapping="Wrap"
                           FontSize="{StaticResource Type.Small.Size}"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Backup Recovery Vault" 
                            Width="180"
                            Command="{Binding BackupRecoveryVaultNowCommand}"
                            IsEnabled="{Binding IsRecoveryVaultAvailable}"
                            Classes="primary"
                            ToolTip.Tip="Create immediate backup of recovery vault"/>
                    <Button Content="Restore Recovery Vault" 
                            Width="180"
                            Command="{Binding RestoreRecoveryVaultCommand}"
                            IsEnabled="{Binding IsRecoveryVaultAvailable}"
                            Classes="liquid-glass"
                            ToolTip.Tip="Restore recovery vault from backup"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

