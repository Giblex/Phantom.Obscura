<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PhantomVault.UI.Views.Settings.PasswordHealthView">
    <StackPanel Spacing="16" Margin="0,0,30,60">
        <TextBlock Text="Password Health" 
                   FontSize="20" 
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"/>
        
        <TextBlock Text="Analyze your vault passwords for security issues"
                   FontSize="{StaticResource Type.Label.Size}"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   Margin="0,0,0,8"/>

        <!-- Analysis Button -->
        <Button Content="Analyze Passwords" 
                Command="{Binding AnalyzeCommand}"
                HorizontalAlignment="Left"
                Padding="20,8"
                FontWeight="SemiBold"
                Background="{DynamicResource AccentBrush}"
                Foreground="White"
                BorderThickness="0"
                CornerRadius="6"/>

        <!-- Results Panel -->
        <Border Background="{DynamicResource TileGlassBrush}"
                BorderBrush="{DynamicResource TileBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,8,0,0">
            <StackPanel Spacing="12">
                <TextBlock Text="Analysis Results"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Total Credentials:" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding Report.TotalCredentials}" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </Grid>
                    
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Weak Passwords:" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding Report.WeakCount}" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ErrorBrush}"/>
                    </Grid>
                    
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Reused Passwords:" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding Report.ReusedCount}" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                    </Grid>
                    
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Old Passwords:" 
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding Report.OldCount}" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningBrush}"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Info Message -->
        <Border Background="{DynamicResource InfoBackgroundBrush}"
                BorderBrush="{DynamicResource InfoBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,8,0,0">
            <StackPanel Spacing="6">
                <TextBlock Text="💡 Tips for Strong Passwords"
                           FontWeight="SemiBold"
                           FontSize="{StaticResource Type.Label.Size}"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="• Use at least 12 characters"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                <TextBlock Text="• Mix uppercase, lowercase, numbers, and symbols"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                <TextBlock Text="• Avoid common words or personal information"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                <TextBlock Text="• Use unique passwords for each account"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>


