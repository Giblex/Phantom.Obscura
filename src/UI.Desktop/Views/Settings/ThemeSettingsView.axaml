<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PhantomVault.UI.ViewModels.Settings"
             x:Class="PhantomVault.UI.Views.Settings.ThemeSettingsView"
             x:DataType="vm:ThemeSettingsViewModel">
    <StackPanel Spacing="20" Margin="0,0,30,60">
        <TextBlock Text="Theme Settings" 
                   FontSize="{StaticResource Type.H3.Size}" 
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"/>
        
        <!-- Runtime Theme Selection -->
        <Border Classes="fade-in stagger-1"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="{StaticResource Radius.Lg}" 
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="App Theme" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="Choose a color scheme for the main vault windows." 
                           FontSize="{StaticResource Type.Small.Size}" 
                           Foreground="{DynamicResource MutedTextBrush}"/>
                <ComboBox 
                    ItemsSource="{Binding RuntimeThemeNames}" 
                    SelectedIndex="{Binding SelectedRuntimeThemeIndex, Mode=TwoWay}"
                    Width="250"
                    HorizontalAlignment="Left"/>
                
                <!-- Custom Theme Controls -->
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,5,0,0">
                    <Button Content="Create Custom Theme" 
                            Command="{Binding CreateCustomThemeCommand}"
                            Classes="accent"
                            Padding="12,6"/>
                    <Button Content="Delete Custom Theme" 
                            Command="{Binding DeleteCustomThemeCommand}"
                            IsVisible="{Binding IsCustomThemeSelected}"
                            Foreground="{DynamicResource ErrorBrush}"
                            Padding="12,6"/>
                </StackPanel>

                <!-- Custom Theme Editor (visible when creating/editing) -->
                <Border IsVisible="{Binding IsCustomEditorOpen}"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Md}"
                        Padding="16"
                        Margin="0,8,0,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Custom Theme Editor" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Pick your base colors. The full theme is generated automatically."
                                   FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource MutedTextBrush}"/>
                        
                        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Theme Name" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CustomThemeName, Mode=TwoWay}" Width="200" HorizontalAlignment="Left"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Primary BG" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Border Width="24" Height="24" CornerRadius="4" Background="{Binding CustomPrimaryBgPreview}"/>
                                <TextBox Text="{Binding CustomPrimaryBg, Mode=TwoWay}" Width="100"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Secondary BG" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Border Width="24" Height="24" CornerRadius="4" Background="{Binding CustomSecondaryBgPreview}"/>
                                <TextBox Text="{Binding CustomSecondaryBg, Mode=TwoWay}" Width="100"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Surface BG" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Border Width="24" Height="24" CornerRadius="4" Background="{Binding CustomSurfaceBgPreview}"/>
                                <TextBox Text="{Binding CustomSurfaceBg, Mode=TwoWay}" Width="100"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Accent" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Border Width="24" Height="24" CornerRadius="4" Background="{Binding CustomAccentPreview}"/>
                                <TextBox Text="{Binding CustomAccent, Mode=TwoWay}" Width="100"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Accent Hover" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Border Width="24" Height="24" CornerRadius="4" Background="{Binding CustomAccentHoverPreview}"/>
                                <TextBox Text="{Binding CustomAccentHover, Mode=TwoWay}" Width="100"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Text Primary" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Border Width="24" Height="24" CornerRadius="4" Background="{Binding CustomTextPrimaryPreview}"/>
                                <TextBox Text="{Binding CustomTextPrimary, Mode=TwoWay}" Width="100"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Text Muted" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Border Width="24" Height="24" CornerRadius="4" Background="{Binding CustomTextMutedPreview}"/>
                                <TextBox Text="{Binding CustomTextMuted, Mode=TwoWay}" Width="100"/>
                            </StackPanel>
                            
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Border" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Border Width="24" Height="24" CornerRadius="4" Background="{Binding CustomBorderPreview}"/>
                                <TextBox Text="{Binding CustomBorder, Mode=TwoWay}" Width="100"/>
                            </StackPanel>
                        </Grid>
                        
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                            <Button Content="Save &amp; Apply" 
                                    Command="{Binding SaveCustomThemeCommand}"
                                    Classes="accent" Padding="12,6"/>
                            <Button Content="Cancel" 
                                    Command="{Binding CancelCustomThemeCommand}"
                                    Padding="12,6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
        
        <Border Classes="fade-in stagger-2"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="{StaticResource Radius.Lg}" 
                Padding="20">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                <StackPanel Grid.Column="0" Spacing="15">
                        <TextBlock Text="Appearance" 
                               FontSize="{StaticResource Type.Body.Size}" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    
                        <ToggleSwitch Content="Dark mode" 
                              IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                              ToolTip.Tip="Switch between light and dark mode"
                              HorizontalAlignment="Left"/>

                        <CheckBox Content="Enable high contrast mode" 
                                  IsChecked="{Binding EnableHighContrast}"
                                  ToolTip.Tip="Increase contrast for better visibility"/>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Display scale:" 
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <ComboBox Width="150" 
                                      HorizontalAlignment="Left"
                                      SelectedIndex="{Binding SelectedDisplayScale}">
                                <ComboBoxItem Content="80%"/>
                                <ComboBoxItem Content="90%"/>
                                <ComboBoxItem Content="100% (Default)"/>
                                <ComboBoxItem Content="110%"/>
                                <ComboBoxItem Content="125%"/>
                                <ComboBoxItem Content="150%"/>
                            </ComboBox>
                        </StackPanel>
                </StackPanel>
                
                <!-- Theme Preview -->
                <Border Grid.Column="1" 
                        Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                        BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                        BorderThickness="1" 
                        CornerRadius="{StaticResource Radius.Lg}" 
                        Padding="20"
                        Width="200">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Preview" 
                                   FontSize="{StaticResource Type.Small.Size}" 
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                        <Border Background="{DynamicResource ContentBackgroundBrush}" 
                                CornerRadius="{StaticResource Radius.Md}" 
                                Padding="12">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="{DynamicResource AccentBrush}" 
                                            Width="20" 
                                            Height="20" 
                                            CornerRadius="4"/>
                                    <TextBlock Text="Accent" 
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Primary text" 
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock Text="Secondary text" 
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Text="Muted text" 
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Classes="fade-in stagger-3"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="{StaticResource Radius.Lg}" 
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Motion &amp; Effects" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <CheckBox Content="Reduce animations" 
                          IsChecked="{Binding ReduceAnimations}"
                          ToolTip.Tip="Minimize motion effects for accessibility"/>

                <CheckBox Content="Reduce transparency effects" 
                          IsChecked="{Binding ReduceTransparency}"
                          ToolTip.Tip="Use solid colors instead of transparency"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
