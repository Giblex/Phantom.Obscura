<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PhantomVault.UI.ViewModels.Settings"
             x:Class="PhantomVault.UI.Views.Settings.PasswordSecurityView"
             x:DataType="vm:PasswordSecurityViewModel"
             x:CompileBindings="False">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="20" Margin="0,0,16,0">
            <!-- Header -->
            <StackPanel Spacing="8">
                <TextBlock Text="🛡️ Password Security Center" 
                           FontSize="24" 
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <TextBlock Text="Comprehensive password analysis, strength monitoring, and security recommendations"
                           FontSize="{StaticResource Type.Body.Size}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8"/>
            </StackPanel>

            <!-- Quick Actions Bar -->
            <Border Background="{DynamicResource TileGlassBrush}"
                    BorderBrush="{DynamicResource TileBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Xl}"
                    Padding="20">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Quick Actions" 
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Analyze and improve your vault security"
                                   FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="🔍 Scan Passwords" 
                            Command="{Binding AnalyzeCommand}"
                            Padding="16,8"
                            FontWeight="SemiBold"
                            Background="{DynamicResource Brush.Accent}"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="6"
                            ToolTip.Tip="Run comprehensive security analysis"/>

                    <Button Grid.Column="2"
                            Content="⚠️ View Flagged" 
                            Command="{Binding ShowFlaggedPasswordsCommand}"
                            Padding="16,8"
                            FontWeight="SemiBold"
                            Background="{DynamicResource WarningBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="6"
                            IsEnabled="{Binding HasFlaggedPasswords}"
                            ToolTip.Tip="Show all flagged passwords"/>

                    <Button Grid.Column="3"
                            Content="📊 Export Report" 
                            Command="{Binding ExportReportCommand}"
                            Padding="16,8"
                            FontWeight="SemiBold"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            Background="Transparent"
                            CornerRadius="6"
                            IsEnabled="{Binding HasReport}"
                            ToolTip.Tip="Export security report to file"/>
                </Grid>
            </Border>

            <!-- Security Score Dashboard -->
            <Border Background="{DynamicResource TileGlassBrush}"
                    BorderBrush="{DynamicResource TileBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Xl}"
                    Padding="24"
                    IsVisible="{Binding HasReport}">
                <Grid RowDefinitions="Auto,Auto,*" RowSpacing="20">
                    <!-- Score Header -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Border Width="80" Height="80"
                                Background="{Binding SecurityScoreColor}"
                                CornerRadius="40"
                                Opacity="0.2"/>
                        <Viewbox Width="80" Height="80">
                            <TextBlock Text="{Binding SecurityScore}"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="{Binding SecurityScoreColor}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Viewbox>

                        <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Overall Security Score"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="{Binding SecurityScoreLabel}"
                                       FontSize="14"
                                       Foreground="{Binding SecurityScoreColor}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding LastAnalyzedText}"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedTextBrush}"/>
                        </StackPanel>

                        <Border Grid.Column="2"
                                Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16"
                                VerticalAlignment="Center">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Security Status"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Text="{Binding SecurityStatusIcon}"
                                           FontSize="32"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding SecurityStatusText}"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           MaxWidth="100"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Statistics Grid -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                        <!-- Total Credentials -->
                        <Border Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="📊"
                                           FontSize="24"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Report.TotalCredentials}"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock Text="Total Passwords"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Weak Passwords -->
                        <Border Grid.Column="1"
                                Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource ErrorBrush}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="🔴"
                                           FontSize="24"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Report.WeakCount}"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource ErrorBrush}"/>
                                <TextBlock Text="Weak Passwords"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Reused Passwords -->
                        <Border Grid.Column="2"
                                Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource WarningBrush}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="🟡"
                                           FontSize="24"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Report.ReusedCount}"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource WarningBrush}"/>
                                <TextBlock Text="Reused Passwords"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Old Passwords -->
                        <Border Grid.Column="3"
                                Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource WarningBrush}"
                                BorderThickness="2"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="📅"
                                           FontSize="24"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Report.OldCount}"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource WarningBrush}"/>
                                <TextBlock Text="Old Passwords"
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Average Entropy Bar -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="Average Password Strength"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding AverageEntropyText}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding AverageEntropyColor}"/>
                            </Grid>

                            <Border Background="{DynamicResource WindowBackgroundBrush}"
                                    Height="8"
                                    CornerRadius="4">
                                <Border Background="{Binding AverageEntropyColor}"
                                        Width="{Binding AverageEntropyBarWidth}"
                                        HorizontalAlignment="Left"
                                        CornerRadius="4"/>
                            </Border>

                            <TextBlock Text="{Binding AverageEntropyDescription}"
                                       FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Detailed Issues -->
            <Border Background="{DynamicResource TileGlassBrush}"
                    BorderBrush="{DynamicResource TileBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Xl}"
                    Padding="20"
                    IsVisible="{Binding HasIssues}">
                <StackPanel Spacing="16">
                    <TextBlock Text="🔍 Detected Issues"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                    <!-- Weak Passwords Section -->
                    <Border Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource ErrorBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            IsVisible="{Binding HasWeakPasswords}">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Width="32" Height="32"
                                        Background="{DynamicResource ErrorBrush}"
                                        CornerRadius="16"
                                        Opacity="0.2"/>
                                <Viewbox Width="32" Height="32">
                                    <TextBlock Text="🔴"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Viewbox>
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding WeakPasswordsHeader}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ErrorBrush}"/>
                                    <TextBlock Text="These passwords have low entropy and are vulnerable to attacks"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Content="View All"
                                        Command="{Binding ViewWeakPasswordsCommand}"
                                        Classes="liquid-glass"
                                        Padding="12,6"
                                        FontSize="12"/>
                            </Grid>
                            
                            <ItemsControl ItemsSource="{Binding WeakPasswordsSample}" Margin="0,4,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource WindowBackgroundBrush}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="12,8"
                                                Margin="0,0,0,6">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <TextBlock Text="⚠️" FontSize="14" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding}"
                                                           FontSize="13"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="Update"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Brush.Accent}"
                                                           VerticalAlignment="Center"
                                                           Cursor="Hand"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Reused Passwords Section -->
                    <Border Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource WarningBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            IsVisible="{Binding HasReusedPasswords}">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Width="32" Height="32"
                                        Background="{DynamicResource WarningBrush}"
                                        CornerRadius="16"
                                        Opacity="0.2"/>
                                <Viewbox Width="32" Height="32">
                                    <TextBlock Text="🟡"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Viewbox>
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ReusedPasswordsHeader}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource WarningBrush}"/>
                                    <TextBlock Text="Using the same password for multiple accounts increases risk"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Content="View All"
                                        Command="{Binding ViewReusedPasswordsCommand}"
                                        Classes="liquid-glass"
                                        Padding="12,6"
                                        FontSize="12"/>
                            </Grid>
                            
                            <ItemsControl ItemsSource="{Binding ReusedPasswordsSample}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource WindowBackgroundBrush}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="12,8"
                                                Margin="0,0,0,6">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <TextBlock Text="⚠️" FontSize="14" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding}"
                                                           FontSize="13"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="Update"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Brush.Accent}"
                                                           VerticalAlignment="Center"
                                                           Cursor="Hand"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Old Passwords Section -->
                    <Border Background="{DynamicResource ContentBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16"
                            IsVisible="{Binding HasOldPasswords}">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Border Width="32" Height="32"
                                        Background="{DynamicResource WarningBrush}"
                                        CornerRadius="16"
                                        Opacity="0.2"/>
                                <Viewbox Width="32" Height="32">
                                    <TextBlock Text="📅"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Viewbox>
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding OldPasswordsHeader}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource WarningBrush}"/>
                                    <TextBlock Text="These passwords haven't been updated in over a year"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Content="View All"
                                        Command="{Binding ViewOldPasswordsCommand}"
                                        Classes="liquid-glass"
                                        Padding="12,6"
                                        FontSize="12"/>
                            </Grid>
                            
                            <ItemsControl ItemsSource="{Binding OldPasswordsSample}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource WindowBackgroundBrush}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="12,8"
                                                Margin="0,0,0,6">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <TextBlock Text="📅" FontSize="14" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding}"
                                                           FontSize="13"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="Update"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource Brush.Accent}"
                                                           VerticalAlignment="Center"
                                                           Cursor="Hand"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Security Settings -->
            <Border Background="{DynamicResource TileGlassBrush}"
                    BorderBrush="{DynamicResource TileBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Xl}"
                    Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="⚙️ Security Settings"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                    <CheckBox Content="Auto-analyze on vault unlock"
                              IsChecked="{Binding AutoAnalyzeOnUnlock}"
                              FontSize="14"/>

                    <CheckBox Content="Show password strength in entry editor"
                              IsChecked="{Binding ShowPasswordStrengthInEditor}"
                              FontSize="14"/>

                    <CheckBox Content="Flag passwords shorter than 12 characters"
                              IsChecked="{Binding FlagShortPasswords}"
                              FontSize="14"/>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Minimum Entropy Threshold"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Slider Value="{Binding EntropyThreshold}"
                                    Minimum="20"
                                    Maximum="80"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding EntropyThreshold, StringFormat='{}{0:F0} bits'}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Accent}"/>
                        </Grid>
                        <TextBlock Text="Lower values flag more passwords as weak"
                                   FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Password Age Threshold (days)"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Slider Value="{Binding AgeThresholdDays}"
                                    Minimum="90"
                                    Maximum="730"
                                    TickFrequency="30"
                                    IsSnapToTickEnabled="True"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AgeThresholdDays, StringFormat='{}{0:F0} days'}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Accent}"/>
                        </Grid>
                        <TextBlock Text="Passwords older than this will be flagged"
                                   FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Best Practices -->
            <Border Background="{DynamicResource InfoBackgroundBrush}"
                    BorderBrush="{DynamicResource InfoBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Lg}"
                    Padding="16">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Text="💡"
                                   FontSize="20"
                                   VerticalAlignment="Top"/>
                        <StackPanel Grid.Column="1" Spacing="8" Margin="8,0,0,0">
                            <TextBlock Text="Security Best Practices"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="• Use passwords with at least 12-16 characters"
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="• Combine uppercase, lowercase, numbers, and symbols"
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="• Avoid using the same password for multiple accounts"
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="• Update passwords every 3-6 months for sensitive accounts"
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="• Never include personal information (names, birthdays, etc.)"
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="• Use the password generator for maximum security"
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
