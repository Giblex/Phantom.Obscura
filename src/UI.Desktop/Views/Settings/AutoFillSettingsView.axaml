<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PhantomVault.UI.Views.Settings.AutoFillSettingsView">
    <StackPanel Spacing="20" Margin="0,0,30,60">
        <TextBlock Text="Auto-Fill Settings" 
                   FontSize="{StaticResource Type.H3.Size}" 
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"/>
        
        <Border Classes="fade-in stagger-1"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="{StaticResource Radius.Lg}" 
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Browser Integration" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <CheckBox Content="Enable browser auto-fill" 
                          IsChecked="True"
                          ToolTip.Tip="Allow PhantomVault to auto-fill credentials in browsers"/>
                
                <CheckBox Content="Auto-submit after filling" 
                          ToolTip.Tip="Automatically submit forms after filling credentials"/>
                
                <CheckBox Content="Show auto-fill icon in password fields" 
                          IsChecked="True"
                          ToolTip.Tip="Display PhantomVault icon next to password fields"/>
            </StackPanel>
        </Border>

        <Border Classes="fade-in stagger-2"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="{StaticResource Radius.Lg}" 
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Mobile Integration" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <TextBlock Text="Configure auto-fill settings for Android and iOS devices" 
                           FontSize="{StaticResource Type.Small.Size}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
                
                <Button Content="Configure Mobile Auto-Fill" 
                        Width="240" 
                        HorizontalAlignment="Left"
                        Classes="liquid-glass"
                        ToolTip.Tip="Set up auto-fill for mobile devices"/>
            </StackPanel>
        </Border>

        <Border Classes="fade-in stagger-3"
                Background="{DynamicResource SettingsPanelBackgroundBrush}"
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Lg}"
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Desktop Applications"
                           FontSize="{StaticResource Type.Body.Size}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>

                <CheckBox Content="Enable auto-fill for desktop apps"
                          ToolTip.Tip="Allow PhantomVault to auto-fill credentials in desktop applications"/>

                <Button Content="Manage App Permissions"
                        Width="200"
                        HorizontalAlignment="Left"
                        Classes="liquid-glass"
                        ToolTip.Tip="Control which apps can use auto-fill"/>
            </StackPanel>
        </Border>

        <!-- AutoFill Mode (USB-Triggered) -->
        <Border Classes="fade-in stagger-4"
                Background="{DynamicResource SettingsPanelBackgroundBrush}"
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Lg}"
                Padding="20">
            <StackPanel Spacing="15">
                <StackPanel Spacing="4">
                    <TextBlock Text="AutoFill Mode  —  USB-Triggered"
                               FontSize="{StaticResource Type.Body.Size}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="Inserting your USB key automatically detects the active login portal and fills your credentials. Passkeys are used when available. Requires vault to be unlocked."
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <ToggleSwitch IsChecked="{Binding AutoFillModeEnabled}"
                              OnContent="Enabled — App runs in System Tray"
                              OffContent="Disabled"
                              ToolTip.Tip="When enabled, Phantom Obscura stays alive in the notification tray and auto-fills login portals on USB insertion"/>

                <StackPanel Spacing="10"
                            IsEnabled="{Binding AutoFillModeEnabled}">
                    <CheckBox IsChecked="{Binding AutoFillAutoInputTotp}"
                              Content="Auto-input TOTP code after fill"
                              ToolTip.Tip="After filling username and password, wait for a 2FA code field to appear and fill it automatically"/>
                    <CheckBox IsChecked="{Binding AutoFillShowNewEntryOnNoMatch}"
                              Content="Show 'New Entry' dialog when no credential matches"
                              ToolTip.Tip="When no stored credential matches the active login portal, offer to add a new entry or create a passkey"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>


