<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PhantomVault.UI.Views.Settings.SecuritySettingsView">
    <StackPanel Spacing="{StaticResource Space.Xl}"
                Margin="0,0,30,60">
        <TextBlock Text="Security Settings" 
                   FontSize="{StaticResource Type.H3.Size}" 
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"/>
        
        <Border Classes="fade-in stagger-1"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="{StaticResource Radius.Lg}" 
                Padding="20"
                MaxWidth="640"
                HorizontalAlignment="Stretch">
            <StackPanel Spacing="15">
                <TextBlock Text="Authentication" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <CheckBox Content="Require hardware-token presence check" 
                          IsChecked="{Binding RequireHardwareToken, Mode=TwoWay}"
                          ToolTip.Tip="Require the supported hardware-token presence check during unlock on compatible Windows builds"/>
                
                <CheckBox Content="Require keyfile" 
                          IsChecked="{Binding RequireKeyfile, Mode=TwoWay}"
                          ToolTip.Tip="Require a keyfile in addition to password"/>
                
                <StackPanel Spacing="{StaticResource Space.Sm}">
                    <TextBlock Text="Idle timeout (minutes):" 
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBox Width="100" 
                             HorizontalAlignment="Left"
                             Text="{Binding IdleTimeoutMinutes, Mode=TwoWay}"
                             ToolTip.Tip="Lock vault after this many minutes of inactivity"/>
                </StackPanel>

                <Border Background="{DynamicResource SettingsPanelBackgroundBrush}"
                        BorderBrush="{DynamicResource SettingsPanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource Radius.Lg}"
                        Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="PIN Lock"
                                   FontSize="{StaticResource Type.Label.Size}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>

                        <TextBlock Text="Enable a quick lockscreen PIN for re-authentication without exiting the app."
                                   FontSize="{StaticResource Type.Small.Size}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>

                        <CheckBox Content="Enable PIN lock"
                                  IsChecked="{Binding EnablePinLock, Mode=TwoWay}"/>

                        <CheckBox Content="Use PIN lock for auto-lock (do not dismount)"
                                  IsChecked="{Binding UsePinLockForAutoLock, Mode=TwoWay}"
                                  IsVisible="{Binding EnablePinLock}"
                                  ToolTip.Tip="If enabled, auto-lock shows the lockscreen without dismounting the vault."/>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Set / Change PIN"
                                    Command="{Binding SetOrChangePinCommand}"
                                    Classes="liquid-glass"
                                    Width="170"/>

                            <Button Content="Disable PIN"
                                    Command="{Binding ClearPinCommand}"
                                    Classes="liquid-glass"
                                    Width="120"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Classes="fade-in stagger-2"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="{DynamicResource Radius.Lg}" 
                Padding="20"
                MaxWidth="640"
                HorizontalAlignment="Stretch">
            <StackPanel Spacing="15">
                <TextBlock Text="Clipboard Security" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <CheckBox Content="Clear clipboard after copying passwords" 
                          IsChecked="{Binding ClearClipboardAfterCopy, Mode=TwoWay}"
                          ToolTip.Tip="Automatically clear copied secrets after the selected delay"/>
                
                <StackPanel Spacing="{StaticResource Space.Sm}">
                    <TextBlock Text="Clipboard clear delay:" 
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <ComboBox Width="180"
                              HorizontalAlignment="Left"
                              SelectedIndex="{Binding ClipboardClearTimeIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="30 seconds"/>
                        <ComboBoxItem Content="1 minute"/>
                        <ComboBoxItem Content="2 minutes"/>
                        <ComboBoxItem Content="5 minutes"/>
                        <ComboBoxItem Content="Never"/>
                    </ComboBox>
                </StackPanel>
                
                <CheckBox Content="Auto-copy TOTP code with password" 
                          IsChecked="{Binding AutoCopyTotpWithPassword, Mode=TwoWay}"
                          ToolTip.Tip="When copying passwords, automatically include the current TOTP code in the clipboard"/>
            </StackPanel>
        </Border>

        <!-- Screenshot Protection -->
        <Border Classes="fade-in stagger-3"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="{DynamicResource Radius.Lg}" 
                Padding="20"
                MaxWidth="640"
                HorizontalAlignment="Stretch">
            <StackPanel Spacing="15">
                <TextBlock Text="Screenshot Protection" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <CheckBox Content="Enable screenshot protection" 
                          IsChecked="{Binding EnableScreenshotProtection, Mode=TwoWay}"
                          ToolTip.Tip="When enabled, the vault window appears black in screenshots and screen recordings"/>
                
                <TextBlock Text="This security feature prevents credential exposure through screenshots, screen recordings, and screen sharing. When enabled, the vault window will be hidden from screen capture tools."
                           FontSize="{StaticResource Type.Small.Size}" 
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Decoy Vault Section -->
        <Border Classes="fade-in stagger-4"
                Background="{DynamicResource SettingsPanelBackgroundBrush}"
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Radius.Lg}"
                Padding="20"
                MaxWidth="640"
                HorizontalAlignment="Stretch">
            <StackPanel Spacing="15">
                <TextBlock Text="Decoy Vault Protection"
                           FontSize="{StaticResource Type.Body.Size}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>

                <TextBlock Text="When enabled, PhantomVault will show fake credentials to attackers during security incidents, protecting your real data"
                           FontSize="{StaticResource Type.Small.Size}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap"/>

                <CheckBox Content="Enable decoy vault activation"
                          IsChecked="{Binding EnableDecoyVault, Mode=TwoWay}"
                          ToolTip.Tip="Automatically switch to fake credentials when threats are detected"/>

                <StackPanel Spacing="{StaticResource Space.Sm}"
                            IsEnabled="{Binding EnableDecoyVault}">
                    <TextBlock Text="Number of fake credentials to generate:"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox Width="100"
                                 HorizontalAlignment="Left"
                                 Text="{Binding DecoyCredentialCount, Mode=TwoWay}"
                                 ToolTip.Tip="Between 15-30 credentials recommended for realism"/>
                        <TextBlock Text="(15-30 recommended)"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <CheckBox Content="Enable read-only mode when decoy is active"
                          IsChecked="{Binding DecoyReadOnlyMode, Mode=TwoWay}"
                          IsEnabled="{Binding EnableDecoyVault}"
                          ToolTip.Tip="Prevents attackers from modifying fake credentials"/>

                <CheckBox Content="Log decoy vault activations"
                          IsChecked="{Binding DecoyLogActivations, Mode=TwoWay}"
                          IsEnabled="{Binding EnableDecoyVault}"
                          ToolTip.Tip="Record security events for forensic analysis"/>

                <Border Background="{DynamicResource WindowBackgroundBrush}"
                        BorderBrush="{DynamicResource Brush.Accent}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Md}"
                        Padding="12"
                        Margin="0,5,0,0">
                    <StackPanel Spacing="6">
                        <TextBlock Text="How Decoy Vault Works"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="{StaticResource Type.Small.Size}"
                                   Foreground="{DynamicResource MutedTextBrush}">
                            When a security threat is detected (debugger, memory scanning, multiple failed authentications),
                            the vault automatically switches to showing realistic fake credentials. Attackers believe they succeeded,
                            while your real data remains protected. All activations are logged for security auditing.
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Classes="fade-in stagger-5"
                Background="{DynamicResource SettingsPanelBackgroundBrush}"
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="{DynamicResource Radius.Lg}"
                Padding="20"
                MaxWidth="640"
                HorizontalAlignment="Stretch">
            <StackPanel Spacing="15">
                <TextBlock Text="Master Password"
                           FontSize="{StaticResource Type.Body.Size}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>

                <Button Content="Change Master Password"
                        Width="200"
                        HorizontalAlignment="Left"
                        Classes="liquid-glass"
                        ToolTip.Tip="Update your vault's master password"/>
            </StackPanel>
        </Border>

        <!-- Multi-Factor Authentication Section -->
        <Border Classes="fade-in stagger-6"
                Background="{DynamicResource SettingsPanelBackgroundBrush}" 
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}" 
                BorderThickness="1" 
                CornerRadius="{DynamicResource Radius.Lg}" 
                Padding="20"
                MaxWidth="640"
                HorizontalAlignment="Stretch">
            <StackPanel Spacing="15">
                <TextBlock Text="Multi-Factor Authentication" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                
                <TextBlock Text="Review the security factors that are currently available for this vault and this device" 
                           FontSize="{StaticResource Type.Small.Size}" 
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap"/>

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" Margin="0,8,0,0">
                    <!-- TOTP Setup -->
                    <Button Grid.Row="0" Grid.Column="0"
                            Click="OpenTotpSettings_Click"
                            Classes="liquid-glass"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,6,12"
                            Height="50"
                            ToolTip.Tip="Set up time-based one-time password (Google Authenticator, Authy, etc.)">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Path Data="{StaticResource Icon.QrCode}" Width="22" Height="22" Stretch="Uniform"
                                  Stroke="#FFFFFFFF" StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="TOTP Setup" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Passkey Setup -->
                    <Button Grid.Row="0" Grid.Column="1"
                            Click="OpenPasskeySettings_Click"
                            Classes="liquid-glass"
                            HorizontalAlignment="Stretch"
                            Margin="6,0,0,12"
                            Height="50"
                            ToolTip.Tip="Configure the Windows Hello-backed device authenticator for this vault">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Path Data="{StaticResource Icon.Key}" Width="22" Height="22" Stretch="Uniform"
                                  Stroke="#FFFFFFFF" StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Device Authenticator" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Windows Hello Setup -->
                    <Button Grid.Row="1" Grid.Column="0"
                            Click="OpenWindowsHelloSettings_Click"
                            Classes="liquid-glass"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,6,0"
                            Height="50"
                            ToolTip.Tip="Review Windows Hello availability for face, fingerprint, or PIN-backed unlock">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Path Data="{StaticResource Icon.Eye}" Width="22" Height="22" Stretch="Uniform"
                                  Stroke="#FFFFFFFF" StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Windows Hello" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Backup Codes -->
                    <Button Grid.Row="1" Grid.Column="1"
                            Click="OpenBackupCodes_Click"
                            Classes="liquid-glass"
                            HorizontalAlignment="Stretch"
                            Margin="6,0,0,0"
                            Height="50"
                            ToolTip.Tip="Generate emergency backup codes for account recovery">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Path Data="{StaticResource Icon.Clipboard}" Width="22" Height="22" Stretch="Uniform"
                                  Stroke="#FFFFFFFF" StrokeThickness="1.5" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Backup Codes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>




