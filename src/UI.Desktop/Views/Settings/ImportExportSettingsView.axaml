<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PhantomVault.UI.Views.Settings.ImportExportSettingsView">
    <StackPanel Spacing="20" Margin="0,0,30,60">
        <TextBlock Text="Import / Export" 
                   FontSize="{StaticResource Type.H3.Size}" 
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"/>
        
        <!-- Import Section -->
        <Border Classes="fade-in stagger-1"
                Background="{DynamicResource SettingsPanelBackgroundBrush}"
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Lg}"
                MaxWidth="640"
                HorizontalAlignment="Stretch"
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Import Credentials" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="Import from Obscura JSON, generic CSV, KeePass XML, KeePass KDBX, Bitwarden, 1Password CSV, Proton Pass JSON, LastPass CSV, and browser CSV exports." 
                           FontSize="{StaticResource Type.Small.Size}" 
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
                <TextBlock Text="KDBX import prompts for the database password or keyfile in the import flow. Duplicate review happens before new credentials are added."
                           FontSize="{StaticResource Type.Tiny.Size}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
                <Button Command="{Binding $parent[Window].DataContext.OpenImportWindowCommand}"
                        Classes="liquid-glass"
                        HorizontalAlignment="Stretch"
                        Height="40"
                        Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="{StaticResource Icon.Download}" Width="18" Height="18" Stretch="Uniform"
                              Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" Fill="Transparent"
                              VerticalAlignment="Center"/>
                        <TextBlock Text="Import Credentials" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
        
        <!-- Export Section -->
        <Border Classes="fade-in stagger-2"
                Background="{DynamicResource SettingsPanelBackgroundBrush}"
                BorderBrush="{DynamicResource SettingsPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Lg}"
                MaxWidth="640"
                HorizontalAlignment="Stretch"
                Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Export Credentials" 
                           FontSize="{StaticResource Type.Body.Size}" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="Export your vault data to portable JSON, CSV, or KeePass XML files for backup or migration." 
                           FontSize="{StaticResource Type.Small.Size}" 
                           Foreground="{DynamicResource MutedTextBrush}"
                           TextWrapping="Wrap"/>
                <Grid ColumnDefinitions="*,12,*,12,*" Margin="0,8,0,0">
                    <Button Grid.Column="0"
                            Command="{Binding $parent[Window].DataContext.ExportVaultCommand}"
                            Classes="liquid-glass"
                            HorizontalAlignment="Stretch"
                            Height="40">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="{StaticResource Icon.Upload}" Width="18" Height="18" Stretch="Uniform"
                                  Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" Fill="Transparent"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Export JSON" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2"
                            Command="{Binding $parent[Window].DataContext.ExportVaultCsvCommand}"
                            Classes="liquid-glass"
                            HorizontalAlignment="Stretch"
                            Height="40">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="{StaticResource Icon.Upload}" Width="18" Height="18" Stretch="Uniform"
                                  Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" Fill="Transparent"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Export CSV" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4"
                            Command="{Binding $parent[Window].DataContext.ExportKeePassCommand}"
                            Classes="liquid-glass"
                            HorizontalAlignment="Stretch"
                            Height="40">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="{StaticResource Icon.Upload}" Width="18" Height="18" Stretch="Uniform"
                                  Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" Fill="Transparent"
                                  VerticalAlignment="Center"/>
                            <TextBlock Text="Export KeePass XML" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
                <TextBlock Text="⚠ Exported files contain unencrypted passwords. Store them securely!" 
                           FontSize="{StaticResource Type.Tiny.Size}" 
                           Foreground="{DynamicResource WarningBrush}"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>

