<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PhantomVault.UI.Views.EditForms.BankAccountEditForm">
    
    <Border x:Name="BankPanelBorder" Background="Transparent" IsVisible="{Binding IsBankAccountEntry}">
        <StackPanel x:Name="BankPanel" Spacing="12">
        <TextBlock Text="Bank Account" FontSize="{StaticResource Type.Body.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
        <StackPanel Spacing="6">
            <TextBlock Text="Bank Name" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding BankName}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="Contoso Bank"/>
        </StackPanel>
        <StackPanel Spacing="6">
            <TextBlock Text="Account Number" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding BankAccountNumber}" PasswordChar="•" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="000123456789"/>
        </StackPanel>
        <StackPanel Spacing="6">
            <TextBlock Text="Routing Number" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding BankRoutingNumber}" PasswordChar="•" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="110000000"/>
        </StackPanel>
        <Grid ColumnDefinitions="*,16,*">
            <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="IBAN" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                <TextBox Text="{Binding BankIBAN}" PasswordChar="•" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="DE89 3704 0044 0532 0130 00"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="6">
                <TextBlock Text="SWIFT / BIC" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                <TextBox Text="{Binding BankSWIFT}" PasswordChar="•" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="COBADEFFXXX"/>
            </StackPanel>
        </Grid>
        <StackPanel Spacing="6">
            <TextBlock Text="Account Type" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding BankAccountType}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="Checking"/>
        </StackPanel>
        <StackPanel Spacing="6">
            <TextBlock Text="Branch Code" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding BankBranchCode}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="1234"/>
        </StackPanel>
        <StackPanel Spacing="6">
            <TextBlock Text="Branch Address" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding BankBranchAddress}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="60"
                     FontSize="{StaticResource Type.Label.Size}"
                     />
        </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
