<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PhantomVault.UI.Views.EditForms.WiFiEditForm">
    
    <Border x:Name="WiFiPanelBorder" Background="Transparent" IsVisible="{Binding IsWiFiEntry}">
        <StackPanel x:Name="WiFiPanel" Spacing="12">
        <TextBlock Text="Wi-Fi Network" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
        <StackPanel Spacing="6">
            <TextBlock Text="Network Name (SSID) *" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding WiFiSSID}" Height="40" FontSize="14" Watermark="MyHomeWifi"/>
        </StackPanel>
        <StackPanel Spacing="6">
            <TextBlock Text="Security Type" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding WiFiSecurityType}" Height="40" FontSize="14" Watermark="WPA2"/>
        </StackPanel>
        <StackPanel Spacing="6">
            <TextBlock Text="BSSID / MAC" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding WiFiBSSID}" Height="40" FontSize="14" Watermark="AA:BB:CC:DD:EE:FF"/>
        </StackPanel>
        <StackPanel Spacing="6">
            <TextBlock Text="Network Password" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding WiFiPassword}" PasswordChar="•" Height="40" FontSize="14" Watermark="••••••••"/>
        </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
