<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PhantomVault.UI.Views.EditForms.IdentityEditForm">
    
    <Border x:Name="IdentityPanelBorder" Background="Transparent" IsVisible="{Binding IsIdentityEntry}">
        <StackPanel x:Name="IdentityPanel" Spacing="12">
        <TextBlock Text="Identity Document" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
        <StackPanel Spacing="6">
            <TextBlock Text="ID Type" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <ComboBox ItemsSource="{Binding IdentityTypeOptions}"
                      SelectedItem="{Binding IdDocumentType}"
                      Height="40"
                      FontSize="14"/>
        </StackPanel>
        <StackPanel Spacing="6">
            <TextBlock Text="{Binding IdNumberLabel}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding IdNumber}" Height="40" FontSize="14" Watermark="{Binding IdNumberWatermark}"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding ShowIdIssuingCountry}">
            <TextBlock Text="{Binding IdIssuingCountryLabel}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding IdIssuingCountry}" Height="40" FontSize="14" Watermark="{Binding IdIssuingCountryWatermark}"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding ShowIdIssuingState}">
            <TextBlock Text="{Binding IdIssuingStateLabel}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding IdIssuingState}" Height="40" FontSize="14" Watermark="{Binding IdIssuingStateWatermark}"/>
        </StackPanel>
        <Grid ColumnDefinitions="*,16,*">
            <StackPanel Grid.Column="0" Spacing="6" IsVisible="{Binding ShowIdIssueDate}">
                <TextBlock Text="Issue Date" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                <DatePicker SelectedDate="{Binding IdIssueDate}" Height="40" FontSize="14"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="6" IsVisible="{Binding ShowIdExpiryDate}">
                <TextBlock Text="Expiration Date" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                <DatePicker SelectedDate="{Binding IdExpiryDate}" Height="40" FontSize="14"/>
            </StackPanel>
        </Grid>
        </StackPanel>
    </Border>
</UserControl>
