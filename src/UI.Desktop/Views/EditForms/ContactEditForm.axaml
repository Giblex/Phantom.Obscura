<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PhantomVault.UI.Views.EditForms.ContactEditForm">
    
    <StackPanel Spacing="12" IsVisible="{Binding IsContactEntry}">
        <TextBlock Text="Contact" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
        <StackPanel Spacing="6">
            <TextBlock Text="Full Name" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding ContactFullName}" Height="40" FontSize="14" Watermark="Jane Doe"/>
        </StackPanel>
        <StackPanel Spacing="6">
            <TextBlock Text="Email" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding ContactEmail}" Height="40" FontSize="14" Watermark="user@example.com"/>
        </StackPanel>
        <StackPanel Spacing="6">
            <TextBlock Text="Phone" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding ContactPhone}" Height="40" FontSize="14" Watermark="+1 555 123 4567"/>
        </StackPanel>
        <Grid ColumnDefinitions="*,16,*">
            <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock Text="Company" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                <TextBox Text="{Binding ContactCompany}" Height="40" FontSize="14" Watermark="Contoso"/>
            </StackPanel>
            <StackPanel Grid.Column="2" Spacing="6">
                <TextBlock Text="Job Title" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                <TextBox Text="{Binding ContactJobTitle}" Height="40" FontSize="14" Watermark="CTO"/>
            </StackPanel>
        </Grid>
        <StackPanel Spacing="6">
            <TextBlock Text="Address" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox Text="{Binding ContactAddress}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Height="80"
                     FontSize="13"
                     />
        </StackPanel>
    </StackPanel>
</UserControl>
