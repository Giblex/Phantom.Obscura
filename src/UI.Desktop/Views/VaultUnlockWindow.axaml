<?xml version="1.0" encoding="utf-8"?>
<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PhantomVault.UI.ViewModels"
        xmlns:views="clr-namespace:PhantomVault.UI.Views"
        x:Class="PhantomVault.UI.Views.VaultUnlockWindow"
        x:DataType="vm:VaultUnlockViewModel"
        Title="Unlocking Vault"
        Width="520"
        Height="340"
        MinWidth="450"
        MinHeight="250"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        AutomationProperties.Name="Vault Unlock Progress Window"
        AutomationProperties.HelpText="This window shows the progress of unlocking your secure vault"
        Classes="animated-window">

    <views:ThemeAwareWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PhantomVault.UI/Assets/Themes/PreVaultTheme.axaml"/>
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="UnlockAccentBrush" Color="#5D7DA7"/>
            <SolidColorBrush x:Key="UnlockTrackBrush" Color="#13202D"/>
            <SolidColorBrush x:Key="UnlockOrbBrush" Color="#173247"/>
        </ResourceDictionary>
    </views:ThemeAwareWindow.Resources>

    <views:ThemeAwareWindow.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <!--
            Breathing pulse for the unlock orb. Runs while the orb is visible
            (i.e. IsBusy=true) and stays purely on the GPU compositor — no
            code-behind, no ViewModel touch. The animation is scoped to the
            'unlock-orb' class so it can't leak to other Borders.
        -->
        <Style Selector="Border.unlock-orb">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Style.Animations>
                <Animation Duration="0:0:1.8" IterationCount="INFINITE" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="RenderTransform" Value="scale(1.0)"/>
                        <Setter Property="Opacity" Value="0.92"/>
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="RenderTransform" Value="scale(1.08)"/>
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RenderTransform" Value="scale(1.0)"/>
                        <Setter Property="Opacity" Value="0.92"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Slow rotating accent ring behind the orb. -->
        <Style Selector="Ellipse.unlock-ring">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Style.Animations>
                <Animation Duration="0:0:6" IterationCount="INFINITE" Easing="LinearEasing">
                    <KeyFrame Cue="0%">
                        <Setter Property="RenderTransform" Value="rotate(0deg)"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RenderTransform" Value="rotate(360deg)"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </views:ThemeAwareWindow.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="34,28">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,28">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                <Image Source="avares://PhantomVault.UI/Assets/Visuals/Giblex Icons/Icon Transparent background.png"
                       Width="32" Height="32" VerticalAlignment="Center"/>
                <TextBlock Text="Unlocking Your Vault"
                           FontSize="{StaticResource Type.H2.Size}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Please wait while we access your secure vault..."
                       FontSize="{StaticResource Type.Body.Size}"
                       Foreground="{DynamicResource MutedTextBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Status Content -->
        <StackPanel Grid.Row="1" 
                    Spacing="22"
                    VerticalAlignment="Center">
            
            <!-- Progress Indicator with Icon -->
            <Grid Width="92" Height="92" HorizontalAlignment="Center" IsVisible="{Binding IsBusy}">
                <!-- Slow rotating accent ring -->
                <Ellipse Classes="unlock-ring"
                         Width="92" Height="92"
                         StrokeThickness="2"
                         StrokeDashArray="3,6">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Offset="0" Color="#5D7DA7"/>
                            <GradientStop Offset="0.5" Color="#8FB5DF"/>
                            <GradientStop Offset="1" Color="#173247"/>
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                </Ellipse>
                <!-- Breathing orb with brand icon -->
                <Border Classes="unlock-orb"
                        Width="70"
                        Height="70"
                        CornerRadius="35"
                        Background="{DynamicResource UnlockOrbBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Image Source="avares://PhantomVault.UI/Assets/Visuals/Giblex Icons/Icon Transparent background.png"
                           Width="42" Height="42"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Status Message -->
            <TextBlock Text="{Binding Status}"
                       FontSize="{StaticResource Type.H4.Size}"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"
                       AutomationProperties.Name="Unlock Status"
                       AutomationProperties.LiveSetting="Assertive"/>

            <!-- Progress Bar with Percentage -->
            <StackPanel Spacing="12" Margin="32,26,32,0" IsVisible="{Binding IsBusy}"
                        AutomationProperties.Name="Unlock Progress">
                <Grid ColumnDefinitions="*,Auto">
                    <Border Grid.Column="0"
                            Background="{DynamicResource UnlockTrackBrush}"
                            CornerRadius="8"
                            Padding="4">
                        <ProgressBar Value="{Binding ProgressPercent}"
                                     Maximum="100"
                                     Height="10"
                                     CornerRadius="6"
                                     Foreground="{DynamicResource UnlockAccentBrush}"
                                     Background="{DynamicResource UnlockTrackBrush}"
                                     AutomationProperties.Name="Unlock progress bar"/>
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ProgressPercent, StringFormat={}{0}%}"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               AutomationProperties.Name="Progress percentage"
                               AutomationProperties.LiveSetting="Polite"/>
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- Footer -->
        <TextBlock Grid.Row="2"
                   Text="Phantom Obscura • zero-knowledge vault access"
                   FontSize="{StaticResource Type.Tiny.Size}"
                   Foreground="{DynamicResource MutedTextBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,30,0,0"/>
    </Grid>
</views:ThemeAwareWindow>
