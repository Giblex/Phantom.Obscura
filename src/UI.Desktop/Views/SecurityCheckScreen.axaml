<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhantomVault.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="750" d:DesignHeight="650"
        x:Class="PhantomVault.UI.Views.SecurityCheckScreen"
        x:DataType="vm:SecurityCheckScreenViewModel"
        Title="Security Check"
        Width="750" Height="650"
        MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Background="{DynamicResource ContentBackgroundBrush}" Icon="avares://PhantomVault.UI/Assets/Visuals/Giblex Icons/Parent Icon.ico"
        FontFamily="{DynamicResource DefaultFontFamily}"
        FontSize="{DynamicResource DefaultFontSize}">

    <Design.DataContext>
        <vm:SecurityCheckScreenViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="0">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource ContentBackgroundBrush}" Padding="20,15">
            <StackPanel Spacing="8" MaxWidth="700">
                <TextBlock Text="Welcome to Your Vault"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           HorizontalAlignment="Center"/>
                
                <TextBlock Text="Running security checks to ensure your vault is safe..."
                           FontSize="14"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           MaxWidth="600"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" 
                      Padding="40,30,40,20" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="25" Margin="0,0,0,20" MaxWidth="700" HorizontalAlignment="Center">

                <!-- Progress Bar -->
                <StackPanel Spacing="12">
                    <ProgressBar Value="{Binding PercentComplete}"
                                 Minimum="0"
                                 Maximum="100"
                                 Height="6"
                                 IsIndeterminate="False"
                                 Foreground="{DynamicResource AccentBrush}"/>
                    
                    <TextBlock Text="{Binding PercentComplete, StringFormat='{}{0}% complete'}"
                               FontSize="13"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Current Check Display - Single Item -->
                <Border Background="{DynamicResource ControlBackgroundBrush}" 
                        Padding="20,18"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        MinHeight="80">
                    <Grid>
                        <!-- Default/Running state -->
                        <TextBlock Text="{Binding CurrentCheckDisplay}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding !CurrentCheckPassed, FallbackValue=True}">
                            <TextBlock.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="!CurrentCheckPassed"/>
                                    <Binding Path="!CurrentCheckFailed"/>
                                </MultiBinding>
                            </TextBlock.IsVisible>
                        </TextBlock>
                        
                        <!-- Passed state - Green -->
                        <TextBlock Text="{Binding CurrentCheckDisplay}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#4CAF50"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding CurrentCheckPassed}"/>
                        
                        <!-- Failed state - Red -->
                        <TextBlock Text="{Binding CurrentCheckDisplay}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#F44336"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding CurrentCheckFailed}"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Background="{DynamicResource ContentBackgroundBrush}" Padding="25,12">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Spacing="15">
                
                <!-- Continue Button (visible when checks pass) -->
                <Button Command="{Binding ContinueCommand}"
                        Width="140"
                        Height="40"
                        FontSize="15"
                        FontWeight="Bold"
                        Classes="liquid-glass primary"
                        IsVisible="{Binding ChecksSuccessful}"
                        ToolTip.Tip="All security checks passed successfully.">
                    <TextBlock Text="Continue" TextAlignment="Center"/>
                </Button>

                <!-- Retry Button (visible when checks fail) -->
                <Button Command="{Binding RetryCommand}"
                        Width="130"
                        Height="36"
                        Classes="liquid-glass"
                        FontSize="14"
                        IsVisible="{Binding !ChecksSuccessful}"
                        ToolTip.Tip="Some checks failed. Click to re-run the security checks.">
                    <TextBlock Text="Retry"/>
                </Button>

                <!-- Cancel Button -->
                <Button Command="{Binding CancelCommand}"
                        Width="130"
                        Height="36"
                        Classes="liquid-glass"
                        
                        FontSize="14"
                        IsVisible="{Binding !IsRunningChecks}"
                        ToolTip.Tip="Cancel and return to the previous screen.">
                    <TextBlock Text="Cancel"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
