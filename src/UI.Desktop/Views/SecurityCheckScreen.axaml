<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhantomVault.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="750" d:DesignHeight="650"
        x:Class="PhantomVault.UI.Views.SecurityCheckScreen"
        x:DataType="vm:SecurityCheckScreenViewModel"
        Title="Security Check"
        Width="750" Height="650"
        MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Background="{DynamicResource ContentBackgroundBrush}" Icon="avares://PhantomVault.UI/Assets/Visuals/Giblex Icons/Parent Icon.ico"
        FontFamily="{DynamicResource DefaultFontFamily}"
        FontSize="{DynamicResource DefaultFontSize}"
        Classes="animated-window">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PhantomVault.UI/Assets/Themes/PreVaultTheme.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Design.DataContext>
        <vm:SecurityCheckScreenViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="0">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource ContentBackgroundBrush}" Padding="15,8">
            <StackPanel Spacing="{StaticResource Space.Sm}">
                <TextBlock Text="Welcome to Your Vault"
                           FontSize="{StaticResource Type.SubHeading.Size}"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Running security checks to ensure your vault is safe..."
                           FontSize="{StaticResource Type.Label.Size}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="25" Margin="40,30,40,20" MaxWidth="700" HorizontalAlignment="Center">

                <!-- Current Check Display - Single Item -->
                <Border Background="{DynamicResource ControlBackgroundBrush}" 
                        Padding="20,18"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        MinHeight="80">
                    <Grid>
                        <!-- Default/Running state -->
                        <TextBlock Text="{Binding CurrentCheckDisplay}"
                                   FontSize="{StaticResource Type.H5.Size}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding !CurrentCheckPassed, FallbackValue=True}">
                            <TextBlock.IsVisible>
                                <MultiBinding Converter="{x:Static BoolConverters.And}">
                                    <Binding Path="!CurrentCheckPassed"/>
                                    <Binding Path="!CurrentCheckFailed"/>
                                </MultiBinding>
                            </TextBlock.IsVisible>
                        </TextBlock>
                        
                        <!-- Passed state - Green -->
                        <TextBlock Text="{Binding CurrentCheckDisplay}"
                                   FontSize="{StaticResource Type.H5.Size}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SuccessTextBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding CurrentCheckPassed}"/>
                        
                        <!-- Failed state - Red -->
                        <TextBlock Text="{Binding CurrentCheckDisplay}"
                                   FontSize="{StaticResource Type.H5.Size}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding CurrentCheckFailed}"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer: Progress, Status, and Action Buttons -->
        <Border Grid.Row="2" Background="{DynamicResource FooterBackgroundBrush}" Padding="25,15,25,15">
            <StackPanel Spacing="18" MaxWidth="700" HorizontalAlignment="Center">
                
                <!-- Progress Bar -->
                <StackPanel Spacing="{StaticResource Space.Sm}" IsVisible="{Binding IsRunningChecks}">
                    <ProgressBar Value="{Binding PercentComplete}"
                                 Minimum="0"
                                 Maximum="100"
                                 Height="12"
                                 Width="600"
                                 IsIndeterminate="False"
                                 Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding PercentComplete, StringFormat='{}{0}% complete'}"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource SuccessBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Status Message -->
                <Border Background="{DynamicResource FooterBackgroundBrush}"
                        Padding="12,10"
                        CornerRadius="{StaticResource Radius.Md}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        Margin="0,5,0,0"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            Spacing="15">
                    
                    <!-- Cancel Button -->
                    <Button Command="{Binding CancelCommand}"
                            Width="140"
                            Height="42"
                            FontSize="{StaticResource Type.Body.Size}"
                            Classes="liquid-glass"
                            IsEnabled="{Binding !IsRunningChecks}"
                            ToolTip.Tip="Cancel and return to the previous screen.">
                        <TextBlock Text="Cancel" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <!-- Retry Button (visible when checks fail) -->
                    <Button Command="{Binding RetryCommand}"
                            Width="140"
                            Height="42"
                            FontSize="{StaticResource Type.Body.Size}"
                            Classes="liquid-glass"
                            IsVisible="{Binding !ChecksSuccessful}"
                            ToolTip.Tip="Some checks failed. Click to re-run the security checks.">
                        <TextBlock Text="Retry" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <!-- Continue Button (visible when checks pass) -->
                    <Button Command="{Binding ContinueCommand}"
                            Width="160"
                            Height="42"
                            FontSize="{StaticResource Type.H5.Size}"
                            FontWeight="SemiBold"
                            Classes="liquid-glass primary"
                            IsVisible="{Binding ChecksSuccessful}"
                            ToolTip.Tip="All security checks passed successfully.">
                        <TextBlock Text="Continue" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
