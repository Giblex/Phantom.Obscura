<?xml version="1.0" encoding="utf-8"?>
<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
    x:Class="PhantomVault.UI.Views.AddPasswordWindow"
        Title="Add Password" Width="450" Height="350"
        Classes="animated-window">
    <Border Padding="15">
        <StackPanel Spacing="10">
            <!-- Auto-detected Icon Display -->
            <Border Background="{DynamicResource ControlBackgroundBrush}" Padding="10" CornerRadius="5" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Auto-detected Icon:" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding AutoDetectedIconDisplay}" 
                               FontSize="{StaticResource Type.H2.Size}" 
                               VerticalAlignment="Center" 
                               ToolTip.Tip="Icon will be automatically matched based on Title or URL" />
                    <TextBlock Text="(Updates as you type)" 
                               VerticalAlignment="Center" 
                               Foreground="{DynamicResource MutedTextBrush}" 
                               FontSize="{StaticResource Type.Tiny.Size}" />
                </StackPanel>
            </Border>

            <!-- Color picker for text-based icon backgrounds (horizontal, scrollable) -->
            <StackPanel Spacing="6">
                <TextBlock Text="Icon background color:" FontWeight="SemiBold" />
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="56">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="No color" Command="{Binding SelectIconColorCommand}" CommandParameter="{x:Null}" Width="88" Height="40" />
                        <ItemsControl ItemsSource="{Binding AvailableColors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="40" Height="40" Margin="4" Padding="0"
                                            Command="{Binding DataContext.SelectIconColorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding .}">
                                        <Border Width="36" Height="36" CornerRadius="6" Background="{Binding .}" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="Title:" Width="80" VerticalAlignment="Center" />
                <TextBox Text="{Binding Title, Mode=TwoWay}" Width="300" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="Username:" Width="80" VerticalAlignment="Center" />
                <TextBox Text="{Binding Username, Mode=TwoWay}" Width="300" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="Password:" Width="80" VerticalAlignment="Center" />
                <TextBox Text="{Binding Password, Mode=TwoWay}" Width="220" PasswordChar="●" />
                <Button Content="Generate" Click="OpenPasswordGenerator_Click" Width="70" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="URL:" Width="80" VerticalAlignment="Center" />
                <TextBox Text="{Binding Url, Mode=TwoWay}" Width="300" />
            </StackPanel>
            <CheckBox Content="Generate random password" IsChecked="{Binding GenerateRandom, Mode=TwoWay}" />
            <Button Content="Save" Command="{Binding SaveCommand}" Width="80" HorizontalAlignment="Left" />
        </StackPanel>
    </Border>
</views:ThemeAwareWindow>

