<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PhantomVault.UI.ViewModels"
             xmlns:converters="using:PhantomVault.UI.Converters"
             x:Class="PhantomVault.UI.Views.IconManagerView"
             x:Name="IconManagerControl">
    <Design.DataContext>
        <vm:IconManagerViewModel/>
    </Design.DataContext>

    <UserControl.Resources>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <SolidColorBrush x:Key="IconTileCellBrush">Transparent</SolidColorBrush>
    </UserControl.Resources>

    <DockPanel Margin="20" LastChildFill="True">
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource HeaderBackgroundBrush}"
                Padding="16"
                CornerRadius="6"
                Margin="0,0,0,16">
            <StackPanel Spacing="6">
                <TextBlock Text="Icon Library Manager"
                           FontSize="{StaticResource Type.H3.Size}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                    <Border Grid.Column="0"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            CornerRadius="4"
                            Padding="6,0">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="1"
                                     Text="{Binding SearchText, Mode=TwoWay}"
                                     Watermark="Search icons..."
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Button Command="{Binding RefreshCommand}"
                                Classes="liquid-glass"
                                Width="110" Height="34">
                            <TextBlock Text="Refresh" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <!-- Options dropdown placed as vertical three-dashes: ⋮ -->
                        <Button Name="OptionsButton" Classes="liquid-glass" Width="40" Height="34" ToolTip.Tip="Options">
                            <TextBlock Text="⋮" FontSize="{StaticResource Type.Icon.Size}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Download Icons" Command="{Binding DownloadFlatIconsCommand}"/>
                                    <MenuItem Header="Import Icons" Command="{Binding ImportIconCommand}"/>
                                    <MenuItem Header="Open Icons Folder" Command="{Binding OpenIconsFolderCommand}"/>
                                    <MenuItem Header="Toggle grid view" Command="{Binding ToggleGridViewCommand}"/>
                                    <MenuItem Header="Show Selected" Command="{Binding RevealIconCommand}" CommandParameter="{Binding SelectedIcon}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Status footer -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource ControlBackgroundBrush}"
                Padding="8"
                CornerRadius="6"
                Margin="0,8,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Grid.Column="0">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="{StaticResource Type.Tiny.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
                <!-- Pagination (only shown in list view) -->
                <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Center" Spacing="8" VerticalAlignment="Center"
                            IsVisible="{Binding IsGridView, Converter={StaticResource InvertBoolConverter}}">
                    <Button Command="{Binding PrevPageCommand}" IsEnabled="{Binding IsFirstPage, Converter={StaticResource InvertBoolConverter}}" Classes="liquid-glass" Width="72" Height="30">Prev</Button>
                    <TextBlock Text="{Binding PageIndicatorText}" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" FontSize="{StaticResource Type.Small.Size}"/>
                    <Button Command="{Binding NextPageCommand}" IsEnabled="{Binding IsLastPage, Converter={StaticResource InvertBoolConverter}}" Classes="liquid-glass" Width="72" Height="30">Next</Button>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" VerticalAlignment="Center"
                            IsVisible="{Binding IsGridView, Converter={StaticResource InvertBoolConverter}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                        <TextBlock Text="Page size:" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" />
                        <ComboBox SelectedItem="{Binding PageSize, Mode=TwoWay}" Width="80" ItemsSource="{Binding PageSizeOptions}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Variant popup anchored below the clicked icon -->
        <Popup Name="VariantPopup" IsOpen="{Binding IsVariantPopupOpen, Mode=TwoWay}" Placement="Bottom"
               IsLightDismissEnabled="True">
            <Border Margin="0,4,0,0" Background="Transparent" Padding="0" MaxWidth="350">
                <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="6" Padding="6" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" Effect="{DynamicResource SubtleDropShadow}">
                    <ItemsControl Name="VariantItemsControl" ItemsSource="{Binding VariantIcons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding #VariantItemsControl.DataContext.ApplyVariantToCategoryCommand}"
                                        CommandParameter="{Binding}" Margin="2" Padding="0"
                                        Width="36" Height="36" MinWidth="0" MinHeight="0"
                                        Cursor="Hand" Focusable="True">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Width="36" Height="36" CornerRadius="2" Background="Transparent">
                                                <ContentPresenter Content="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Image Source="{Binding IconBitmap}" Width="36" Height="36" Stretch="Uniform"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Border>
        </Popup>

        <!-- Icon grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0" IsVisible="{Binding IsGridView, Converter={StaticResource InvertBoolConverter}}"
                      ItemsSource="{Binding Icons}"
                      SelectedItem="{Binding SelectedIcon, Mode=TwoWay}"
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      RowHeight="48"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="48">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="40" Height="40" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{StaticResource IconTileCellBrush}">
                                    <Image Source="{Binding IconBitmap}" Stretch="Uniform" Width="28" Height="28"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Location" Binding="{Binding RelativePath}" Width="3*"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" Width="*"/>
                    <DataGridTextColumn Header="Updated" Binding="{Binding LastModifiedDisplay}" Width="*"/>
                    <DataGridTemplateColumn Header="Actions" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button Command="{Binding DataContext.RevealIconCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Classes="liquid-glass"
                                            Width="34" Height="30"
                                            ToolTip.Tip="Show in Explorer">
                                        <TextBlock Text="📂" FontSize="{StaticResource Type.Body.Size}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Command="{Binding DataContext.DeleteIconCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Classes="liquid-glass"
                                            Width="34" Height="30"
                                            ToolTip.Tip="Delete icon">
                                        <TextBlock Text="🗑" FontSize="{StaticResource Type.Body.Size}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Section-based grid view. Each section is a collapsible category. -->
            <ScrollViewer Grid.Row="0" Padding="8" IsVisible="{Binding IsGridView}" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredSections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6" CornerRadius="6" ClipToBounds="True">
                                <StackPanel>
                                    <!-- Section header (click to expand/collapse) -->
                                    <Button Command="{Binding ToggleExpandedCommand}"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Height="38"
                                            Padding="12,0"
                                            CornerRadius="6"
                                            Background="{DynamicResource ControlBackgroundBrush}">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                                            <!-- Expand arrow -->
                                            <TextBlock Grid.Column="0" Text="▾" IsVisible="{Binding IsExpanded}"
                                                       FontSize="{StaticResource Type.Label.Size}" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="0" Text="▸" IsVisible="{Binding IsExpanded, Converter={StaticResource InvertBoolConverter}}"
                                                       FontSize="{StaticResource Type.Label.Size}" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" Margin="0,0,8,0"/>
                                            <!-- Section name -->
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       FontWeight="SemiBold" FontSize="{StaticResource Type.Label.Size}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <!-- Count badge -->
                                            <TextBlock Grid.Column="3" Text="{Binding CountDisplay}"
                                                       FontSize="{StaticResource Type.Tiny.Size}" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource MutedTextBrush}" Margin="8,0,0,0"/>
                                        </Grid>
                                    </Button>

                                    <!-- Section content (visible when expanded) -->
                                    <Border IsVisible="{Binding IsExpanded}"
                                            Background="{DynamicResource CardBackgroundBrush}"
                                            Padding="8"
                                            CornerRadius="0,0,6,6"
                                            MinHeight="32">
                                        <StackPanel>
                                            <!-- Loading progress -->
                                            <StackPanel IsVisible="{Binding IsLoading}" Spacing="6" Margin="0,8,0,12">
                                                <ProgressBar IsIndeterminate="True" Height="3" Foreground="{DynamicResource AccentBrush}" Margin="20,0"/>
                                                <TextBlock Text="{Binding LoadingProgressText}"
                                                           FontSize="{StaticResource Type.Tiny.Size}"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.7"/>
                                                <!-- Skeleton placeholders -->
                                                <WrapPanel HorizontalAlignment="Center" Margin="0,4,0,0">
                                                    <Border Width="68" Height="68" CornerRadius="8" Background="{DynamicResource ControlBackgroundBrush}" Margin="4" Opacity="0.4"/>
                                                    <Border Width="68" Height="68" CornerRadius="8" Background="{DynamicResource ControlBackgroundBrush}" Margin="4" Opacity="0.3"/>
                                                    <Border Width="68" Height="68" CornerRadius="8" Background="{DynamicResource ControlBackgroundBrush}" Margin="4" Opacity="0.2"/>
                                                    <Border Width="68" Height="68" CornerRadius="8" Background="{DynamicResource ControlBackgroundBrush}" Margin="4" Opacity="0.15"/>
                                                    <Border Width="68" Height="68" CornerRadius="8" Background="{DynamicResource ControlBackgroundBrush}" Margin="4" Opacity="0.1"/>
                                                </WrapPanel>
                                            </StackPanel>

                                            <!-- Icons wrap panel -->
                                            <ItemsControl ItemsSource="{Binding DisplayIcons}" IsVisible="{Binding IsLoaded}">
                                                <ItemsControl.Transitions>
                                                    <Transitions>
                                                        <DoubleTransition Property="Opacity" Duration="0:0:0.35"/>
                                                    </Transitions>
                                                </ItemsControl.Transitions>
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel HorizontalAlignment="Center"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding DataContext.HandleIconClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                MinWidth="72" Height="96"
                                                                Classes="liquid-glass" Margin="4">
                                                            <StackPanel>
                                                                <Border Width="68" Height="68" CornerRadius="8"
                                                                        Background="{StaticResource IconTileCellBrush}"
                                                                        HorizontalAlignment="Center">
                                                                    <Image Source="{Binding IconBitmap}" Width="60" Height="60" Stretch="Uniform"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Show More button (when section has more icons than displayed) -->
                                            <Button IsVisible="{Binding HasMore}"
                                                    Command="{Binding ShowAllCommand}"
                                                    HorizontalAlignment="Center"
                                                    Classes="liquid-glass"
                                                    Margin="0,8,0,4"
                                                    Padding="16,6">
                                                <TextBlock Text="{Binding ShowMoreText}" FontSize="{StaticResource Type.Small.Size}"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="0"
                    Background="{DynamicResource OverlayBackgroundBrush}"
                    CornerRadius="6"
                    IsVisible="{Binding IsBusy}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Border.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                    </Transitions>
                </Border.Transitions>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <ProgressBar IsIndeterminate="True" Width="260" Height="4" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="Loading icons..." FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" Opacity="0.7"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>



