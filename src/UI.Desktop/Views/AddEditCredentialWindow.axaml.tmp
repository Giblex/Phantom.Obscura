<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PhantomVault.UI.Views.AddEditCredentialWindow"
        Title="Add Credential" 
        Width="600" 
        Height="750"
        MinWidth="500"
        MinHeight="650"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">
    
    <Grid RowDefinitions="Auto,*,Auto">
        
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource HeaderBackgroundBrush}" 
                Padding="25,20"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="6">
                <TextBlock Text="{Binding WindowTitle}" 
                           FontSize="20" 
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="Enter credential details securely" 
                           FontSize="13" 
                           Foreground="{DynamicResource MutedTextBrush}"/>
            </StackPanel>
        </Border>
        
        <!-- Form Content -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="25,20">
            <StackPanel Spacing="20">
                
                <!-- Icon Selector -->
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="Icon (Optional)" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <Button Command="{Binding OpenIconPickerCommand}"
                                    Content="🎨 Choose Icon"
                                    Classes="secondary"
                                    Height="28"
                                    Padding="10,4"
                                    FontSize="11"
                                    ToolTip.Tip="Choose an icon for this credential"/>
                            <Button Command="{Binding OpenIconLibraryCommand}"
                                    Content="🗂 Icon Library"
                                    Classes="secondary"
                                    Height="28"
                                    Padding="10,4"
                                    FontSize="11"
                                    ToolTip.Tip="Manage the offline icon library"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Icon Preview - Clickable -->
            <Button Command="{Binding OpenIconPickerCommand}"
                            Background="{DynamicResource AccentBrush}"
                            Width="48"
                            Height="48"
                            CornerRadius="24"
                            Padding="0"
                            BorderThickness="2"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                ToolTip.Tip="Choose an icon or use quick picks below"
                            Cursor="Hand"
                            HorizontalAlignment="Left">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}"/>
                                <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                            </Style>
                        </Button.Styles>
                        <TextBlock Text="{Binding DisplayIcon}" 
                                   FontSize="24"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"/>
                    </Button>
                    
                    <!-- Quick Icon Picker -->
                    <Border Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="15,15,15,18"
                            IsVisible="{Binding ShowQuickPicks}">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Quick Pick:" 
                                       FontSize="11" 
                                       Foreground="{DynamicResource MutedTextBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Command="{Binding SetIconCommand}" CommandParameter="🌐" Classes="secondary" Width="40" Height="40" Padding="0" ToolTip.Tip="Website" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBlock Text="🌐" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button Command="{Binding SetIconCommand}" CommandParameter="💳" Classes="secondary" Width="40" Height="40" Padding="0" ToolTip.Tip="Credit Card" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBlock Text="💳" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button Command="{Binding SetIconCommand}" CommandParameter="🏦" Classes="secondary" Width="40" Height="40" Padding="0" ToolTip.Tip="Bank" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBlock Text="🏦" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button Command="{Binding SetIconCommand}" CommandParameter="🔐" Classes="secondary" Width="40" Height="40" Padding="0" ToolTip.Tip="Security" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBlock Text="🔐" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                                <Button Command="{Binding SetIconCommand}" CommandParameter="📧" Classes="secondary" Width="40" Height="40" Padding="0" ToolTip.Tip="Email" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBlock Text="📧" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- Title Field -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Title *" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Text="{Binding Title}"
                             Watermark="e.g., GitHub, Gmail, Bank Account"
                             Height="40"
                             FontSize="14"/>
                    <TextBlock Text="{Binding TitleError}" 
                               FontSize="11" 
                               Foreground="{DynamicResource ErrorBrush}"
                               IsVisible="{Binding HasTitleError}"/>
                </StackPanel>
                
                <!-- Username/Email Field -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Username / Email *" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Text="{Binding Username}"
                             Watermark="username@example.com"
                             Height="40"
                             FontSize="14"/>
                    <TextBlock Text="{Binding UsernameError}" 
                               FontSize="11" 
                               Foreground="{DynamicResource ErrorBrush}"
                               IsVisible="{Binding HasUsernameError}"/>
                </StackPanel>
                
                <!-- Password Field -->
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto,4,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="Password *" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <Button Grid.Column="1"
                                Command="{Binding GeneratePasswordCommand}"
                                Classes="secondary"
                                Height="26"
                                Padding="10,4"
                                FontSize="11"
                                ToolTip.Tip="Generate strong password">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="⚡" FontSize="12"/>
                                <TextBlock Text="Generate"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3"
                                Command="{Binding OpenPasswordGeneratorCommand}"
                                Classes="secondary"
                                Height="26"
                                Width="26"
                                Padding="4"
                                FontSize="11"
                                ToolTip.Tip="Open password generator settings">
                            <TextBlock Text="⚙" FontSize="13"/>
                        </Button>
                    </Grid>
                    
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding Password}"
                                 PasswordChar="{Binding PasswordChar}"
                                 Watermark="Enter secure password"
                                 Height="40"
                                 FontSize="14"
                                 Padding="12,10,45,10"/>
                        <Button Grid.Column="1"
                                Command="{Binding TogglePasswordVisibilityCommand}"
                                Classes="secondary"
                                Width="40"
                                Height="40"
                                Margin="-40,0,0,0"
                                ToolTip.Tip="Show/Hide password">
                            <TextBlock Text="{Binding PasswordVisibilityIcon}" FontSize="16"/>
                        </Button>
                    </Grid>
                    
                    <!-- Password Strength Meter -->
                    <Border Background="{DynamicResource ControlBackgroundBrush}"
                            CornerRadius="4"
                            Padding="10,8"
                            IsVisible="{Binding HasPassword}">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="Strength:" 
                                       FontSize="11" 
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <ProgressBar Grid.Column="1"
                                         Value="{Binding PasswordStrength}"
                                         Maximum="100"
                                         Height="8"
                                         VerticalAlignment="Center"
                                         Foreground="{Binding PasswordStrengthColor}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding PasswordStrengthText}" 
                                       FontSize="11" 
                                       FontWeight="SemiBold"
                                       Foreground="{Binding PasswordStrengthColor}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </Grid>
                    </Border>
                    
                    <TextBlock Text="{Binding PasswordError}" 
                               FontSize="11" 
                               Foreground="{DynamicResource ErrorBrush}"
                               IsVisible="{Binding HasPasswordError}"/>
                </StackPanel>
                
                <!-- URL Field -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Website URL" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Text="{Binding Url}"
                             Watermark="https://example.com"
                             Height="40"
                             FontSize="14"/>
                    <TextBlock Text="Optional - Used for auto-fill and quick access" 
                               FontSize="11" 
                               Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>
                
                <!-- Category Selection -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Category" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <ComboBox SelectedItem="{Binding SelectedCategory}"
                              ItemsSource="{Binding Categories}"
                              Height="40"
                              FontSize="14">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Icon}" FontSize="14"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                
                <!-- Tags -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Tags" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Text="{Binding TagsText}"
                             Watermark="work, personal, important (comma-separated)"
                             Height="40"
                             FontSize="14"/>
                    <TextBlock Text="Add tags to organize and search credentials easily" 
                               FontSize="11" 
                               Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>
                
                <!-- Notes Field -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Notes" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Text="{Binding Notes}"
                             Watermark="Add any additional information..."
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="100"
                             FontSize="13"/>
                </StackPanel>
                
                <!-- Expiry Date -->
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="Auto,*">
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding HasExpiryDate}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="Set expiration date (e.g., for temporary passwords)" 
                                   FontSize="13" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <DatePicker SelectedDate="{Binding ExpiryDate}"
                                Height="40"
                                FontSize="14"
                                IsVisible="{Binding HasExpiryDate}"/>
                </StackPanel>
                
                <!-- Mark as Favorite -->
                <Border Background="{DynamicResource ControlBackgroundBrush}"
                        CornerRadius="6"
                        Padding="15,12">
                    <Grid ColumnDefinitions="Auto,*">
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsFavorite}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="⭐ Mark as Favorite" 
                                       FontSize="13" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="Quick access from favorites list" 
                                       FontSize="11" 
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Footer with Action Buttons -->
        <Border Grid.Row="2" 
                Background="{DynamicResource FooterBackgroundBrush}" 
                Padding="25,15"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="* Required fields" 
                           FontSize="11" 
                           Foreground="{DynamicResource MutedTextBrush}"
                           VerticalAlignment="Center"/>
                
                <Button Grid.Column="1"
                        Command="{Binding CancelCommand}"
                        Classes="secondary"
                        Width="100"
                        Height="40"
                        Margin="0,0,10,0"
                        Content="Cancel"/>
                
                <Button Grid.Column="2"
                        Command="{Binding SaveCommand}"
                        Background="{DynamicResource AccentBrush}"
                        Width="120"
                        Height="40"
                        FontWeight="Bold">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="💾" FontSize="14"/>
                        <TextBlock Text="{Binding SaveButtonText}"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        
    </Grid>
    
</Window>
