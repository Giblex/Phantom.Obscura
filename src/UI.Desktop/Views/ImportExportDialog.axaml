<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PhantomVault.UI.ViewModels"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
    x:Class="PhantomVault.UI.Views.ImportExportDialog"
    Title="Import / Export Credentials"
    Width="900" Height="750"
    MinWidth="700" MinHeight="600"
    WindowStartupLocation="CenterOwner"
    CanResize="True"
    Background="{DynamicResource WindowBackgroundBrush}"
    Classes="animated-window">

    <views:ThemeAwareWindow.Styles>
        <!-- Import tile styles -->
        <Style Selector="Button.import-tile">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Tab button styles -->
        <Style Selector="ToggleButton.tab-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style Selector="ToggleButton.tab-button:checked">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </views:ThemeAwareWindow.Styles>

    <DockPanel>
        <!-- Tab Strip at Top -->
        <Border DockPanel.Dock="Top" 
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,15">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <ToggleButton x:Name="ImportTab"
                             Content="📥 Import"
                             IsChecked="True"
                             Classes="tab-button"
                             Width="120"
                             Height="36"/>
                <ToggleButton x:Name="ExportTab"
                             Content="📤 Export"
                             Classes="tab-button"
                             Width="120"
                             Height="36"/>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Grid>
            <!-- Import Panel -->
            <ScrollViewer x:Name="ImportPanel"
                         IsVisible="{Binding #ImportTab.IsChecked}"
                         VerticalScrollBarVisibility="Auto" 
                         HorizontalScrollBarVisibility="Disabled">
                <Border Padding="30,25" ClipToBounds="True">
                    <StackPanel Spacing="16">
                        <!-- Import Header -->
                        <TextBlock Text="Import Credentials" 
                                  FontSize="{StaticResource Type.Icon.Size}" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource PrimaryTextBrush}"/>
                        
                        <TextBlock Text="Import credentials from other password managers or backup files" 
                                  TextWrapping="Wrap" 
                                  Foreground="{DynamicResource SecondaryTextBrush}"/>

                        <!-- Import Format Tiles -->
                        <TextBlock Text="Select Import Format:" 
                                  FontWeight="SemiBold"
                                  Margin="0,8,0,0"/>
                        
                        <UniformGrid Columns="3" ColumnSpacing="16" RowSpacing="16" Margin="0,8">
                            <Button Command="{Binding ImportKeePassCommand}"
                                   Classes="import-tile"
                                   Height="100">
                                <StackPanel Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="•" FontSize="{StaticResource Type.H1.Size}"/>
                                    <TextBlock Text="KeePass" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Command="{Binding ImportLastPassCommand}"
                                   Classes="import-tile"
                                   Height="100">
                                <StackPanel Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="🔴" FontSize="{StaticResource Type.H1.Size}"/>
                                    <TextBlock Text="LastPass" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Command="{Binding Import1PasswordCommand}"
                                   Classes="import-tile"
                                   Height="100">
                                <StackPanel Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="🔵" FontSize="{StaticResource Type.H1.Size}"/>
                                    <TextBlock Text="1Password" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Command="{Binding ImportBitwardenCommand}"
                                   Classes="import-tile"
                                   Height="100">
                                <StackPanel Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="🛡️" FontSize="{StaticResource Type.H1.Size}"/>
                                    <TextBlock Text="Bitwarden" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Command="{Binding ImportDashlaneCommand}"
                                   Classes="import-tile"
                                   Height="100">
                                <StackPanel Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="🟢" FontSize="{StaticResource Type.H1.Size}"/>
                                    <TextBlock Text="Dashlane" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Command="{Binding ImportCsvCommand}"
                                   Classes="import-tile"
                                   Height="100">
                                <StackPanel Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="📄" FontSize="{StaticResource Type.H1.Size}"/>
                                    <TextBlock Text="CSV" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </UniformGrid>

                        <!-- Import Status -->
                        <Border Background="{DynamicResource TileGlassBrush}"
                               BorderBrush="{DynamicResource ControlBorderBrush}"
                               BorderThickness="1"
                               CornerRadius="{StaticResource Radius.Lg}"
                               Padding="16"
                               Margin="0,16,0,0"
                               IsVisible="{Binding ImportStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding ImportStatusMessage}"
                                      TextWrapping="Wrap"
                                      Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Export Panel -->
            <ScrollViewer x:Name="ExportPanel"
                         IsVisible="{Binding #ExportTab.IsChecked}"
                         VerticalScrollBarVisibility="Auto">
                <Border Padding="30,25" ClipToBounds="True">
                    <StackPanel Spacing="16">
                        <!-- Export Header -->
                        <TextBlock Text="Export Credentials" 
                                  FontSize="{StaticResource Type.Icon.Size}" 
                                  FontWeight="SemiBold"
                                  Foreground="{DynamicResource PrimaryTextBrush}"/>
                        
                        <TextBlock Text="Export your credentials to external formats for backup or migration" 
                                  TextWrapping="Wrap" 
                                  Foreground="{DynamicResource SecondaryTextBrush}"/>

                        <!-- Format Selection -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Export Format:" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding ExportFormats}" 
                                     SelectedValue="{Binding SelectedExportFormat}" 
                                     Width="250"
                                     HorizontalAlignment="Left"
                                     ToolTip.Tip="Choose the file format for export"/>
                        </StackPanel>

                        <!-- Group Filter -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Filter by Group:" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding ExportGroups}" 
                                     SelectedValue="{Binding FilterGroup}" 
                                     Width="250"
                                     HorizontalAlignment="Left"
                                     ToolTip.Tip="Export all credentials or filter by specific group"/>
                        </StackPanel>

                        <!-- Security Options -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Security Options:" FontWeight="SemiBold"/>
                            <CheckBox IsChecked="{Binding IncludePasswords}" 
                                     Content="Include passwords in export"
                                     ToolTip.Tip="Uncheck to export without passwords"/>
                            <TextBlock Text="⚠️ Warning: Exported files are NOT encrypted. Handle with care!" 
                                      Foreground="{DynamicResource ErrorBrush}"
                                      FontSize="{StaticResource Type.Small.Size}"
                                      TextWrapping="Wrap"
                                      Margin="24,4,0,0"
                                      IsVisible="{Binding IncludePasswords}"/>
                        </StackPanel>

                        <!-- Destination Selection -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Destination File:" FontWeight="SemiBold"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0" 
                                        Text="{Binding DestinationFile}" 
                                        IsReadOnly="True" 
                                        Watermark="No destination selected..."
                                        Margin="0,0,8,0"/>
                                <Button Grid.Column="1" 
                                       Content="Browse..." 
                                       Width="100"
                                       Classes="liquid-glass"
                                       Command="{Binding BrowseExportCommand}"/>
                            </Grid>
                        </StackPanel>

                        <!-- Export Status -->
                        <Border Background="{DynamicResource TileGlassBrush}"
                               BorderBrush="{DynamicResource ControlBorderBrush}"
                               BorderThickness="1"
                               CornerRadius="{StaticResource Radius.Lg}"
                               Padding="16"
                               IsVisible="{Binding ExportStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="{Binding ExportStatusMessage}"
                                          TextWrapping="Wrap"
                                          Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock Text="{Binding ExportCredentialCount, StringFormat='Ready to export {0} credentials'}"
                                          FontSize="{StaticResource Type.Small.Size}"
                                          Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Export Button -->
                        <Button Content="Export Credentials"
                               Command="{Binding ExportCommand}"
                               HorizontalAlignment="Left"
                               Padding="24,10"
                               FontWeight="SemiBold"
                               Classes="liquid-glass primary"
                               IsEnabled="{Binding !!DestinationFile}"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>

        <!-- Bottom Button Bar -->
        <Border DockPanel.Dock="Bottom"
               Background="{DynamicResource HeaderBackgroundBrush}"
               BorderBrush="{DynamicResource ControlBorderBrush}"
               BorderThickness="0,1,0,0"
               Padding="20,15">
            <StackPanel Orientation="Horizontal" 
                       HorizontalAlignment="Right" 
                       Spacing="12">
                <Button Content="Close" 
                       Command="{Binding CloseCommand}"
                       Width="100"
                       Classes="liquid-glass"/>
            </StackPanel>
        </Border>
    </DockPanel>
</views:ThemeAwareWindow>
