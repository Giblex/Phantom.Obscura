<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
    x:Class="PhantomVault.UI.Views.ChangeMasterPasswordDialog"
    Title="Change Master Password"
    Width="460" Height="430"
    WindowStartupLocation="CenterOwner"
    CanResize="False"
    Background="{DynamicResource WindowBackgroundBrush}"
    Classes="animated-window">

    <StackPanel Margin="24" Spacing="14">
        <TextBlock Text="Change Master Password"
                   FontSize="{StaticResource Type.H3.Size}"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"/>

        <TextBlock TextWrapping="Wrap"
                   FontSize="{StaticResource Type.Small.Size}"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Text="Your keyfile is mandatory and will be rotated automatically. A password is optional — leave the new password blank to protect the vault with the keyfile alone."/>

        <!-- Current password (only when one is set) -->
        <StackPanel x:Name="CurrentPanel" Spacing="6">
            <TextBlock Text="Current password" Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBox x:Name="CurrentBox" PasswordChar="●" Watermark="Enter current password"/>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="New password" Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBox x:Name="NewBox" PasswordChar="●" Watermark="Leave blank for no password"/>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Confirm new password" Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBox x:Name="ConfirmBox" PasswordChar="●" Watermark="Re-enter new password"/>
        </StackPanel>

        <TextBlock x:Name="ErrorText"
                   IsVisible="False"
                   TextWrapping="Wrap"
                   FontSize="{StaticResource Type.Small.Size}"
                   Foreground="{DynamicResource ErrorBrush}"/>

        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button Content="Cancel" Width="110" Classes="liquid-glass" Click="Cancel_Click" IsCancel="True"/>
            <Button Content="Change Password"
                    Width="150"
                    Background="#2B4A7A"
                    Foreground="#FFFFFFFF"
                    BorderBrush="{DynamicResource Brush.Glass.Border}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Md}"
                    Click="Change_Click"
                    IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</views:ThemeAwareWindow>
