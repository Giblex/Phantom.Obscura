<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PhantomVault.UI.Views.Dialogs.BackupCredentialsDialog"
        Width="420" Height="340"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Title="Backup Credentials">
  <StackPanel Margin="16" Spacing="10">
    <TextBlock Text="Enter backup credentials" FontSize="{StaticResource Type.H4.Size}" FontWeight="Bold"/>
    <TextBlock Text="Passphrase (required if no keyfile)" />
    <TextBox x:Name="PassphraseBox"/>
    <TextBlock Text="Keyfile (optional)" />
    <StackPanel Orientation="Horizontal" Spacing="6">
      <TextBox x:Name="KeyfileBox" Width="280"/>
      <Button x:Name="BrowseButton" Content="Browse" Width="80" Classes="liquid-glass" />
    </StackPanel>
    <TextBlock Text="PIN (required)" />
    <TextBox x:Name="PinBox"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,16,0,0">
      <Button x:Name="CancelButton" Content="Cancel" Width="90" Classes="liquid-glass"/>
      <Button x:Name="OkButton" Content="OK" Width="90" Classes="liquid-glass primary" />
    </StackPanel>
  </StackPanel>
</Window>
