<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PhantomVault.UI.Views.Dialogs.KeePassPasswordDialog"
        Title="KeePass Database Password"
        Width="500"
        Height="350"
        MinWidth="400"
        MinHeight="300"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ObscuraCanvasBrush}">
  <Grid RowDefinitions="Auto,*,Auto">
    <!-- Header -->
    <Border Grid.Row="0"
            Background="{DynamicResource ObscuraSurfaceAltBrush}"
            BorderBrush="{DynamicResource ObscuraBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="20,16">
      <StackPanel Spacing="8">
        <TextBlock Text="Enter KeePass Database Credentials"
                   FontSize="18"
                   FontWeight="SemiBold"/>
        <TextBlock Text="Provide the master password (and optional keyfile) to unlock the KeePass database."
                   FontSize="12"
                   Classes="subtle"
                   TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <!-- Content -->
    <ScrollViewer Grid.Row="1" Padding="20,16">
      <StackPanel Spacing="16">
        <!-- Password -->
        <StackPanel Spacing="8">
          <TextBlock Text="Master Password *"
                     FontSize="13"/>
          <TextBox x:Name="PasswordTextBox"
                   Watermark="Enter master password"
                   PasswordChar="•"
                   MinHeight="38"/>
          <CheckBox x:Name="ShowPasswordCheckBox"
                    Content="Show password"
                    FontSize="12"
                    Checked="ShowPasswordCheckBox_Changed"
                    Unchecked="ShowPasswordCheckBox_Changed"/>
        </StackPanel>

        <!-- Optional Keyfile -->
        <StackPanel Spacing="8">
          <TextBlock Text="Keyfile (Optional)"
                     FontSize="13"/>
          <Grid ColumnDefinitions="*,Auto">
            <TextBox x:Name="KeyfileTextBox"
                     Grid.Column="0"
                     Watermark="No keyfile selected"
                     IsReadOnly="True"
                     MinHeight="38"/>
            <Button Grid.Column="1"
                    Content="Browse..."
                    Click="BrowseKeyfile_Click"
                    MinWidth="100"
                    Margin="8,0,0,0"/>
          </Grid>
        </StackPanel>

        <!-- Info -->
        <Border Background="{DynamicResource ObscuraSurfaceBrush}"
                BorderBrush="{DynamicResource ObscuraBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
          <StackPanel Spacing="4">
            <TextBlock Text="ℹ️ About KeePass Import"
                       FontSize="12"
                       FontWeight="SemiBold"/>
            <TextBlock Text="• Supports KDBX v3 and v4 formats (KeePass 2.x, KeePassXC)"
                       FontSize="11"
                       Classes="subtle"/>
            <TextBlock Text="• All credentials, groups, custom fields, and tags will be imported"
                       FontSize="11"
                       Classes="subtle"/>
            <TextBlock Text="• Passwords will be securely re-encrypted in Phantom Vault"
                       FontSize="11"
                       Classes="subtle"/>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <!-- Footer -->
    <Border Grid.Row="2"
            Background="{DynamicResource ObscuraSurfaceAltBrush}"
            BorderBrush="{DynamicResource ObscuraBorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="20,12">
      <Grid ColumnDefinitions="*,Auto,Auto">
        <TextBlock x:Name="StatusTextBlock"
                   Grid.Column="0"
                   VerticalAlignment="Center"
                   FontSize="12"
                   Classes="subtle"/>
        <Button Grid.Column="1"
                Content="Cancel"
                Classes="secondary"
                Click="Cancel_Click"
                MinWidth="100"
                Margin="0,0,8,0"/>
        <Button Grid.Column="2"
                Content="Unlock"
                Click="Unlock_Click"
                MinWidth="100"/>
      </Grid>
    </Border>
  </Grid>
</Window>
