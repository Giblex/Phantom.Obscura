<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
    x:Class="PhantomVault.UI.Views.AppPermissionsWindow"
    Title="Manage App Permissions"
    Width="560" Height="560"
    WindowStartupLocation="CenterOwner"
    Background="{DynamicResource WindowBackgroundBrush}"
    Classes="animated-window">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="24">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="App Auto-Fill Permissions"
                       FontSize="{StaticResource Type.H3.Size}"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBlock Text="Control which desktop applications PhantomVault is allowed to auto-fill credentials into. Blocked apps will never receive auto-fill."
                       FontSize="{StaticResource Type.Small.Size}"
                       Foreground="{DynamicResource MutedTextBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Add row -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="0,16,0,12">
            <TextBox Grid.Column="0"
                     Text="{Binding NewAppName, Mode=TwoWay}"
                     Watermark="Application name or process (e.g. chrome.exe)"/>
            <Button Grid.Column="1"
                    Content="Add"
                    Width="90"
                    Background="#2B4A7A"
                    Foreground="#FFFFFFFF"
                    BorderBrush="{DynamicResource Brush.Glass.Border}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Md}"
                    Command="{Binding AddAppCommand}"/>
        </Grid>

        <!-- Permission list -->
        <Border Grid.Row="2"
                Background="{DynamicResource ContentBackgroundBrush}"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource Radius.Md}"
                Padding="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Permissions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SettingsPanelBackgroundBrush}"
                                        BorderBrush="{DynamicResource SettingsPanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource Radius.Md}"
                                        Padding="12,10"
                                        Margin="2,3">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                        <Path Grid.Column="0"
                                              Width="20" Height="20" Stretch="Uniform"
                                              VerticalAlignment="Center"
                                              Data="M19 11h-1.5V7c0-2.76-2.24-5-5-5s-5 2.24-5 5v4H6c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h13c1.1 0 2-.9 2-2v-8c0-1.1-.9-2-2-2zm-9-4c0-1.66 1.34-3 3-3s3 1.34 3 3v4h-6V7z"
                                              Stroke="#FFFFFFFF" StrokeThickness="1.5" Fill="Transparent"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding AppName}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <ToggleSwitch Grid.Column="2"
                                                      IsChecked="{Binding Allowed, Mode=TwoWay}"
                                                      OnContent="Allowed"
                                                      OffContent="Blocked"
                                                      VerticalAlignment="Center"/>
                                        <Button Grid.Column="3"
                                                Content="✕"
                                                Width="30" Height="30"
                                                Padding="0"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                Foreground="{DynamicResource ErrorBrush}"
                                                Command="{Binding $parent[ItemsControl].DataContext.RemoveAppCommand}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No apps added yet. Add an application above to control its auto-fill access."
                               IsVisible="{Binding IsEmpty}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               FontSize="{StaticResource Type.Small.Size}"
                               TextWrapping="Wrap"
                               Margin="12,16"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save"
                    Width="110"
                    Background="#2B4A7A"
                    Foreground="#FFFFFFFF"
                    BorderBrush="{DynamicResource Brush.Glass.Border}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource Radius.Md}"
                    Command="{Binding SaveCommand}"/>
            <Button Content="Cancel"
                    Width="110"
                    Classes="liquid-glass"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</views:ThemeAwareWindow>
