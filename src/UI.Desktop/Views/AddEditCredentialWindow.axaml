<?xml version="1.0" encoding="utf-8"?>
<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
    x:Class="PhantomVault.UI.Views.AddEditCredentialWindow"
        Title="Add Credential" 
        Width="800" 
        Height="700"
        MinWidth="700"
        MinHeight="600"
        WindowStartupLocation="Manual"
    Background="{DynamicResource WindowBackgroundBrush}"
    Classes="animated-window"
        Opacity="0">
    <views:ThemeAwareWindow.Styles>
        <!-- Fade in animation when window opens -->
        <Style Selector="views|ThemeAwareWindow">
            <Style.Animations>
                <Animation Duration="0:0:0.3" FillMode="Forward">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </views:ThemeAwareWindow.Styles>
    
    <Grid RowDefinitions="Auto,*,Auto">
        
        <Grid.KeyBindings>
            <!-- Ctrl+S: Save credential -->
            <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}"/>
            <!-- Ctrl+G: Generate password -->
            <KeyBinding Gesture="Ctrl+G" Command="{Binding GeneratePasswordCommand}"/>
            <!-- Escape: Cancel -->
            <KeyBinding Gesture="Escape" Command="{Binding CancelCommand}"/>
        </Grid.KeyBindings>
        
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource HeaderBackgroundBrush}" 
                Padding="25,20"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="6">
                    <TextBlock Text="{Binding WindowTitle}" 
                               FontSize="{StaticResource Type.H2.Size}" 
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="Enter credential details securely" 
                               FontSize="{StaticResource Type.Label.Size}" 
                               Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Command="{Binding CancelCommand}"
                        Classes="liquid-glass"
                        Width="36"
                        Height="36"
                        VerticalAlignment="Top"
                        ToolTip.Tip="Close">
                    <TextBlock Text="✕" FontSize="16"/>
                </Button>
            </Grid>
        </Border>
        
        <!-- Form Content -->
        <ScrollViewer Grid.Row="1" 
                  VerticalScrollBarVisibility="Visible"
                  HorizontalScrollBarVisibility="Disabled"
                  HorizontalContentAlignment="Stretch"
                  AllowAutoHide="False"
                  Padding="25,20">
            <StackPanel Spacing="20"
                HorizontalAlignment="Stretch"
                MaxWidth="720">
                
                <!-- Icon Selector -->
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*">
                        <TextBlock Grid.Column="0"
                                   Text="Icon (Optional)" 
                                   FontSize="{StaticResource Type.Label.Size}" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </Grid>
                    
                    <!-- Icon Preview with contextual flyout for icon/color controls -->
                    <Button Width="72"
                            Height="72"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalAlignment="Left"
                            Click="OnIconFlyoutButtonClick">
                        <Button.Content>
                            <Border Width="64"
                                    Height="64"
                                    CornerRadius="32"
                                    BorderThickness="2"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    Background="Transparent">
                                <Grid>
                                    <!-- Color background shown only when there is NO auto-detected image -->
                                    <Ellipse Width="64" Height="64" IsVisible="{Binding !HasAutoDetectedIcon}">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding SelectedIconColor}" />
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <!-- Show image if auto-detected -->
                                    <Image Source="{Binding AutoDetectedIconBitmap}"
                                           Width="60"
                                           Height="60"
                                           IsVisible="{Binding HasAutoDetectedIcon}"
                                           Stretch="UniformToFill"/>

                                    <!-- Show initials if no image -->
                                    <TextBlock Text="{Binding IconInitials}" 
                                               FontSize="24"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               IsVisible="{Binding !HasAutoDetectedIcon}"/>
                                </Grid>
                            </Border>
                        </Button.Content>
                        <FlyoutBase.AttachedFlyout>
                            <Flyout Placement="BottomEdgeAlignedLeft">
                                <Border Padding="12"
                                        Background="{DynamicResource WindowBackgroundBrush}"
                                        CornerRadius="8"
                                        MaxWidth="280">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Icon Options"
                                                   FontWeight="SemiBold"
                                                   FontSize="{StaticResource Type.Label.Size}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <Button Content="Change Icon"
                                                Command="{Binding OpenIconPickerCommand}"
                                                HorizontalAlignment="Stretch"
                                                Padding="10,6"
                                                Classes="liquid-glass"
                                                ToolTip.Tip="Open the icon library"/>
                                        <Button Content="Manage Icon Library"
                                                Command="{Binding OpenIconLibraryCommand}"
                                                HorizontalAlignment="Stretch"
                                                Padding="10,6"
                                                Classes="liquid-glass"
                                                ToolTip.Tip="Manage offline icon collections"/>
                                        <Expander Header="Change Color"
                                                  IsExpanded="True">
                                            <Border Margin="0,8,0,0"
                                                    Padding="6"
                                                    Background="{DynamicResource ControlBackgroundBrush}"
                                                                CornerRadius="8"
                                                                Classes="fade-toggle">
                                                <ItemsControl ItemsSource="{Binding AvailableColors}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <UniformGrid Columns="5" HorizontalAlignment="Left"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Width="42"
                                                                    Height="42"
                                                                    Margin="4"
                                                                    Padding="0"
                                                                    BorderThickness="0"
                                                                    Command="{Binding DataContext.SelectColorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip.Tip="Select this color">
                                                                <Button.Content>
                                                                    <Border CornerRadius="21" BorderThickness="2" BorderBrush="{DynamicResource ControlBorderBrush}">
                                                                        <Border.Background>
                                                                            <SolidColorBrush Color="{Binding}"/>
                                                                        </Border.Background>
                                                                    </Border>
                                                                </Button.Content>
                                                                <Button.Styles>
                                                                    <Style Selector="Button:pointerover Border">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                        <Setter Property="BorderThickness" Value="3"/>
                                                                    </Style>
                                                                </Button.Styles>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </Expander>
                                    </StackPanel>
                                </Border>
                            </Flyout>
                        </FlyoutBase.AttachedFlyout>
                    </Button>
                </StackPanel>
                
                <!-- Title Field -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Title *" 
                               FontSize="{StaticResource Type.Label.Size}" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Text="{Binding Title}"
                             Watermark="e.g., GitHub, Gmail, Bank Account"
                             Height="40"
                             FontSize="{StaticResource Type.Body.Size}"
                             AutomationProperties.Name="Credential title"
                             AutomationProperties.HelpText="Enter a descriptive name for this credential"/>
                    <TextBlock Text="{Binding TitleError}" 
                               FontSize="{StaticResource Type.Tiny.Size}" 
                               Foreground="{DynamicResource ErrorBrush}"
                               IsVisible="{Binding HasTitleError}"/>
                </StackPanel>
                
                <!-- Username/Email Field -->
                <StackPanel Spacing="8" IsVisible="{Binding IsPasswordEntry}">
                    <TextBlock Text="Username / Email *" 
                               FontSize="{StaticResource Type.Label.Size}" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Text="{Binding Username}"
                             Watermark="username@example.com"
                             Height="40"
                             FontSize="{StaticResource Type.Body.Size}"
                             AutomationProperties.Name="Username or email"
                             AutomationProperties.HelpText="Enter your username or email address for this account"/>
                    <TextBlock Text="{Binding UsernameError}" 
                               FontSize="{StaticResource Type.Tiny.Size}" 
                               Foreground="{DynamicResource ErrorBrush}"
                               IsVisible="{Binding HasUsernameError}"/>
                </StackPanel>
                
                <!-- Password / Secret Field -->
                <StackPanel Spacing="8" IsVisible="{Binding ShowPasswordField}">
                    <Grid ColumnDefinitions="*,Auto,4,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding PasswordLabelText}" 
                                   FontSize="{StaticResource Type.Label.Size}" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <Button Grid.Column="1"
                                Command="{Binding GeneratePasswordCommand}"
                                Classes="secondary action-button"
                                Height="26"
                                Padding="10,4"
                                FontSize="{StaticResource Type.Tiny.Size}"
                                ToolTip.Tip="Generate strong password"
                                AutomationProperties.Name="Generate password"
                                AutomationProperties.HelpText="Generate a strong random password"
                                IsVisible="{Binding ShowPasswordGenerator}">
                            <TextBlock Text="Generate" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button Grid.Column="3"
                                Command="{Binding OpenPasswordGeneratorCommand}"
                                Classes="secondary action-button"
                                Height="26"
                                Width="26"
                                Padding="4"
                                FontSize="{StaticResource Type.Tiny.Size}"
                                ToolTip.Tip="Open password generator settings"
                                AutomationProperties.Name="Password generator settings"
                                AutomationProperties.HelpText="Open advanced password generator settings"
                                IsVisible="{Binding ShowPasswordGenerator}">
                            <TextBlock Text="..." FontSize="{StaticResource Type.Label.Size}"/>
                        </Button>
                    </Grid>

                    <Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding Password}"
                                     PasswordChar="{Binding PasswordChar}"
                                     Watermark="Enter secure password"
                                     Height="40"
                                     FontSize="{StaticResource Type.Body.Size}"
                                     Padding="12,10"
                                     Margin="0,0,8,0"
                                     AutomationProperties.Name="Password"
                                     AutomationProperties.HelpText="Enter or generate a strong password for this credential"/>
                            <Button Grid.Column="1"
                                    Command="{Binding TogglePasswordVisibilityCommand}"
                                    Classes="liquid-glass"
                                    Width="40"
                                    Height="40"
                                    ToolTip.Tip="Show/Hide password"
                                    AutomationProperties.Name="Toggle password visibility"
                                    AutomationProperties.HelpText="Show or hide the password text"
                                    IsVisible="{Binding ShowPasswordVisibilityToggle}">
                                <TextBlock Text="{Binding PasswordVisibilityIcon}" FontSize="{StaticResource Type.H4.Size}"/>
                            </Button>
                        </Grid>

                        <Border HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="18,-10,0,0"
                                Padding="8,2"
                                CornerRadius="4"
                                Background="{Binding PasswordFlagBackground}"
                                IsVisible="{Binding ShowPasswordFlag}"
                                IsHitTestVisible="False"
                                Classes="fade-toggle">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="⚑" FontSize="{StaticResource Type.Tiny.Size}"/>
                                <TextBlock Text="{Binding PasswordFlagText}"
                                           FontSize="{StaticResource Type.Tiny.Size}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Password Strength Meter -->
                    <StackPanel IsVisible="{Binding ShowPasswordStrength}">
                        <Border Background="{DynamicResource ControlBackgroundBrush}"
                                CornerRadius="4"
                                Padding="10,8"
                                IsVisible="{Binding HasPassword}"
                                Classes="fade-toggle">
                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Strength:" 
                                           FontSize="{StaticResource Type.Tiny.Size}" 
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,0"/>
                                <ProgressBar Grid.Column="1"
                                             Value="{Binding PasswordStrength}"
                                             Maximum="100"
                                             Height="8"
                                             VerticalAlignment="Center"
                                             Foreground="{Binding PasswordStrengthColor}"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding PasswordStrengthText}" 
                                           FontSize="{StaticResource Type.Tiny.Size}" 
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PasswordStrengthColor}"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="{Binding PasswordError}" 
                               FontSize="{StaticResource Type.Tiny.Size}" 
                               Foreground="{DynamicResource ErrorBrush}"
                               IsVisible="{Binding HasPasswordError}"/>
                </StackPanel>
                
                <!-- URL Field -->
                <StackPanel Spacing="8" IsVisible="{Binding IsPasswordEntry}">
                    <TextBlock Text="Website URL" 
                               FontSize="{StaticResource Type.Label.Size}" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding Url}"
                                 Watermark="https://example.com"
                                 Height="40"
                                 FontSize="{StaticResource Type.Body.Size}"
                                 />
                </StackPanel>
                
                <!-- Wi-Fi Details -->
                <StackPanel Spacing="12" IsVisible="{Binding IsWiFiEntry}">
                    <TextBlock Text="Wi-Fi Network" FontSize="{StaticResource Type.Body.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Network Name (SSID) *" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding WiFiSSID}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="MyHomeWifi"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Security Type" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding WiFiSecurityType}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="WPA2"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="BSSID / MAC" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding WiFiBSSID}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="AA:BB:CC:DD:EE:FF"/>
                    </StackPanel>
                </StackPanel>

                <!-- Credit Card Details -->
                <StackPanel Spacing="12" IsVisible="{Binding IsCreditCardEntry}">
                    <TextBlock Text="Card Details" FontSize="{StaticResource Type.Body.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Cardholder Name" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding CardholderName}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="Name on card"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Card Number" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding CardNumber}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="1234 5678 9012 3456"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Card Type" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding CardType}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="Visa"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,16,*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="Expiry Month" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding CardExpiryMonth}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="MM"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="Expiry Year" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding CardExpiryYear}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="YYYY"/>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,16,*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="CVV" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding CardCVV}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="123"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="PIN" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding CardPIN}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="0000"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Billing Address" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding CardBillingAddress}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="80"
                                 FontSize="{StaticResource Type.Label.Size}"
                                 />
                    </StackPanel>
                </StackPanel>

                <!-- Bank Account Details -->
                <StackPanel Spacing="12" IsVisible="{Binding IsBankAccountEntry}">
                    <TextBlock Text="Bank Account" FontSize="{StaticResource Type.Body.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Bank Name" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding BankName}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="Local Credit Union"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Account Type" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding BankAccountType}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="Checking"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Account Number" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding BankAccountNumber}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="••••1234"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Routing Number" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding BankRoutingNumber}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="012345678"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="IBAN" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding BankIBAN}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="DE89 3704 0044 0532 0130 00"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="SWIFT / BIC" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding BankSWIFT}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="DEUTDEFF"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Branch Code" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding BankBranchCode}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="BSB"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Branch Address" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding BankBranchAddress}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="80"
                                 FontSize="{StaticResource Type.Label.Size}"
                                 />
                    </StackPanel>
                </StackPanel>

                <!-- Identity Details -->
                <StackPanel Spacing="12" IsVisible="{Binding IsIdentityEntry}">
                    <TextBlock Text="Identity Document" FontSize="{StaticResource Type.Body.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Document Type" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding IdDocumentType}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="Passport"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Document Number" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding IdNumber}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="123456789"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,16,*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="Issuing Country" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding IdIssuingCountry}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="USA"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="State / Region" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding IdIssuingState}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="CA"/>
                        </StackPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,16,*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="Issue Date" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <DatePicker SelectedDate="{Binding IdIssueDate}" Height="40" FontSize="{StaticResource Type.Body.Size}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="Expiration Date" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <DatePicker SelectedDate="{Binding IdExpiryDate}" Height="40" FontSize="{StaticResource Type.Body.Size}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- API Key Details -->
                <StackPanel Spacing="12" IsVisible="{Binding IsApiKeyEntry}">
                    <TextBlock Text="API Access" FontSize="{StaticResource Type.Body.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="API Key / Token" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding ApiKeyValue}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="70"
                                 FontSize="{StaticResource Type.Label.Size}"
                                 Watermark="sk-live-xxxx"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Environment" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding ApiEnvironment}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="Production"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Endpoint" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding ApiEndpoint}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="70"
                                 FontSize="{StaticResource Type.Label.Size}"
                                 Watermark="https://api.example.com"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Documentation URL" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding ApiDocumentationUrl}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="https://docs.example.com"/>
                    </StackPanel>
                </StackPanel>

                <!-- Contact Details -->
                <StackPanel Spacing="12" IsVisible="{Binding IsContactEntry}">
                    <TextBlock Text="Contact Card" FontSize="{StaticResource Type.Body.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Full Name" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding ContactFullName}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="Jane Doe"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Email" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding ContactEmail}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="user@example.com"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Phone" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding ContactPhone}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="+1 555 123 4567"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,16,*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="Company" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding ContactCompany}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="Contoso"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="Job Title" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding ContactJobTitle}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="CTO"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel Spacing="6">
                        <TextBlock Text="Address" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding ContactAddress}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="80"
                                 FontSize="{StaticResource Type.Label.Size}"
                                 />
                    </StackPanel>
                </StackPanel>

                <!-- TOTP Authenticator Details -->
                <StackPanel Spacing="12" IsVisible="{Binding IsTotpEntry}">
                    <TextBlock Text="TOTP Authenticator" FontSize="{StaticResource Type.Body.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Issuer (e.g., Google, Microsoft)" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding TotpIssuer}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="Google"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Account Name / Email" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding TotpAccountName}" Height="40" FontSize="{StaticResource Type.Body.Size}" Watermark="user@example.com"/>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Secret Key (Base32)" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox Text="{Binding TotpSecret}"
                                 AcceptsReturn="False"
                                 TextWrapping="NoWrap"
                                 Height="40"
                                 FontFamily="Consolas,monospace"
                                 FontSize="{StaticResource Type.Body.Size}"
                                 Watermark="JBSWY3DPEHPK3PXP"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,8,Auto,8,Auto">
                        <Button Grid.Column="0"
                                Command="{Binding GenerateTotpSecretCommand}"
                                Height="40"
                                Classes="liquid-glass"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🎲" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Generate Secret" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2"
                                Command="{Binding ImportFromOtpAuthCommand}"
                                Height="40"
                                Classes="liquid-glass"
                                ToolTip.Tip="Import from otpauth:// URL in clipboard">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="📋" FontSize="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Import from Clipboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Advanced Settings" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}"/>

                            <Grid ColumnDefinitions="*,16,*">
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Text="Digits" FontSize="{StaticResource Type.Label.Size}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <NumericUpDown Value="{Binding TotpDigits}"
                                                   Minimum="6"
                                                   Maximum="8"
                                                   Increment="1"
                                                   Height="40"
                                                   FontSize="{StaticResource Type.Body.Size}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock Text="Time Step (seconds)" FontSize="{StaticResource Type.Label.Size}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <NumericUpDown Value="{Binding TotpTimeStep}"
                                                   Minimum="15"
                                                   Maximum="60"
                                                   Increment="15"
                                                   Height="40"
                                                   FontSize="{StaticResource Type.Body.Size}"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Algorithm" FontSize="{StaticResource Type.Label.Size}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <ComboBox SelectedItem="{Binding TotpAlgorithm}"
                                          Height="40"
                                          FontSize="{StaticResource Type.Body.Size}">
                                    <ComboBoxItem Content="SHA1"/>
                                    <ComboBoxItem Content="SHA256"/>
                                    <ComboBoxItem Content="SHA512"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="💡 How to use:" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock TextWrapping="Wrap" FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource SecondaryTextBrush}">
                                • Scan the QR code from your service and copy the otpauth:// URL, then click "Import from Clipboard"
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource SecondaryTextBrush}">
                                • Or manually enter the secret key (usually shown alongside the QR code)
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource SecondaryTextBrush}">
                                • The code will be generated automatically in your vault
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Category Selection -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Category"
                               FontSize="{StaticResource Type.Label.Size}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <ComboBox SelectedItem="{Binding SelectedCategory}"
                              ItemsSource="{Binding Categories}"
                              Height="40"
                              FontSize="{StaticResource Type.Body.Size}"
                              HorizontalContentAlignment="Left"
                              VerticalContentAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center"
                                            Height="36">
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="{StaticResource Type.Body.Size}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               FontSize="{StaticResource Type.Body.Size}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                
                <!-- Tags -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Tags" 
                               FontSize="{StaticResource Type.Label.Size}" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Text="{Binding TagsText}"
                             Watermark="work, personal, important (comma-separated)"
                             Height="40"
                             FontSize="{StaticResource Type.Body.Size}"/>
                    <TextBlock Text="Add tags to organize and search credentials easily" 
                               FontSize="{StaticResource Type.Tiny.Size}" 
                               Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>
                
                <!-- Notes Field -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Notes" 
                               FontSize="{StaticResource Type.Label.Size}" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Text="{Binding Notes}"
                             Watermark="Add any additional information..."
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="100"
                             FontSize="{StaticResource Type.Label.Size}"/>
                </StackPanel>
                
                <!-- Expiry Date -->
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="Auto,*">
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding HasExpiryDate}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="Set expiration date (e.g., for temporary passwords)" 
                                   FontSize="{StaticResource Type.Label.Size}" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <DatePicker SelectedDate="{Binding ExpiryDate}"
                                Height="40"
                                FontSize="{StaticResource Type.Body.Size}"
                                IsVisible="{Binding HasExpiryDate}"/>
                </StackPanel>
                
                <!-- Mark as Favorite -->
                <Border Background="{DynamicResource ControlBackgroundBrush}"
                        CornerRadius="6"
                        Padding="15,12">
                    <Grid ColumnDefinitions="Auto,*">
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsFavorite}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="⭐ Mark as Favorite" 
                                       FontSize="{StaticResource Type.Label.Size}" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="Quick access from favorites list" 
                                       FontSize="{StaticResource Type.Tiny.Size}" 
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Footer with Action Buttons -->
        <Border Grid.Row="2" 
                Background="{DynamicResource FooterBackgroundBrush}" 
                Padding="25,15"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="{DynamicResource Str.Message.RequiredFields}" 
                           FontSize="{StaticResource Type.Tiny.Size}" 
                           Foreground="{DynamicResource MutedTextBrush}"
                           VerticalAlignment="Center"/>
                
                <Button Grid.Column="1"
                        Command="{Binding CancelCommand}"
                        Classes="secondary action-button"
                        Width="100"
                        Height="40"
                        Margin="0,0,10,0"
                        Content="{DynamicResource Str.Common.Cancel}"
                        AutomationProperties.Name="Cancel"
                        AutomationProperties.HelpText="Cancel and close without saving changes"/>
                
                <Button Grid.Column="2"
                        Command="{Binding SaveCommand}"
                        Background="{DynamicResource AccentBrush}"
                        Classes="action-button"
                        Width="120"
                        Height="40"
                        FontWeight="Bold"
                        AutomationProperties.Name="Save credential"
                        AutomationProperties.HelpText="Save this credential to your vault">
                    <TextBlock Text="{Binding SaveButtonText}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
    
</views:ThemeAwareWindow>
