<?xml version="1.0" encoding="utf-8"?>
<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PhantomVault.UI.ViewModels"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
    x:Class="PhantomVault.UI.Views.SignInDialog"
    Title="Sign in" Width="560" Height="420" CanResize="False" WindowStartupLocation="CenterOwner"
    Background="{DynamicResource WindowBackgroundBrush}"
    Classes="animated-window">

    <Design.DataContext>
        <vm:SignInDialogViewModel/>
    </Design.DataContext>

    <Border Padding="18" CornerRadius="{StaticResource Radius.Lg}">
        <StackPanel Spacing="12">
            <TextBlock Text="Sign in to Phantom Vault" FontSize="{StaticResource Type.H3.Size}" FontWeight="SemiBold"/>

            <StackPanel Spacing="8">
                <TextBlock Text="Local Vault Password"/>
                <TextBox Width="320" PasswordChar="●" Text="{Binding Passphrase, Mode=TwoWay}" />
                <Button Content="Sign in with password" Width="220" HorizontalAlignment="Left" Classes="liquid-glass primary" Command="{Binding SignInCommand}" />
            </StackPanel>

            <Separator/>

            <TextBlock Text="Other sign-in options" FontWeight="SemiBold" />
            <StackPanel Orientation="Vertical" Spacing="8">
                <Button Content="Windows Hello / OS Auth (placeholder)" Width="320" Classes="liquid-glass" />
                <Button Content="Sign in with Google (placeholder)" Width="320" Classes="liquid-glass" />
                <Button Content="Sign in with Microsoft (placeholder)" Width="320" Classes="liquid-glass" />

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Manifest:" VerticalAlignment="Center"/>
                    <TextBox Width="320" IsReadOnly="True" Text="{Binding ManifestPath}" />
                    <Button Content="Browse..." Classes="liquid-glass" Click="OnPickManifestClicked" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Keyfile:" VerticalAlignment="Center"/>
                    <TextBox Width="320" IsReadOnly="True" Text="{Binding KeyfilePath}" />
                    <Button Content="Browse..." Classes="liquid-glass" Click="OnPickKeyfileClicked" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,0,12,0">
                <Button Content="Cancel" Width="100" IsCancel="True" Classes="liquid-glass" Command="{Binding CancelCommand}" />
                <Button Content="Sign in" Width="100" IsDefault="True" Classes="liquid-glass primary" Command="{Binding SignInCommand}" />
            </StackPanel>
        </StackPanel>
    </Border>
</views:ThemeAwareWindow>


