<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PhantomVault.UI.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:PhantomVault.UI.Views"
        mc:Ignorable="d" d:DesignWidth="720" d:DesignHeight="560"
    x:Class="PhantomVault.UI.Views.IconManagerWindow"
    Title="Icon Library Manager"
    Width="1280" Height="800"
    MinWidth="900" MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Classes="animated-window">

    <Window.Resources>
        <converters:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <SolidColorBrush x:Key="IconTileCellBrush">Transparent</SolidColorBrush>
    </Window.Resources>

    <DockPanel Margin="20" LastChildFill="True">
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource HeaderBackgroundBrush}"
                Padding="16"
                CornerRadius="6"
                Margin="0,0,0,16">
                <StackPanel Spacing="6">
                <TextBlock Text="Icon Library Manager"
                           FontSize="{StaticResource Type.H3.Size}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                    <Border Grid.Column="0"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            CornerRadius="4"
                            Padding="6,0">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="1"
                                     Text="{Binding SearchText, Mode=TwoWay}"
                                     Watermark="Search icons..."
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"/>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Button Command="{Binding RefreshCommand}"
                                Classes="liquid-glass"
                                Width="110" Height="34">
                            <TextBlock Text="Refresh" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <!-- Options dropdown placed as vertical three-dashes: ⋮ -->
                        <Button Name="OptionsButton" Classes="liquid-glass" Width="40" Height="34" ToolTip.Tip="Options">
                            <TextBlock Text="⋮" FontSize="{StaticResource Type.Icon.Size}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Download Icons" Command="{Binding DownloadFlatIconsCommand}"/>
                                    <MenuItem Header="Import Icons" Command="{Binding ImportIconCommand}"/>
                                    <MenuItem Header="Open Icons Folder" Command="{Binding OpenIconsFolderCommand}"/>
                                    <MenuItem Header="Toggle grid view" Command="{Binding ToggleGridViewCommand}"/>
                                    <MenuItem Header="Show Selected" Command="{Binding RevealIconCommand}" CommandParameter="{Binding SelectedIcon}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Status footer -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource ControlBackgroundBrush}"
                Padding="8"
                CornerRadius="6"
                Margin="0,8,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="{StaticResource Space.Sm}" VerticalAlignment="Center" Grid.Column="0">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="{StaticResource Type.Tiny.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"/>
                    <Border Width="1" Height="14" Background="{DynamicResource ControlBorderBrush}"/>
                    <TextBlock Text="{Binding FilteredIconCount, StringFormat='Visible icons: {0}'}"
                               FontSize="{StaticResource Type.Tiny.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Center" Spacing="{StaticResource Space.Sm}" VerticalAlignment="Center">
                    <Button Command="{Binding PrevPageCommand}" IsEnabled="{Binding IsFirstPage, Converter={StaticResource InvertBoolConverter}}" Classes="liquid-glass" Width="72" Height="30">Prev</Button>
                    <TextBlock Text="{Binding PageIndicatorText}" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" FontSize="{StaticResource Type.Small.Size}"/>
                    <Button Command="{Binding NextPageCommand}" IsEnabled="{Binding IsLastPage, Converter={StaticResource InvertBoolConverter}}" Classes="liquid-glass" Width="72" Height="30">Next</Button>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="{StaticResource Space.Sm}" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                        <TextBlock Text="Page size:" VerticalAlignment="Center" Foreground="{DynamicResource MutedTextBrush}" />
                        <ComboBox SelectedItem="{Binding PageSize, Mode=TwoWay}" Width="80" ItemsSource="{Binding PageSizeOptions}" />
                    </StackPanel>
                    <Button Command="{Binding CloseCommand}" Classes="liquid-glass" Width="100" Height="28">
                        <TextBlock Text="Close" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Thumbnail preview (top icons) -->
    <Border Margin="0,0,0,8" CornerRadius="6" Background="{DynamicResource HeaderBackgroundBrush}" Padding="8" DockPanel.Dock="Top">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="100" Padding="0,0,0,8">
                <ItemsControl Name="TopIconsList" ItemsSource="{Binding TopIcons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.ShowVariantsCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" MinWidth="72" Height="82" Classes="liquid-glass" Margin="2">
                                <Border Width="56" Height="56" CornerRadius="8" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Source="{Binding IconBitmap}" Stretch="Uniform" Width="48" Height="48"/>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Variant popup anchored below the clicked icon -->
        <Popup Name="VariantPopup" IsOpen="{Binding IsVariantPopupOpen, Mode=TwoWay}" Placement="Bottom"
               IsLightDismissEnabled="True">
            <Border Margin="0,4,0,0" Background="Transparent" Padding="0" MaxWidth="350">
                <Border Background="{DynamicResource WindowBackgroundBrush}" CornerRadius="6" Padding="6" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" Effect="{DynamicResource SubtleDropShadow}">
                    <ItemsControl Name="VariantItemsControl" ItemsSource="{Binding VariantIcons}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding #VariantItemsControl.DataContext.ApplyVariantToCategoryCommand}"
                                        CommandParameter="{Binding}" Margin="2" Padding="0"
                                        Width="36" Height="36" MinWidth="0" MinHeight="0"
                                        Cursor="Hand" Focusable="True">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Width="36" Height="36" CornerRadius="2" Background="Transparent">
                                                <ContentPresenter Content="{TemplateBinding Content}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <Image Source="{Binding IconBitmap}" Width="36" Height="36" Stretch="Uniform"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Border>
        </Popup>

        <!-- Icon grid -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0" IsVisible="{Binding IsGridView, Converter={StaticResource InvertBoolConverter}}"
                      ItemsSource="{Binding Icons}"
                      SelectedItem="{Binding SelectedIcon, Mode=TwoWay}"
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      RowHeight="48"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="48">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="40" Height="40" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center" Background="{StaticResource IconTileCellBrush}">
                                    <Image Source="{Binding IconBitmap}" Stretch="Uniform" Width="28" Height="28"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Location" Binding="{Binding RelativePath}" Width="3*"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" Width="*"/>
                    <DataGridTextColumn Header="Updated" Binding="{Binding LastModifiedDisplay}" Width="*"/>
                    <DataGridTemplateColumn Header="Actions" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button Command="{Binding DataContext.RevealIconCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Classes="liquid-glass"
                                            Width="34" Height="30"
                                            ToolTip.Tip="Show in Explorer">
                                        <TextBlock Text="📂" FontSize="{StaticResource Type.Body.Size}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Command="{Binding DataContext.DeleteIconCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Classes="liquid-glass"
                                            Width="34" Height="30"
                                            ToolTip.Tip="Delete icon">
                                        <TextBlock Text="🗑" FontSize="{StaticResource Type.Body.Size}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Grid view of icons (wrap panel). Visible when IsGridView is true -->
            <ScrollViewer Grid.Row="0" Padding="20" IsVisible="{Binding IsGridView}" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding GridIcons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                                <Button Command="{Binding DataContext.ShowVariantsCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" MinWidth="72" Height="96" Classes="liquid-glass" Margin="6">
                                <StackPanel>
                                    <Border Width="68" Height="68" CornerRadius="8" Background="{StaticResource IconTileCellBrush}" HorizontalAlignment="Center">
                                        <Image Source="{Binding IconBitmap}" Width="60" Height="60" Stretch="Uniform"/>
                                    </Border>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Pagination controls for the grid view -->
            <!-- Pagination controls are now in the combined footer below -->
            <!-- Removed limited-grid preview warning; grid shows all (deduped) icons now -->

                <Border Grid.Row="0"
                    Background="{DynamicResource OverlayBackgroundBrush}"
                    CornerRadius="6"
                    IsVisible="{Binding IsBusy}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                <Border.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                    </Transitions>
                </Border.Transitions>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="{StaticResource Space.Md}">
                    <ProgressBar IsIndeterminate="True" Width="260" Height="4" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="Loading icons..." FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource MutedTextBrush}" HorizontalAlignment="Center" Opacity="0.7"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</views:ThemeAwareWindow>






