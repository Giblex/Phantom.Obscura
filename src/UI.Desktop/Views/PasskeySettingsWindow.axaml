<?xml version="1.0" encoding="utf-8"?>
<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PhantomVault.UI.Views"
        xmlns:vm="using:PhantomVault.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="600"
        x:Class="PhantomVault.UI.Views.PasskeySettingsWindow"
        x:DataType="vm:PasskeySettingsViewModel"
        Title="Device Authenticator Settings"
        Width="520" Height="600"
        MinWidth="480" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Classes="animated-window">

    <Design.DataContext>
        <vm:PasskeySettingsViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource HeaderBackgroundBrush}" 
                Padding="24,20">
            <StackPanel Spacing="{StaticResource Space.Xs}">
                <TextBlock Text="Device Authenticator"
                           FontSize="{StaticResource Type.Icon.Size}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HeaderTextBrush}"/>
                <TextBlock Text="Configure the current local Windows Hello-backed authenticator flow for this device"
                           FontSize="{StaticResource Type.Label.Size}"
                           Foreground="{DynamicResource HeaderMutedTextBrush}"/>
            </StackPanel>
        </Border>
        
        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30,20,30,30">
            <StackPanel Spacing="0" Margin="0,0,30,60">
                
                <!-- Status Row -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,20">
                    <StackPanel Grid.Column="0" Spacing="{StaticResource Space.Xs}">
                        <TextBlock Text="Status" FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBlock Text="{Binding RegistrationStatus}" FontSize="{StaticResource Type.Body.Size}" FontWeight="Medium"/>
                    </StackPanel>
                    <Border Grid.Column="1" 
                            Background="{DynamicResource ControlBackgroundBrush}" 
                            CornerRadius="{DynamicResource Radius.Sm}" 
                            Padding="10,6"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding IsPasskeyAvailable}" FontSize="{StaticResource Type.Small.Size}"/>
                    </Border>
                </Grid>
                
                <!-- Enable Toggle -->
                <Border Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource Radius.Lg}" 
                        Padding="16" 
                        Margin="0,0,0,16">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="{StaticResource Space.Xs}">
                            <TextBlock Text="Enable Device Authenticator" FontSize="{StaticResource Type.Body.Size}" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Enable the local device-authenticator flow currently supported by this build"
                                       FontSize="{StaticResource Type.Small.Size}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" 
                                      IsChecked="{Binding IsPasskeyEnabled, Mode=TwoWay}"
                                      IsEnabled="{Binding IsPasskeyAvailable}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                
                <!-- Device Name -->
                <Border Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource Radius.Lg}" 
                        Padding="16" 
                        Margin="0,0,0,16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Device Name" FontSize="{StaticResource Type.Body.Size}" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBox Text="{Binding DeviceName, Mode=TwoWay}"
                                 Watermark="My Desktop PC"
                                 Height="40"/>
                    </StackPanel>
                </Border>
                
                <!-- Actions -->
                <Border Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource Radius.Lg}" 
                        Padding="16" 
                        Margin="0,0,0,16">
                    <StackPanel Spacing="{StaticResource Space.Md}">
                        <TextBlock Text="Registration" FontSize="{StaticResource Type.Body.Size}" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="Register the authenticator flow exposed by the current build. Today this is centered on the local Windows Hello-backed path rather than a full cross-device passkey ecosystem."
                                   FontSize="{StaticResource Type.Small.Size}"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   TextWrapping="Wrap"/>
                        
                        <Button Command="{Binding RegisterPasskeyCommand}"
                                IsEnabled="{Binding !HasRegisteredPasskey}"
                                IsVisible="{Binding IsPasskeyAvailable}"
                                HorizontalAlignment="Stretch"
                                Height="42">
                                <TextBlock Text="Register on This Device" FontSize="{StaticResource Type.Body.Size}"/>
                        </Button>
                        
                        <StackPanel Spacing="{StaticResource Space.Sm}" IsVisible="{Binding HasRegisteredPasskey}">
                            <Button Command="{Binding TestPasskeyCommand}"
                                    Classes="liquid-glass"
                                    HorizontalAlignment="Stretch"
                                    Height="42">
                                <TextBlock Text="Test Authentication" FontSize="{StaticResource Type.Body.Size}"/>
                            </Button>
                            <Button Command="{Binding RemovePasskeyCommand}"
                                    Classes="liquid-glass"
                                    HorizontalAlignment="Stretch"
                                    Height="42">
                                <TextBlock Text="Remove Stored Credential" FontSize="{StaticResource Type.Body.Size}"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Supported Authenticators -->
                <Border Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource Radius.Lg}" 
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Current Build Scope" FontSize="{StaticResource Type.Body.Size}" FontWeight="Medium" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <StackPanel Spacing="6">
                            <TextBlock Text="• Primary path: Windows Hello-backed local authenticator support" FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource MutedTextBrush}"/>
                            <TextBlock Text="• Hardware security keys and password-manager passkeys are not fully surfaced in this window yet" FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap"/>
                            <TextBlock Text="• macOS and Linux platform passkeys are not implemented in this build" FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource MutedTextBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Status Message -->
                <Border Background="{DynamicResource InfoBackgroundBrush}"
                        CornerRadius="{DynamicResource Radius.Lg}"
                        Padding="16"
                        Margin="0,16,0,0"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="{StaticResource Type.Small.Size}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Footer -->
        <Border Grid.Row="2" 
                Background="{DynamicResource CardBackgroundBrush}" 
                Padding="24,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="{StaticResource Space.Md}">
                <Button Content="Close" 
                        Classes="liquid-glass"
                        Width="100"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
        
        <!-- Loading Overlay -->
        <Border Grid.RowSpan="3"
                Background="{DynamicResource OverlayBackgroundBrush}"
                IsVisible="{Binding IsBusy}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <ProgressBar IsIndeterminate="True" Width="200" Classes="enhanced-spinner"/>
                <TextBlock Text="Processing..." Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</views:ThemeAwareWindow>







