<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhantomVault.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:PhantomVault.UI.Views"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="PhantomVault.UI.Views.MergeCredentialsWindow"
        x:DataType="vm:MergeCredentialsViewModel"
        Title="Merge Duplicate Credentials"
        Width="1200" Height="700"
        MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        Classes="animated-window">

  <views:ThemeAwareWindow.Styles>
    <Style Selector="Border.credential-card">
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="15"/>
      <Setter Property="Margin" Value="5"/>
      <Setter Property="Background" Value="{DynamicResource ContentBackgroundBrush}"/>
    </Style>

    <Style Selector="Border.credential-card.selected">
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
    </Style>

    <Style Selector="Border.credential-card.new-credential">
      <Setter Property="Background" Value="{DynamicResource SuccessBackgroundBrush}"/>
    </Style>

    <Style Selector="Border.credential-card.existing-credential">
      <Setter Property="Background" Value="{DynamicResource WarningBackgroundBrush}"/>
    </Style>

    <Style Selector="TextBlock.field-label">
      <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
      <Setter Property="FontSize" Value="{StaticResource Type.Tiny.Size}"/>
      <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <Style Selector="TextBlock.field-value">
      <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
      <Setter Property="FontSize" Value="{StaticResource Type.Label.Size}"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style Selector="Button.action-button">
      <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
      <Setter Property="Padding" Value="15,8"/>
      <Setter Property="Margin" Value="5"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
    </Style>
  </views:ThemeAwareWindow.Styles>

  <DockPanel>
    <!-- Header -->
    <Border DockPanel.Dock="Top" Background="{DynamicResource HeaderBackgroundBrush}" Padding="20" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="0,0,0,1">
      <StackPanel>
        <TextBlock Text="Merge Duplicate Credentials" FontSize="{StaticResource Type.Icon.Size}" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
        <TextBlock Margin="0,5,0,0" FontSize="{StaticResource Type.Label.Size}" Foreground="{DynamicResource SecondaryTextBrush}">
          <Run Text="Found"/>
          <Run Text="{Binding TotalDuplicates}" FontWeight="Bold"/>
          <Run Text="duplicate(s). Select which version to keep for each conflict."/>
        </TextBlock>
        <TextBlock Margin="0,5,0,0" FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource MutedTextBrush}" FontStyle="Italic">
          💡 Tip: The most recently created credential is selected by default.
        </TextBlock>
      </StackPanel>
    </Border>

    <!-- Action Bar -->
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource HeaderBackgroundBrush}" Padding="15" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="0,1,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Horizontal">
          <TextBlock VerticalAlignment="Center" Margin="5,0" Foreground="{DynamicResource SecondaryTextBrush}">
            <Run Text="Selected:"/>
            <Run Text="{Binding SelectedCount}" FontWeight="Bold"/>
            <Run Text="/"/>
            <Run Text="{Binding TotalDuplicates}"/>
          </TextBlock>
          
          <Button Content="Select All New" Command="{Binding SelectAllNewCommand}" 
                  Margin="10,0,0,0" Padding="12,6" Background="{DynamicResource ControlBackgroundBrush}"/>
          <Button Content="Select All Existing" Command="{Binding SelectAllExistingCommand}" 
                  Margin="5,0,0,0" Padding="12,6" Background="{DynamicResource ControlBackgroundBrush}"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button Content="Cancel" Command="{Binding CancelCommand}" 
                  Padding="20,8" Margin="5" Background="{DynamicResource AccentBrush}"/>
          <Button Content="Merge Selected" Command="{Binding MergeCommand}" 
                  Classes="action-button" Padding="20,8" Margin="5"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Duplicate List -->
    <ScrollViewer Padding="20" Background="{DynamicResource WindowBackgroundBrush}">
      <ItemsControl ItemsSource="{Binding MergeItems}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{DynamicResource HeaderBackgroundBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" 
                    CornerRadius="8" Padding="20" Margin="0,0,0,15">
              <StackPanel>
                <!-- Duplicate Header -->
                <Grid Margin="0,0,0,15">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>

                  <StackPanel Grid.Column="0">
                    <TextBlock FontSize="{StaticResource Type.H4.Size}" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}">
                      <Run Text="Duplicate #"/>
                      <Run Text="{Binding Index}"/>
                    </TextBlock>
                    <TextBlock FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource MutedTextBrush}" Margin="0,3,0,0">
                      <Run Text="Match Type:"/>
                      <Run Text="{Binding MatchTypeText}" FontWeight="SemiBold"/>
                    </TextBlock>
                  </StackPanel>

                  <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔄" FontSize="{StaticResource Type.H3.Size}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <Button Content="Keep Both" Command="{Binding KeepBothCommand}" 
                            Padding="10,5" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}"/>
                  </StackPanel>
                </Grid>

                <!-- Side-by-Side Comparison -->
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>

                  <!-- New Credential -->
                  <Border Grid.Column="0" Classes="credential-card new-credential"
                          Classes.selected="{Binding KeepNew}"
                          PointerPressed="OnCredentialCardPressed"
                          Tag="new">
                    <StackPanel>
                      <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" IsChecked="{Binding KeepNew}" 
                                  Margin="0,0,10,0" VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="📥 NEW CREDENTIAL" FontWeight="Bold" FontSize="{StaticResource Type.Small.Size}" 
                                     Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,5"/>
                          <TextBlock Text="{Binding NewCredential.CreatedUtc, StringFormat='Created: {0:MMM dd, yyyy HH:mm}'}" 
                                     FontSize="{StaticResource Type.Tiny.Size}" Foreground="{DynamicResource MutedTextBrush}"/>
                        </StackPanel>
                      </Grid>

                      <Separator Background="{DynamicResource ControlBackgroundBrush}" Margin="0,0,0,10"/>

                      <TextBlock Classes="field-label" Text="TITLE"/>
                      <TextBlock Classes="field-value" Text="{Binding NewCredential.Title, TargetNullValue='(empty)'}"/>

                      <TextBlock Classes="field-label" Text="USERNAME"/>
                      <TextBlock Classes="field-value" Text="{Binding NewCredential.Username, TargetNullValue='(empty)'}"/>

                      <TextBlock Classes="field-label" Text="PASSWORD"/>
                      <TextBlock Classes="field-value" Text="{Binding NewPasswordPreview}" FontFamily="{StaticResource MonoFontFamily}"/>

                      <TextBlock Classes="field-label" Text="URL"/>
                      <TextBlock Classes="field-value" Text="{Binding NewCredential.Url, TargetNullValue='(empty)'}"/>

                      <TextBlock Classes="field-label" Text="GROUP"/>
                      <TextBlock Classes="field-value" Text="{Binding NewCredential.Group, TargetNullValue='(empty)'}"/>

                      <TextBlock Classes="field-label" Text="NOTES" IsVisible="{Binding HasNewNotes}"/>
                      <TextBlock Classes="field-value" Text="{Binding NewCredential.Notes}" 
                                 MaxLines="3" TextTrimming="CharacterEllipsis" IsVisible="{Binding HasNewNotes}"/>

                      <TextBlock Classes="field-label" Text="TAGS" IsVisible="{Binding HasNewTags}"/>
                      <TextBlock Classes="field-value" Text="{Binding NewTagsText}" IsVisible="{Binding HasNewTags}"/>
                    </StackPanel>
                  </Border>

                  <!-- VS Indicator -->
                  <TextBlock Grid.Column="1" Text="VS" FontSize="{StaticResource Type.H4.Size}" FontWeight="Bold" 
                             HorizontalAlignment="Center" VerticalAlignment="Center" 
                             Foreground="{DynamicResource MutedTextBrush}"/>

                  <!-- Existing Credential -->
                  <Border Grid.Column="2" Classes="credential-card existing-credential"
                          Classes.selected="{Binding KeepExisting}"
                          PointerPressed="OnCredentialCardPressed"
                          Tag="existing">
                    <StackPanel>
                      <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" IsChecked="{Binding KeepExisting}" 
                                  Margin="0,0,10,0" VerticalAlignment="Center"/>
                        
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="💾 EXISTING CREDENTIAL" FontWeight="Bold" FontSize="{StaticResource Type.Small.Size}" 
                                     Foreground="{DynamicResource WarningBrush}" Margin="0,0,0,5"/>
                          <TextBlock Text="{Binding ExistingCredential.CreatedUtc, StringFormat='Created: {0:MMM dd, yyyy HH:mm}'}" 
                                     FontSize="{StaticResource Type.Tiny.Size}" Foreground="{DynamicResource MutedTextBrush}"/>
                        </StackPanel>
                      </Grid>

                      <Separator Background="{DynamicResource ControlBackgroundBrush}" Margin="0,0,0,10"/>

                      <TextBlock Classes="field-label" Text="TITLE"/>
                      <TextBlock Classes="field-value" Text="{Binding ExistingCredential.Title, TargetNullValue='(empty)'}"/>

                      <TextBlock Classes="field-label" Text="USERNAME"/>
                      <TextBlock Classes="field-value" Text="{Binding ExistingCredential.Username, TargetNullValue='(empty)'}"/>

                      <TextBlock Classes="field-label" Text="PASSWORD"/>
                      <TextBlock Classes="field-value" Text="{Binding ExistingPasswordPreview}" FontFamily="{StaticResource MonoFontFamily}"/>

                      <TextBlock Classes="field-label" Text="URL"/>
                      <TextBlock Classes="field-value" Text="{Binding ExistingCredential.Url, TargetNullValue='(empty)'}"/>

                      <TextBlock Classes="field-label" Text="GROUP"/>
                      <TextBlock Classes="field-value" Text="{Binding ExistingCredential.Group, TargetNullValue='(empty)'}"/>

                      <TextBlock Classes="field-label" Text="NOTES" IsVisible="{Binding HasExistingNotes}"/>
                      <TextBlock Classes="field-value" Text="{Binding ExistingCredential.Notes}" 
                                 MaxLines="3" TextTrimming="CharacterEllipsis" IsVisible="{Binding HasExistingNotes}"/>

                      <TextBlock Classes="field-label" Text="TAGS" IsVisible="{Binding HasExistingTags}"/>
                      <TextBlock Classes="field-value" Text="{Binding ExistingTagsText}" IsVisible="{Binding HasExistingTags}"/>
                    </StackPanel>
                  </Border>
                </Grid>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</views:ThemeAwareWindow>


