<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhantomVault.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="640"
        x:Class="PhantomVault.UI.Views.PasswordGeneratorWindow"
        x:DataType="vm:PasswordGeneratorViewModel"
        Title="Password Generator"
        Width="720" Height="640"
        MinWidth="560" MinHeight="560"
        MaxWidth="900" MaxHeight="900"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource WindowBackgroundBrush}"
        Classes="animated-window">

    <Design.DataContext>
        <vm:PasswordGeneratorViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="0">
        <InputElement.KeyBindings>
            <KeyBinding Gesture="Escape" Command="{Binding CloseCommand}"/>
        </InputElement.KeyBindings>
        
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource HeaderBackgroundBrush}" 
                Padding="20,15">
            <StackPanel Spacing="5">
                <TextBlock Text="⚡ Password Generator"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="Generate strong, secure passwords"
                           FontSize="13"
                           Foreground="{DynamicResource MutedTextBrush}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel Spacing="{StaticResource Space.Xl}">
                
                <!-- Generated Password Display -->
                <Border Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="15">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Generated Password"
                                   FontSize="{StaticResource Type.Small.Size}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                        
                        <Border Background="{DynamicResource WindowBackgroundBrush}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12">
                            <TextBox Text="{Binding GeneratedPassword}"
                                     IsReadOnly="True"
                                     FontFamily="Consolas,Courier New,monospace"
                                     FontSize="16"
                                     FontWeight="SemiBold"
                                     Foreground="{DynamicResource AccentBrush}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     TextWrapping="Wrap"/>
                        </Border>
                        
                        <!-- Password Strength Meter -->
                        <Border Background="{DynamicResource WindowBackgroundBrush}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10">
                            <Grid ColumnDefinitions="Auto,10,*,10,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Strength:"
                                           FontSize="{StaticResource Type.Small.Size}"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <ProgressBar Grid.Column="2"
                                             Value="{Binding PasswordStrength}"
                                             Maximum="100"
                                             Height="8"
                                             CornerRadius="4"
                                             Foreground="{Binding PasswordStrengthColor}"
                                             VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4"
                                           Text="{Binding PasswordStrengthText}"
                                           FontSize="{StaticResource Type.Small.Size}"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding PasswordStrengthColor}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Password Options -->
                <Border Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="15">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Password Options"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        
                        <!-- Length Slider -->
                        <StackPanel Spacing="{StaticResource Space.Sm}">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="Password Length"
                                           FontSize="{StaticResource Type.Small.Size}"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource AccentBrush}"
                                        CornerRadius="4"
                                        Padding="8,4"
                                        MinWidth="40">
                                    <TextBlock Text="{Binding PasswordLength}"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <Slider Value="{Binding PasswordLength}"
                                    Minimum="8"
                                    Maximum="64"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"/>
                        </StackPanel>

                        <!-- Character Type Options -->
                        <StackPanel Spacing="10">
                            <CheckBox IsChecked="{Binding IncludeUppercase}"
                                      Content="Include Uppercase Letters (A-Z)"
                                      FontSize="{StaticResource Type.Small.Size}"
                                      Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <CheckBox IsChecked="{Binding IncludeLowercase}"
                                      Content="Include Lowercase Letters (a-z)"
                                      FontSize="{StaticResource Type.Small.Size}"
                                      Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <CheckBox IsChecked="{Binding IncludeNumbers}"
                                      Content="Include Numbers (0-9)"
                                      FontSize="{StaticResource Type.Small.Size}"
                                      Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <CheckBox IsChecked="{Binding IncludeSymbols}"
                                      Content="Include Symbols (!@#$%^&amp;*)"
                                      FontSize="{StaticResource Type.Small.Size}"
                                      Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>

                        <!-- Advanced Options -->
                        <Expander Header="Advanced Options" IsExpanded="False">
                            <Border Background="{DynamicResource WindowBackgroundBrush}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10"
                                    Classes="fade-toggle">
                                <StackPanel Spacing="{StaticResource Space.Sm}">
                                    <CheckBox IsChecked="{Binding AvoidAmbiguous}"
                                              Content="Avoid Ambiguous Characters (0, O, l, 1, etc.)"
                                              FontSize="11"
                                              Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <CheckBox IsChecked="{Binding EasyToRead}"
                                              Content="Easy to Read (No similar looking chars)"
                                              FontSize="11"
                                              Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </StackPanel>
                            </Border>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- Quick Presets -->
                <Border Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="15">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Quick Presets"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <Grid ColumnDefinitions="*,8,*,8,*">
                            <Button Grid.Column="0"
                                    Command="{Binding ApplyWeakPresetCommand}"
                                    Content="Weak (8)"
                                    Classes="liquid-glass"
                                    HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="2"
                                    Command="{Binding ApplyStrongPresetCommand}"
                                    Content="Strong (16)"
                                    Classes="liquid-glass"
                                    HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="4"
                                    Command="{Binding ApplyMaxPresetCommand}"
                                    Content="Max (64)"
                                    Classes="liquid-glass"
                                    HorizontalAlignment="Stretch"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" 
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,15">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           FontSize="{StaticResource Type.Small.Size}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Command="{Binding GenerateCommand}"
                        Content="_Generate"
                        Classes="accent"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource AccentButtonForeground}"
                        Width="150"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="2"
                        Command="{Binding CopyToClipboardCommand}"
                        Content="_Copy"
                        Classes="liquid-glass"
                        Background="{DynamicResource SecondaryButtonBackgroundBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        Width="110"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="3"
                        Command="{Binding AddCommand}"
                        Content="_Add"
                        Classes="accent"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="{DynamicResource AccentButtonForeground}"
                        Width="100"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="4"
                        Command="{Binding CloseCommand}"
                        Content="_Close"
                        Classes="liquid-glass"
                        Background="{DynamicResource SecondaryButtonBackgroundBrush}"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        Width="90"/>
            </Grid>
        </Border>

    </Grid>
</views:ThemeAwareWindow>





