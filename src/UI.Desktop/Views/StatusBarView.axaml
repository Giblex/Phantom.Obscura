<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="42"
             x:Class="PhantomVault.UI.Views.StatusBarView">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PhantomVault.UI/Resources/Converters/ConverterResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Border Classes="footer-surface"
            Background="{DynamicResource FooterBackgroundBrush}" 
            Padding="20,10"
            BorderBrush="{DynamicResource ControlBorderBrush}"
            BorderThickness="0,1,0,0">
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" 
                       FontSize="{StaticResource Type.Small.Size}" 
                       Classes="footer-muted"
                       VerticalAlignment="Center">
                <TextBlock.Effect>
                    <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                </TextBlock.Effect>
                <TextBlock.Text>
                    <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Status">
                        <Binding Path="StatusMessage"/>
                        <Binding Path="PrivacyModeEnabled"/>
                    </MultiBinding>
                </TextBlock.Text>
            </TextBlock>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
                <TextBlock Text="{Binding LastSyncTime, StringFormat='Last sync: {0}'}" 
                           FontSize="11" 
                           Classes="footer-muted"
                           VerticalAlignment="Center"/>
                <Border Width="1" Height="16" Background="{DynamicResource ControlBorderBrush}"/>
                <TextBlock Text="🔒 Encrypted" 
                           FontSize="11" 
                           Foreground="{DynamicResource SuccessBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
    
</UserControl>



