<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PhantomVault.UI.Views.Controls.PinEntryControl"
             x:Name="PinRoot">

    <StackPanel Spacing="24" HorizontalAlignment="Center" MinWidth="320">

        <!-- PIN dot indicators -->
        <ItemsControl x:Name="DotDisplay" HorizontalAlignment="Center">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="14"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!-- Hidden input that captures keyboard entry -->
        <TextBox x:Name="HiddenInput"
                 PasswordChar="●"
                 MaxLength="12"
                 Opacity="0"
                 Height="0"
                 Width="0"
                 IsHitTestVisible="False"
                 Focusable="True"/>

        <!-- Numeric key pad  (phone-style: 1-9, then 0) -->
        <Grid ColumnDefinitions="*,*,*"
              RowDefinitions="Auto,Auto,Auto,Auto"
              HorizontalAlignment="Center"
              Width="280">

            <Grid.Styles>
                <Style Selector="Button.pin-key">
                    <Setter Property="Width"      Value="80"/>
                    <Setter Property="Height"     Value="56"/>
                    <Setter Property="FontSize"   Value="22"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="VerticalContentAlignment"   Value="Center"/>
                    <Setter Property="CornerRadius" Value="12"/>
                    <Setter Property="Margin"     Value="4"/>
                    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Style>
                <Style Selector="Button.pin-key:pointerover">
                    <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}"/>
                </Style>
                <Style Selector="Button.pin-key:pressed">
                    <Setter Property="Background" Value="{DynamicResource SurfaceActiveBrush}"/>
                </Style>
            </Grid.Styles>

            <!-- Row 0 -->
            <Button Grid.Row="0" Grid.Column="0" Content="1" Classes="pin-key" Click="OnDigitClick"/>
            <Button Grid.Row="0" Grid.Column="1" Content="2" Classes="pin-key" Click="OnDigitClick"/>
            <Button Grid.Row="0" Grid.Column="2" Content="3" Classes="pin-key" Click="OnDigitClick"/>

            <!-- Row 1 -->
            <Button Grid.Row="1" Grid.Column="0" Content="4" Classes="pin-key" Click="OnDigitClick"/>
            <Button Grid.Row="1" Grid.Column="1" Content="5" Classes="pin-key" Click="OnDigitClick"/>
            <Button Grid.Row="1" Grid.Column="2" Content="6" Classes="pin-key" Click="OnDigitClick"/>

            <!-- Row 2 -->
            <Button Grid.Row="2" Grid.Column="0" Content="7" Classes="pin-key" Click="OnDigitClick"/>
            <Button Grid.Row="2" Grid.Column="1" Content="8" Classes="pin-key" Click="OnDigitClick"/>
            <Button Grid.Row="2" Grid.Column="2" Content="9" Classes="pin-key" Click="OnDigitClick"/>

            <!-- Row 3: Clear / 0 / Backspace -->
            <Button Grid.Row="3" Grid.Column="0" Content="Clear" Classes="pin-key"
                    FontSize="14" Click="OnClearClick"/>
            <Button Grid.Row="3" Grid.Column="1" Content="0" Classes="pin-key" Click="OnDigitClick"/>
            <Button Grid.Row="3" Grid.Column="2" Content="⌫" Classes="pin-key" Click="OnBackspaceClick"/>
        </Grid>

        <!-- Unlock button -->
        <Button x:Name="UnlockButton"
                Content="Unlock"
                Classes="liquid-glass"
                HorizontalAlignment="Center"
                Width="200"
                Height="44"
                FontSize="16"
                FontWeight="SemiBold"
                IsEnabled="False"/>
    </StackPanel>
</UserControl>
