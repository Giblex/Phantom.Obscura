<?xml version="1.0" encoding="utf-8"?>
<views:ThemeAwareWindow
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="https://github.com/avaloniaui/design"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
    mc:Ignorable="d"
    x:Class="PhantomVault.UI.Views.EditPasswordWindow"
    Title="Edit Password"
    Width="700"
    Height="900"
    MinWidth="600"
    MinHeight="700"
    WindowStartupLocation="CenterScreen"
    Background="{DynamicResource WindowBackgroundBrush}"
    Classes="animated-window">
    
    <Grid RowDefinitions="Auto,*,Auto" Margin="0" Background="{DynamicResource WindowBackgroundBrush}">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" Padding="24,16" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Edit Password" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="{Binding CredentialTitle}" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="✕" FontSize="16" Padding="12,8" Background="Transparent" Foreground="{DynamicResource SecondaryTextBrush}" Command="{Binding CancelCommand}"/>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16" Spacing="24">
                
                <!-- Credential Info -->
                <Border CornerRadius="6" Padding="16" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Credential Information" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        
                        <StackPanel Spacing="4">
                            <TextBlock Text="Title" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding CredentialTitle}" Padding="12,8" CornerRadius="4" Background="{DynamicResource TextBoxBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Username" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding CredentialUsername}" Padding="12,8" CornerRadius="4" Background="{DynamicResource TextBoxBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Current Password -->
                <Border CornerRadius="6" Padding="16" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Current Password" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBox Text="{Binding CurrentPassword}" Padding="12,8" CornerRadius="4" Background="{DynamicResource TextBoxBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>

                        <!-- Strength Indicator -->
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Strength:" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <Border CornerRadius="3" Padding="8,4" Background="{Binding TestPasswordStrengthColor}">
                                    <TextBlock Text="{Binding TestPasswordStrengthLabel}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Text="{Binding TestPasswordScore}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="/100" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Suggested Password -->
                <Border CornerRadius="6" Padding="16" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" IsVisible="{Binding HasSuggestedPassword}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="✨ Suggested Stronger Password" FontSize="14" FontWeight="SemiBold" Foreground="#10B981"/>
                        
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Suggested" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <Border CornerRadius="4" Padding="12,8" Background="{DynamicResource DividerBrush}">
                                    <TextBlock Text="{Binding SuggestedPassword}" Foreground="{DynamicResource PrimaryTextBrush}" TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Copy" Command="{Binding CopySuggestedPasswordCommand}" Padding="12,8" CornerRadius="4" VerticalAlignment="Top" Margin="12,0,0,0" Classes="liquid-glass"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Similarity:" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="{Binding SimilarityPercentage}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Text="%" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Password Generator -->
                <Border CornerRadius="6" Padding="16" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Generate New Password" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <Button Content="🔑 Generate Secure Password" Command="{Binding GeneratePasswordCommand}" Padding="16,12" CornerRadius="6" Classes="liquid-glass" FontSize="12"/>
                        <TextBlock Text="Click to replace current password with a randomly generated secure one" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <!-- TOTP Setup -->
                <Border CornerRadius="6" Padding="16" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="Two-Factor Authentication (TOTP)" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <ToggleButton IsChecked="{Binding HasTotpSecret}" Padding="12,4" CornerRadius="4" Classes="liquid-glass"/>
                        </StackPanel>

                        <StackPanel Spacing="4" IsVisible="{Binding HasTotpSecret}">
                            <TextBlock Text="TOTP Secret" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Text="{Binding TotpSecret}" Padding="12,8" CornerRadius="4" Background="{DynamicResource TextBoxBackgroundBrush}" Foreground="{DynamicResource PrimaryTextBrush}" Watermark="Paste TOTP secret or scan QR code"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Passkey -->
                <Border CornerRadius="6" Padding="16" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="Passkey" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <ToggleButton IsChecked="{Binding HasPasskey}" Padding="12,4" CornerRadius="4" Classes="liquid-glass"/>
                        </StackPanel>
                        <TextBlock Text="Enable passkey authentication for this credential" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" IsVisible="{Binding !HasPasskey}"/>
                        <TextBlock Text="Passkey is enabled" FontSize="11" Foreground="#10B981" IsVisible="{Binding HasPasskey}"/>
                    </StackPanel>
                </Border>

                <!-- Phantom Key -->
                <Border CornerRadius="6" Padding="16" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="Phantom Key" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <ToggleButton IsChecked="{Binding HasPhantomKey}" Padding="12,4" CornerRadius="4" Classes="liquid-glass"/>
                        </StackPanel>
                        <TextBlock Text="Enable Phantom Key biometric authentication for this credential" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" IsVisible="{Binding !HasPhantomKey}"/>
                        <TextBlock Text="Phantom Key is enabled" FontSize="11" Foreground="#10B981" IsVisible="{Binding HasPhantomKey}"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource HeaderBackgroundBrush}" Padding="24,12" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <Button Grid.Column="1" Content="Delete (⚠️)" Command="{Binding DeleteCommand}" Padding="16,10" CornerRadius="4" Background="#EF4444" Foreground="White" Margin="0,0,12,0"/>
                <Button Grid.Column="2" Content="Cancel" Command="{Binding CancelCommand}" Padding="16,10" CornerRadius="4" Classes="liquid-glass" Margin="0,0,12,0"/>
                <Button Grid.Column="3" Content="✓ Save" Command="{Binding SaveCommand}" Padding="16,10" CornerRadius="4" Background="#10B981" Foreground="White"/>
            </Grid>
        </Border>
    </Grid>
</views:ThemeAwareWindow>
