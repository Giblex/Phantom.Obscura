<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Giblex.Controls"
             xmlns:dcontrols="clr-namespace:PhantomVault.UI.Desktop.Controls"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="70"
             x:Class="PhantomVault.UI.Views.HeaderView">
    
    <Border Classes="header-surface"
            Background="{DynamicResource HeaderBackgroundBrush}" 
            Padding="{StaticResource DialogPadding}"
            BorderBrush="{DynamicResource HeaderBorderBrush}"
            BorderThickness="0,0,0,1"
            CornerRadius="0,0,12,12"
            ClipToBounds="True"
            Effect="{x:Null}">
        <Grid ColumnDefinitions="Auto,*,Auto">
            
            <!-- Left: Logo and Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="{StaticResource Space12}" VerticalAlignment="Center">
                <Image Source="avares://PhantomVault.UI/Assets/Visuals/Giblex Icons/Icon Transparent background.png" Width="48" Height="48" VerticalAlignment="Center"/>
                <StackPanel Spacing="2">
                    <TextBlock Text="PhantomObscura" 
                               FontSize="{StaticResource Type.H4.Size}" 
                               FontWeight="Bold"
                               Foreground="{DynamicResource LogoTitleBrush}"/>
                    <TextBlock Text="{Binding VaultName}" 
                               FontSize="{StaticResource Type.Tiny.Size}" 
                               Classes="header-muted"/>
                </StackPanel>
            </StackPanel>
            
            <!-- Center: Search Box and View Toggle -->
            <Grid Grid.Column="1" ColumnDefinitions="*,Auto" Margin="30,0" VerticalAlignment="Center">
                <Border Grid.Column="0"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="20"
                        MinWidth="320"
                        MaxWidth="700"
                        Margin="0,0,1,0">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Path Grid.Column="0"
                              Data="{StaticResource Icon.Search}"
                              Width="20"
                              Height="20"
                              Margin="12,0,0,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Stretch="Uniform"
                              Stroke="{DynamicResource MutedTextBrush}"
                              StrokeThickness="1.5"
                              Fill="Transparent"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText}"
                                 Watermark="Search credentials..."
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Padding="8,8"
                                 FontSize="{StaticResource Type.Label.Size}">
                            <InputElement.KeyBindings>
                                <KeyBinding Gesture="Escape" Command="{Binding ClearSearchCommand}"/>
                            </InputElement.KeyBindings>
                        </TextBox>
                        <Button Grid.Column="2"
                                Command="{Binding ClearSearchCommand}"
                                Classes="liquid-glass"
                                Width="30"
                                Height="30"
                                MinWidth="30"
                                MinHeight="30"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Margin="0,0,4,0"
                                ToolTip.Tip="Clear search"
                                IsVisible="{Binding HasSearchText}">
                            <Path Data="{StaticResource Icon.X}"
                                  Width="14"
                                  Height="14"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Stretch="Uniform"
                                  Stroke="{DynamicResource HeaderSvgIconColor}"
                                  StrokeThickness="1.5"
                                  Fill="Transparent"/>
                        </Button>
                    </Grid>
                </Border>

                <controls:LiquidGlassButton Grid.Column="1"
                        Command="{Binding ToggleViewModeCommand}"
                        WidthOverride="44"
                        HeightOverride="44"
                        CornerRadiusValue="12"
                        PaddingOverride="8,12,8,8"
                        ToolTipText="Toggle list/grid view"
                        IsVisible="{Binding !IsShowingSecureTrash}">
                    <controls:LiquidGlassButton.ButtonContent>
                        <!-- Issue #9: Canvas children don't honour Stretch and pin to
                             top-left, so the view-toggle icons rendered off-centre
                             in the 22×22 button content. Use Viewbox to scale the
                             paths uniformly inside a centred host grid. -->
                        <Grid Width="22" Height="22">
                            <Viewbox Width="22" Height="22"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding !IsGridView}">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M3,3 L10,3 L10,10 L3,10 Z M14,3 L21,3 L21,10 L14,10 Z M14,14 L21,14 L21,21 L14,21 Z M3,14 L10,14 L10,21 L3,21 Z"
                                          Stroke="{DynamicResource HeaderSvgIconColor}"
                                          StrokeThickness="1.5"
                                          Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                            <Viewbox Width="22" Height="22"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     IsVisible="{Binding IsGridView}">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M4 6h16M4 12h16M4 18h16"
                                          Stroke="{DynamicResource HeaderSvgIconColor}"
                                          StrokeThickness="1.7"
                                          StrokeLineCap="Round"
                                          Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </controls:LiquidGlassButton.ButtonContent>
                </controls:LiquidGlassButton>
            </Grid>
            
            <!-- Right: Action Buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <!-- Actions Menu Button -->
                <Button x:Name="ActionsMenuButton"
                        Classes="liquid-glass icon"
                        Width="44"
                        Height="44"
                        MinWidth="44"
                        MinHeight="44"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        CornerRadius="{StaticResource Radius.Lg}"
                        ToolTip.Tip="Actions menu">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <Border Background="{DynamicResource ContentBackgroundBrush}" 
                                    CornerRadius="{StaticResource Radius.Lg}" 
                                    Padding="8" 
                                    MinWidth="240">
                                <StackPanel Spacing="4">
                                    <!-- Add Credential Section -->
                                    <TextBlock Text="Add Credential" 
                                               FontSize="{StaticResource Type.Body.Size}" 
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Margin="12,8,12,12"/>
                                    <Button Command="{Binding AddLoginCredentialCommand}"
                                            Classes="liquid-glass"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,8">
                                        <TextBlock Text="→ Login / Password" FontSize="{StaticResource Type.Small.Size}"/>
                                    </Button>
                                    <Button Command="{Binding AddCreditCardCommand}"
                                            Classes="liquid-glass"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,8">
                                        <TextBlock Text="→ Credit Card" FontSize="{StaticResource Type.Small.Size}"/>
                                    </Button>
                                    <Button Command="{Binding AddBankAccountCommand}"
                                            Classes="liquid-glass"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,8">
                                        <TextBlock Text="→ Bank Account" FontSize="{StaticResource Type.Small.Size}"/>
                                    </Button>
                                    <Button Command="{Binding AddIdentityCommand}"
                                            Classes="liquid-glass"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,8">
                                        <TextBlock Text="→ Identity / Document" FontSize="{StaticResource Type.Small.Size}"/>
                                    </Button>
                                    <Button Command="{Binding AddSecureNoteCommand}"
                                            Classes="liquid-glass"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,8">
                                        <TextBlock Text="→ Secure Note" FontSize="{StaticResource Type.Small.Size}"/>
                                    </Button>
                                    <Button Command="{Binding AddWiFiPasswordCommand}"
                                            Classes="liquid-glass"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,8">
                                        <TextBlock Text="→ WiFi Network" FontSize="{StaticResource Type.Small.Size}"/>
                                    </Button>
                                    <Button Command="{Binding AddApiKeyCommand}"
                                            Classes="liquid-glass"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,8">
                                        <TextBlock Text="→ API Key" FontSize="{StaticResource Type.Small.Size}"/>
                                    </Button>
                                    <Button Command="{Binding AddContactCommand}"
                                            Classes="liquid-glass"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,8">
                                        <TextBlock Text="→ Contact / Personal Info" FontSize="{StaticResource Type.Small.Size}"/>
                                    </Button>
                                    <Button Command="{Binding AddPinCodeCommand}"
                                            Classes="liquid-glass"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,8">
                                        <TextBlock Text="→ PIN Code" FontSize="{StaticResource Type.Small.Size}"/>
                                    </Button>
                                    
                                    <Separator Margin="0,8" Background="{DynamicResource ControlBorderBrush}"/>
                                    
                                    <!-- Actions Section -->
                                    <TextBlock Text="ACTIONS" 
                                               FontSize="{StaticResource Type.Tiny.Size}" 
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               Margin="8,4,8,4"/>
                                    <Button x:Name="PasswordGeneratorButton"
                                            Classes="liquid-glass"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,10">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <Path Data="{StaticResource Icon.Key}"
                                                  Width="22"
                                                  Height="22"
                                                  Stretch="Uniform"
                                                  Stroke="{DynamicResource PrimaryTextBrush}"
                                                  StrokeThickness="1.5"
                                                  Fill="Transparent"/>
                                            <TextBlock Text="Password Generator" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding ToggleSecurityDashboardCommand}"
                                            Classes="liquid-glass"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,10">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <Path Data="{StaticResource Icon.Shield}"
                                                  Width="22"
                                                  Height="22"
                                                  Stretch="Uniform"
                                                  Stroke="{DynamicResource PrimaryTextBrush}"
                                                  StrokeThickness="1.5"
                                                  Fill="Transparent"/>
                                            <TextBlock Text="Security Dashboard" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding LockCommand}"
                                            Classes="liquid-glass"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Left"
                                            Padding="12,10">
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <Path Data="{StaticResource Icon.Lock}"
                                                  Width="22"
                                                  Height="22"
                                                  Stretch="Uniform"
                                                  Stroke="{DynamicResource PrimaryTextBrush}"
                                                  StrokeThickness="1.5"
                                                  Fill="Transparent"/>
                                            <TextBlock Text="Lock Vault" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                    <Path Data="{StaticResource Icon.Menu}"
                          Width="22"
                          Height="22"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Stretch="Uniform"
                          Stroke="{DynamicResource HeaderSvgIconColor}"
                          StrokeThickness="1.7"
                          StrokeLineCap="Round"
                          Fill="Transparent"/>
                </Button>

                <!-- Settings Button (Separate) -->
                <Button x:Name="SettingsButton"
                        Classes="liquid-glass icon"
                        Width="44"
                        Height="44"
                        MinWidth="44"
                        MinHeight="44"
                        Padding="0"
                        CornerRadius="{StaticResource Radius.Lg}"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        ToolTip.Tip="Vault settings">
                    <Path Data="{StaticResource Icon.Settings}"
                          Width="22"
                          Height="22"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Stretch="Uniform"
                          Stroke="{DynamicResource HeaderSvgIconColor}"
                          StrokeThickness="1.5"
                          Fill="Transparent"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
    
</UserControl>
