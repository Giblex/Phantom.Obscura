<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:nav="clr-namespace:PhantomVault.UI.Components.Navigation"
             xmlns:controls="clr-namespace:PhantomVault.UI.Desktop.Controls"
             mc:Ignorable="d" d:DesignWidth="220" d:DesignHeight="800"
             x:Class="PhantomVault.UI.Views.SidebarView">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PhantomVault.UI/Resources/Converters/ConverterResources.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Navigation buttons (Dashboard, Passwords) with data-driven active state -->
        <!-- Dashboard / Passwords nav buttons. Height + CornerRadius now
             match the QuickFilter (36 / 12) so the entire sidebar reads as a
             single stack of consistent pill affordances. -->
        <Style Selector="Button.nav-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <!-- nav-button: flat rectangular highlight that spans the full
                 sidebar width (Margin/CornerRadius zeroed) so the active
                 indicator reaches both edges of the sidebar surface. -->
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.18"/>
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Panel>
                            <Border x:Name="NavBase"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"/>
                            <Border x:Name="NavGlass"
                                    Opacity="0"
                                    BorderBrush="#70CFE8FF"
                                    BorderThickness="1"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.20"/>
                                    </Transitions>
                                </Border.Transitions>
                                <!-- Darker, more saturated blue for the active state; the
                                     previous mix was too light and barely visible on the
                                     sidebar surface. -->
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                        <GradientStop Color="#5500B4FF" Offset="0"/>
                                        <GradientStop Color="#4A1E7BFF" Offset="0.55"/>
                                        <GradientStop Color="#3C0066CC" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <!-- Inner accent border: thin inset stroke that reads as an
                                 outline on the active highlight, giving the rectangular
                                 fill a defined edge against the sidebar background. -->
                            <Border x:Name="NavInnerBorder"
                                    Opacity="0"
                                    Margin="1"
                                    BorderBrush="#80E5F8FF"
                                    BorderThickness="1"
                                    CornerRadius="0"
                                    IsHitTestVisible="False">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.20"/>
                                    </Transitions>
                                </Border.Transitions>
                            </Border>
                            <Border x:Name="NavSheen"
                                    Opacity="0"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    IsHitTestVisible="False">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.20"/>
                                    </Transitions>
                                </Border.Transitions>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                        <GradientStop Color="#00CFE8FF" Offset="0"/>
                                        <GradientStop Color="#36CFE8FF" Offset="0.5"/>
                                        <GradientStop Color="#00CFE8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Panel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="Button.nav-button:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#30CFE8FF" />
        </Style>
        <Style Selector="Button.nav-button:pointerover /template/ Border#NavGlass">
            <Setter Property="Opacity" Value="0.18"/>
        </Style>
        <Style Selector="Button.nav-button:pointerover /template/ Border#NavSheen">
            <Setter Property="Opacity" Value="0.16"/>
        </Style>
        <Style Selector="Button.nav-button.active">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#50CFE8FF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>
        <Style Selector="Button.nav-button.active /template/ Border#NavGlass">
            <!-- Deeper blue fill — bump opacity so the darker gradient is clearly
                 visible across the full button width. -->
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style Selector="Button.nav-button.active /template/ Border#NavSheen">
            <Setter Property="Opacity" Value="0.22"/>
        </Style>
        <Style Selector="Button.nav-button.active /template/ Border#NavInnerBorder">
            <!-- Inset stroke visible only when the button is active. -->
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.nav-button.active:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#68CFE8FF" />
        </Style>
        <Style Selector="Button.nav-button.active:pointerover /template/ Border#NavGlass">
            <Setter Property="Opacity" Value="0.95"/>
        </Style>
        <Style Selector="Button.nav-button.active:pointerover /template/ Border#NavSheen">
            <Setter Property="Opacity" Value="0.28"/>
        </Style>
        <Style Selector="Button.nav-button:pressed">
            <Setter Property="Background" Value="{DynamicResource FilterPressedGradient}" />
        </Style>
        <Style Selector="Button.nav-button.active:pressed">
            <Setter Property="Background" Value="{DynamicResource FilterPressedGradient}" />
            <Setter Property="BorderBrush" Value="{DynamicResource QuickFilterGlassActiveBorderBrush}" />
        </Style>

        <!-- Sidebar nav button: idle = transparent (matches sidebar background),
             active (currently-selected page) = flat dark navy #26385C. No
             hover/pressed sheen. Full ControlTemplate override is required to
             suppress Avalonia Fluent Button chrome. Background is bound via
             TemplateBinding so the .active selector can swap it. -->
        <Style Selector="Button.flat-navy">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Effect" Value="{x:Null}"/>
            <Setter Property="Transitions" Value="{x:Null}"/>
            <Setter Property="RenderTransform" Value="none"/>
            <Setter Property="Template">
                <ControlTemplate TargetType="Button">
                    <Panel>
                        <Border x:Name="NavyBase"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="0"/>
                        <!-- Pressed-in look: heavy dark stroke on top/left + soft
                             dark gradient fade from the top edge inward to mimic
                             a cast shadow inside the recessed well, plus a faint
                             bottom/right rim-light. -->
                        <!-- Vertical fill gradient: darker at top, lighter at bottom.
                             Reinforces "light from above striking a recessed
                             surface" — the base depth cue. -->
                        <Border x:Name="NavyFillGradient"
                                Opacity="0"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#08101C" Offset="0"/>
                                    <GradientStop Color="#0F1A2E" Offset="0.5"/>
                                    <GradientStop Color="#152340" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Top cast-shadow: tall, opaque at the top edge, fading
                             ~24px down into the well. -->
                        <Border x:Name="NavyShadowFade"
                                Opacity="0"
                                Height="24"
                                VerticalAlignment="Top"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#D0000000" Offset="0"/>
                                    <GradientStop Color="#60000000" Offset="0.4"/>
                                    <GradientStop Color="#00000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Left cast-shadow: wider band fading inward. -->
                        <Border x:Name="NavyShadowFadeLeft"
                                Opacity="0"
                                Width="18"
                                HorizontalAlignment="Left"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                    <GradientStop Color="#A0000000" Offset="0"/>
                                    <GradientStop Color="#40000000" Offset="0.4"/>
                                    <GradientStop Color="#00000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Hard inset stroke: 3px top/left, near-black at the
                             corner where the well is deepest. -->
                        <Border x:Name="NavyInsetShadow"
                                Opacity="0"
                                BorderThickness="3,3,0,0"
                                IsHitTestVisible="False">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Color="#FF000000" Offset="0"/>
                                    <GradientStop Color="#60000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                        </Border>
                        <!-- Bottom/right rim-light: stronger so the recessed
                             edge catches a clear specular highlight. -->
                        <Border x:Name="NavyInsetHighlight"
                                Opacity="0"
                                BorderThickness="0,0,2,2"
                                IsHitTestVisible="False">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                                    <GradientStop Color="#50FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                        </Border>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Panel>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.flat-navy:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.flat-navy:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <!-- Active fill: darker than WindowBackgroundBrush (#1E2A38 in default
             dark theme) so the selected row reads recessed, not lifted. -->
        <Style Selector="Button.flat-navy.active">
            <Setter Property="Background" Value="#0F1A2E"/>
            <Setter Property="BorderBrush" Value="#0F1A2E"/>
        </Style>
        <Style Selector="Button.flat-navy.active /template/ Border#NavyFillGradient">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.flat-navy.active /template/ Border#NavyShadowFade">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.flat-navy.active /template/ Border#NavyShadowFadeLeft">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.flat-navy.active /template/ Border#NavyInsetShadow">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.flat-navy.active /template/ Border#NavyInsetHighlight">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.flat-navy.active:pointerover">
            <Setter Property="Background" Value="#0F1A2E"/>
            <Setter Property="BorderBrush" Value="#0F1A2E"/>
        </Style>
        <Style Selector="Button.flat-navy.active:pressed">
            <Setter Property="Background" Value="#0F1A2E"/>
            <Setter Property="BorderBrush" Value="#0F1A2E"/>
        </Style>

        <Style Selector="ToggleButton.category-filter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="#36CFE8FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Panel>
                            <Border x:Name="FilterShadow"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    IsHitTestVisible="False"
                                    Opacity="0.55"
                                    Effect="{DynamicResource LiquidGlassButtonEffect}"/>
                            <Border x:Name="FilterBase"
                                    Background="#10162232"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"/>
                            <Border x:Name="CategoryTint"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Opacity="0.26"
                                    Background="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource HexToBrushConverter}}"/>
                            <Border x:Name="CyanGlass"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Opacity="0.20">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                        <GradientStop Color="#1A00E5CC" Offset="0"/>
                                        <GradientStop Color="#1200A8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border x:Name="AnimatedBorder"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    BorderThickness="1"
                                    Opacity="0.50"
                                    IsHitTestVisible="False">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                        <GradientStop Color="#10CFE8FF" Offset="0"/>
                                        <GradientStop Color="#90CFE8FF" Offset="0.5"/>
                                        <GradientStop Color="#10CFE8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                            </Border>
                            <Border x:Name="TopSheen"
                                    Height="14"
                                    VerticalAlignment="Top"
                                    Margin="5,2,5,0"
                                    CornerRadius="12"
                                    Opacity="0.12"
                                    Background="#70FFFFFF"
                                    IsHitTestVisible="False"/>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Panel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.category-filter:pointerover /template/ Border#FilterShadow">
            <Setter Property="Opacity" Value="0.82"/>
            <Setter Property="Effect" Value="{DynamicResource LiquidGlassButtonEffectHover}"/>
        </Style>
        <Style Selector="ToggleButton.category-filter:pointerover /template/ Border#CategoryTint">
            <Setter Property="Opacity" Value="0.42"/>
        </Style>
        <Style Selector="ToggleButton.category-filter:pointerover /template/ Border#CyanGlass">
            <Setter Property="Opacity" Value="0.30"/>
        </Style>
        <Style Selector="ToggleButton.category-filter:pointerover /template/ Border#AnimatedBorder">
            <Setter Property="Opacity" Value="0.82"/>
        </Style>
        <Style Selector="ToggleButton.category-filter:checked /template/ Border#CategoryTint">
            <Setter Property="Opacity" Value="0.60"/>
        </Style>
        <Style Selector="ToggleButton.category-filter:checked /template/ Border#CyanGlass">
            <Setter Property="Opacity" Value="0.26"/>
        </Style>
        <Style Selector="ToggleButton.category-filter:checked /template/ Border#AnimatedBorder">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="ToggleButton.category-filter:checked /template/ Border#FilterShadow">
            <Setter Property="Opacity" Value="0.90"/>
            <Setter Property="Effect" Value="{DynamicResource LiquidGlassButtonEffectHover}"/>
        </Style>

        <!-- T1: "Category rows show only the colour bar" setting. When the
             .bar-only class is applied (bound from VaultViewModel.ShowCategoryColorBarOnly
             via CategoryItemTemplate), suppress the full-row category tint,
             cyan glass and animated border overlays at every interaction
             state. FilterShadow + FilterBase remain so the row still has a
             subtle hit target; only the chromatic wash is removed, leaving
             the small left colour bar as the sole category indicator. -->
        <Style Selector="ToggleButton.category-filter.bar-only /template/ Border#CategoryTint">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.bar-only /template/ Border#CyanGlass">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.bar-only /template/ Border#AnimatedBorder">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.bar-only:pointerover /template/ Border#CategoryTint">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.bar-only:pointerover /template/ Border#CyanGlass">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.bar-only:pointerover /template/ Border#AnimatedBorder">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.bar-only:checked /template/ Border#CategoryTint">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.bar-only:checked /template/ Border#CyanGlass">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.bar-only:checked /template/ Border#AnimatedBorder">
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <!-- Sidebar refinement: the ENTRY TYPES / CATEGORIES *header* toggles
             (the two dropdown chevrons that open the filter lists) are
             borderless AND tint-less so they read as flush headers on the
             sidebar surface. We have to neutralise every overlay the shared
             category-filter ControlTemplate stacks (FilterBase bg, CategoryTint,
             CyanGlass, AnimatedBorder, FilterShadow, TopSheen) — otherwise the
             button reads as a tinted pill even with the border removed. -->
        <Style Selector="ToggleButton.category-filter.filter-header">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header /template/ Border#FilterBase">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header /template/ Border#CategoryTint">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header /template/ Border#CyanGlass">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header /template/ Border#FilterShadow">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Effect" Value="{x:Null}"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header /template/ Border#TopSheen">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header /template/ Border#AnimatedBorder">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header:pointerover /template/ Border#AnimatedBorder">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header:pointerover /template/ Border#CategoryTint">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header:pointerover /template/ Border#CyanGlass">
            <Setter Property="Opacity" Value="0.10"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header:pointerover /template/ Border#FilterShadow">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header:checked /template/ Border#AnimatedBorder">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header:checked /template/ Border#CategoryTint">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header:checked /template/ Border#CyanGlass">
            <Setter Property="Opacity" Value="0.14"/>
        </Style>
        <Style Selector="ToggleButton.category-filter.filter-header:checked /template/ Border#FilterShadow">
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <!-- Sidebar refinement: items inside the ENTRY TYPES / CATEGORIES
             dropdowns are borderless AND tint-less in their resting state so
             they read flush against the sidebar (no dark pill behind the
             label). Hover/checked use a soft cyan wash to provide affordance
             without painting a discoloured block. -->
        <Style Selector="Button.sidebar-filter-item">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Effect" Value="{x:Null}"/>
        </Style>
        <Style Selector="Button.sidebar-filter-item:pointerover">
            <Setter Property="Background" Value="#1A2A3F58"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Effect" Value="{x:Null}"/>
        </Style>
        <Style Selector="Button.sidebar-filter-item:pressed">
            <Setter Property="Background" Value="#22304558"/>
        </Style>

        <!-- Toggle variant used by CategoryItemTemplate so category list items
             match entry-type list items: same background, no border, same
             hover/checked feel. Sits OUTSIDE the category-filter glass
             treatment by overriding background + opacity-bearing pieces are
             not in scope here (template comes from the shared
             category-filter ControlTemplate, but borders are nuked). -->
        <Style Selector="ToggleButton.sidebar-filter-item-toggle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="ToggleButton.sidebar-filter-item-toggle:pointerover">
            <Setter Property="Background" Value="#1A2A3F58"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.sidebar-filter-item-toggle:checked">
            <Setter Property="Background" Value="#22304558"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <!-- Keep per-category tint visible on list items (that's the whole
             point — each category has its own colour from Tag). Just neutralise
             the extra cyan glow / animated ring / drop shadow / top sheen so
             rows read as flat coloured pills instead of glowing glass buttons. -->
        <Style Selector="ToggleButton.sidebar-filter-item-toggle /template/ Border#AnimatedBorder">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.sidebar-filter-item-toggle /template/ Border#FilterBase">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ToggleButton.sidebar-filter-item-toggle /template/ Border#CategoryTint">
            <Setter Property="Opacity" Value="0.26"/>
        </Style>
        <Style Selector="ToggleButton.sidebar-filter-item-toggle /template/ Border#CyanGlass">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.sidebar-filter-item-toggle /template/ Border#FilterShadow">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Effect" Value="{x:Null}"/>
        </Style>
        <Style Selector="ToggleButton.sidebar-filter-item-toggle /template/ Border#TopSheen">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.sidebar-filter-item-toggle:pointerover /template/ Border#CategoryTint">
            <Setter Property="Opacity" Value="0.42"/>
        </Style>
        <Style Selector="ToggleButton.sidebar-filter-item-toggle:pointerover /template/ Border#CyanGlass">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.sidebar-filter-item-toggle:pointerover /template/ Border#FilterShadow">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.sidebar-filter-item-toggle:checked /template/ Border#CategoryTint">
            <Setter Property="Opacity" Value="0.60"/>
        </Style>
        <Style Selector="ToggleButton.sidebar-filter-item-toggle:checked /template/ Border#CyanGlass">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="ToggleButton.sidebar-filter-item-toggle:checked /template/ Border#FilterShadow">
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <Style Selector="Button.collapsed-icon">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ToggleButton.collapsed-icon">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.collapsed-icon.active">
            <Setter Property="Background" Value="#1800E5CC"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="Button.collapsed-icon.active:pointerover">
            <Setter Property="Background" Value="#2200E5CC"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Thin sidebar scrollbar: track + thumb narrower, positioned flush-right -->
        <Style Selector="ScrollViewer /template/ ScrollBar[IsExpanded=true]">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar:pointerover">
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar /template/ Thumb">
            <Setter Property="MinWidth" Value="4"/>
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.15"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ScrollViewer /template/ ScrollBar:pointerover /template/ Thumb">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="{DynamicResource SecondaryTextBrush}"/>
        </Style>
    </UserControl.Styles>
    
    <Border Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource ControlBorderBrush}"
            BorderThickness="0,0,1,0"
            Padding="0"
            Effect="{x:Null}"
            Classes="sidebar-animated">
        <Border.Styles>
            <Style Selector="Border.sidebar-animated">
                <Setter Property="Transitions">
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.4" Easing="CubicEaseInOut"/>
                    </Transitions>
                </Setter>
            </Style>
        </Border.Styles>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="0" Margin="0,20">
                
                <!-- Collapse Button (Expanded View) -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Left" 
                            Spacing="0" 
                            Margin="8,0,0,16"
                            IsVisible="{Binding !IsSidebarCollapsed}">
                    <Button Command="{Binding ToggleSidebarCommand}"
                            Classes="liquid-glass collapsed-icon"
                            ToolTip.Tip="Collapse Sidebar"
                            ClickMode="Press">
                        <Path Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" 
                              Fill="{DynamicResource PrimaryTextBrush}" 
                              Stretch="Uniform"
                              Width="13" 
                              Height="13"/>
                    </Button>
                </StackPanel>

                <!-- Dashboard and Passwords Buttons.
                     Edge-to-edge: outer Margin zeroed so the active highlight
                     spans the full sidebar width (previous 6px outer margin
                     left a visible inset on either side). Inner label padding
                     handles text alignment instead. -->
                <StackPanel Spacing="6" Margin="0,0,0,12" IsVisible="{Binding !IsSidebarCollapsed}">
                    <Button Command="{Binding ShowDashboardCommand}"
                                  Classes="flat-navy"
                                  Classes.active="{Binding IsShowingDashboard}"
                                  HorizontalContentAlignment="Left"
                                  ToolTip.Tip="Dashboard"
                                  IsVisible="{Binding IsDashboardEnabled}">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left" Margin="16,0,0,0">
                            <TextBlock Text="Dashboard" FontSize="{StaticResource Type.Label.Size}" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" IsVisible="{Binding !IsSidebarCollapsed}"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ShowPasswordsCommand}"
                                  Classes="flat-navy"
                                  Classes.active="{Binding IsShowingPasswords}"
                                  HorizontalContentAlignment="Left"
                                  ToolTip.Tip="Passwords">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left" Margin="16,0,0,0">
                            <TextBlock Text="Passwords" FontSize="{StaticResource Type.Label.Size}" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" IsVisible="{Binding !IsSidebarCollapsed}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- Collapsed Icon-Only View -->
                <StackPanel Spacing="6" Margin="0,0,0,12" IsVisible="{Binding IsSidebarCollapsed}">
                    <!-- Expand Button -->
                    <Button Command="{Binding ToggleSidebarCommand}"
                            Classes="liquid-glass collapsed-icon"
                            ToolTip.Tip="Expand Sidebar"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16"
                            IsVisible="{Binding !IsShowingDashboard}"
                            ClickMode="Press">
                        <Path Data="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z" 
                              Fill="{DynamicResource PrimaryTextBrush}" 
                              Stretch="Uniform"
                              Width="13" 
                              Height="13"/>
                    </Button>
                    
                    <!-- Dashboard Icon -->
                    <Button Command="{Binding ShowDashboardCommand}"
                            Classes="liquid-glass collapsed-icon"
                            Classes.active="{Binding IsShowingDashboard}"
                            ToolTip.Tip="Dashboard"
                            HorizontalAlignment="Center"
                            ClickMode="Press"
                            IsVisible="{Binding IsDashboardEnabled}">
                        <Viewbox Width="21" Height="21">
                            <Canvas Width="24" Height="24">
                                <Path Data="M3,3 L10,3 L10,10 L3,10 Z M14,3 L21,3 L21,10 L14,10 Z M14,14 L21,14 L21,21 L14,21 Z M3,14 L10,14 L10,21 L3,21 Z" 
                                      Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" Fill="Transparent"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Passwords Icon -->
                    <Button Command="{Binding ShowPasswordsCommand}"
                            Classes="liquid-glass collapsed-icon"
                            Classes.active="{Binding IsShowingPasswords}"
                            ToolTip.Tip="Passwords"
                            HorizontalAlignment="Center"
                            ClickMode="Press">
                        <Path Data="{StaticResource Icon.Key}"
                              Width="21"
                              Height="21"
                              Stretch="Uniform"
                              Stroke="{DynamicResource PrimaryTextBrush}"
                              StrokeThickness="1.5"
                              Fill="Transparent"/>
                    </Button>

                    <!-- Password Health Icon -->
                    <Button Command="{Binding OpenPasswordHealthPanelCommand}"
                            Classes="liquid-glass collapsed-icon"
                            ToolTip.Tip="Password Health"
                            HorizontalAlignment="Center"
                            ClickMode="Press">
                        <Path Data="{StaticResource Icon.Shield}"
                              Width="21"
                              Height="21"
                              Stretch="Uniform"
                              Stroke="{DynamicResource PrimaryTextBrush}"
                              StrokeThickness="1.5"
                              Fill="Transparent"/>
                    </Button>

                    <!-- Category Manager Icon -->
                    <Button Command="{Binding ManageCategoriesCommand}"
                            Classes="liquid-glass collapsed-icon"
                            ToolTip.Tip="Category Manager"
                            HorizontalAlignment="Center"
                            ClickMode="Press">
                        <Path Data="{StaticResource Icon.Folder}"
                              Width="21"
                              Height="21"
                              Stretch="Uniform"
                              Stroke="{DynamicResource PrimaryTextBrush}"
                              StrokeThickness="1.5"
                              Fill="Transparent"/>
                    </Button>

                    <!-- Recovery Icon -->
                    <Button Command="{Binding ToggleRecoveryPanelCommand}"
                            Classes="liquid-glass collapsed-icon"
                            ToolTip.Tip="Recovery • Click to toggle Recovery panel"
                            IsEnabled="{Binding IsEmbeddedRecoveryAvailable}"
                            Opacity="{Binding IsEmbeddedRecoveryAvailable, Converter={StaticResource BoolToOpacityConverter}, FallbackValue=1}"
                            HorizontalAlignment="Center"
                            ClickMode="Press">
                        <controls:SvgIcon IconName="Assets/SVG/Current/Recovery.svg"
                                          Width="21" Height="21" IconColor="{DynamicResource PrimaryTextBrush}" />
                    </Button>

                    <!-- TOTP Icon -->
                    <Button Command="{Binding DashboardViewModel.LaunchPhantomAttestorCommand}"
                            Classes="liquid-glass collapsed-icon"
                            ToolTip.Tip="{Binding DashboardViewModel.AttestorStatus}"
                            IsEnabled="{Binding DashboardViewModel.IsAttestorAvailable}"
                            HorizontalAlignment="Center"
                            ClickMode="Press">
                        <Viewbox Width="21" Height="21">
                            <Canvas Width="24" Height="24">
                                <Path Data="M5,2 L19,2 C20.1,2 21,2.9 21,4 L21,20 C21,21.1 20.1,22 19,22 L5,22 C3.9,22 3,21.1 3,20 L3,4 C3,2.9 3.9,2 5,2 Z" 
                                      Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" Fill="Transparent"/>
                                <Path Data="M12,7 C13.66,7 15,8.34 15,10 C15,11.66 13.66,13 12,13 C10.34,13 9,11.66 9,10 C9,8.34 10.34,7 12,7 Z" 
                                      Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" Fill="Transparent"/>
                                <Path Data="M12,18 L12.01,18" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="2" StrokeLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
                
                <!-- Quick Access -->
                <StackPanel Spacing="{StaticResource Space6}" Margin="0,0,0,12" IsVisible="{Binding !IsSidebarCollapsed}">
                    <Border Background="Transparent"
                            Margin="6,0,0,6"
                            Padding="12,0">
                        <Border.Styles>
                            <Style Selector="Border:pointerover">
                                <Setter Property="Background" Value="{DynamicResource SidebarHeadingHoverCompositeBrush}"/>
                            </Style>
                        </Border.Styles>
                        <TextBlock Text="QUICK ACCESS"
                                   FontSize="{StaticResource Type.Small.Size}"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </Border>

                    <Grid>
                        <StackPanel x:Name="QuickFilterButtonsPanel"
                                    Spacing="{StaticResource Space6}"
                                    Margin="0">
                            <ToggleButton Command="{Binding ShowAllCommand}"
                                          IsChecked="{Binding IsShowingAll, Mode=OneWay}"
                                          Classes="quick-filter">
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                    <TextBlock Text="All Items" FontSize="{StaticResource Type.Label.Size}" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TotalCount}"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"/>
                                </StackPanel>
                            </ToggleButton>

                            <ToggleButton Command="{Binding ShowFavoritesCommand}"
                                          IsChecked="{Binding IsShowingFavorites, Mode=OneWay}"
                                          Classes="quick-filter">
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                    <TextBlock Text="Favorites" FontSize="{StaticResource Type.Label.Size}" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding FavoritesCount}"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"/>
                                </StackPanel>
                            </ToggleButton>

                            <nav:QuickFilterButton 
                                Label="Passkeys" 
                                Command="{Binding ShowPasskeysCommand}" 
                                IsChecked="{Binding IsShowingPasskeys, Mode=OneWay}" 
                                Count="{Binding PasskeysCount}" 
                                ShowCount="True" />

                            <nav:QuickFilterButton 
                                Label="Recent" 
                                Command="{Binding ShowRecentCommand}" 
                                IsChecked="{Binding IsShowingRecent, Mode=OneWay}" 
                                ShowCount="False" />

                            <nav:QuickFilterButton 
                                Label="Expiring Soon" 
                                Command="{Binding ShowExpiringSoonCommand}" 
                                IsChecked="{Binding IsShowingExpiringSoon, Mode=OneWay}" 
                                ShowCount="False" />
                        </StackPanel>

                        <Border x:Name="QuickFilterHighlight"
                                Height="44"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Stretch"
                                Margin="{Binding QuickFilterHighlightMargin}"
                                Opacity="{Binding QuickFilterHighlightOpacity}"
                                RenderTransformOrigin="0.5,0.5"
                                IsHitTestVisible="False">
                            <Border.Transitions>
                                <Transitions>
                                    <ThicknessTransition Property="Margin" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.12" Easing="CubicEaseOut"/>
                                </Transitions>
                            </Border.Transitions>
                            <Border.RenderTransform>
                                <TranslateTransform X="{Binding QuickFilterHighlightOffset}">
                                    <TranslateTransform.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="X" Duration="0:0:0.10" Easing="CubicEaseOut"/>
                                        </Transitions>
                                    </TranslateTransform.Transitions>
                                </TranslateTransform>
                            </Border.RenderTransform>
                            <!-- Issue #20: persistent highlight was reading too
                                 white. Drop the white reflection + gel layers
                                 way down and let the cyan glass border carry
                                 the look. -->
                            <Grid IsHitTestVisible="False" ClipToBounds="True" Margin="0">
                                <!-- Glass border ring — dominant feature -->
                                <Border CornerRadius="12"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource QuickFilterGlassActiveBorderBrush}"
                                        Background="{DynamicResource QuickFilterGlassActiveBrush}"/>
                                <!-- Subtle background reflection (halved) -->
                                <Border CornerRadius="12"
                                        Margin="0"
                                        Opacity="0.05">
                                    <Border.Background>
                                        <VisualBrush Visual="{Binding ElementName=QuickFilterButtonsPanel}"
                                                     Stretch="UniformToFill"
                                                     AlignmentX="Center"
                                                     AlignmentY="Center"/>
                                    </Border.Background>
                                    <Border.OpacityMask>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#20FFFFFF" Offset="0"/>
                                            <GradientStop Color="#04FFFFFF" Offset="0.5"/>
                                            <GradientStop Color="#20FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.OpacityMask>
                                </Border>
                                <!-- Cyan glass sheen (kept but lower) -->
                                <Border CornerRadius="12"
                                        Opacity="0.18">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00A0C8E8" Offset="0"/>
                                            <GradientStop Color="#16A0C8E8" Offset="{Binding QuickFilterHighlightLightLeft}"/>
                                            <GradientStop Color="#38D8E8F8" Offset="{Binding QuickFilterHighlightSheenInnerLeft}"/>
                                            <GradientStop Color="#50D8E8F8" Offset="{Binding QuickFilterHighlightLightShift}"/>
                                            <GradientStop Color="#38D8E8F8" Offset="{Binding QuickFilterHighlightSheenInnerRight}"/>
                                            <GradientStop Color="#16A0C8E8" Offset="{Binding QuickFilterHighlightLightRight}"/>
                                            <GradientStop Color="#00A0C8E8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <!-- Top + bottom gel rings: opacity halved so
                                     they read as a faint specular not a white
                                     glow. -->
                                <Border Background="{DynamicResource QuickFilterGelTopHighlightBrush}"
                                        CornerRadius="13"
                                        Margin="6,2,6,0"
                                        Height="18"
                                        VerticalAlignment="Top"
                                        Opacity="0.10"/>
                                <Border Background="{DynamicResource QuickFilterGelBottomGlowBrush}"
                                        CornerRadius="14"
                                        Margin="8,0,8,4"
                                        Height="16"
                                        VerticalAlignment="Bottom"
                                        Opacity="0.12"/>
                            </Grid>
                        </Border>
                    </Grid>
                </StackPanel>
                
                <!-- Entry Types Dropdown Filter -->
                <!-- Issue #13: right-side scrollbar (6px) was eating into the visual
                     right margin of dropdown buttons, making them sit asymmetrically.
                     Add a 6px right margin to the group so the dropdown chrome reads
                     with equal whitespace on each side regardless of scrollbar state. -->
                <StackPanel Spacing="4" Margin="0,0,6,12" IsVisible="{Binding !IsSidebarCollapsed}">
                    <ToggleButton x:Name="EntryTypeDropdownToggle"
                                  Classes="category-filter filter-header"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Left"
                                  Height="36"
                                  CornerRadius="14"
                                  Margin="6,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="ENTRY TYPES"
                                       FontSize="{StaticResource Type.Small.Size}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                            <Path Grid.Column="1"
                                  Data="M6 9 L12 15 L18 9"
                                  Stroke="{DynamicResource PrimaryTextBrush}"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  Width="12"
                                  Height="6"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="8,0">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </Path.RenderTransform>
                                <Path.Styles>
                                    <Style Selector="Path">
                                        <Setter Property="RenderTransform">
                                            <RotateTransform Angle="0"/>
                                        </Setter>
                                    </Style>
                                    <Style Selector="ToggleButton:checked Path">
                                        <Setter Property="RenderTransform">
                                            <RotateTransform Angle="180"/>
                                        </Setter>
                                    </Style>
                                </Path.Styles>
                            </Path>
                        </Grid>
                    </ToggleButton>

                    <ItemsControl Margin="0" IsVisible="{Binding IsChecked, ElementName=EntryTypeDropdownToggle}">
                        <Button Command="{Binding FilterByEntryTypeCommand}"
                                CommandParameter="All"
                                Classes="liquid-glass sidebar-filter-item"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Height="36"
                                CornerRadius="12"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                Margin="6,2">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="6,0,0,0">
                                <Path Data="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" StrokeLineCap="Round" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="All Types" FontSize="{StaticResource Type.Label.Size}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding FilterByEntryTypeCommand}"
                                CommandParameter="Password"
                                Classes="liquid-glass sidebar-filter-item"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Height="36"
                                CornerRadius="12"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                Margin="6,2">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="6,0,0,0">
                                <Path Data="M19 11h-1.5V7c0-2.76-2.24-5-5-5s-5 2.24-5 5v4H6c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h13c1.1 0 2-.9 2-2v-8c0-1.1-.9-2-2-2zm-9-4c0-1.66 1.34-3 3-3s3 1.34 3 3v4h-6V7z" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="Passwords" FontSize="{StaticResource Type.Label.Size}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding FilterByEntryTypeCommand}"
                                CommandParameter="CreditCard"
                                Classes="liquid-glass sidebar-filter-item"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Height="36"
                                CornerRadius="12"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                Margin="6,2">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="6,0,0,0">
                                <Path Data="M3 6h18v12H3z M3 10h18" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" StrokeLineCap="Round" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="Credit Cards" FontSize="{StaticResource Type.Label.Size}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding FilterByEntryTypeCommand}"
                                CommandParameter="BankAccount"
                                Classes="liquid-glass sidebar-filter-item"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Height="36"
                                CornerRadius="12"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                Margin="6,2">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="6,0,0,0">
                                <Path Data="M3 5h18v14H3z" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" StrokeLineCap="Round" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="Bank Accounts" FontSize="{StaticResource Type.Label.Size}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding FilterByEntryTypeCommand}"
                                CommandParameter="Identity"
                                Classes="liquid-glass sidebar-filter-item"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Height="36"
                                CornerRadius="12"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                Margin="6,2">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="6,0,0,0">
                                <Path Data="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2 M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" StrokeLineCap="Round" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="Identity Documents" FontSize="{StaticResource Type.Label.Size}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding FilterByEntryTypeCommand}"
                                CommandParameter="ApiKey"
                                Classes="liquid-glass sidebar-filter-item"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Height="36"
                                CornerRadius="12"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                Margin="6,2">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="6,0,0,0">
                                <Path Data="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" StrokeLineCap="Round" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="API Keys" FontSize="{StaticResource Type.Label.Size}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding FilterByEntryTypeCommand}"
                                CommandParameter="WiFi"
                                Classes="liquid-glass sidebar-filter-item"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Height="36"
                                CornerRadius="12"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                Margin="6,2">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="6,0,0,0">
                                <Path Data="M1 11.5a11.43 11.43 0 0 1 22 0 M5 13a7 7 0 0 1 14 0 M12 20h.01 M9 17a3 3 0 0 1 6 0" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" StrokeLineCap="Round" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="WiFi Networks" FontSize="{StaticResource Type.Label.Size}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding FilterByEntryTypeCommand}"
                                CommandParameter="Contact"
                                Classes="liquid-glass sidebar-filter-item"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Height="36"
                                CornerRadius="12"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                Margin="6,2">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="6,0,0,0">
                                <Path Data="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2 M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" StrokeLineCap="Round" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="Contacts" FontSize="{StaticResource Type.Label.Size}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding FilterByEntryTypeCommand}"
                                CommandParameter="PinCode"
                                Classes="liquid-glass sidebar-filter-item"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Height="36"
                                CornerRadius="12"
                                Foreground="{DynamicResource PrimaryTextBrush}"
                                Margin="6,2">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="6,0,0,0">
                                <Path Data="M7 2h10v4H7z M5 6h14v16H5z M9 10h2 M13 10h2 M9 14h2 M13 14h2 M9 18h6" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" StrokeLineCap="Round" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="PIN Codes" FontSize="{StaticResource Type.Label.Size}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </ItemsControl>
                </StackPanel>
                
                <!-- Categories Dropdown (Collapsible).
                     The CATEGORIES toggle and the gear (Manage Categories) sit on
                     the same row so the gear is 'right next to the drop menu' (#12).
                     The full-width 'Category Settings' button below the list has
                     been removed in favour of this compact gear-only affordance. -->
                <!-- Issue #13: matching 6px right margin to compensate for scrollbar. -->
                <StackPanel Spacing="4" Margin="0,0,6,12" IsVisible="{Binding !IsSidebarCollapsed}">
                    <Grid ColumnDefinitions="*,Auto" Margin="6,0">
                        <ToggleButton x:Name="CategoryDropdownToggle"
                                  Grid.Column="0"
                                  Classes="category-filter filter-header"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Left"
                                  Height="36"
                                  CornerRadius="14"
                                  Margin="0">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="CATEGORIES"
                                       FontSize="{StaticResource Type.Small.Size}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                            <Path Grid.Column="1"
                                  Data="M6 9 L12 15 L18 9"
                                  Stroke="{DynamicResource PrimaryTextBrush}"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  Width="12"
                                  Height="6"
                                  Stretch="Uniform"
                                  VerticalAlignment="Center"
                                  Margin="8,0">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </Path.RenderTransform>
                                <Path.Styles>
                                    <Style Selector="Path">
                                        <Setter Property="RenderTransform">
                                            <RotateTransform Angle="0"/>
                                        </Setter>
                                    </Style>
                                    <Style Selector="ToggleButton:checked Path">
                                        <Setter Property="RenderTransform">
                                            <RotateTransform Angle="180"/>
                                        </Setter>
                                    </Style>
                                </Path.Styles>
                            </Path>
                        </Grid>
                    </ToggleButton>

                        <!-- Gear-only Category Settings affordance, sits on the same
                             row as the CATEGORIES toggle (#12). Issue #36:
                             rounder corners (8 → 14) to match the dropdown
                             toggle next to it. -->
                        <Button Grid.Column="1"
                                Command="{Binding ManageCategoriesCommand}"
                                Classes="liquid-glass collapsed-icon"
                                Width="36" Height="36"
                                MinWidth="36" MinHeight="36"
                                Margin="4,0,0,0"
                                CornerRadius="14"
                                ToolTip.Tip="Manage Categories">
                            <Path Data="M19.14 12.94c.04-.31.06-.63.06-.94 0-.31-.02-.63-.06-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.49.49 0 0 0-.59-.22l-2.39.96a7.04 7.04 0 0 0-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96a.49.49 0 0 0-.59.22L2.74 8.87a.48.48 0 0 0 .12.61l2.03 1.58c-.04.31-.06.63-.06.94 0 .31.02.63.06.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.37 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6A3.6 3.6 0 1 1 12 8.4a3.6 3.6 0 0 1 0 7.2z"
                                  Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.2" Fill="Transparent"
                                  Width="14" Height="14" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <Grid IsVisible="{Binding IsChecked, ElementName=CategoryDropdownToggle}">
                        <Border x:Name="CategoryHighlightSource" Background="Transparent">
                            <ItemsControl ItemsSource="{Binding Categories}"
                                          ItemTemplate="{StaticResource CategoryItemTemplate}" />
                        </Border>

                        <Border x:Name="CategoryHighlight"
                                Height="38"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Stretch"
                                Margin="{Binding CategoryHighlightMargin}"
                                Opacity="{Binding CategoryHighlightOpacity}"
                                RenderTransformOrigin="0.5,0.5"
                                IsHitTestVisible="False"
                                IsVisible="False">
                            <Border.Transitions>
                                <Transitions>
                                    <ThicknessTransition Property="Margin" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.12" Easing="CubicEaseOut"/>
                                </Transitions>
                            </Border.Transitions>
                            <Border.RenderTransform>
                                <TranslateTransform X="{Binding CategoryHighlightOffset}">
                                    <TranslateTransform.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="X" Duration="0:0:0.10" Easing="CubicEaseOut"/>
                                        </Transitions>
                                    </TranslateTransform.Transitions>
                                </TranslateTransform>
                            </Border.RenderTransform>
                            <Grid IsHitTestVisible="False" ClipToBounds="True">
                                <!-- Glass border ring -->
                                <Border CornerRadius="8"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource Brush.Glass.Border}"
                                        Background="Transparent"/>
                                <Border CornerRadius="8"
                                        Margin="0"
                                        Opacity="0"/>
                                <!-- Blue-glass sheen -->
                                <Border CornerRadius="8"
                                        Opacity="0.30">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00A0C8E8" Offset="0"/>
                                            <GradientStop Color="#16A0C8E8" Offset="{Binding CategoryHighlightLightLeft}"/>
                                            <GradientStop Color="#38D8E8F8" Offset="{Binding CategoryHighlightSheenInnerLeft}"/>
                                            <GradientStop Color="#50D8E8F8" Offset="{Binding CategoryHighlightLightShift}"/>
                                            <GradientStop Color="#38D8E8F8" Offset="{Binding CategoryHighlightSheenInnerRight}"/>
                                            <GradientStop Color="#16A0C8E8" Offset="{Binding CategoryHighlightLightRight}"/>
                                            <GradientStop Color="#00A0C8E8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Category Settings is now the gear icon next to the CATEGORIES
                         dropdown header (#12); the previous full-width button has
                         been removed. -->
                </StackPanel>
                
                <!-- Password Dashboard and Giblex Apps Section.
                     All three buttons here share Height=36 + CornerRadius=12 +
                     liquid-glass treatment so they read as a consistent stack
                     of sidebar affordances (#sidebar-consistency). -->
                <StackPanel Spacing="{StaticResource Space6}" IsVisible="{Binding !IsSidebarCollapsed}">
                    <Button Command="{Binding OpenSecurityDashboardWindowCommand}"
                            Classes="liquid-glass"
                            Foreground="{DynamicResource ControlForegroundBrush}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Height="36"
                            FontSize="{StaticResource Type.Label.Size}"
                            CornerRadius="12"
                            Margin="12,6,12,6"
                            ToolTip.Tip="Open Password Dashboard">
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource Space6}" Margin="6,0,0,0">
                            <TextBlock Text="Password Dashboard" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FlaggedCredentialCount}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- GIBLEX APPS section header (was 'RECOVERY' + external
                         green dot). The per-app green dot now lives on each
                         app's button so each entry communicates its own
                         availability state. -->
                    <Border Background="Transparent"
                            Margin="0,6,0,6"
                            Padding="12,0">
                        <TextBlock Text="GIBLEX APPS"
                                   FontSize="{StaticResource Type.Tiny.Size}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                    </Border>

                    <!-- Phantom Recovery: green status dot moved onto the
                         button (right side) instead of next to the section
                         label, so availability reads with the action. -->
                    <Button Command="{Binding OpenPhantomRecoveryCommand}"
                            Classes="liquid-glass"
                            Foreground="{DynamicResource ControlForegroundBrush}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            IsEnabled="{Binding IsExternalRecoveryAvailable}"
                            Opacity="{Binding IsExternalRecoveryAvailable, Converter={StaticResource BoolToOpacityConverter}, FallbackValue=1}"
                            ToolTip.Tip="{Binding ExternalRecoveryStatus}"
                            Height="36"
                            FontSize="{StaticResource Type.Label.Size}"
                            CornerRadius="12"
                            Margin="12,0,12,6">
                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="6,0">
                            <controls:SvgIcon Grid.Column="0"
                                              IconName="Assets/SVG/Current/Recovery.svg"
                                              Width="16" Height="16"
                                              IconColor="{DynamicResource PrimaryTextBrush}"
                                              VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Phantom Recovery"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                            <Ellipse Grid.Column="2"
                                     Width="8" Height="8"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource SuccessBrush}"
                                     IsVisible="{Binding IsExternalRecoveryAvailable}"
                                     ToolTip.Tip="Phantom Recovery is available"/>
                        </Grid>
                    </Button>

                    <!-- Phantom Attestor: matches the Phantom Recovery row
                         (same height/shape/glass border) so the Giblex Apps
                         section reads as a uniform launcher list. -->
                    <Button Command="{Binding DashboardViewModel.LaunchPhantomAttestorCommand}"
                            Classes="liquid-glass"
                            Foreground="{DynamicResource ControlForegroundBrush}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            IsEnabled="{Binding DashboardViewModel.IsAttestorAvailable}"
                            Opacity="{Binding DashboardViewModel.IsAttestorAvailable, Converter={StaticResource BoolToOpacityConverter}, FallbackValue=1}"
                            ToolTip.Tip="{Binding DashboardViewModel.AttestorStatus}"
                            Height="36"
                            FontSize="{StaticResource Type.Label.Size}"
                            CornerRadius="12"
                            Margin="12,0,12,12">
                        <Grid ColumnDefinitions="Auto,*,Auto" Margin="6,0">
                            <Viewbox Grid.Column="0" Width="16" Height="16" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M5,2 L19,2 C20.1,2 21,2.9 21,4 L21,20 C21,21.1 20.1,22 19,22 L5,22 C3.9,22 3,21.1 3,20 L3,4 C3,2.9 3.9,2 5,2 Z"
                                          Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Path Data="M12,7 C13.66,7 15,8.34 15,10 C15,11.66 13.66,13 12,13 C10.34,13 9,11.66 9,10 C9,8.34 10.34,7 12,7 Z"
                                          Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Path Data="M12,18 L12.01,18" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="2" StrokeLineCap="Round"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1"
                                       Text="Phantom Attestor"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                            <Ellipse Grid.Column="2"
                                     Width="8" Height="8"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource SuccessBrush}"
                                     IsVisible="{Binding DashboardViewModel.IsAttestorAvailable}"
                                     ToolTip.Tip="Phantom Attestor is available"/>
                        </Grid>
                    </Button>

                    <TextBlock Text="{Binding ExternalRecoveryStatus}"
                               Margin="12,-6,12,12"
                               FontSize="{StaticResource Type.Micro.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               IsVisible="{Binding !IsExternalRecoveryAvailable}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
    
</UserControl>
