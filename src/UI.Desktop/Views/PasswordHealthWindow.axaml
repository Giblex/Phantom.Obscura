<?xml version="1.0" encoding="utf-8"?>
<views:ThemeAwareWindow
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="https://github.com/avaloniaui/design"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:PhantomVault.UI.ViewModels"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
    mc:Ignorable="d"
    x:Class="PhantomVault.UI.Views.PasswordHealthWindow"
    Title="Password Health"
    Width="420"
    Height="260"
    MinWidth="380"
    MinHeight="240"
    WindowStartupLocation="CenterOwner"
    Background="{DynamicResource WindowBackgroundBrush}"
    Classes="animated-window">
    <StackPanel Margin="20" Spacing="12">
        <Button Content="Analyse Passwords" Command="{Binding AnalyzeCommand}"/>
        <TextBlock Text="{Binding Report.TotalCredentials, StringFormat='Total credentials: {0}'}" Foreground="{DynamicResource PrimaryTextBrush}"/>
        <TextBlock Text="{Binding Report.WeakCount, StringFormat='Weak passwords: {0}'}" Foreground="{DynamicResource PrimaryTextBrush}"/>
        <TextBlock Text="{Binding Report.ReusedCount, StringFormat='Reused passwords: {0}'}" Foreground="{DynamicResource PrimaryTextBrush}"/>
        <TextBlock Text="{Binding Report.OldCount, StringFormat='Old passwords: {0}'}" Foreground="{DynamicResource PrimaryTextBrush}"/>
    </StackPanel>
</views:ThemeAwareWindow>

