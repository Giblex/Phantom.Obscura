<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
    x:Class="PhantomVault.UI.Views.AboutWindow"
        Title="About Phantom Vault"
        Width="420" Height="320"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        Classes="animated-window">

    <StackPanel Margin="24" Spacing="14">
        <!-- App identity -->
        <StackPanel Spacing="4">
            <TextBlock Text="Phantom Vault"
                       FontSize="{StaticResource Type.H2.Size}"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBlock Text="{Binding AppVersion, StringFormat='Version {0}'}"
                       FontSize="{StaticResource Type.Small.Size}"
                       Foreground="{DynamicResource MutedTextBrush}"/>
        </StackPanel>

        <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,4"/>

        <!-- Description -->
        <TextBlock Text="A secure credential vault built with privacy-first principles.&#x0a;Designed and developed by Giblex."
                   FontSize="{StaticResource Type.Body.Size}"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   TextWrapping="Wrap"
                   LineHeight="22"/>

        <TextBlock Text="© 2025 Giblex. All rights reserved."
                   FontSize="{StaticResource Type.Tiny.Size}"
                   Foreground="{DynamicResource MutedTextBrush}"
                   Margin="0,4,0,0"/>

        <!-- Close button -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Click="Close_Click"
                    Classes="primary"
                    MinWidth="90"
                    Height="34"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    CornerRadius="{StaticResource Radius.Md}">
                <TextBlock Text="Close"
                           FontSize="{StaticResource Type.Body.Size}"
                           FontWeight="SemiBold"/>
            </Button>
        </StackPanel>
    </StackPanel>
</views:ThemeAwareWindow>


