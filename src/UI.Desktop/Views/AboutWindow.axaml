<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
    x:Class="PhantomVault.UI.Views.AboutWindow"
        Title="About Phantom Vault"
        Width="420" Height="300"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource WindowBackgroundBrush}">

    <StackPanel Margin="18" Spacing="12">
        <TextBlock Text="Phantom Vault" FontSize="18" FontWeight="SemiBold"/>
        <TextBlock Text="A secure vault application by Giblex." FontSize="12"/>
        <TextBlock Text="Version: {Binding AppVersion}" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>

        <TextBlock TextWrapping="Wrap" Margin="0,8,0,0">This is a placeholder About dialog. Replace with licensing and credits as needed.</TextBlock>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,12,0">
            <Button Click="Close_Click" Width="80" Height="30">Close</Button>
        </StackPanel>
    </StackPanel>
</views:ThemeAwareWindow>


