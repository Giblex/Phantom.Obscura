<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:PhantomVault.UI.Converters"
    xmlns:controls="clr-namespace:PhantomVault.UI.Controls"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
    
        
        x:Class="PhantomVault.UI.Views.VaultWindow"
        Title="PhantomVault - My Secure Vault" 
        Width="1600" 
        Height="800"
        MinWidth="1400"
        MinHeight="700"
        Background="{DynamicResource WindowBackgroundBrush}">
    
    <Window.KeyBindings>
        <!-- Ctrl+N: Add new credential -->
        <KeyBinding Gesture="Ctrl+N" Command="{Binding AddCredentialCommand}"/>
        <!-- Ctrl+F: Focus search box -->
        <KeyBinding Gesture="Ctrl+F" Command="{Binding FocusSearchCommand}"/>
        <!-- Ctrl+L: Lock vault -->
        <KeyBinding Gesture="Ctrl+L" Command="{Binding LockCommand}"/>
        <!-- F5: Refresh credential list -->
        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}"/>
    </Window.KeyBindings>
    
    <Window.Resources>
        <converters:BoolToStarBrushConverter x:Key="BoolToStarBrushConverter"/>
        <converters:WidthToButtonSizeConverter x:Key="WidthToButtonSizeConverter"/>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <converters:HexToBrushConverter x:Key="HexToBrushConverter"/>
        <converters:HexToForegroundBrushConverter x:Key="HexToForegroundBrushConverter"/>
        <converters:PrivacyMaskConverter x:Key="PrivacyMaskConverter"/>
    <converters:PrivacyBlurEffectConverter x:Key="PrivacyBlurEffectConverter"/>
        <converters:IconPathToBitmapConverter x:Key="IconPathToBitmapConverter"/>
        <converters:IconPathExistsConverter x:Key="IconPathExistsConverter"/>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter"/>
        <!-- Spacing tokens system -->
        <x:Double x:Key="Space2">2</x:Double>
        <x:Double x:Key="Space4">4</x:Double>
        <x:Double x:Key="Space6">6</x:Double>
        <x:Double x:Key="Space8">8</x:Double>
        <x:Double x:Key="Space10">10</x:Double>
        <x:Double x:Key="Space12">12</x:Double>
        <x:Double x:Key="Space14">14</x:Double>
        <x:Double x:Key="Space16">16</x:Double>
        <x:Double x:Key="Space20">20</x:Double>
        <x:Double x:Key="Space24">24</x:Double>
    <x:Double x:Key="Space32">32</x:Double>
    <!-- Tile sizing tokens (adjust to change all tiles uniformly) -->
    <x:Double x:Key="TileWidth">420</x:Double>
    <x:Double x:Key="TileHeight">100</x:Double>
        
        <!-- Common thickness tokens -->
        <Thickness x:Key="ContentPadding">20,16,20,24</Thickness>
        <Thickness x:Key="DialogPadding">25,20</Thickness>
        <Thickness x:Key="TilePadding">16,12,10,12</Thickness>
        <Thickness x:Key="ButtonPadding">10,8</Thickness>
        <Thickness x:Key="CompactMargin">0,0,0,8</Thickness>

        <!-- Responsive helpers -->
        <converters:IsWidthAtLeastConverter x:Key="IsWidthAtLeastConverter"/>
        <converters:BoolToGridLengthConverter x:Key="BoolToGridLengthConverter"/>
        <converters:IsWidthLessThanConverter x:Key="IsWidthLessThanConverter"/>
        <!-- Subtle full-bleed hover for sidebar headings -->
        <SolidColorBrush x:Key="SidebarHeadingHoverBrush" Color="#12000000"/>
        <!-- Very subtle grey base layer that sits under the glass highlight (almost invisible) -->
        <SolidColorBrush x:Key="SidebarHoverBaseGreyBrush" Color="#08000000"/>
        <!-- Composite hover: subtle grey base plus the glass tint on top to simulate depth -->
        <LinearGradientBrush x:Key="SidebarHeadingHoverCompositeBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#08000000" Offset="0"/>
            <GradientStop Color="#12000000" Offset="1"/>
        </LinearGradientBrush>
        <converters:CategoryNameToBrushConverter x:Key="CategoryNameToBrushConverter"/>
        <converters:CategoryNameToForegroundBrushConverter x:Key="CategoryNameToForegroundBrushConverter"/>
        
        <!-- Acrylic/Mica-like tile visuals -->
        <!-- Dark acrylic-style base (semi-transparent dark slate) -->
        <SolidColorBrush x:Key="TileGlassBrush" Color="#AA1F2937"/>
        
        <LinearGradientBrush x:Key="TileOverlayBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#33FFFFFF" Offset="0"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
        </LinearGradientBrush>
        
        <!-- Liquid glass gradients for sidebar quick filters -->
        <LinearGradientBrush x:Key="QuickFilterGlassBaseBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#18FFFFFF" Offset="0"/>
            <GradientStop Color="#08000000" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="QuickFilterGlassHoverBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#28FFFFFF" Offset="0"/>
            <GradientStop Color="#176B8CAE" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="QuickFilterGlassActiveBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#B0FFFFFF" Offset="0"/>
            <GradientStop Color="#6A6B8CAE" Offset="0.58"/>
            <GradientStop Color="#3A6B8CAE" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="QuickFilterGlassActiveHoverBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#D0FFFFFF" Offset="0"/>
            <GradientStop Color="#7A7FA3C3" Offset="0.55"/>
            <GradientStop Color="#4C7FA3C3" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="QuickFilterGlassSheenBrush" StartPoint="0.08,0" EndPoint="0.92,1">
            <GradientStop Color="#00FFFFFF" Offset="0"/>
            <GradientStop Color="#66FFFFFF" Offset="0.18"/>
            <GradientStop Color="#22FFFFFF" Offset="0.6"/>
            <GradientStop Color="#00000000" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="QuickFilterGelBodyBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#44FFFFFF" Offset="0"/>
            <GradientStop Color="#20607F98" Offset="0.28"/>
            <GradientStop Color="#28607F98" Offset="0.72"/>
            <GradientStop Color="#5CFFFFFF" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="QuickFilterGelEdgeContourBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#281A2536" Offset="0"/>
            <GradientStop Color="#001A2536" Offset="0.16"/>
            <GradientStop Color="#001A2536" Offset="0.84"/>
            <GradientStop Color="#281A2536" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="QuickFilterGelTopHighlightBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#CCFFFFFF" Offset="0"/>
            <GradientStop Color="#66FFFFFF" Offset="0.22"/>
            <GradientStop Color="#00FFFFFF" Offset="0.55"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="QuickFilterGelBottomGlowBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#00162230" Offset="0"/>
            <GradientStop Color="#00314251" Offset="0.5"/>
            <GradientStop Color="#66162230" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="QuickFilterGelRefractionBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#005B7F96" Offset="0"/>
            <GradientStop Color="#3CFFFFFF" Offset="0.34"/>
            <GradientStop Color="#10607F98" Offset="0.58"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="QuickFilterGlassBorderBrush" Color="#44FFFFFF"/>
        <SolidColorBrush x:Key="QuickFilterGlassActiveBorderBrush" Color="#AA7FA3C3"/>
        
    </Window.Resources>

    <!-- Styles must go in Window.Styles for Avalonia; keep visual styles separate from resources. -->
    <Window.Styles>
        <!-- Tile button styles with explicit ControlTemplate so DataTemplate content is always shown.
             Split styles so list tiles can stretch while grid tiles keep fixed sizing. -->
        <Style Selector="Button.tile-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <!-- List tiles: stretch to fill available width, fixed height via template or explicit Height -->
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="{StaticResource TileHeight}" />
            <Setter Property="MaxHeight" Value="{StaticResource TileHeight}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style Selector="Button.tile-button-grid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <!-- Grid tiles: sizing handled inside the template (e.g., inner Border Width/Height) -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ensure hovered/pressed states remain transparent -->
        <Style Selector="Button.tile-button:pointerover, Button.tile-button:pressed, Button.tile-button-grid:pointerover, Button.tile-button-grid:pressed">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <!-- Keyboard accessibility: show a subtle focus outline on tile buttons -->
        <Style Selector="Button.tile-button:focus, Button.tile-button-grid:focus">
            <!-- Keep a visual focus indicator but do not change BorderThickness so layout doesn't shift.
                 Use BorderBrush only (thickness is controlled in the inner tile Border) -->
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>

        <!-- Sidebar quick filter toggles return to their original look. -->
        <Style Selector="ToggleButton.quick-filter">
            <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style Selector="ToggleButton.quick-filter:pointerover">
            <!-- Apply composite sidebar hover so quick-filter items get the subtle grey base under the glass highlight -->
            <Setter Property="Background" Value="{DynamicResource SidebarHeadingHoverCompositeBrush}" />
            <!-- Slightly reduce padding on hover so highlight visually stretches closer to the edges -->
            <Setter Property="Padding" Value="6,0" />
        </Style>

        <Style Selector="ToggleButton.quick-filter:checked">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>

        <Style Selector="ToggleButton.quick-filter:checked:pointerover">
            <!-- When active & hovered, use a stronger composite (keep accent/active look if you prefer) -->
            <Setter Property="Background" Value="{DynamicResource QuickFilterGlassActiveHoverBrush}" />
            <Setter Property="Padding" Value="6,0" />
        </Style>
    </Window.Styles>
    
    <DockPanel LastChildFill="True">
        
        <!-- Footer/Status Bar - Docked to Bottom FIRST -->
        <Border DockPanel.Dock="Bottom" 
                Background="{DynamicResource FooterBackgroundBrush}" 
                Padding="20,10"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" 
                           FontSize="12" 
                           Foreground="{DynamicResource MutedTextBrush}"
                           VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                    </TextBlock.Effect>
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Status">
                            <Binding Path="StatusMessage"/>
                            <Binding Path="PrivacyModeEnabled"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
                    <TextBlock Text="{Binding LastSyncTime, StringFormat='Last sync: {0}'}" 
                               FontSize="11" 
                               Foreground="{DynamicResource MutedTextBrush}"
                               VerticalAlignment="Center"/>
                    <Border Width="1" Height="16" Background="{DynamicResource ControlBorderBrush}"/>
                    <TextBlock Text="🔒 Encrypted" 
                               FontSize="11" 
                               Foreground="{DynamicResource SuccessBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Header/Toolbar - Docked to Top -->
    <Border DockPanel.Dock="Top" 
        Background="{DynamicResource HeaderBackgroundBrush}" 
        Padding="{StaticResource DialogPadding}"
        BorderBrush="{DynamicResource ControlBorderBrush}"
        BorderThickness="0,0,0,1"
        Effect="{DynamicResource SubtleDropShadow}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                
                <!-- Left: Logo and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="{StaticResource Space12}" VerticalAlignment="Center">
                    <TextBlock Text="🔒" FontSize="24" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2">
                        <TextBlock Text="PhantomVault" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="{Binding VaultName}" 
                                   FontSize="11" 
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                    </StackPanel>
                </StackPanel>
                
                <!-- Center: Search Box -->
        <Border Grid.Column="1" 
                        Background="{DynamicResource ControlBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
            Margin="30,0"
            MinWidth="320"
            MaxWidth="700">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0" 
                                   Text="🔍" 
                                   FontSize="16" 
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                        <TextBox Grid.Column="1" 
                                 Text="{Binding SearchText}"
                                 Watermark="{DynamicResource Str.Vault.SearchPlaceholder}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="8,8"
                                 FontSize="13"
                                 AutomationProperties.Name="Search credentials"
                                 AutomationProperties.HelpText="Type to filter your stored credentials by name, username, or URL"/>
                        <!-- Allow Esc to clear search quickly -->
                        <InputElement.KeyBindings>
                            <KeyBinding Gesture="Escape" Command="{Binding ClearSearchCommand}"/>
                        </InputElement.KeyBindings>
                        <Button Grid.Column="2"
                                Content="✕"
                                Command="{Binding ClearSearchCommand}"
                                Classes="secondary"
                                Width="30"
                                Height="30"
                                Margin="0,0,4,0"
                                ToolTip.Tip="Clear search"
                                AutomationProperties.Name="Clear search"
                                IsVisible="{Binding HasSearchText}"/>
                    </Grid>
                </Border>
                
                <!-- Right: Action Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="{StaticResource Space10}">
                    <!-- Add Entry Dropdown Button -->
                    <Button x:Name="AddEntryButton"
                            Background="{DynamicResource AccentBrush}"
                            Width="140"
                            Height="36"
                            ToolTip.Tip="Add new entry"
                            AutomationProperties.Name="Add new entry"
                            AutomationProperties.HelpText="Create a new entry of various types"
                            Click="AddEntryButton_Click">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" 
                                       Text="Add Entry" 
                                       VerticalAlignment="Center" 
                                       HorizontalAlignment="Center"
                                       Margin="0,0,4,0"/>
                            <TextBlock Grid.Column="1" 
                                       Text="▼" 
                                       FontSize="10" 
                                       VerticalAlignment="Center"
                                       Opacity="0.8"/>
                        </Grid>
                        <Button.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                <MenuItem Header="Login Credential" Command="{Binding AddLoginCredentialCommand}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="🔐" FontSize="16"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Secure Note" Command="{Binding AddSecureNoteCommand}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="📝" FontSize="16"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Credit Card" Command="{Binding AddCreditCardCommand}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="💳" FontSize="16"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Identity Document" Command="{Binding AddIdentityCommand}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="🆔" FontSize="16"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Bank Account" Command="{Binding AddBankAccountCommand}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="🏦" FontSize="16"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="API Key" Command="{Binding AddApiKeyCommand}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="🔑" FontSize="16"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    
                    <Button Click="OpenPasswordGenerator_Click"
                            Classes="secondary"
                            Width="40"
                            Height="36"
                            ToolTip.Tip="Password Generator"
                            AutomationProperties.Name="Password Generator"
                            AutomationProperties.HelpText="Open the password generator to create strong random passwords">
                        <TextBlock Text="⚡" FontSize="18" VerticalAlignment="Center"/>
                    </Button>
                    
                    <Button Command="{Binding LockCommand}"
                            Classes="secondary"
                            Width="100"
                            Height="36"
                            ToolTip.Tip="Lock vault and return"
                            AutomationProperties.Name="Lock vault"
                            AutomationProperties.HelpText="Lock and close the vault to protect your credentials">
                        <TextBlock Text="{DynamicResource Str.Vault.Lock}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    
                    <Button x:Name="SettingsButton"
                            Classes="secondary"
                            Width="36"
                            Height="36"
                            ToolTip.Tip="Vault settings"
                            AutomationProperties.Name="Settings menu"
                            AutomationProperties.HelpText="Open settings menu for theme, layout, and vault configuration">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="Dark theme"
                                          ToggleType="CheckBox"
                                          IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"/>
                                <MenuItem Header="Grid layout"
                                          ToggleType="CheckBox"
                                          IsChecked="{Binding IsGridView, Mode=TwoWay}"/>
                                <Separator/>
                                <MenuItem Header="Theme Settings…" Click="OpenThemeSettings_Click"/>
                                <MenuItem Header="More settings…" Click="OpenSettings_Click"/>
                            </MenuFlyout>
                        </Button.Flyout>
                        <TextBlock Text="⚙" FontSize="16"/>
                    </Button>
                    <!-- Header star removed; favorites quick-access restored in sidebar. -->
                    <!-- Theme toggle removed from top-right toolbar; theme switching is available in Settings only -->
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content Area: Sidebar + Credential List + Detail View - Fills Remaining Space -->
        <Grid>
            <!-- Base Content Layer -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <!-- Slightly larger center column while keeping tiles' internal sizes fixed -->
                    <ColumnDefinition Width="*" MinWidth="300" MaxWidth="440"/>
                    <ColumnDefinition
                                      Width="{Binding IsVisible, ElementName=DetailPanel, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter='*|0'}"
                                      MinWidth="520"/>
                </Grid.ColumnDefinitions>
            
            <!-- Left Sidebar: Categories and Filters -->
        <Border Grid.Column="0" 
            Background="{DynamicResource ContentBackgroundBrush}"
            BorderBrush="{DynamicResource ControlBorderBrush}"
            BorderThickness="0,0,1,0"
        Padding="0,20"
        Effect="{DynamicResource SubtleDropShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="0">
                        
                        <!-- Entry Types Dropdown Filter -->
                        <StackPanel Spacing="4" Margin="0,0,0,12">
                            <ToggleButton x:Name="EntryTypeDropdownToggle"
                                          Classes="secondary"
                                          HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Left"
                                          Height="36"
                                          CornerRadius="0"
                                          Background="{DynamicResource ContentBackgroundBrush}"
                                          Foreground="{DynamicResource ControlForegroundBrush}"
                                          Margin="6,0">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <TextBlock Grid.Column="0" 
                                               Text="🔽" 
                                               FontSize="14" 
                                               VerticalAlignment="Center"
                                               Margin="4,0,8,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="ENTRY TYPES"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="▼"
                                               FontSize="10"
                                               VerticalAlignment="Center"
                                               Margin="4,0">
                                        <TextBlock.Styles>
                                            <Style Selector="TextBlock">
                                                <Setter Property="RenderTransform">
                                                    <RotateTransform Angle="0"/>
                                                </Setter>
                                            </Style>
                                            <Style Selector="ToggleButton:checked TextBlock">
                                                <Setter Property="RenderTransform">
                                                    <RotateTransform Angle="180"/>
                                                </Setter>
                                            </Style>
                                        </TextBlock.Styles>
                                    </TextBlock>
                                </Grid>
                            </ToggleButton>

                            <ItemsControl Margin="0" IsVisible="{Binding #EntryTypeDropdownToggle.IsChecked}">
                                <Button Command="{Binding FilterByEntryTypeCommand}"
                                        CommandParameter="All"
                                        Classes="secondary"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="36"
                                        CornerRadius="0"
                                        Background="{DynamicResource ContentBackgroundBrush}"
                                        Foreground="{DynamicResource ControlForegroundBrush}"
                                        Margin="6,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                        <TextBlock Text="📋" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="All Types" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding FilterByEntryTypeCommand}"
                                        CommandParameter="Password"
                                        Classes="secondary"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="36"
                                        CornerRadius="0"
                                        Background="{DynamicResource ContentBackgroundBrush}"
                                        Foreground="{DynamicResource ControlForegroundBrush}"
                                        Margin="6,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                        <TextBlock Text="🔐" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Passwords" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding FilterByEntryTypeCommand}"
                                        CommandParameter="CreditCard"
                                        Classes="secondary"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="36"
                                        CornerRadius="0"
                                        Background="{DynamicResource ContentBackgroundBrush}"
                                        Foreground="{DynamicResource ControlForegroundBrush}"
                                        Margin="6,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                        <TextBlock Text="💳" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Credit Cards" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding FilterByEntryTypeCommand}"
                                        CommandParameter="BankAccount"
                                        Classes="secondary"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="36"
                                        CornerRadius="0"
                                        Background="{DynamicResource ContentBackgroundBrush}"
                                        Foreground="{DynamicResource ControlForegroundBrush}"
                                        Margin="6,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                        <TextBlock Text="🏦" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Bank Accounts" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding FilterByEntryTypeCommand}"
                                        CommandParameter="Identity"
                                        Classes="secondary"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="36"
                                        CornerRadius="0"
                                        Background="{DynamicResource ContentBackgroundBrush}"
                                        Foreground="{DynamicResource ControlForegroundBrush}"
                                        Margin="6,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                        <TextBlock Text="🆔" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Identity Documents" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding FilterByEntryTypeCommand}"
                                        CommandParameter="ApiKey"
                                        Classes="secondary"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="36"
                                        CornerRadius="0"
                                        Background="{DynamicResource ContentBackgroundBrush}"
                                        Foreground="{DynamicResource ControlForegroundBrush}"
                                        Margin="6,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                        <TextBlock Text="🔑" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="API Keys" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding FilterByEntryTypeCommand}"
                                        CommandParameter="WiFi"
                                        Classes="secondary"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="36"
                                        CornerRadius="0"
                                        Background="{DynamicResource ContentBackgroundBrush}"
                                        Foreground="{DynamicResource ControlForegroundBrush}"
                                        Margin="6,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                        <TextBlock Text="📶" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="WiFi Networks" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding FilterByEntryTypeCommand}"
                                        CommandParameter="Contact"
                                        Classes="secondary"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="36"
                                        CornerRadius="0"
                                        Background="{DynamicResource ContentBackgroundBrush}"
                                        Foreground="{DynamicResource ControlForegroundBrush}"
                                        Margin="6,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                        <TextBlock Text="👤" FontSize="16" VerticalAlignment="Center"/>
                                        <TextBlock Text="Contacts" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </ItemsControl>
                        </StackPanel>
                        
                        <!-- Quick Filters -->
                        <StackPanel Spacing="{StaticResource Space6}">
                            <Border Background="Transparent"
                                    Margin="0,0,0,6"
                                    Padding="12,0">
                                <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <!-- Use composite brush so a very subtle grey base sits under the glass highlight -->
                                            <Setter Property="Background" Value="{DynamicResource SidebarHeadingHoverCompositeBrush}"/>
                                            <!-- Reduce horizontal padding on hover so the highlight reaches almost to the edges -->
                                            <Setter Property="Padding" Value="6,0"/>
                                        </Style>
                                    </Border.Styles>
                                <TextBlock Text="QUICK ACCESS"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                            </Border>

                            <Grid>
                                <StackPanel x:Name="QuickFilterButtonsPanel"
                                            Spacing="{StaticResource Space6}"
                                            Margin="0">
                                    <ToggleButton Command="{Binding ShowAllCommand}"
                                                  IsChecked="{Binding IsShowingAll, Mode=TwoWay}"
                                                  Classes="quick-filter">
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                            <TextBlock Text="All Items" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding TotalCount}"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </ToggleButton>

                                    <ToggleButton Command="{Binding ShowFavoritesCommand}"
                                                  IsChecked="{Binding IsShowingFavorites, Mode=TwoWay}"
                                                  Classes="quick-filter">
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                            <TextBlock Text="Favorites" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding FavoritesCount}"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </ToggleButton>

                                    <ToggleButton Command="{Binding ShowPasskeysCommand}"
                                                  IsChecked="{Binding IsShowingPasskeys, Mode=TwoWay}"
                                                  Classes="quick-filter">
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                            <TextBlock Text="Passkeys" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding PasskeysCount}"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </ToggleButton>

                                    <ToggleButton Command="{Binding ShowRecentCommand}"
                                                  IsChecked="{Binding IsShowingRecent, Mode=TwoWay}"
                                                  Classes="quick-filter">
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                            <TextBlock Text="Recent" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>

                                    <ToggleButton Command="{Binding ShowExpiringSoonCommand}"
                                                  IsChecked="{Binding IsShowingExpiringSoon, Mode=TwoWay}"
                                                  Classes="quick-filter">
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                            <TextBlock Text="Expiring Soon" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                </StackPanel>

                                <Border x:Name="QuickFilterHighlight"
                                        Height="44"
                                        VerticalAlignment="Top"
                                        HorizontalAlignment="Stretch"
                                        Margin="{Binding QuickFilterHighlightMargin}"
                                        Opacity="{Binding QuickFilterHighlightOpacity}"
                                        RenderTransformOrigin="0.5,0.5"
                                        IsHitTestVisible="False">
                                    <Border.Transitions>
                                        <Transitions>
                                            <ThicknessTransition Property="Margin" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                                            <DoubleTransition Property="Opacity" Duration="0:0:0.12" Easing="CubicEaseOut"/>
                                        </Transitions>
                                    </Border.Transitions>
                                    <Border.RenderTransform>
                                        <TranslateTransform X="{Binding QuickFilterHighlightOffset}">
                                            <TranslateTransform.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="X" Duration="0:0:0.10" Easing="CubicEaseOut"/>
                                                </Transitions>
                                            </TranslateTransform.Transitions>
                                        </TranslateTransform>
                                    </Border.RenderTransform>
                                    <Grid IsHitTestVisible="False" ClipToBounds="True" Margin="0">
                                        <Border CornerRadius="16"
                                                Margin="0"
                                                Opacity="0.18">
                                            <Border.Background>
                                                <VisualBrush Visual="{Binding #QuickFilterButtonsPanel}"
                                                             Stretch="UniformToFill"
                                                             AlignmentX="Center"
                                                             AlignmentY="Center"/>
                                            </Border.Background>
                                            <Border.OpacityMask>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                    <GradientStop Color="#18FFFFFF" Offset="0.5"/>
                                                    <GradientStop Color="#FFFFFFFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.OpacityMask>
                                        </Border>
                                        <Border CornerRadius="16"
                                                Opacity="0.72">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                                                    <GradientStop Color="#28FFFFFF" Offset="{Binding QuickFilterHighlightLightLeft}"/>
                                                    <GradientStop Color="#88FFFFFF" Offset="{Binding QuickFilterHighlightSheenInnerLeft}"/>
                                                    <GradientStop Color="#C6FFFFFF" Offset="{Binding QuickFilterHighlightLightShift}"/>
                                                    <GradientStop Color="#88FFFFFF" Offset="{Binding QuickFilterHighlightSheenInnerRight}"/>
                                                    <GradientStop Color="#28FFFFFF" Offset="{Binding QuickFilterHighlightLightRight}"/>
                                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <Border Background="{StaticResource QuickFilterGelTopHighlightBrush}"
                                                CornerRadius="13"
                                                Margin="6,2,6,0"
                                                Height="18"
                                                VerticalAlignment="Top"
                                                Opacity="0.72"/>
                                        <Border Background="{StaticResource QuickFilterGelBottomGlowBrush}"
                                                CornerRadius="14"
                                                Margin="8,0,8,4"
                                                Height="16"
                                                VerticalAlignment="Bottom"
                                                Opacity="0.62"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <TextBlock Text="CATEGORIES"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,4,0,0"/>

                            <ItemsControl ItemsSource="{Binding Categories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding $parent[Window].DataContext.SelectCategoryCommand}"
                                                CommandParameter="{Binding Name}"
                                                Classes="secondary"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Height="36"
                                                CornerRadius="0"
                                                AutomationProperties.Name="{Binding Name, StringFormat='Category: {0} ({1} items)'}"
                                                Background="{DynamicResource ContentBackgroundBrush}"
                                                Foreground="{DynamicResource ControlForegroundBrush}"
                                                Margin="0,1">
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="8,0,0,0">
                                                <!-- Category color bar (slightly inset) -->
                                                <Border Width="6" Height="20" CornerRadius="3" VerticalAlignment="Center">
                                                    <Border.Background>
                                                        <Binding Path="TileColor" Converter="{StaticResource HexToBrushConverter}"/>
                                                    </Border.Background>
                                                </Border>
                                                <TextBlock Text="{Binding Name}"
                                                           VerticalAlignment="Center"
                                                               Foreground="{Binding TileColor, Converter={StaticResource HexToForegroundBrushConverter}, TargetNullValue={StaticResource ControlForegroundBrush}}"/>
                                                <TextBlock Text="{Binding Count}"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Command="{Binding ManageCategoriesCommand}"
                                    Classes="secondary"
                                    Background="{DynamicResource ContentBackgroundBrush}"
                                    Foreground="{DynamicResource ControlForegroundBrush}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Height="32"
                                    FontSize="11"
                                    CornerRadius="0"
                                    Margin="12,6,12,12">
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource Space6}">
                                    <TextBlock Text="Manage"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            
            <!-- Middle: Credentials List -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*">
                
                <!-- Header Section (Fixed) -->
        <Border Grid.Row="0" 
                        Background="{DynamicResource ContentBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="0,0,0,1"
            Padding="16,14"
            Effect="{DynamicResource SubtleDropShadow}">
                    <!-- Wrap header content so we can place a subtle shadow line under the bottom border -->
                    <Grid RowDefinitions="*,Auto">
                        <Grid Grid.Row="0">
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{Binding CurrentViewTitle}" 
                                               FontSize="18" 
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <TextBlock Text="{Binding FilteredCount, StringFormat='{}{0} items'}" 
                                               FontSize="12" 
                                               Foreground="{DynamicResource MutedTextBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" IsVisible="{Binding !IsShowingSecureTrash}">
                                    <ComboBox SelectedIndex="{Binding SortOption}"
                                              Width="150"
                                              Height="32"
                                              Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                              BorderBrush="{DynamicResource ControlBorderBrush}"
                                              ToolTip.Tip="Sort by">
                                        <ComboBoxItem Content="Name (A-Z)"/>
                                        <ComboBoxItem Content="Name (Z-A)"/>
                                        <ComboBoxItem Content="Recently Added"/>
                                        <ComboBoxItem Content="Recently Modified"/>
                                        <ComboBoxItem Content="Category"/>
                                    </ComboBox>
                                    
                                    <Button Command="{Binding ToggleViewModeCommand}"
                                                Classes="secondary"
                                                Width="36"
                                                Height="36"
                        MinWidth="0"
                                                ToolTip.Tip="Toggle list/grid view">
                                        <TextBlock Text="{Binding ViewModeIcon}" FontSize="16"/>
                                    </Button>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsShowingSecureTrash}">
                                    <Button Command="{Binding ToggleTrashSelectAllCommand}"
                                            Classes="secondary"
                                            Height="36"
                                            MinWidth="0"
                                            Padding="12,0"
                                            ToolTip.Tip="Toggle selection for all items">
                                        <TextBlock Text="Toggle All" FontSize="13"/>
                                    </Button>
                                    <Button Command="{Binding RestoreSelectedTrashCommand}"
                                            Background="{DynamicResource AccentBrush}"
                                            Height="36"
                                            MinWidth="0"
                                            Padding="12,0"
                                            IsEnabled="{Binding HasTrashSelection}">
                                        <TextBlock Text="Recover Selected" FontSize="13" Foreground="White"/>
                                    </Button>
                                    <Button Command="{Binding PurgeSelectedTrashCommand}"
                                            Background="{DynamicResource ErrorBrush}"
                                            Height="36"
                                            MinWidth="0"
                                            Padding="12,0"
                                            IsEnabled="{Binding HasTrashSelection}">
                                        <TextBlock Text="Delete Selected" FontSize="13" Foreground="White"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Subtle shadow below header border: position lower so it sits under the 1px header border -->
                        <Rectangle Grid.Row="1" Height="8" VerticalAlignment="Top" Margin="0,1,0,0" IsHitTestVisible="False">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#1A000000" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Grid>
                </Border>
                
                <!-- Scrollable Content Area -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,4,0,16"
                              ZIndex="0">
                    <!-- Center the list inside the center column and constrain tile widths so they don't touch the right column -->
                    <StackPanel Spacing="0" HorizontalAlignment="Stretch" Margin="0">
                        <StackPanel IsVisible="{Binding !IsShowingSecureTrash}">
                            <!-- Credentials List (List Mode - Virtualized) -->
                            <Grid x:Name="CredentialListHost" Margin="16,0,16,0" IsVisible="{Binding !IsGridView}">
                                <ListBox x:Name="CredentialListBox"
                                         ItemsSource="{Binding FilteredCredentials}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         SelectionMode="Single"
                                         HorizontalAlignment="Stretch"
                                         PointerMoved="CredentialListBox_PointerMoved"
                                         PointerExited="CredentialListBox_PointerExited">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Background" Value="{x:Null}"/>
                                        <Setter Property="BorderBrush" Value="{x:Null}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Height" Value="100"/>
                                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{x:Null}" Height="{StaticResource TileHeight}" MinHeight="{StaticResource TileHeight}" MaxHeight="{StaticResource TileHeight}" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                                        <ContentPresenter Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}" HorizontalAlignment="Stretch" VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover, ListBoxItem:selected, ListBoxItem:focus">
                                        <Setter Property="Background" Value="{x:Null}"/>
                                        <Setter Property="BorderBrush" Value="{x:Null}"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Each Credential Card (List) -->
                                                <Button Command="{Binding $parent[Window].DataContext.TileClickCommand}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Classes="tile-button"
                                                HorizontalAlignment="Stretch"
                                                VerticalContentAlignment="Center"
                                                Height="100"
                                                AutomationProperties.Name="{Binding Title}">
                                                <Border Background="{DynamicResource TileGlassBrush}"
                                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="12,10,12,10"
                                                        HorizontalAlignment="Stretch"
                                                        Height="100"
                                                        VerticalAlignment="Center"
                                                        ClipToBounds="True"
                                                        Effect="{DynamicResource SubtleDropShadow}">
                                                    <Border.Styles>
                                                        <Style Selector="Border:pointerover">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter Property="Effect" Value="{DynamicResource TileActiveShadow}" />
                                                        </Style>
                                                        <Style Selector="Border:pressed">
                                                            <Setter Property="Effect" Value="{DynamicResource TileActiveShadowPressed}" />
                                                        </Style>
                                                    </Border.Styles>

                                                    <Grid>
                                                        <!-- Material sheen overlay below content -->
                                                        <Border Background="{DynamicResource TileOverlayBrush}" CornerRadius="8" IsHitTestVisible="False"/>
                                                        <!-- Category color bar on the left edge -->
                                                        <Border Width="8" HorizontalAlignment="Left" VerticalAlignment="Stretch" CornerRadius="8,0,0,8" Margin="-22,-8,0,-8" IsHitTestVisible="False" Opacity="0.45">
                                                            <Border.Background>
                                                                <MultiBinding Converter="{StaticResource CategoryNameToBrushConverter}">
                                                                    <Binding Path="Group"/>
                                                                    <Binding Path="$parent[Window].DataContext.Categories"/>
                                                                </MultiBinding>
                                                            </Border.Background>
                                                        </Border>
                                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                                            <Grid Grid.Column="0" Margin="0,0,18,0" VerticalAlignment="Center">
                                                                <!-- Icon with an overlaid category tag that sits at the bottom, centered -->
                                                                <Border Background="{Binding IconBackgroundBrush}" Width="88" Height="88" CornerRadius="44" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <Grid>
                                                                        <Image Source="{Binding AutoDetectedIconBitmap}" Width="80" Height="80" Stretch="Uniform" IsVisible="{Binding HasAutoDetectedIcon}"/>

                                                                        <StackPanel IsVisible="{Binding !HasAutoDetectedIcon}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding DisplayIcon}" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" IsVisible="{Binding HasCustomIcon}"/>
                                                                            <TextBlock Text="{Binding IconText}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>

                                                            <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="6" VerticalAlignment="Center" Margin="0,0,6,0">
                                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap">
                                                                        <TextBlock.Effect>
                                                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                                                        </TextBlock.Effect>
                                                                        <TextBlock.Text>
                                                                            <MultiBinding Converter="{StaticResource PrivacyMaskConverter}">
                                                                                <Binding Path="Title"/>
                                                                                <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                    <!-- Non-interactive favorite indicator for list tiles -->
                                                                    <TextBlock Text="{Binding FavoriteIcon}" FontSize="14" VerticalAlignment="Center"/>
                                                                </StackPanel>

                                                                <!-- Username on first line, URL underneath it on its own line -->
                                                                <StackPanel Orientation="Vertical" Spacing="2">
                                                                    <TextBlock FontSize="15" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" MaxWidth="360">
                                                                        <TextBlock.Effect>
                                                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                                                        </TextBlock.Effect>
                                                                        <TextBlock.Text>
                                                                            <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Username">
                                                                                <Binding Path="Username"/>
                                                                                <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                    <TextBlock FontSize="14" Foreground="{DynamicResource MutedTextBrush}" TextTrimming="CharacterEllipsis" IsVisible="{Binding HasUrl}" MaxWidth="360">
                                                                        <TextBlock.Effect>
                                                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                                                        </TextBlock.Effect>
                                                                        <TextBlock.Text>
                                                                            <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Url">
                                                                                <Binding Path="Url"/>
                                                                                <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <!-- Only Copy Password button on tiles -->
                                                            <Button Grid.Column="2"
                                                                    Command="{Binding $parent[Window].DataContext.CopyPasswordCommand}"
                                                                    CommandParameter="{Binding}"
                                                                    Background="{DynamicResource AccentBrush}"
                                                                    Width="34"
                                                                    Height="34"
                                                                    MinWidth="0"
                                                                    Padding="4"
                                                                    CornerRadius="6"
                                                                    VerticalAlignment="Center"
                                                                    Margin="6,0,0,0"
                                                                    ToolTip.Tip="Copy password to clipboard">
                                                                <Image Source="avares://PhantomVault.UI/Assets/Icons/PO%20UI/Copy%20to%20clipboard%202/Copy%20to%20clipboard%202_charcoal.png"
                                                                       Width="22"
                                                                       Height="22"
                                                                       Stretch="Uniform"/>
                                                            </Button>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                        </Button>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            
                                </ListBox>

                                <!-- <controls:LiquidGlassHighlightBar x:Name="CredentialHoverHighlight"
                                                                HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Margin="0"
                                                                Opacity="0"
                                                                IsHitTestVisible="False"
                                                                BarWidth="260"
                                                                BarHeight="100"
                                                                ZIndex="2"/> -->
                            </Grid>

                            <!-- Credentials Grid (Grid Mode) -->
                            <!-- Note: Grid view does not use virtualization due to WrapPanel limitations.
                                 For large vaults (500+ credentials), use List view for better performance. -->
                            <ItemsControl ItemsSource="{Binding FilteredCredentials}" IsVisible="{Binding IsGridView}" ClipToBounds="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <!-- Do not fix ItemWidth/ItemHeight so tiles can be measured and tile Margin will add spacing -->
                                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" ClipToBounds="False" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Tile container: Button contains only the visible tile; overlay is sibling so it does not expand hit area -->
                                    <Grid HorizontalAlignment="Left" Margin="16,24,16,24">
                                        <!-- Visible tile button -->
                                        <Button Command="{Binding $parent[Window].DataContext.TileClickCommand}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Classes="tile-button-grid"
                                                HorizontalAlignment="Left">
                        <Border Width="260" Height="108" Padding="8" CornerRadius="10"
                                                    Background="{DynamicResource TileGlassBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="0"
                                                    Effect="{DynamicResource SubtleDropShadow}">
                                                <Grid>
                                                    <!-- Material sheen overlay below content -->
                                                    <Border Background="{DynamicResource TileOverlayBrush}" CornerRadius="10" IsHitTestVisible="False"/>
                                                    <!-- Category color bar on the left edge -->
                                                    <Border Width="8" HorizontalAlignment="Left" VerticalAlignment="Stretch" CornerRadius="10,0,0,10" Margin="-18,-8,0,-8" IsHitTestVisible="False" Opacity="0.45">
                                                        <Border.Background>
                                                            <MultiBinding Converter="{StaticResource CategoryNameToBrushConverter}">
                                                                <Binding Path="Group"/>
                                                                <Binding Path="$parent[Window].DataContext.Categories"/>
                                                            </MultiBinding>
                                                        </Border.Background>
                                                    </Border>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                            <!-- Increase bottom area to push visual separators further down -->
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="24" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Spacing="10">
                                                <Border Width="64" Height="64" CornerRadius="32" Background="{Binding IconBackgroundBrush}">
                                                    <Grid>
                                                        <Image Source="{Binding AutoDetectedIconBitmap}" Width="56" Height="56" Stretch="Uniform" IsVisible="{Binding HasAutoDetectedIcon}"/>
                                                        <TextBlock Text="{Binding IconText}" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding !HasAutoDetectedIcon}"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center">
                                                <!-- Truncate long titles to prevent pushing action buttons out of the tile -->
                                                <TextBlock FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis" MaxWidth="120">
                                                    <TextBlock.Effect>
                                                        <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                                    </TextBlock.Effect>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource PrivacyMaskConverter}">
                                                            <Binding Path="Title"/>
                                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock FontSize="13" Foreground="{DynamicResource MutedTextBrush}" TextTrimming="CharacterEllipsis" MaxWidth="160">
                                                    <TextBlock.Effect>
                                                        <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                                    </TextBlock.Effect>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Username">
                                                            <Binding Path="Username"/>
                                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                    <!-- Subtle bottom separator pushed down for clearer separation -->
                                    <Rectangle Grid.Row="1" Grid.ColumnSpan="3" Height="4" Opacity="0.18" Fill="{DynamicResource SeparatorBrush}" />
                                    <Rectangle Grid.Row="1" Grid.ColumnSpan="3" Height="1" Fill="{DynamicResource ControlBorderBrush}" Opacity="0.6" VerticalAlignment="Bottom"/>
                    </Grid>
                                            </Border>
                                        </Button>

                                        <!-- Overlay action panel positioned to the right of the tile; does not affect tile's hit area -->
                    <Border Width="72" Height="120" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="-60,0,0,0" Background="Transparent" IsHitTestVisible="False">
                                            <Canvas IsHitTestVisible="True">
                        <Border Canvas.Top="-26" Canvas.Right="0" CornerRadius="8" Padding="0" Width="72" Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            Effect="{DynamicResource HoverMenuDropShadow}"
                            Opacity="0">
                                                    <Grid Name="ActionOverlayInner" Width="72" Margin="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <!-- Copy button -->
                                                        <Button Grid.Row="0" Grid.Column="0" Command="{Binding $parent[Window].DataContext.CopyPasswordCommand}"
                                                            CommandParameter="{Binding}"
                                                            Background="{DynamicResource ButtonWhiteBackgroundBrush}" Foreground="{DynamicResource AccentBrush}"
                                                            Width="28"
                                                            Height="28"
                                                            Padding="0"
                                                            HorizontalAlignment="Center"
                                                            HorizontalContentAlignment="Center"
                                                            MinWidth="0"
                                                            Margin="0,4,0,0">
                                                            <TextBlock Text="⧉" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Button>

                                                        <Button Grid.Row="1" Grid.Column="0" Command="{Binding $parent[Window].DataContext.EditCredentialCommand}"
                                                            CommandParameter="{Binding}"
                                                            Classes="secondary"
                                                            Width="28"
                                                            Height="28"
                                                            Padding="0"
                                                            HorizontalAlignment="Center"
                                                            HorizontalContentAlignment="Center"
                                                            MinWidth="0"
                                                            Margin="0,6,0,0">
                                                            <TextBlock Text="✏" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Button>

                                                        <Button Grid.Row="2" Grid.Column="0" Command="{Binding $parent[Window].DataContext.DeleteCredentialCommand}"
                                                            CommandParameter="{Binding}"
                                                            Classes="secondary"
                                                            Width="28"
                                                            Height="28"
                                                            Padding="0"
                                                            HorizontalAlignment="Center"
                                                            HorizontalContentAlignment="Center"
                                                            MinWidth="0"
                                                            Margin="0,6,0,0">
                                                            <TextBlock Text="🗑" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Button>

                                                        <Button Grid.Row="3" Grid.Column="0" Command="{Binding $parent[Window].DataContext.ToggleFavoriteCommand}"
                                                            CommandParameter="{Binding}"
                                                            Classes="secondary"
                                                            Width="28"
                                                            Height="28"
                                                            Padding="0"
                                                            HorizontalAlignment="Center"
                                                            HorizontalContentAlignment="Center"
                                                            MinWidth="0"
                                                            Margin="0,6,0,0">
                                                            <TextBlock Text="{Binding FavoriteIcon}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </Canvas>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Secure Trash List -->
                        <ListBox ItemsSource="{Binding FilteredTrashItems}" IsVisible="{Binding IsShowingSecureTrash}" BorderThickness="0" Background="Transparent" Margin="16,0,16,0" SelectionMode="Single" HorizontalAlignment="Stretch" SelectedItem="{Binding SelectedTrashItem, Mode=TwoWay}">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Background" Value="{x:Null}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,4"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                                <Style Selector="ListBoxItem:pointerover, ListBoxItem:selected, ListBoxItem:focus">
                                    <Setter Property="Background" Value="{x:Null}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource TileGlassBrush}"
                                            BorderBrush="{DynamicResource ControlBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12"
                                            HorizontalAlignment="Stretch"
                                            Effect="{DynamicResource SubtleDropShadow}">
                                        <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="6">
                                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <TextBlock FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis">
                                                        <TextBlock.Effect>
                                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                                        </TextBlock.Effect>
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource PrivacyMaskConverter}">
                                                                <Binding Path="Payload.Title"/>
                                                                <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding DeletedRelative}" Foreground="{DynamicResource MutedTextBrush}" FontSize="13" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <TextBlock FontSize="15" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Effect>
                                                        <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                                    </TextBlock.Effect>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Username">
                                                            <Binding Path="Payload.Username"/>
                                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>

                                                <TextBlock FontSize="13" Foreground="{DynamicResource MutedTextBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,0,2">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Url">
                                                            <Binding Path="Payload.Url"/>
                                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                    <TextBlock.Effect>
                                                        <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>

                                                <TextBlock Text="{Binding OriginalGroup, StringFormat='Original group: {0}'}" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                <TextBlock Text="{Binding ScheduledPurgeLabel}" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <!-- Bottom spacer to prevent last credential from being cut off by footer -->
                        <Border Height="80" Background="Transparent"/>
                        
                        <!-- Empty State -->
                        <StackPanel Spacing="15" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"
                                    Margin="0,80,0,0"
                                    IsVisible="{Binding IsEmpty}">
                            <TextBlock Text="🔓" FontSize="64" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="No credentials found" 
                                       FontSize="18" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Add your first credential to get started" 
                                       FontSize="13" 
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       HorizontalAlignment="Center"/>
                            <Button Command="{Binding AddCredentialCommand}"
                                    Background="{DynamicResource AccentBrush}"
                                    Width="160"
                                    Height="40"
                                    HorizontalAlignment="Center"
                                    Margin="0,15,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="+" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="Add Credential" FontSize="14"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Edge depth shadows along side panel borders -->
                <Rectangle Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="8" IsHitTestVisible="False" ZIndex="2">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#14000000" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="8" IsHitTestVisible="False" IsVisible="{Binding IsVisible, ElementName=DetailPanel}" ZIndex="2">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="1,0" EndPoint="0,0">
                            <GradientStop Color="#14000000" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Top fade overlay so content appears to glide under the header -->
                <Rectangle Grid.Row="1" Height="18" VerticalAlignment="Top" IsHitTestVisible="False" ZIndex="2">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#12000000" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
            </Grid>
            
        <!-- Detail View Panel -->
        <Border x:Name="DetailPanel" Grid.Column="2" 
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
            BorderThickness="1,0,0,0"
            IsVisible="{Binding $parent[Window].Bounds.Width, Converter={StaticResource IsWidthAtLeastConverter}, ConverterParameter=1200}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="32,20,32,20">
                        <StackPanel IsVisible="{Binding !IsShowingSecureTrash}">
                        <!-- When SelectedCredential is not null -->
                        <StackPanel Spacing="24" IsVisible="{Binding SelectedCredential, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <!-- Header with Icon on left, text inline to the right; actions pinned top-right -->
                        <Grid ColumnDefinitions="Auto,16,*,Auto" HorizontalAlignment="Stretch">
                            <!-- Icon -->
                            <Border Grid.Column="0" Width="120" Height="120" CornerRadius="60" Background="{Binding SelectedCredential.IconBackgroundBrush}">
                                <Grid>
                                    <Image Source="{Binding SelectedCredential.AutoDetectedIconBitmap}"
                                           Width="108" Height="108" Stretch="Uniform"
                                           IsVisible="{Binding SelectedCredential.HasAutoDetectedIcon}"/>
                                    <TextBlock Text="{Binding SelectedCredential.IconText}" FontSize="48" FontWeight="Bold" Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               IsVisible="{Binding !SelectedCredential.HasAutoDetectedIcon}"/>
                                </Grid>
                            </Border>
                            
                            <!-- Text to the right of icon -->
                            <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center">
                                <TextBlock FontSize="32" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           TextWrapping="Wrap">
                                    <TextBlock.Effect>
                                        <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                    </TextBlock.Effect>
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource PrivacyMaskConverter}">
                                            <Binding Path="SelectedCredential.Title"/>
                                            <Binding Path="PrivacyModeEnabled"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="18" 
                                           Foreground="{DynamicResource SecondaryTextBrush}">
                                    <TextBlock.Effect>
                                        <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                    </TextBlock.Effect>
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Username">
                                            <Binding Path="SelectedCredential.Username"/>
                                            <Binding Path="PrivacyModeEnabled"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>

                            <!-- Action buttons (top-right) -->
                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,0,0,0">
                                <Button Command="{Binding EditCredentialCommand}"
                                        CommandParameter="{Binding SelectedCredential}"
                                        Classes="secondary"
                                        Width="36" Height="36" MinWidth="0"
                                        ToolTip.Tip="Edit">
                                    <TextBlock Text="✏" FontSize="16"/>
                                </Button>
                                <Button Command="{Binding ToggleFavoriteCommand}"
                                        CommandParameter="{Binding SelectedCredential}"
                                        Classes="secondary"
                                        Width="36" Height="36" MinWidth="0"
                                        ToolTip.Tip="Toggle favorite">
                                    <TextBlock Text="{Binding SelectedCredential.FavoriteIcon}" FontSize="16"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Credential Details -->
                        <StackPanel Spacing="20" Margin="0,16,0,0">
                            <!-- Username -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="Username" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" 
                                             Text="{Binding SelectedCredential.Username}" 
                                             IsReadOnly="True"
                                             Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                             Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}"
                                             BorderThickness="1"
                                             BorderBrush="{DynamicResource ControlBorderBrush}"
                                             Height="36"
                                             Padding="10,8">
                                        <TextBox.Effect>
                                            <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                        </TextBox.Effect>
                                        <TextBox.Styles>
                                            <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Style>
                                            <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Style>
                                        </TextBox.Styles>
                                    </TextBox>
                                    <Button Grid.Column="1"
                                            Command="{Binding CopyUsernameCommand}"
                                            CommandParameter="{Binding SelectedCredential}"
                                            Classes="secondary"
                                            Width="36"
                                            Height="36"
                                            Padding="4"
                                            Margin="8,0,0,0"
                                            ToolTip.Tip="Copy username">
                                        <Image Source="avares://PhantomVault.UI/Assets/Icons/PO%20UI/Copy%20to%20clipboard%202/Copy%20to%20clipboard%202_charcoal.png" 
                                               Width="18" 
                                               Height="18"
                                               Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                            
                            <!-- Password -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="Password" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" 
                                             Text="{Binding SelectedCredential.Password}" 
                                             PasswordChar="•"
                                             IsReadOnly="True"
                                             Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                             Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}"
                                             BorderThickness="1"
                                             BorderBrush="{DynamicResource ControlBorderBrush}"
                                             Height="36"
                                             Padding="10,8">
                                        <TextBox.Effect>
                                            <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                        </TextBox.Effect>
                                        <TextBox.Styles>
                                            <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Style>
                                            <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Style>
                                        </TextBox.Styles>
                                    </TextBox>
                                    <Button Grid.Column="1"
                                            Command="{Binding CopyPasswordCommand}"
                                            CommandParameter="{Binding SelectedCredential}"
                                            Background="{DynamicResource AccentBrush}"
                                            Width="36"
                                            Height="36"
                                            Padding="4"
                                            Margin="8,0,0,0"
                                            ToolTip.Tip="Copy password">
                                        <Image Source="avares://PhantomVault.UI/Assets/Icons/PO%20UI/Copy%20to%20clipboard%202/Copy%20to%20clipboard%202_charcoal.png" 
                                               Width="18" 
                                               Height="18"
                                               Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                            
                            <!-- URL -->
                            <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasUrl}">
                                <TextBlock Text="Website" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0" 
                                             Text="{Binding SelectedCredential.Url}" 
                                             IsReadOnly="True"
                                             Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                             Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}"
                                             BorderThickness="1"
                                             BorderBrush="{DynamicResource ControlBorderBrush}"
                                             Height="36"
                                             Padding="10,8">
                                        <TextBox.Effect>
                                            <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                        </TextBox.Effect>
                                        <TextBox.Styles>
                                            <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Style>
                                            <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Style>
                                        </TextBox.Styles>
                                    </TextBox>
                                    <Button Grid.Column="1"
                                            Command="{Binding OpenUrlCommand}"
                                            CommandParameter="{Binding SelectedCredential}"
                                            Classes="secondary"
                                            Width="36"
                                            Height="36"
                                            Padding="6"
                                            Margin="8,0,0,0"
                                            ToolTip.Tip="Open in browser">
                                        <Image Source="avares://PhantomVault.UI/Assets/Icons/PO%20UI/Web/3917565_charcoal.png" 
                                               Width="18" 
                                               Height="18"
                                               Stretch="Uniform"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                            
                            <!-- Category/Group -->
                            <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasGroup}">
                                <TextBlock Text="Category" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <Border Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1"
                                        Height="36"
                                        Padding="10,8"
                                        CornerRadius="4">
                                    <TextBlock Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}"
                                               VerticalAlignment="Center">
                                        <TextBlock.Effect>
                                            <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                        </TextBlock.Effect>
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource PrivacyMaskConverter}">
                                                <Binding Path="SelectedCredential.Group"/>
                                                <Binding Path="PrivacyModeEnabled"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            
                            <!-- Notes -->
                            <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasNotes}">
                                <TextBlock Text="Notes" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <TextBox Text="{Binding SelectedCredential.Notes}" 
                                         IsReadOnly="True"
                                         Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                         Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}"
                                         BorderThickness="1"
                                         BorderBrush="{DynamicResource ControlBorderBrush}"
                                         Padding="10,8"
                                         MinHeight="70"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap">
                                    <TextBox.Effect>
                                        <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                    </TextBox.Effect>
                                    <TextBox.Styles>
                                        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                            <Setter Property="Background" Value="#33FFFFFF"/>
                                        </Style>
                                        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                            <Setter Property="Background" Value="#33FFFFFF"/>
                                        </Style>
                                    </TextBox.Styles>
                                </TextBox>
                            </StackPanel>
                            
                            <!-- Metadata -->
                            <StackPanel Spacing="8">
                                <TextBlock Text="Information" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" 
                                               Text="Created:" 
                                               FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,0,12,0"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Text="{Binding SelectedCredential.Created}" 
                                               FontSize="12"
                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    
                                    <TextBlock Grid.Row="1" Grid.Column="0" 
                                               Text="Modified:" 
                                               FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,8,12,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" 
                                               Text="{Binding SelectedCredential.LastModified}" 
                                               FontSize="12"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Margin="0,8,0,0"/>
                                </Grid>
                            </StackPanel>
                            
                            <!-- Tags -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="Tags" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <Border Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1"
                                        Padding="10,8"
                                        CornerRadius="4"
                                        MinHeight="36">
                                    <TextBlock Text="{Binding SelectedCredential.TagsText}" 
                                               Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}"
                                               TextWrapping="Wrap"
                                               VerticalAlignment="Center">
                                        <TextBlock.Effect>
                                            <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            
                            <!-- Expiry Date -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="Expiration" 
                                           FontSize="13" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                                <Border Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1"
                                        Height="36"
                                        Padding="10,8"
                                        CornerRadius="4">
                                    <TextBlock Text="{Binding SelectedCredential.ExpiryText}"
                                               Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}"
                                               VerticalAlignment="Center">
                                        <TextBlock.Effect>
                                            <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            
                            <!-- Action Buttons -->
                            <Grid ColumnDefinitions="*,*" Margin="0,8,0,0">
                                <Button Grid.Column="0"
                                        Command="{Binding EditCredentialCommand}"
                                        CommandParameter="{Binding SelectedCredential}"
                                        Classes="secondary"
                                        HorizontalAlignment="Stretch"
                                        Height="44"
                                        FontWeight="SemiBold"
                                        Margin="0,0,6,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="✏" FontSize="16"/>
                                        <TextBlock Text="Edit" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1"
                                        Command="{Binding DeleteCredentialCommand}"
                                        CommandParameter="{Binding SelectedCredential}"
                                        Background="{DynamicResource ErrorBrush}"
                                        HorizontalAlignment="Stretch"
                                        Height="44"
                                        FontWeight="SemiBold"
                                        Margin="6,0,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="🗑" FontSize="16"/>
                                        <TextBlock Text="Delete" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Empty State when SelectedCredential is null -->
                    <StackPanel Spacing="20" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Center"
                                Margin="0,120,0,0"
                                IsVisible="{Binding SelectedCredential, Converter={x:Static ObjectConverters.IsNull}}">
                        <TextBlock Text="🔍" 
                                   FontSize="80" 
                                   HorizontalAlignment="Center" 
                                   Opacity="0.2"/>
                        <TextBlock Text="Select an item to view details" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Click on a credential from the list" 
                                   FontSize="13" 
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                        </StackPanel>

                        <!-- Secure trash detail -->
                        <StackPanel Spacing="24" IsVisible="{Binding IsShowingSecureTrash}">
                            <StackPanel Spacing="24" IsVisible="{Binding SelectedTrashItem, Converter={x:Static ObjectConverters.IsNotNull}}">
                                <Grid ColumnDefinitions="Auto,16,*,Auto" HorizontalAlignment="Stretch">
                                    <Border Grid.Column="0" Width="120" Height="120" CornerRadius="60" Background="{Binding SelectedTrashItem.Payload.IconBackgroundBrush}">
                                        <Grid>
                                            <Image Source="{Binding SelectedTrashItem.Payload.AutoDetectedIconBitmap}"
                                                   Width="108" Height="108" Stretch="Uniform"
                                                   IsVisible="{Binding SelectedTrashItem.Payload.HasAutoDetectedIcon}"/>
                                            <TextBlock Text="{Binding SelectedTrashItem.Payload.IconText}" FontSize="48" FontWeight="Bold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       IsVisible="{Binding !SelectedTrashItem.Payload.HasAutoDetectedIcon}"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="2" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock FontSize="32" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Effect>
                                                <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                            </TextBlock.Effect>
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource PrivacyMaskConverter}">
                                                    <Binding Path="SelectedTrashItem.Payload.Title"/>
                                                    <Binding Path="PrivacyModeEnabled"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock FontSize="18" Foreground="{DynamicResource SecondaryTextBrush}">
                                            <TextBlock.Effect>
                                                <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                            </TextBlock.Effect>
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Username">
                                                    <Binding Path="SelectedTrashItem.Payload.Username"/>
                                                    <Binding Path="PrivacyModeEnabled"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top" HorizontalAlignment="Right">
                                        <Button Command="{Binding RecoverTrashItemCommand}"
                                                CommandParameter="{Binding SelectedTrashItem}"
                                                Background="{DynamicResource AccentBrush}"
                                                Width="140"
                                                Height="40"
                                                FontWeight="SemiBold"
                                                ToolTip.Tip="Restore this entry">
                                            <TextBlock Text="Recover" FontSize="14" Foreground="White" HorizontalAlignment="Center"/>
                                        </Button>
                                        <Button Command="{Binding PurgeTrashItemCommand}"
                                                CommandParameter="{Binding SelectedTrashItem}"
                                                Background="{DynamicResource ErrorBrush}"
                                                Width="170"
                                                Height="40"
                                                FontWeight="SemiBold"
                                                ToolTip.Tip="Permanently delete this entry">
                                            <TextBlock Text="Delete Permanently" FontSize="14" Foreground="White" HorizontalAlignment="Center"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Spacing="20" Margin="0,16,0,0">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Username"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                        <Border Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                Height="36"
                                                Padding="10,8"
                                                CornerRadius="4">
                                            <TextBlock Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Effect>
                                                    <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                                </TextBlock.Effect>
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Username">
                                                        <Binding Path="SelectedTrashItem.Payload.Username"/>
                                                        <Binding Path="PrivacyModeEnabled"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Password"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                        <Border Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                Height="36"
                                                Padding="10,8"
                                                CornerRadius="4">
                                            <TextBlock Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Effect>
                                                    <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                                </TextBlock.Effect>
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Password">
                                                        <Binding Path="SelectedTrashItem.Payload.Password"/>
                                                        <Binding Path="PrivacyModeEnabled"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="6" IsVisible="{Binding SelectedTrashItem.Payload.HasUrl}">
                                        <TextBlock Text="Website"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                        <Border Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                Height="36"
                                                Padding="10,8"
                                                CornerRadius="4">
                                            <TextBlock Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Effect>
                                                    <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                                </TextBlock.Effect>
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Url">
                                                        <Binding Path="SelectedTrashItem.Payload.Url"/>
                                                        <Binding Path="PrivacyModeEnabled"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Original group"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                        <Border Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                Height="36"
                                                Padding="10,8"
                                                CornerRadius="4">
                                            <TextBlock Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                       Text="{Binding SelectedTrashItem.OriginalGroup}"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Deleted on"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                        <Border Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                Height="36"
                                                Padding="10,8"
                                                CornerRadius="4">
                                            <TextBlock Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}" VerticalAlignment="Center"
                                                       Text="{Binding SelectedTrashItem.DeletedUtc, StringFormat='{}{0:MMM dd, yyyy HH:mm}'}"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Scheduled purge"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                        <Border Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                Height="36"
                                                Padding="10,8"
                                                CornerRadius="4">
                                            <TextBlock Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}" VerticalAlignment="Center"
                                                       Text="{Binding SelectedTrashItem.ScheduledPurgeLabel}"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Placeholder when no trash item is selected -->
                            <StackPanel Spacing="20"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Margin="0,120,0,0"
                                        IsVisible="{Binding SelectedTrashItem, Converter={x:Static ObjectConverters.IsNull}}">
                                <TextBlock Text="🗑"
                                           FontSize="80"
                                           HorizontalAlignment="Center"
                                           Opacity="0.2"/>
                                <TextBlock Text="Select a secure bin item"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Choose an entry from the rubbish list to recover or delete"
                                           FontSize="13"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
            
            </Grid>
            
            <!-- Narrow-width Detail Overlay (mobile-style) -->
            <Border x:Name="MobileDetailOverlay"
                    Background="Transparent"
                    Tag="{Binding SelectedCredential, Converter={x:Static ObjectConverters.IsNotNull}}"
                    IsVisible="{Binding $parent[Window].Bounds.Width, Converter={StaticResource IsWidthLessThanConverter}, ConverterParameter=1200}"
                    IsHitTestVisible="{Binding SelectedCredential, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Border.Styles>
                    <Style Selector="Border#MobileDetailOverlay">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="Border#MobileDetailOverlay[IsVisible=True][Tag=True]">
                        <Setter Property="Background" Value="{DynamicResource OverlayBackgroundBrush}"/>
                        <Style.Animations>
                            <Animation Duration="0:0:0.20" FillMode="Forward" Easing="SineEaseOut">
                                <KeyFrame Cue="0%">
                                    <Setter Property="Opacity" Value="0"/>
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="Opacity" Value="1"/>
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                    <Style Selector="Border#MobileDetailPanel">
                        <Setter Property="Margin" Value="0,-12,0,0"/>
                    </Style>
                    <Style Selector="Border#MobileDetailOverlay[IsVisible=True] Border#MobileDetailPanel">
                        <Setter Property="Margin" Value="0,0,0,0"/>
                    </Style>
                </Border.Styles>
                <Grid>
                    <!-- Backdrop click closes overlay; content stops propagation -->
                    <Border Background="Transparent" PointerPressed="CloseMobileDetailOverlay_Click"/>
                    <!-- Fullscreen panel for detail view on narrow widths -->
                    <Border x:Name="MobileDetailPanel"
                            Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                        <!-- Esc closes overlay -->
                        <InputElement.KeyBindings>
                            <KeyBinding Gesture="Escape" Command="{Binding ClearSelectedCredentialCommand}"/>
                        </InputElement.KeyBindings>
                        <Border.Transitions>
                            <Transitions>
                                <ThicknessTransition Property="Margin" Duration="0:0:0.18" Easing="SineEaseOut"/>
                            </Transitions>
                        </Border.Transitions>

                        <Grid RowDefinitions="Auto,*">
                            <!-- Header -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource HeaderBackgroundBrush}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,12">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Button Grid.Column="0"
                                            Command="{Binding ClearSelectedCredentialCommand}"
                                            Classes="secondary"
                                            Width="36" Height="36"
                                            ToolTip.Tip="Back">
                                        <TextBlock Text="←" FontSize="16"/>
                                    </Button>
                                    <TextBlock Grid.Column="1"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource PrivacyMaskConverter}">
                                                <Binding Path="SelectedCredential.Title"/>
                                                <Binding Path="PrivacyModeEnabled"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- Content -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled" AllowAutoHide="False">
                                <StackPanel Spacing="{StaticResource Space20}" Margin="20,16,20,24" IsVisible="{Binding SelectedCredential, Converter={x:Static ObjectConverters.IsNotNull}}">
                                    <!-- Icon and basic info -->
                                    <Grid ColumnDefinitions="Auto,16,*" VerticalAlignment="Top">
                                        <Border Grid.Column="0" Width="84" Height="84" CornerRadius="42" Background="{Binding SelectedCredential.IconBackgroundBrush}">
                                            <Grid>
                                                <Image Source="{Binding SelectedCredential.AutoDetectedIconBitmap}"
                                                       Width="72" Height="72" Stretch="Uniform"
                                                       IsVisible="{Binding SelectedCredential.HasAutoDetectedIcon}"/>
                                                <TextBlock Text="{Binding SelectedCredential.IconText}" FontSize="34" FontWeight="Bold" Foreground="White"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           IsVisible="{Binding !SelectedCredential.HasAutoDetectedIcon}"/>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="2" Spacing="{StaticResource Space6}" VerticalAlignment="Center">
                                            <TextBlock FontSize="22" FontWeight="Bold">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource PrivacyMaskConverter}">
                                                        <Binding Path="SelectedCredential.Title"/>
                                                        <Binding Path="PrivacyModeEnabled"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Username">
                                                        <Binding Path="SelectedCredential.Username"/>
                                                        <Binding Path="PrivacyModeEnabled"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Username (read-only) with copy -->
                                    <StackPanel Spacing="{StaticResource Space6}">
                                        <TextBlock Text="Username" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Grid.Column="0" Text="{Binding SelectedCredential.Username}" IsReadOnly="True" Background="{DynamicResource ReadOnlyFieldBackgroundBrush}" Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}" BorderThickness="1" BorderBrush="{DynamicResource ControlBorderBrush}" Height="36" Padding="10,8"/>
                                            <Button Grid.Column="1" Command="{Binding CopyUsernameCommand}" CommandParameter="{Binding SelectedCredential}" Classes="secondary" Width="36" Height="36" Margin="8,0,0,0" ToolTip.Tip="Copy username">
                                                <Image Source="avares://PhantomVault.UI/Assets/Icons/PO%20UI/Copy%20to%20clipboard%202/Copy%20to%20clipboard%202_charcoal.png" Width="18" Height="18" Stretch="Uniform"/>
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Password (masked) with copy -->
                                    <StackPanel Spacing="{StaticResource Space6}">
                                        <TextBlock Text="Password" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Grid.Column="0" Text="{Binding SelectedCredential.Password}" PasswordChar="•" IsReadOnly="True" Background="{DynamicResource ReadOnlyFieldBackgroundBrush}" Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}" BorderThickness="1" BorderBrush="{DynamicResource ControlBorderBrush}" Height="36" Padding="10,8"/>
                                            <Button Grid.Column="1" Command="{Binding CopyPasswordCommand}" CommandParameter="{Binding SelectedCredential}" Background="{DynamicResource AccentBrush}" Width="36" Height="36" Margin="8,0,0,0" ToolTip.Tip="Copy password">
                                                <Image Source="avares://PhantomVault.UI/Assets/Icons/PO%20UI/Copy%20to%20clipboard%202/Copy%20to%20clipboard%202_charcoal.png" Width="18" Height="18" Stretch="Uniform"/>
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <!-- URL -->
                                    <StackPanel Spacing="{StaticResource Space6}" IsVisible="{Binding SelectedCredential.HasUrl}">
                                        <TextBlock Text="Website" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Grid.Column="0" Text="{Binding SelectedCredential.Url}" IsReadOnly="True" Background="{DynamicResource ReadOnlyFieldBackgroundBrush}" Foreground="{DynamicResource ReadOnlyFieldForegroundBrush}" BorderThickness="1" BorderBrush="{DynamicResource ControlBorderBrush}" Height="36" Padding="10,8"/>
                                            <Button Grid.Column="1" Command="{Binding OpenUrlCommand}" CommandParameter="{Binding SelectedCredential}" Classes="secondary" Width="36" Height="36" Margin="8,0,0,0" ToolTip.Tip="Open in browser">
                                                <Image Source="avares://PhantomVault.UI/Assets/Icons/PO%20UI/Web/3917565_charcoal.png" Width="18" Height="18" Stretch="Uniform"/>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Slide-in Edit Panel Overlay -->
            <Border x:Name="EditPanelOverlay"
                    Background="{DynamicResource OverlayBackgroundBrush}"
                    IsVisible="{Binding IsEditPanelVisible}"
                    IsHitTestVisible="{Binding IsEditPanelVisible}">
                <Border.Styles>
                    <Style Selector="Border#EditPanelOverlay">
                        <Setter Property="Opacity" Value="0"/>
                    </Style>
                    <Style Selector="Border#EditPanelOverlay[IsVisible=True]">
                        <Style.Animations>
                            <Animation Duration="0:0:0.25" FillMode="Forward" Easing="SineEaseOut">
                                <KeyFrame Cue="0%">
                                    <Setter Property="Opacity" Value="0"/>
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="Opacity" Value="1"/>
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </Border.Styles>
                
                <Grid ClipToBounds="True">
                    <!-- Transparent area to close panel -->
                    <Border Background="Transparent" 
                            PointerPressed="CloseEditPanel_Click"/>
                    
                    <!-- Edit Panel Container - Slides in from right -->
            <Canvas x:Name="EditPanelContainer" 
                HorizontalAlignment="Right"
                Width="800"
                Tag="{Binding IsEditPanelVisible}">
                        <!-- Smooth both directions with an overshoot on open using BackEaseOut.
                             Using ThicknessTransition ensures we animate when the Margin setter changes. -->
                        <Canvas.Transitions>
                            <Transitions>
                                <!-- Base slide: slightly longer and smoother deceleration -->
                                <ThicknessTransition Property="Margin" Duration="0:0:0.60" Easing="CubicEaseOut"/>
                            </Transitions>
                        </Canvas.Transitions>
                        <Canvas.Styles>
                            <!-- Default: hidden off-screen to the right -->
                            <Style Selector="Canvas#EditPanelContainer">
                                <Setter Property="Margin" Value="0,0,-800,0"/>
                            </Style>
                            <!-- When Tag (bound to IsEditPanelVisible) is true, slide into place -->
                            <Style Selector="Canvas#EditPanelContainer[Tag=True]">
                                <Setter Property="Margin" Value="0,0,0,0"/>
                            </Style>
                            <!-- Tiny bounce on inner panel using Canvas.Right; runs only when container Tag=True -->
                            <Style Selector="Canvas#EditPanelContainer[Tag=True] Border#EditPanel">
                                <Style.Animations>
                                    <!-- Make overshoot even more subtle and quick -->
                                    <Animation Duration="0:0:0.16" FillMode="Forward" Easing="SineEaseOut">
                                        <KeyFrame Cue="0%">
                                            <Setter Property="Canvas.Right" Value="6"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="72%">
                                            <Setter Property="Canvas.Right" Value="-1"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="100%">
                                            <Setter Property="Canvas.Right" Value="0"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </Canvas.Styles>
                        
                        <!-- Edit Panel Content -->
            <Border x:Name="EditPanel"
                                Canvas.Right="0"
                Width="800"
                                Canvas.Top="0"
                                Canvas.Bottom="0"
                                Background="{DynamicResource WindowBackgroundBrush}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1,0,0,0"
                                BoxShadow="-10 0 30 0 #40000000">
                        <!-- Touch/touchpad-friendly scrollbars scoped to this panel -->
                        <Border.Styles>
                            <!-- Vertical scrollbar: slim by default, slightly wider and more opaque on hover/press -->
                            <Style Selector="Border#EditPanel ScrollViewer ScrollBar:vertical">
                                <Setter Property="Width" Value="8"/>
                                <Setter Property="Opacity" Value="0.55"/>
                            </Style>
                            <Style Selector="Border#EditPanel ScrollViewer ScrollBar:vertical:pointerover">
                                <Setter Property="Width" Value="10"/>
                                <Style.Animations>
                                    <Animation Duration="0:0:0.12" FillMode="Forward" Easing="SineEaseOut">
                                        <KeyFrame Cue="0%">
                                            <Setter Property="Opacity" Value="0.55"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="100%">
                                            <Setter Property="Opacity" Value="1"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                            <Style Selector="Border#EditPanel ScrollViewer ScrollBar:vertical:pressed">
                                <Setter Property="Width" Value="10"/>
                                <Setter Property="Opacity" Value="1"/>
                            </Style>
                            <!-- Horizontal (not used here, but added for consistency) -->
                            <Style Selector="Border#EditPanel ScrollViewer ScrollBar:horizontal">
                                <Setter Property="Height" Value="8"/>
                                <Setter Property="Opacity" Value="0.55"/>
                            </Style>
                            <Style Selector="Border#EditPanel ScrollViewer ScrollBar:horizontal:pointerover">
                                <Setter Property="Height" Value="10"/>
                                <Style.Animations>
                                    <Animation Duration="0:0:0.12" FillMode="Forward" Easing="SineEaseOut">
                                        <KeyFrame Cue="0%">
                                            <Setter Property="Opacity" Value="0.55"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="100%">
                                            <Setter Property="Opacity" Value="1"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                            <Style Selector="Border#EditPanel ScrollViewer ScrollBar:horizontal:pressed">
                                <Setter Property="Height" Value="10"/>
                                <Setter Property="Opacity" Value="1"/>
                            </Style>
                        </Border.Styles>
                        
                        <!-- Edit Form Content -->
                        <Grid RowDefinitions="Auto,*,Auto">
                            
                            <!-- Header -->
                            <Border Grid.Row="0" 
                                    Background="{DynamicResource HeaderBackgroundBrush}" 
                                    Padding="25,20"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="6">
                                        <TextBlock Text="{Binding EditViewModel.WindowTitle}" 
                                                   FontSize="20" 
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="Enter credential details securely" 
                                                   FontSize="13" 
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Command="{Binding CloseEditPanelCommand}"
                                            Classes="secondary"
                                            Width="36"
                                            Height="36"
                                            VerticalAlignment="Top"
                                            ToolTip.Tip="Close">
                                        <TextBlock Text="✕" FontSize="16"/>
                                    </Button>
                                </Grid>
                            </Border>
                            
                            <!-- Form Content -->
                            <ScrollViewer Grid.Row="1" 
                                          VerticalScrollBarVisibility="Visible"
                                          HorizontalScrollBarVisibility="Disabled"
                                          AllowAutoHide="False"
                                          Padding="25,20">
                                <StackPanel Spacing="20" DataContext="{Binding EditViewModel}">
                                    
                                    <!-- Title Field -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Title *" 
                                                   FontSize="13" 
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBox Text="{Binding Title}"
                                                 Watermark="e.g., GitHub, Gmail, Bank Account"
                                                 Height="40"
                                                 FontSize="14"
                                                 Background="{DynamicResource ReadOnlyFieldBackgroundBrush}">
                                            <TextBox.Styles>
                                                <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                                    <Setter Property="Background" Value="#33FFFFFF"/>
                                                </Style>
                                                <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                                    <Setter Property="Background" Value="#33FFFFFF"/>
                                                </Style>
                                            </TextBox.Styles>
                                        </TextBox>
                                        <TextBlock Text="{Binding TitleError}" 
                                                   FontSize="11" 
                                                   Foreground="{DynamicResource ErrorBrush}"
                                                   IsVisible="{Binding HasTitleError}"/>
                                    </StackPanel>
                                    
                                    <!-- Username/Email Field -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Username / Email *" 
                                                   FontSize="13" 
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBox Text="{Binding Username}"
                                                 Watermark="username@example.com"
                                                 Height="40"
                                                 FontSize="14"
                                                 Background="{DynamicResource ReadOnlyFieldBackgroundBrush}">
                                            <TextBox.Styles>
                                                <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                                    <Setter Property="Background" Value="#33FFFFFF"/>
                                                </Style>
                                                <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                                    <Setter Property="Background" Value="#33FFFFFF"/>
                                                </Style>
                                            </TextBox.Styles>
                                        </TextBox>
                                        <TextBlock Text="{Binding UsernameError}" 
                                                   FontSize="11" 
                                                   Foreground="{DynamicResource ErrorBrush}"
                                                   IsVisible="{Binding HasUsernameError}"/>
                                    </StackPanel>
                                    
                                    <!-- Password Field -->
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto,4,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="Password *" 
                                                       FontSize="13" 
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <Button Grid.Column="1"
                                                    Command="{Binding GeneratePasswordCommand}"
                                                    Classes="secondary"
                                                    Width="90"
                                                    Height="26"
                                                    Padding="10,4"
                                                    FontSize="11"
                                                    ToolTip.Tip="Generate strong password">
                                                <TextBlock Text="Generate" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>
                                            <Button Grid.Column="3"
                                                    Command="{Binding OpenPasswordGeneratorCommand}"
                                                    Classes="secondary"
                                                    Height="26"
                                                    Width="26"
                                                    Padding="4"
                                                    FontSize="11"
                                                    ToolTip.Tip="Open password generator settings">
                                                <TextBlock Text="..." FontSize="13"/>
                                            </Button>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding Password}"
                                                     PasswordChar="{Binding PasswordChar}"
                                                     Watermark="Enter secure password"
                                                     Height="40"
                                                     FontSize="14"
                                                     Padding="12,10,45,10"
                                                     Background="{DynamicResource ReadOnlyFieldBackgroundBrush}">
                                                <TextBox.Styles>
                                                    <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                                        <Setter Property="Background" Value="#33FFFFFF"/>
                                                    </Style>
                                                    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                                        <Setter Property="Background" Value="#33FFFFFF"/>
                                                    </Style>
                                                </TextBox.Styles>
                                            </TextBox>
                                            <Button Grid.Column="1"
                                                    Command="{Binding TogglePasswordVisibilityCommand}"
                                                    Classes="secondary"
                                                    Width="36"
                                                    Height="36"
                                                    Margin="-40,2,4,2"
                                                    ToolTip.Tip="Show/Hide password">
                                                <TextBlock Text="{Binding PasswordVisibilityIcon}" FontSize="16"/>
                                            </Button>
                                        </Grid>

                                        <!-- Password Strength Meter -->
                                        <Border Background="{DynamicResource ControlBackgroundBrush}"
                                                CornerRadius="4"
                                                Padding="10,8"
                                                IsVisible="{Binding HasPassword}">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <TextBlock Grid.Column="0"
                                                           Text="Strength:" 
                                                           FontSize="11" 
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0"/>
                                                <ProgressBar Grid.Column="1"
                                                             Value="{Binding PasswordStrength}"
                                                             Maximum="100"
                                                             Height="8"
                                                             VerticalAlignment="Center"
                                                             Foreground="{Binding PasswordStrengthColor}"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding PasswordStrengthText}" 
                                                           FontSize="11" 
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding PasswordStrengthColor}"
                                                           VerticalAlignment="Center"
                                                           Margin="10,0,0,0"/>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="{Binding PasswordError}" 
                                                   FontSize="11" 
                                                   Foreground="{DynamicResource ErrorBrush}"
                                                   IsVisible="{Binding HasPasswordError}"/>
                                    </StackPanel>
                                    
                                    <!-- URL Field -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Website URL" 
                                                   FontSize="13" 
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBox Text="{Binding Url}"
                                                 Watermark="https://example.com"
                                                 Height="40"
                                                 FontSize="14"
                                                 Background="{DynamicResource ReadOnlyFieldBackgroundBrush}">
                                            <TextBox.Styles>
                                                <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                                    <Setter Property="Background" Value="#33FFFFFF"/>
                                                </Style>
                                                <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                                    <Setter Property="Background" Value="#33FFFFFF"/>
                                                </Style>
                                            </TextBox.Styles>
                                        </TextBox>
                                        <TextBlock Text="Optional - Used for auto-fill and quick access" 
                                                   FontSize="11" 
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                    </StackPanel>
                                    
                                    <!-- Category Selection -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Category" 
                                                   FontSize="13" 
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <ComboBox SelectedItem="{Binding SelectedCategory}"
                                                  ItemsSource="{Binding Categories}"
                                                  Height="40"
                                                  FontSize="14">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Image Source="{Binding Icon, Converter={StaticResource IconPathToBitmapConverter}}" Width="22" Height="22" Stretch="Uniform" IsVisible="{Binding Icon, Converter={StaticResource IconPathExistsConverter}}"/>
                                                        <TextBlock Text="{Binding Icon}" FontSize="14" IsVisible="{Binding Icon, Converter={StaticResource IconPathExistsConverter}, ConverterParameter=invert}"/>
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    
                                    <!-- Icon/Logo Selection -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Icon / Logo" 
                                                   FontSize="13" 
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <Border Background="{DynamicResource ReadOnlyFieldBackgroundBrush}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="15"
                                                Height="100">
                                            <Border.Styles>
                                                <Style Selector="Border:pointerover">
                                                    <Setter Property="Background" Value="#33FFFFFF"/>
                                                </Style>
                                            </Border.Styles>
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <!-- Current Icon Display -->
                                                <Border Grid.Column="0"
                                                        Width="70"
                                                        Height="70"
                                                        Background="{DynamicResource ControlBackgroundBrush}"
                                                        CornerRadius="8"
                                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                                        BorderThickness="1">
                                                    <Image Source="{Binding IconPath}"
                                                           Width="50"
                                                           Height="50"
                                                           Stretch="Uniform"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- Icon Info -->
                                                <StackPanel Grid.Column="1"
                                                            Margin="15,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Spacing="4">
                                                    <TextBlock Text="Custom icon for this credential" 
                                                               FontSize="13" 
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                          <TextBlock Text="Click 'Change Icon' to select from library or upload custom" 
                                                               FontSize="11" 
                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                
                                                <!-- Change Icon Button -->
                                                <Button Grid.Column="2"
                                                        Command="{Binding PickIconCommand}"
                                                        Classes="secondary"
                                                        Width="110"
                                                        Height="36"
                                                        VerticalAlignment="Center"
                                              ToolTip.Tip="Open icon picker">
                                           <TextBlock Text="Change Icon" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                    
                                    <!-- Notes Field -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Notes" 
                                                   FontSize="13" 
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBox Text="{Binding Notes}"
                                                 Watermark="Add any additional information..."
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 Height="100"
                                                 FontSize="13"
                                                 Background="{DynamicResource ReadOnlyFieldBackgroundBrush}">
                                            <TextBox.Styles>
                                                <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
                                                    <Setter Property="Background" Value="#33FFFFFF"/>
                                                </Style>
                                                <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
                                                    <Setter Property="Background" Value="#33FFFFFF"/>
                                                </Style>
                                            </TextBox.Styles>
                                        </TextBox>
                                    </StackPanel>
                                    
                                </StackPanel>
                            </ScrollViewer>
                            
                            <!-- Footer with Action Buttons -->
                            <Border Grid.Row="2" 
                                    Background="{DynamicResource FooterBackgroundBrush}" 
                                    Padding="25,15"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="0,1,0,0">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="* Required fields" 
                                               FontSize="11" 
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               VerticalAlignment="Center"/>
                                    
                                    <Button Grid.Column="1"
                                            Command="{Binding CloseEditPanelCommand}"
                                            Classes="secondary"
                                            Width="100"
                                            Height="40"
                                            Margin="0,0,10,0"
                                            Content="Cancel"/>
                                    
                                    <Button Grid.Column="2"
                                            Command="{Binding EditViewModel.SaveCommand}"
                                            Background="{DynamicResource AccentBrush}"
                                            Width="120"
                                            Height="40"
                                            FontWeight="Bold">
                                        <TextBlock Text="{Binding EditViewModel.SaveButtonText}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>
                            </Border>
                            
                        </Grid>
                    </Border>
                    </Canvas>
                </Grid>
            </Border>

            <!-- Category Manager Overlay (same behaviour as in settings - slides in from right) -->
            <Border x:Name="CategoryManagerOverlay"
                    Grid.RowSpan="3"
                    Background="{DynamicResource OverlayBackgroundBrush}"
                    IsVisible="{Binding IsCategoryManagerPanelVisible}"
                    IsHitTestVisible="{Binding IsCategoryManagerPanelVisible}">
                <Border.Styles>
                    <Style Selector="Border#CategoryManagerOverlay">
                        <Setter Property="Opacity" Value="0"/>
                    </Style>
                    <Style Selector="Border#CategoryManagerOverlay[IsVisible=True]">
                        <Style.Animations>
                            <Animation Duration="0:0:0.25" FillMode="Forward" Easing="SineEaseOut">
                                <KeyFrame Cue="0%">
                                    <Setter Property="Opacity" Value="0"/>
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="Opacity" Value="1"/>
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </Border.Styles>

                <Grid ClipToBounds="True">
                    <!-- Transparent area to close panel -->
                    <Border Background="Transparent" 
                            PointerPressed="OnCategoryManagerOverlayBackgroundPressed"/>

                    <!-- Category Manager Container - Slides in from right -->
                    <Border x:Name="CategoryManagerSlideHost" 
                            HorizontalAlignment="Right"
                            Width="820"
                            Tag="{Binding IsCategoryManagerPanelVisible}"
                            RenderTransformOrigin="0.5,0.5"
                            Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1,0,0,0"
                            BoxShadow="-10 0 30 0 #40000000">
                        <Border.RenderTransform>
                            <TranslateTransform X="820"/>
                        </Border.RenderTransform>
                        <Border.Styles>
                            <!-- When Tag (bound to IsCategoryManagerPanelVisible) is true, slide into view with animation -->
                            <Style Selector="Border#CategoryManagerSlideHost[Tag=True]">
                                <Style.Animations>
                                    <Animation Duration="0:0:0.4" FillMode="Forward" Easing="CubicEaseOut">
                                        <KeyFrame Cue="0%">
                                            <Setter Property="(TranslateTransform.X)" Value="820"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="100%">
                                            <Setter Property="(TranslateTransform.X)" Value="0"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </Border.Styles>

                        <!-- Embed the CategoryManagerView and bind to the ViewModel provided by VaultViewModel -->
                        <views:CategoryManagerView DataContext="{Binding CategoryManagerViewModel}"/>
                    </Border>
                </Grid>
            </Border>
            
        </Grid>
        
    </DockPanel>
    
</Window>
