<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhantomVault.UI.ViewModels"
        xmlns:views="clr-namespace:PhantomVault.UI.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="PhantomVault.UI.Views.WelcomePage"
        x:DataType="vm:WelcomePageViewModel"
        Title="Welcome to Phantom Vault"
        Width="800" Height="600"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Icon="avares://PhantomVault.UI/Assets/images/Parent Icon.ico"
        FontFamily="Segoe UI"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Design.DataContext>
        <vm:WelcomePageViewModel/>
    </Design.DataContext>

        <Grid RowDefinitions="Auto,*,Auto"
            Margin="0"
            Background="{DynamicResource WindowBackgroundBrush}">
        
        <!-- Header Section - slightly taller and more prominent -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" Padding="14,12">
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="{Binding AppName}"
                           FontSize="{StaticResource Type.H2.Size}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource HeaderTextBrush}"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="{Binding WelcomeMessage}"
                           FontSize="{StaticResource Type.Body.Size}"
                           Foreground="{DynamicResource HeaderTextBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content Section - Center large transparent icon -->
        <ScrollViewer Grid.Row="1" 
                      Background="{DynamicResource WindowBackgroundBrush}"
                      Padding="20,20,20,80"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="18" HorizontalAlignment="Center" VerticalAlignment="Center" MinHeight="300" Margin="0,0,0,20">
                <!-- Centered tile with logo in the middle (high-res) -->
                <Border Classes="liquid-glass-tile"
                        CornerRadius="16"
                        ClipToBounds="True"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        MinWidth="280" MinHeight="160" MaxWidth="920" MaxHeight="260" Padding="0">
                        <Image Source="avares://PhantomVault.UI/Assets/images/Phantom Obscura Title + Logo.png"
                               Stretch="Uniform" MaxWidth="880" MaxHeight="220" Margin="12"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="{Binding AppVersion}"
                           FontSize="{StaticResource Type.Tiny.Size}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>

                <!-- Status and loading (kept but centered) -->
                <Border Background="{DynamicResource ControlBackgroundBrush}"
                        CornerRadius="20"
                        Padding="16,10"
                        HorizontalAlignment="Center"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                        Margin="0,10,0,0"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="2">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="{StaticResource Type.Label.Size}"
                               Foreground="#FFC107"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding IsCheckingForVault}"
                             Height="4"
                             Foreground="{DynamicResource AccentBrush}"
                             Width="260"
                             Margin="0,10,0,0"/>

                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" IsVisible="{Binding IsDeveloperBypassVisible}" Margin="0,16,0,20">
                    <Button Command="{Binding DeveloperBypassCommand}"
                            Classes="liquid-glass"
                            CornerRadius="10"
                            Height="34"
                            Width="140"
                            FontSize="{StaticResource Type.Label.Size}"
                            FontFamily="{DynamicResource MainFontFamily}"
                            ToolTip.Tip="Bypass normal unlock flow (debug only)">
                        <TextBlock Text="Dev Bypass" Foreground="{DynamicResource ButtonTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding OpenInstallerCommand}"
                            Classes="liquid-glass"
                            CornerRadius="10"
                            Height="34"
                            Width="140"
                            FontSize="{StaticResource Type.Label.Size}"
                            FontFamily="{DynamicResource MainFontFamily}"
                            ToolTip.Tip="Open installer screen (debug only)">
                        <TextBlock Text="Open Installer" Foreground="{DynamicResource ButtonTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons Section - floating footer bar centered -->
        <Border Grid.Row="2"
                Background="{DynamicResource FooterBackgroundBrush}"
                Padding="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Width="640"
                CornerRadius="16"
                Margin="0,-22,0,12"
                Effect="{DynamicResource FooterGroundedShadow}"
                BorderBrush="{DynamicResource FooterBorderBrush}"
                BorderThickness="1"
                ClipToBounds="True">
            <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Center">
                <Button Command="{Binding GetStartedCommand}" Classes="liquid-glass" CornerRadius="10" Height="40" Width="140" FontSize="{StaticResource Type.Body.Size}" FontWeight="SemiBold" FontFamily="{DynamicResource MainFontFamily}">
                    <TextBlock Text="Get Started" Foreground="{DynamicResource ButtonTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <Button Command="{Binding OpenExistingVaultCommand}" Classes="liquid-glass" CornerRadius="10" Height="40" Width="140" FontSize="{StaticResource Type.Body.Size}" FontFamily="{DynamicResource MainFontFamily}" IsVisible="{Binding HasExistingVault}">
                    <TextBlock Text="Access your vault" Foreground="{DynamicResource ButtonTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Placeholder dialog buttons - match sizes to primary actions -->
                <Button Click="About_Click" Classes="liquid-glass" CornerRadius="10" Height="40" Width="140" FontFamily="{DynamicResource MainFontFamily}" FontSize="{StaticResource Type.Body.Size}" ToolTip.Tip="About this app" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                    <TextBlock Text="About" Foreground="{DynamicResource ButtonTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <Button Click="Import_Click" Classes="liquid-glass" CornerRadius="10" Height="40" Width="140" FontFamily="{DynamicResource MainFontFamily}" FontSize="{StaticResource Type.Body.Size}" ToolTip.Tip="Import data" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                    <TextBlock Text="Import" Foreground="{DynamicResource ButtonTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <!-- Settings button removed per request -->
                <!-- Export button removed per request -->
            </StackPanel>
        </Border>
    </Grid>
</views:ThemeAwareWindow>
