<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PhantomVault.UI.Converters"
             x:Class="PhantomVault.UI.Views.Details.ApiKeyDetailView">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PhantomVault.UI/Resources/Converters/ConverterResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <!-- API Keys -->
    <StackPanel Spacing="12"
                IsVisible="{Binding SelectedCredential.IsApiKeyEntry}">
        <TextBlock Text="API Access"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource SecondaryTextBrush}"/>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasApiKeyValue}">
            <TextBlock Text="API Key" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
            <TextBox Text="{Binding SelectedCredential.MaskedApiKeyValue}" IsReadOnly="True" Height="36" Padding="10,8">
                <TextBox.Effect>
                    <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                </TextBox.Effect>
            </TextBox>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasApiEnvironment}">
            <TextBlock Text="Environment" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
            <TextBox Text="{Binding SelectedCredential.ApiEnvironment}" IsReadOnly="True" Height="36" Padding="10,8"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasApiEndpoint}">
            <TextBlock Text="Endpoint" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
            <TextBox Text="{Binding SelectedCredential.ApiEndpoint}" IsReadOnly="True" Height="36" Padding="10,8"
                     TextWrapping="Wrap" AcceptsReturn="True"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasApiDocumentation}">
            <TextBlock Text="Documentation URL" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
            <TextBox Text="{Binding SelectedCredential.ApiDocumentationUrl}" IsReadOnly="True" Height="36" Padding="10,8"/>
        </StackPanel>
    </StackPanel>
</UserControl>
