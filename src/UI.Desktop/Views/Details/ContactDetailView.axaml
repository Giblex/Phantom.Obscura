<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PhantomVault.UI.Converters"
             x:Class="PhantomVault.UI.Views.Details.ContactDetailView">
    
    <!-- Contact Cards -->
    <StackPanel Spacing="12"
                IsVisible="{Binding SelectedCredential.IsContactEntry}">
        <TextBlock Text="Contact Details"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource SecondaryTextBrush}"/>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasContactName}">
            <TextBlock Text="Full Name" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
              <TextBox Text="{Binding SelectedCredential.ContactFullName}" IsReadOnly="True" Height="36" Padding="10,8"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasContactEmail}">
            <TextBlock Text="Email" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
              <TextBox Text="{Binding SelectedCredential.ContactEmail}" IsReadOnly="True" Height="36" Padding="10,8"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasContactPhone}">
            <TextBlock Text="Phone" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
              <TextBox Text="{Binding SelectedCredential.ContactPhone}" IsReadOnly="True" Height="36" Padding="10,8"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasContactCompany}">
            <TextBlock Text="Company" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
              <TextBox Text="{Binding SelectedCredential.ContactCompany}" IsReadOnly="True" Height="36" Padding="10,8"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasContactJobTitle}">
            <TextBlock Text="Job Title" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
              <TextBox Text="{Binding SelectedCredential.ContactJobTitle}" IsReadOnly="True" Height="36" Padding="10,8"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasContactAddress}">
            <TextBlock Text="Address" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
            <TextBox Text="{Binding SelectedCredential.ContactAddress}"
                     IsReadOnly="True"
                     Background="{DynamicResource ControlBackgroundBrush}"
                     Foreground="{DynamicResource PrimaryTextBrush}"
                     BorderThickness="1"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     Padding="10,8"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>
        </StackPanel>
    </StackPanel>
</UserControl>
