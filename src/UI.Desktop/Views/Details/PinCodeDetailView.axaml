<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PhantomVault.UI.Converters"
             x:Class="PhantomVault.UI.Views.Details.PinCodeDetailView">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PhantomVault.UI/Resources/Converters/ConverterResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <!-- PIN Code Details -->
    <StackPanel Spacing="12"
                IsVisible="{Binding SelectedCredential.IsPinCodeEntry}">
        <TextBlock Text="PIN Code"
                   FontSize="{StaticResource Type.Body.Size}"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource SecondaryTextBrush}"/>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasPinLabel}">
            <TextBlock Text="Label" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
            <TextBox Text="{Binding SelectedCredential.PinLabel}" IsReadOnly="True" Height="36" Padding="10,8"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasPinValue}">
            <TextBlock Text="PIN" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
            <TextBox Text="{Binding SelectedCredential.MaskedPinValue}" IsReadOnly="True" Height="36" Padding="10,8">
                <TextBox.Effect>
                    <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                </TextBox.Effect>
            </TextBox>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasPinCategory}">
            <TextBlock Text="Category" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
            <TextBox Text="{Binding SelectedCredential.PinCategory}" IsReadOnly="True" Height="36" Padding="10,8"/>
        </StackPanel>
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasPinIssuer}">
            <TextBlock Text="Issuer" FontSize="{StaticResource Type.Label.Size}" FontWeight="SemiBold" Foreground="{DynamicResource MutedTextBrush}"/>
            <TextBox Text="{Binding SelectedCredential.PinIssuer}" IsReadOnly="True" Height="36" Padding="10,8"/>
        </StackPanel>
    </StackPanel>
</UserControl>
