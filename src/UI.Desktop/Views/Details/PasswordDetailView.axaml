<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PhantomVault.UI.ViewModels"
             xmlns:models="clr-namespace:PhantomVault.UI.Models"
             x:Class="PhantomVault.UI.Views.Details.PasswordDetailView">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PhantomVault.UI/Resources/Converters/ConverterResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <!-- Login Credentials Detail View -->
    <StackPanel Spacing="2"
                IsVisible="{Binding SelectedCredential.IsPasswordEntry}">
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasUsername}">
            <TextBlock Text="Username" 
                       FontSize="13" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource MutedTextBrush}"/>
            <TextBox Text="{Binding SelectedCredential.Username}" 
                     IsReadOnly="True"
                     BorderThickness="1"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     Height="36"
                     Padding="8,16"
                     Cursor="Hand"
                     ToolTip.Tip="Click to copy username"
                     Tapped="CopyUsername_Tapped">
                <TextBox.Effect>
                    <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                </TextBox.Effect>
            </TextBox>
        </StackPanel>

        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasPassword}">
            <TextBlock Text="Password" 
                       FontSize="13" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource MutedTextBrush}"/>
            <TextBox Text="{Binding SelectedCredential.Password}" 
                     PasswordChar="•"
                     IsReadOnly="True"
                     BorderThickness="1"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     Height="36"
                     Padding="8,16"
                     Cursor="Hand"
                     ToolTip.Tip="Click to copy password"
                     Tapped="CopyPassword_Tapped">
                <TextBox.Effect>
                    <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                </TextBox.Effect>
            </TextBox>
        </StackPanel>

        <!-- TOTP Code Display -->
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasTotpSecret}">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="TOTP Code" 
                           FontSize="13" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MutedTextBrush}"/>
                <Button Grid.Column="1"
                        Command="{Binding AddTotpCommand}"
                        Classes="secondary-btn"
                        Height="24"
                        Padding="8,4"
                        IsVisible="{Binding !SelectedCredential.HasTotpSecret}"
                        ToolTip.Tip="Add TOTP authenticator">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="+" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="Add TOTP" FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>
            <Grid ColumnDefinitions="*,Auto">
                <!-- TOTP Code Display with Timer -->
                <Border Grid.Column="0"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        CornerRadius="6"
                        Height="50"
                        Padding="12,8"
                        Cursor="Hand"
                        ToolTip.Tip="Click to copy TOTP code"
                        Tapped="CopyTotpCode_Tapped">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedCredential.CurrentTotpCode}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       FontFamily="Consolas,Courier New,monospace"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       LetterSpacing="2"/>
                            <TextBlock Text="{Binding SelectedCredential.TotpIssuer}"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       IsVisible="{Binding SelectedCredential.HasTotpIssuer}"/>
                        </StackPanel>
                        <!-- Circular Countdown Timer -->
                        <Canvas Grid.Column="1" Width="40" Height="40" VerticalAlignment="Center">
                            <!-- Background circle -->
                            <Ellipse Width="40" Height="40"
                                     Stroke="{DynamicResource ControlBorderBrush}"
                                     StrokeThickness="2.5"
                                     Fill="Transparent"/>
                            <!-- Animated arc that decreases clockwise -->
                            <Path Stroke="{DynamicResource SecondaryTextBrush}"
                                  StrokeThickness="2.5"
                                  StrokeLineCap="Round"
                                  Fill="Transparent"
                                  Data="{Binding SelectedCredential.TotpTimerArcPath}"/>
                            <!-- Seconds text in center -->
                            <TextBlock Canvas.Left="20" Canvas.Top="20"
                                       Text="{Binding SelectedCredential.TotpSecondsRemaining}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextAlignment="Center"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform X="-10" Y="-8"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Canvas>
                    </Grid>
                </Border>

                <!-- Edit/Remove TOTP Button -->
                <Button Grid.Column="1"
                        Command="{Binding EditTotpCommand}"
                        CommandParameter="{Binding SelectedCredential}"
                        Classes="liquid-glass"
                        Width="36"
                        Height="50"
                        Padding="4"
                        Margin="8,0,0,0"
                        ToolTip.Tip="Edit TOTP settings">
                    <TextBlock Text="⚙" FontSize="16"/>
                </Button>
            </Grid>
        </StackPanel>

        <!-- Add TOTP Button (when no TOTP exists) -->
        <Button Command="{Binding AddTotpCommand}"
                Classes="liquid-glass"
                Height="36"
                IsVisible="{Binding !SelectedCredential.HasTotpSecret}"
                HorizontalAlignment="Stretch"
                ToolTip.Tip="Add two-factor authentication">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="🔒" FontSize="16"/>
                <TextBlock Text="Add TOTP Authenticator" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
            </StackPanel>
        </Button>
    </StackPanel>
    
</UserControl>
