<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PhantomVault.UI.ViewModels"
             xmlns:models="clr-namespace:PhantomVault.UI.Models"
             x:Class="PhantomVault.UI.Views.Details.PasswordDetailView">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PhantomVault.UI/Resources/Converters/ConverterResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <!-- Login Credentials Detail View -->
    <StackPanel Spacing="12"
                IsVisible="{Binding SelectedCredential.IsPasswordEntry}">
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasUsername}">
            <TextBlock Text="Username" 
                       FontSize="13" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource MutedTextBrush}"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" 
                         Text="{Binding SelectedCredential.Username}" 
                         IsReadOnly="True"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource ControlBorderBrush}"
                         Height="36"
                         Padding="8,16">
                    <TextBox.Effect>
                        <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                    </TextBox.Effect>
                </TextBox>
                <Button Grid.Column="1"
                        Command="{Binding CopyUsernameCommand}"
                        CommandParameter="{Binding SelectedCredential}"
                        Classes="copy-btn"
                        Width="36"
                        Height="36"
                        Padding="4"
                        Margin="8,0,0,0"
                        ToolTip.Tip="Copy username">
                    <Image Source="{DynamicResource CopyIcon}" Width="18" Height="18" Stretch="Uniform"/>
                </Button>
            </Grid>
        </StackPanel>

        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasPassword}">
            <TextBlock Text="Password" 
                       FontSize="13" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource MutedTextBrush}"/>
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" 
                         Text="{Binding SelectedCredential.Password}" 
                         PasswordChar="•"
                         IsReadOnly="True"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource ControlBorderBrush}"
                         Height="36"
                         Padding="8,16">
                    <TextBox.Effect>
                        <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                    </TextBox.Effect>
                </TextBox>
                <Button Grid.Column="1"
                        Command="{Binding CopyPasswordCommand}"
                        CommandParameter="{Binding SelectedCredential}"
                        Classes="copy-btn"
                        Width="36"
                        Height="36"
                        Padding="4"
                        Margin="8,0,0,0"
                        ToolTip.Tip="Copy password">
                    <Image Source="{DynamicResource CopyIcon}" Width="18" Height="18" Stretch="Uniform"/>
                </Button>
            </Grid>
        </StackPanel>

        <!-- TOTP Code Display -->
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasTotpSecret}">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="TOTP Code" 
                           FontSize="13" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MutedTextBrush}"/>
                <Button Grid.Column="1"
                        Command="{Binding AddTotpCommand}"
                        Classes="secondary-btn"
                        Height="24"
                        Padding="8,4"
                        IsVisible="{Binding !SelectedCredential.HasTotpSecret}"
                        ToolTip.Tip="Add TOTP authenticator">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="+" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="Add TOTP" FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>
            <Grid ColumnDefinitions="*,Auto,Auto">
                <!-- TOTP Code Display with Timer -->
                <Border Grid.Column="0"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        CornerRadius="6"
                        Height="50"
                        Padding="12,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedCredential.CurrentTotpCode}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       FontFamily="Consolas,Courier New,monospace"
                                       Foreground="{DynamicResource AccentBrush}"
                                       LetterSpacing="2"/>
                            <TextBlock Text="{Binding SelectedCredential.TotpIssuer}"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       IsVisible="{Binding SelectedCredential.HasTotpIssuer}"/>
                        </StackPanel>
                        <!-- Countdown Timer -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="{Binding SelectedCredential.TotpSecondsRemaining, StringFormat={}{0}s}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource AccentBrush}"/>
                            <!-- Progress Bar -->
                            <Border Width="40" Height="4" 
                                    Background="{DynamicResource ControlBorderBrush}"
                                    CornerRadius="2">
                                <Border Background="{DynamicResource AccentBrush}"
                                        CornerRadius="2"
                                        HorizontalAlignment="Left"
                                        Width="{Binding SelectedCredential.TotpProgressPercent, Converter={StaticResource PercentageToWidthConverter}}"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Copy TOTP Button -->
                <Button Grid.Column="1"
                        Command="{Binding CopyTotpCodeCommand}"
                        CommandParameter="{Binding SelectedCredential}"
                        Classes="copy-btn"
                        Width="36"
                        Height="50"
                        Padding="4"
                        Margin="8,0,0,0"
                        ToolTip.Tip="Copy TOTP code">
                    <Image Source="{DynamicResource CopyIcon}" Width="18" Height="18" Stretch="Uniform"/>
                </Button>

                <!-- Edit/Remove TOTP Button -->
                <Button Grid.Column="2"
                        Command="{Binding EditTotpCommand}"
                        CommandParameter="{Binding SelectedCredential}"
                        Classes="secondary-btn"
                        Width="36"
                        Height="50"
                        Padding="4"
                        Margin="4,0,0,0"
                        ToolTip.Tip="Edit TOTP settings">
                    <TextBlock Text="⚙" FontSize="16"/>
                </Button>
            </Grid>
        </StackPanel>

        <!-- Add TOTP Button (when no TOTP exists) -->
        <Button Command="{Binding AddTotpCommand}"
                CommandParameter="{Binding SelectedCredential}"
                Classes="secondary-btn"
                Height="36"
                IsVisible="{Binding !SelectedCredential.HasTotpSecret}"
                HorizontalAlignment="Stretch"
                ToolTip.Tip="Add two-factor authentication">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="🔒" FontSize="16"/>
                <TextBlock Text="Add TOTP Authenticator" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>
        </Button>
    </StackPanel>
    
</UserControl>
