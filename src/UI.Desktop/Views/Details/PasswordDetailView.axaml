<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PhantomVault.UI.ViewModels"
             xmlns:models="clr-namespace:PhantomVault.UI.Models"
             xmlns:controls="clr-namespace:PhantomVault.UI.Desktop.Controls"
             x:Class="PhantomVault.UI.Views.Details.PasswordDetailView">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PhantomVault.UI/Resources/Converters/ConverterResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <!-- Login Credentials Detail View -->
    <StackPanel Spacing="12"
                IsVisible="{Binding SelectedCredential.IsPasswordEntry}">
        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasUsername}">
            <TextBlock Text="Username" 
                       FontSize="{StaticResource Type.Label.Size}" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource MutedTextBrush}"/>
            <TextBox Text="{Binding SelectedCredential.Username}" 
                     IsReadOnly="True"
                     BorderThickness="1"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     Height="36"
                     Padding="10,8"
                     Cursor="Hand"
                     ToolTip.Tip="Click to copy username"
                     Tapped="CopyUsername_Tapped">
                <TextBox.Effect>
                    <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                </TextBox.Effect>
            </TextBox>
        </StackPanel>

        <StackPanel Spacing="6" IsVisible="{Binding SelectedCredential.HasPassword}">
            <TextBlock Text="Password" 
                       FontSize="{StaticResource Type.Label.Size}" 
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource MutedTextBrush}"/>
            <TextBox Text="{Binding SelectedCredential.Password}" 
                     PasswordChar="•"
                     IsReadOnly="True"
                     BorderThickness="1"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     Height="36"
                     Padding="10,8"
                     Cursor="Hand"
                     ToolTip.Tip="Click to copy password"
                     Tapped="CopyPassword_Tapped">
                <TextBox.Effect>
                    <Binding Path="PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                </TextBox.Effect>
            </TextBox>
            <!-- Password Strength Bar -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                <ProgressBar Grid.Column="0"
                             Value="{Binding SelectedCredential.PasswordStrength}"
                             Maximum="100"
                             Height="6"
                             CornerRadius="3"
                             VerticalAlignment="Center"
                             Foreground="{Binding SelectedCredential.PasswordStrengthColor}"
                             Background="Transparent"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding SelectedCredential.PasswordStrengthText}"
                           FontSize="{StaticResource Type.Tiny.Size}"
                           FontWeight="SemiBold"
                           Foreground="{Binding SelectedCredential.PasswordStrengthColor}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </Grid>
        </StackPanel>

        <!-- ═══ TOTP Section (Compact) ═══ -->

        <!-- TOTP Code Display (when secret exists) -->
        <StackPanel Spacing="10"
                    IsVisible="{Binding SelectedCredential.HasTotpSecret}"
                    Margin="0,2,0,0">
            <!-- Header row: "TOTP" label + Attestor button + Settings button -->
            <Grid ColumnDefinitions="*,Auto,6,Auto" Margin="0,0,0,0">
                <TextBlock Grid.Column="0"
                           Text="TOTP"
                           FontSize="{StaticResource Type.Label.Size}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource MutedTextBrush}"
                           VerticalAlignment="Center"/>
                <!-- Open Phantom Attestor button -->
                <Button Grid.Column="1"
                        Command="{Binding OpenAttestorCommand}"
                        IsEnabled="{Binding IsAttestorAvailable}"
                        Classes="liquid-glass"
                        Width="26" Height="26"
                        CornerRadius="6"
                        Padding="0"
                        Margin="0,0,0,0"
                        ToolTip.Tip="{Binding AttestorStatus}">
                    <controls:SvgIcon IconName="Assets/SVG/Current/Security.svg"
                                      Width="12" Height="12"
                                      IconColor="{DynamicResource SecondaryTextBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                <!-- Settings button (opens TOTP settings dialog with edit/delete) -->
                <Button Grid.Column="3"
                        Command="{Binding EditTotpCommand}"
                        CommandParameter="{Binding SelectedCredential}"
                        Classes="liquid-glass"
                        Width="26" Height="26"
                        CornerRadius="6"
                        Padding="0"
                        Margin="0,0,0,0"
                        ToolTip.Tip="TOTP Settings">
                    <controls:SvgIcon IconName="Assets/SVG/Current/Settings.svg"
                                      Width="11" Height="11"
                                      IconColor="{DynamicResource SecondaryTextBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </Grid>

            <!-- Code display with liquid glass pill and animated countdown -->
            <Border CornerRadius="28"
                    Padding="20,10"
                    BorderThickness="2,1,1,1"
                    BorderBrush="{DynamicResource Brush.Glass.Border}"
                    Cursor="Hand"
                    ToolTip.Tip="Click to copy TOTP code"
                    Tapped="CopyTotpCode_Tapped"
                    PointerPressed="TotpCodeTile_PointerPressed"
                    PointerReleased="TotpCodeTile_PointerReleased"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1">
                        <ScaleTransform.Transitions>
                            <Transitions>
                                <DoubleTransition Property="ScaleX" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                                <DoubleTransition Property="ScaleY" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                            </Transitions>
                        </ScaleTransform.Transitions>
                    </ScaleTransform>
                </Border.RenderTransform>
                <Border.Background>
                    <RadialGradientBrush Center="35%,40%" RadiusX="80%" RadiusY="80%">
                        <GradientStop Color="#0ED8E8F8" Offset="0"/>
                        <GradientStop Color="#0C8FB5DF" Offset="0.5"/>
                        <GradientStop Color="#0A6B8CAE" Offset="0.8"/>
                        <GradientStop Color="#05272F43" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
                    <Grid ColumnDefinitions="*,Auto">
                        <!-- TOTP Code with fade + scale transitions -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding SelectedCredential.CurrentTotpCode}"
                                   FontSize="{StaticResource Type.SubHeading.Size}"
                                   FontWeight="Bold"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   LetterSpacing="2"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Margin="4,2,0,0"
                                   Opacity="{Binding SelectedCredential.TotpCodeOpacity}"
                                   RenderTransformOrigin="0,0.5">
                            <TextBlock.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.35" Easing="CubicEaseOut"/>
                                </Transitions>
                            </TextBlock.Transitions>
                        </TextBlock>

                        <!-- Circular Countdown Timer (40x40) using Grid for proper centering -->
                        <Grid Grid.Column="1" Width="40" Height="40" VerticalAlignment="Center">
                            <!-- Background ring -->
                            <Ellipse Width="40" Height="40"
                                     StrokeThickness="2.5"
                                     Fill="Transparent"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Ellipse.Stroke>
                                    <SolidColorBrush Color="#FFFFFF" Opacity="0.15"/>
                                </Ellipse.Stroke>
                            </Ellipse>
                            <!-- Active arc -->
                            <Canvas Width="40" Height="40"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Path StrokeThickness="3"
                                      StrokeLineCap="Round"
                                      Fill="Transparent"
                                      Data="{Binding SelectedCredential.TotpTimerArcPath}">
                                    <Path.Stroke>
                                        <SolidColorBrush Color="{DynamicResource AccentColor}"/>
                                    </Path.Stroke>
                                </Path>
                            </Canvas>
                            <!-- Seconds text — properly centred via Grid alignment -->
                            <TextBlock Text="{Binding SelectedCredential.TotpSecondsRemaining}"
                                       FontSize="{StaticResource Type.Small.Size}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
        </StackPanel>

    </StackPanel>
    
</UserControl>
