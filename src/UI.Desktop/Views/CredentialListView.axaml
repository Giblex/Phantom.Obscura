<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Giblex.Controls;assembly=PhantomVault.UI"
             xmlns:dcontrols="clr-namespace:PhantomVault.UI.Desktop.Controls"
             mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="800"
             x:Class="PhantomVault.UI.Views.CredentialListView">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PhantomVault.UI/Resources/Converters/ConverterResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid RowDefinitions="Auto,*" Background="{DynamicResource ContentBackgroundBrush}">
        
        <!-- Header Section (Fixed) -->
        <Border Grid.Row="0" 
                Background="{DynamicResource ContentBackgroundBrush}"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,14"
                Effect="{x:Null}">
            <Grid RowDefinitions="*">
                <Grid Grid.Row="0">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="{Binding CurrentViewTitle}" 
                                       FontSize="{StaticResource Type.H3.Size}" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="{Binding FilteredCount, StringFormat='{}{0} items'}" 
                                       FontSize="{StaticResource Type.Small.Size}" 
                                       Foreground="{DynamicResource MutedTextBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" IsVisible="{Binding !IsShowingSecureTrash}">
                            <ComboBox SelectedIndex="{Binding SortOption}"
                                      Width="150"
                                      Height="32"
                                      Background="{DynamicResource ControlBackgroundBrush}"
                                      BorderBrush="{DynamicResource ControlBorderBrush}"
                                      Foreground="{DynamicResource InputForegroundBrush}"
                                      ToolTip.Tip="Sort by">
                                <ComboBoxItem Content="Name (A-Z)"/>
                                <ComboBoxItem Content="Name (Z-A)"/>
                                <ComboBoxItem Content="Recently Added"/>
                                <ComboBoxItem Content="Recently Modified"/>
                                <ComboBoxItem Content="Category"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsShowingSecureTrash}">
                            <controls:LiquidGlassButton Command="{Binding ToggleTrashSelectAllCommand}"
                                    HeightOverride="36"
                                    WidthOverride="100"
                                    PaddingOverride="12,0"
                                    ToolTipText="Toggle selection for all items">
                                <controls:LiquidGlassButton.ButtonContent>
                                    <TextBlock Text="Toggle All" FontSize="{StaticResource Type.Label.Size}"/>
                                </controls:LiquidGlassButton.ButtonContent>
                            </controls:LiquidGlassButton>
                            <controls:LiquidGlassButton Command="{Binding RestoreSelectedTrashCommand}"
                                    HeightOverride="36"
                                    WidthOverride="130"
                                    PaddingOverride="12,0"
                                    IsEnabled="{Binding HasTrashSelection}">
                                <controls:LiquidGlassButton.ButtonContent>
                                    <TextBlock Text="Recover Selected" FontSize="{StaticResource Type.Label.Size}"/>
                                </controls:LiquidGlassButton.ButtonContent>
                            </controls:LiquidGlassButton>
                            <controls:LiquidGlassButton Command="{Binding PurgeSelectedTrashCommand}"
                                    HeightOverride="36"
                                    WidthOverride="130"
                                    PaddingOverride="12,0"
                                    IsEnabled="{Binding HasTrashSelection}">
                                <controls:LiquidGlassButton.ButtonContent>
                                    <TextBlock Text="Delete Selected" FontSize="{StaticResource Type.Label.Size}"/>
                                </controls:LiquidGlassButton.ButtonContent>
                            </controls:LiquidGlassButton>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        
        <!-- Scrollable Content Area -->
        <ScrollViewer x:Name="CredentialScrollViewer" Grid.Row="1"
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,4,0,16"
                      Background="{DynamicResource ContentBackgroundBrush}"
                      ZIndex="0">
            <StackPanel Spacing="0" HorizontalAlignment="Stretch" Margin="0">
                <StackPanel IsVisible="{Binding !IsShowingSecureTrash}">
                    <!-- Category Header (when filtered by category) -->
                    <Border IsVisible="{Binding IsShowingCategoryFiltered}"
                            Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="20,16"
                            Margin="6,8,16,12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding ActiveCategoryDisplayName}"
                                       FontSize="{StaticResource Type.Icon.Size}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Category"
                                       FontSize="{StaticResource Type.Small.Size}"
                                       Foreground="{DynamicResource MutedTextBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Credentials List (List Mode - Non-grouped) -->
                    <Grid x:Name="CredentialListHost" Margin="0" IsVisible="{Binding !IsGridView}">
                        <!-- Standard list (not sorted by category) -->
                        <ListBox x:Name="CredentialListBox"
                                 ItemsSource="{Binding FilteredCredentials}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionMode="Single"
                                 HorizontalAlignment="Stretch"
                                 IsVisible="{Binding !IsSortedByCategory}">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Background" Value="{x:Null}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="MinHeight" Value="96"/>
                                    <Setter Property="Height" Value="96"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Effect" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter Content="{TemplateBinding Content}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                  HorizontalAlignment="Stretch"
                                                                  VerticalAlignment="Center" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style Selector="ListBoxItem:pointerover, ListBoxItem:selected, ListBoxItem:focus">
                                    <Setter Property="Background" Value="{x:Null}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                    <Setter Property="Effect" Value="{x:Null}"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <StaticResource ResourceKey="CredentialListTileTemplate" />
                            </ListBox.ItemTemplate>
                        </ListBox>
                        
                        <!-- Grouped list with category banners (sorted by category) -->
                        <ListBox x:Name="GroupedCredentialListBox"
                                 ItemsSource="{Binding GroupedListItems}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 SelectionMode="Single"
                                 HorizontalAlignment="Stretch"
                                 IsVisible="{Binding IsSortedByCategory}">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Background" Value="{x:Null}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Effect" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter Content="{TemplateBinding Content}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                  HorizontalAlignment="Stretch"
                                                                  VerticalAlignment="Center" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style Selector="ListBoxItem:pointerover, ListBoxItem:selected, ListBoxItem:focus">
                                    <Setter Property="Background" Value="{x:Null}"/>
                                    <Setter Property="BorderBrush" Value="{x:Null}"/>
                                    <Setter Property="Effect" Value="{x:Null}"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <StaticResource ResourceKey="GroupedListItemTemplate" />
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <!-- Category Header for Grid View (when filtered by category) -->
                    <Border IsVisible="{Binding IsShowingCategoryFiltered}"
                            Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="20,16"
                            Margin="6,8,16,12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding ActiveCategoryDisplayName}"
                                       FontSize="{StaticResource Type.Icon.Size}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Category"
                                       FontSize="{StaticResource Type.Small.Size}"
                                       Foreground="{DynamicResource MutedTextBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Credentials Grid (Grid Mode) -->
                    <ItemsControl x:Name="GridItemsControl"
                                  ItemsSource="{Binding FilteredCredentials}"
                                  IsVisible="{Binding IsGridView}"
                                  ClipToBounds="False"
                                  HorizontalAlignment="Stretch"
                                  Width="{Binding Bounds.Width, ElementName=CredentialScrollViewer}"
                                  Margin="4,8,4,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center" ItemWidth="252" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <StaticResource ResourceKey="CredentialGridTileTemplate" />
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Secure Trash List -->
                <ListBox ItemsSource="{Binding FilteredTrashItems}" IsVisible="{Binding IsShowingSecureTrash}" BorderThickness="0" Background="Transparent" Margin="16,0,16,0" SelectionMode="Single" HorizontalAlignment="Stretch" SelectedItem="{Binding SelectedTrashItem, Mode=TwoWay}">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Background" Value="{x:Null}"/>
                            <Setter Property="BorderBrush" Value="{x:Null}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover, ListBoxItem:selected, ListBoxItem:focus">
                            <Setter Property="Background" Value="{x:Null}"/>
                            <Setter Property="BorderBrush" Value="{x:Null}"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource ContentBackgroundBrush}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource Radius.Lg}"
                                    Padding="12"
                                    HorizontalAlignment="Stretch"
                                    Effect="{x:Null}">
                                <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock FontSize="{StaticResource Type.H3.Size}" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Effect>
                                                    <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                                </TextBlock.Effect>
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource PrivacyMaskConverter}">
                                                        <Binding Path="Payload.Title"/>
                                                        <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Text="{Binding DeletedRelative}" Foreground="{DynamicResource MutedTextBrush}" FontSize="{StaticResource Type.Label.Size}" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock FontSize="{StaticResource Type.H5.Size}" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis">
                                            <TextBlock.Effect>
                                                <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                            </TextBlock.Effect>
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Username">
                                                    <Binding Path="Payload.Username"/>
                                                    <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>

                                        <TextBlock FontSize="{StaticResource Type.Label.Size}" Foreground="{DynamicResource MutedTextBrush}" TextTrimming="CharacterEllipsis" Margin="0,0,0,2">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="Url">
                                                    <Binding Path="Payload.Url"/>
                                                    <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                            <TextBlock.Effect>
                                                <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled" Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                            </TextBlock.Effect>
                                        </TextBlock>

                                        <TextBlock Text="{Binding OriginalGroup, StringFormat='Original group: {0}'}" FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <TextBlock Text="{Binding ScheduledPurgeLabel}" FontSize="{StaticResource Type.Small.Size}" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <!-- Bottom spacer to prevent last credential from being cut off by footer -->
                <Border Height="80" Background="Transparent"/>
                
                <!-- Empty State -->
                <StackPanel Spacing="15" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            Margin="0,80,0,0"
                            IsVisible="{Binding IsEmpty}">
                    <TextBlock Text="🔓" FontSize="{StaticResource Type.EmptyState.Lg.Size}" HorizontalAlignment="Center" Opacity="0.3"/>
                    <TextBlock Text="No credentials found" 
                               FontSize="{StaticResource Type.H3.Size}" 
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Add your first credential to get started" 
                               FontSize="{StaticResource Type.Label.Size}" 
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center"/>
                    <controls:LiquidGlassButton Command="{Binding AddCredentialCommand}"
                            WidthOverride="160"
                            HeightOverride="40"
                            HorizontalAlignment="Center"
                            Margin="0,15,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="+" FontSize="{StaticResource Type.Icon.Size}" FontWeight="Bold"/>
                            <TextBlock Text="Add Credential" FontSize="{StaticResource Type.Body.Size}"/>
                        </StackPanel>
                    </controls:LiquidGlassButton>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Top fade overlay so content appears to glide under the header -->
        <Rectangle Grid.Row="1" Height="18" VerticalAlignment="Top" IsHitTestVisible="False" ZIndex="2">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#12000000" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
    </Grid>
    
</UserControl>
