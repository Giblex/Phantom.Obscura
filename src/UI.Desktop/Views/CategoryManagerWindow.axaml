<?xml version="1.0" encoding="utf-8"?>
<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
    x:Class="PhantomVault.UI.Views.CategoryManagerWindow"
        Title="Manage Categories"
        Width="1000"
        Height="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">
    <views:CategoryManagerView/>
</views:ThemeAwareWindow>


