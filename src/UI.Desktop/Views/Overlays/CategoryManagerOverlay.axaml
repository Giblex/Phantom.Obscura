<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PhantomVault.UI.Views"
             x:Class="PhantomVault.UI.Views.Overlays.CategoryManagerOverlay">
    
    <Border Background="{DynamicResource OverlayBackgroundBrush}"
            IsVisible="{Binding IsCategoryManagerPanelVisible}"
            IsHitTestVisible="{Binding IsCategoryManagerPanelVisible}">
        <Border.Styles>
            <Style Selector="Border">
                <Setter Property="Opacity" Value="0"/>
            </Style>
            <Style Selector="Border[IsVisible=True]">
                <Style.Animations>
                    <Animation Duration="0:0:0.25" FillMode="Forward" Easing="SineEaseOut">
                        <KeyFrame Cue="0%">
                            <Setter Property="Opacity" Value="0"/>
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="Opacity" Value="1"/>
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
        </Border.Styles>

        <Grid ClipToBounds="True">
            <!-- Transparent area to close panel -->
            <Border Background="Transparent" 
                    PointerPressed="OnBackgroundClicked"/>

            <!-- Category Manager Container - Slides in from right -->
            <Border x:Name="CategoryManagerSlideHost" 
                    HorizontalAlignment="Right"
                    Width="820"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1,0,0,0"
                    BoxShadow="{DynamicResource SlideOutPanelShadow}"
                    IsVisible="{Binding IsCategoryManagerPanelVisible}">

                <!-- Embed the CategoryManagerView and bind to the ViewModel provided by VaultViewModel -->
                <views:CategoryManagerView DataContext="{Binding CategoryManagerViewModel}"/>
            </Border>
        </Grid>
    </Border>
    
</UserControl>
