<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PhantomVault.UI.Views.Overlays.SettingsPanelOverlay">
    
    <Border Background="{DynamicResource OverlayBackgroundBrush}"
            IsVisible="{Binding IsSettingsPanelVisible}"
            IsHitTestVisible="{Binding IsSettingsPanelVisible}">
        <Border.Styles>
            <Style Selector="Border">
                <Setter Property="Opacity" Value="0"/>
            </Style>
            <Style Selector="Border[IsVisible=True]">
                <Style.Animations>
                    <Animation Duration="0:0:0.25" FillMode="Forward" Easing="SineEaseOut">
                        <KeyFrame Cue="0%">
                            <Setter Property="Opacity" Value="0"/>
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="Opacity" Value="1"/>
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
        </Border.Styles>

        <Grid ClipToBounds="True">
            <!-- Transparent area to close panel -->
            <Border Background="Transparent" PointerPressed="OnBackgroundClicked" />

            <!-- Settings Panel Container - Slides in from right -->
            <Border x:Name="SettingsSlideHost"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Width="920"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1,0,0,0"
                    BoxShadow="{DynamicResource SlideOutPanelShadow}"
                    RenderTransformOrigin="1,0.5">
                <Border.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.Or}">
                        <Binding Path="IsSettingsPanelVisible"/>
                    </MultiBinding>
                </Border.IsVisible>
                <Border.RenderTransform>
                    <TranslateTransform X="0" />
                </Border.RenderTransform>
                <Border.Styles>
                    <Style Selector="Border">
                        <Setter Property="RenderTransform">
                            <TranslateTransform X="920" />
                        </Setter>
                    </Style>
                    <Style Selector="Border[IsVisible=true]">
                        <Setter Property="RenderTransform">
                            <TranslateTransform X="0" />
                        </Setter>
                    </Style>
                </Border.Styles>
                <Border.Transitions>
                    <Transitions>
                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.7" Easing="CubicEaseOut"/>
                    </Transitions>
                </Border.Transitions>

                    <!-- Settings Panel Content -->
                <Grid RowDefinitions="Auto,*">
                    <!-- Header -->
                    <Border Grid.Row="0" 
                            Classes="header-surface"
                            Background="{DynamicResource HeaderBackgroundBrush}" 
                            Padding="25,20"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Settings" 
                                           FontSize="{StaticResource Type.Icon.Size}" 
                                           FontWeight="Bold"/>
                                <TextBlock Text="Configure your vault preferences and appearance" 
                                           FontSize="{StaticResource Type.Label.Size}" 
                                           Classes="header-muted"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    Command="{Binding CloseSettingsPanelCommand}"
                                    Classes="copy-btn"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    FontSize="{StaticResource Type.H4.Size}"
                                    ToolTip.Tip="Close settings"/>
                        </Grid>
                    </Border>

                    <!-- Tabbed Content -->
                    <Grid Grid.Row="1" ColumnDefinitions="220,*">
                        <!-- Tab Navigation -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource CategoryPanelBackgroundBrush}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="0,0,1,0">
                            <ScrollViewer VerticalScrollBarVisibility="Visible"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="15,20">
                            <StackPanel Spacing="8">
                                <Button Command="{Binding ShowGeneralSettingsCommand}"
                                        Classes="liquid-glass"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="40">
                                    <TextBlock Text="General" VerticalAlignment="Center"/>
                                </Button>
                                
                                <Button Command="{Binding ShowSecuritySettingsCommand}"
                                        Classes="liquid-glass"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="40">
                                    <TextBlock Text="Security" VerticalAlignment="Center"/>
                                </Button>
                                
                                <Button Command="{Binding ShowThemeSettingsCommand}"
                                        Classes="liquid-glass"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="40">
                                    <TextBlock Text="Theme" VerticalAlignment="Center"/>
                                </Button>
                                
                                <Button Command="{Binding ShowImportExportSettingsCommand}"
                                        Classes="liquid-glass"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="40">
                                    <TextBlock Text="Import / Export" VerticalAlignment="Center"/>
                                </Button>
                                
                                <Button Command="{Binding ShowAutoFillSettingsCommand}"
                                        Classes="liquid-glass"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="40">
                                    <TextBlock Text="Auto-Fill" VerticalAlignment="Center"/>
                                </Button>
                                
                                <Button Command="{Binding ShowBackupSettingsCommand}"
                                        Classes="liquid-glass"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="40">
                                    <TextBlock Text="Backup" VerticalAlignment="Center"/>
                                </Button>
                                
                                <Button Command="{Binding ShowAccessibilitySettingsCommand}"
                                        Classes="liquid-glass"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="40">
                                    <TextBlock Text="Accessibility" VerticalAlignment="Center"/>
                                </Button>
                                
                                <Button Command="{Binding ShowAdvancedSettingsCommand}"
                                        Classes="liquid-glass"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="40">
                                    <TextBlock Text="Advanced" VerticalAlignment="Center"/>
                                </Button>
                                
                                <Button Command="{Binding ShowRubbishBinSettingsCommand}"
                                        Classes="liquid-glass"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="40">
                                    <TextBlock Text="Secured Rubbish Bin" VerticalAlignment="Center"/>
                                </Button>
                                
                                <Button Command="{Binding OpenSecurityDashboardWindowCommand}"
                                        Classes="liquid-glass"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="40">
                                    <TextBlock Text="Password Health" VerticalAlignment="Center"/>
                                </Button>

                                <Button Command="{Binding ShowSyncSettingsCommand}"
                                        Classes="liquid-glass"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Height="40">
                                    <TextBlock Text="Sync &amp; Integration" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Tab Content Area -->
                        <ScrollViewer Grid.Column="1"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Padding="30,20,20,30">
                            <ContentControl Content="{Binding SelectedSettingsContent}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,20,0"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
    
</UserControl>
