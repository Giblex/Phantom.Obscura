<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:PhantomVault.UI.Converters"
             x:Class="PhantomVault.UI.Views.Overlays.SettingsPanelOverlay">

    <UserControl.Resources>
        <!-- Drives nav-tab.active toggling from VaultViewModel.SelectedSettingsTab. -->
        <conv:StringEqualsConverter x:Key="SettingsTabEqualsConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Active settings tab: accent foreground + semibold text. Layered on
             top of liquid-glass; the left-edge accent bar is in the Button
             content template itself so we don't have to fight the templated
             parts. -->
        <Style Selector="Button.settings-tab.active TextBlock.tab-label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>
        <Style Selector="Button.settings-tab.active Border.tab-accent">
            <Setter Property="IsVisible" Value="True"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource OverlayBackgroundBrush}"
            IsVisible="{Binding IsSettingsPanelVisible}"
            IsHitTestVisible="{Binding IsSettingsPanelVisible}">
        <Border.Styles>
            <Style Selector="Border">
                <Setter Property="Opacity" Value="0"/>
            </Style>
            <Style Selector="Border[IsVisible=True]">
                <Style.Animations>
                    <Animation Duration="0:0:0.25" FillMode="Forward" Easing="SineEaseOut">
                        <KeyFrame Cue="0%">
                            <Setter Property="Opacity" Value="0"/>
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="Opacity" Value="1"/>
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
        </Border.Styles>

        <Grid ClipToBounds="True">
            <!-- Transparent area to close panel -->
            <Border Background="Transparent" PointerPressed="OnBackgroundClicked" />

            <!-- Settings Panel Container - Slides in from right -->
            <Border x:Name="SettingsSlideHost"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Width="920"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1,0,0,0"
                    BoxShadow="{DynamicResource SlideOutPanelShadow}"
                    RenderTransformOrigin="1,0.5">
                <Border.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.Or}">
                        <Binding Path="IsSettingsPanelVisible"/>
                    </MultiBinding>
                </Border.IsVisible>
                <Border.RenderTransform>
                    <TranslateTransform X="0" />
                </Border.RenderTransform>
                <Border.Styles>
                    <Style Selector="Border">
                        <Setter Property="RenderTransform">
                            <TranslateTransform X="920" />
                        </Setter>
                    </Style>
                    <Style Selector="Border[IsVisible=true]">
                        <Setter Property="RenderTransform">
                            <TranslateTransform X="0" />
                        </Setter>
                    </Style>
                </Border.Styles>
                <Border.Transitions>
                    <Transitions>
                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.7" Easing="CubicEaseOut"/>
                    </Transitions>
                </Border.Transitions>

                    <!-- Settings Panel Content -->
                <Grid RowDefinitions="Auto,*">
                    <!-- Header -->
                    <Border Grid.Row="0" 
                            Classes="header-surface"
                            Background="{DynamicResource HeaderBackgroundBrush}" 
                            Padding="25,20"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Settings" 
                                           FontSize="{StaticResource Type.Icon.Size}" 
                                           FontWeight="Bold"/>
                                <TextBlock Text="Configure your vault preferences and appearance" 
                                           FontSize="{StaticResource Type.Label.Size}" 
                                           Classes="header-muted"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    Command="{Binding CloseSettingsPanelCommand}"
                                    Classes="copy-btn"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    FontSize="{StaticResource Type.H4.Size}"
                                    ToolTip.Tip="Close settings"/>
                        </Grid>
                    </Border>

                    <!-- Tabbed Content -->
                    <Grid Grid.Row="1" ColumnDefinitions="220,*">
                        <!-- Tab Navigation -->
                        <Border Grid.Column="0"
                                Background="{DynamicResource CategoryPanelBackgroundBrush}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="0,0,1,0">
                            <ScrollViewer VerticalScrollBarVisibility="Visible"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="15,20">
                            <StackPanel Spacing="6">
                                <Button Command="{Binding ShowGeneralSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=general}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="General"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowSecuritySettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=security}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Security"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowThemeSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=theme}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Theme"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowImportExportSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=importexport}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Import / Export"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowAutoFillSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=autofill}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Auto-Fill"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowBackupSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=backup}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Backup"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowAccessibilitySettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=accessibility}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Accessibility"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowAdvancedSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=advanced}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Advanced"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowRubbishBinSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=rubbishbin}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Secured Rubbish Bin"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding OpenSecurityDashboardWindowCommand}"
                                        Classes="liquid-glass settings-tab"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Password Health"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowSyncSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=sync}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Sync &amp; Integration"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>
                            </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Tab Content Area -->
                        <ScrollViewer Grid.Column="1"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Padding="30,20,20,30">
                            <ContentControl Content="{Binding SelectedSettingsContent}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,20,0"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
    
</UserControl>
