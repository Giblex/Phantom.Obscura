<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:PhantomVault.UI.Converters"
             x:Class="PhantomVault.UI.Views.Overlays.SettingsPanelOverlay">

    <UserControl.Resources>
        <!-- Drives nav-tab.active toggling from VaultViewModel.SelectedSettingsTab. -->
        <conv:StringEqualsConverter x:Key="SettingsTabEqualsConverter"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Active settings tab: accent foreground + semibold text. Layered on
             top of liquid-glass; the left-edge accent bar is in the Button
             content template itself so we don't have to fight the templated
             parts. -->
        <!-- Selected settings tab uses primary (white) text — keeping the accent
             colour for the left-edge bar only avoids the 'blue text on dark panel'
             low-contrast issue (#7). -->
        <Style Selector="Button.settings-tab.active TextBlock.tab-label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        <Style Selector="Button.settings-tab.active Border.tab-accent">
            <Setter Property="IsVisible" Value="True"/>
        </Style>
        <!-- Issue: Save button visual priority. When enabled (HasUnsavedSettings
             = true) the button takes an accent-tinted background so it reads as
             the primary action. When disabled it falls back to the standard
             liquid-glass look so it doesn't look 'ready' while inert. -->
        <Style Selector="Button.settings-save-primary:not(:disabled) /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource OverlayBackgroundBrush}"
            IsVisible="{Binding IsSettingsPanelVisible}"
            IsHitTestVisible="{Binding IsSettingsPanelVisible}">
        <Border.Styles>
            <Style Selector="Border">
                <Setter Property="Opacity" Value="0"/>
            </Style>
            <Style Selector="Border[IsVisible=True]">
                <Style.Animations>
                    <Animation Duration="0:0:0.25" FillMode="Forward" Easing="SineEaseOut">
                        <KeyFrame Cue="0%">
                            <Setter Property="Opacity" Value="0"/>
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="Opacity" Value="1"/>
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
        </Border.Styles>

        <Grid ClipToBounds="True">
            <!-- Transparent area to close panel -->
            <Border Background="Transparent" PointerPressed="OnBackgroundClicked" />

            <!-- Settings Panel Container - Slides in from right -->
            <Border x:Name="SettingsSlideHost"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Width="920"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1,0,0,0"
                    BoxShadow="{DynamicResource SlideOutPanelShadow}"
                    RenderTransformOrigin="1,0.5">
                <Border.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.Or}">
                        <Binding Path="IsSettingsPanelVisible"/>
                    </MultiBinding>
                </Border.IsVisible>
                <Border.RenderTransform>
                    <TranslateTransform X="0" />
                </Border.RenderTransform>
                <Border.Styles>
                    <Style Selector="Border">
                        <Setter Property="RenderTransform">
                            <TranslateTransform X="920" />
                        </Setter>
                    </Style>
                    <Style Selector="Border[IsVisible=true]">
                        <Setter Property="RenderTransform">
                            <TranslateTransform X="0" />
                        </Setter>
                    </Style>
                </Border.Styles>
                <Border.Transitions>
                    <Transitions>
                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.7" Easing="CubicEaseOut"/>
                    </Transitions>
                </Border.Transitions>

                    <!-- Settings Panel Content -->
                <Grid RowDefinitions="Auto,*">
                    <!-- Header -->
                    <Border Grid.Row="0" 
                            Classes="header-surface"
                            Background="{DynamicResource HeaderBackgroundBrush}" 
                            Padding="25,20"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="Settings" 
                                           FontSize="{StaticResource Type.Icon.Size}" 
                                           FontWeight="Bold"/>
                                <TextBlock Text="Configure your vault preferences and appearance" 
                                           FontSize="{StaticResource Type.Label.Size}" 
                                           Classes="header-muted"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="✕"
                                    Command="{Binding CloseSettingsPanelCommand}"
                                    Classes="copy-btn"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    FontSize="{StaticResource Type.H4.Size}"
                                    ToolTip.Tip="Close settings"/>
                        </Grid>
                    </Border>

                    <!-- Tabbed Content -->
                    <Grid Grid.Row="1" ColumnDefinitions="220,*" VerticalAlignment="Stretch">
                        <!-- Tab Navigation -->
                        <!-- Issue #3: left sidebar ScrollViewer wasn't scrolling
                             because Padding was on the ScrollViewer itself (which in
                             Avalonia interacts oddly with viewport sizing) and the
                             StackPanel was unconstrained. Move padding onto the inner
                             StackPanel and pin ScrollViewer to Stretch so it always
                             gets a bounded viewport from the * row above. -->
                        <Border Grid.Column="0"
                                VerticalAlignment="Stretch"
                                ClipToBounds="True"
                                Background="{DynamicResource CategoryPanelBackgroundBrush}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="0,0,1,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalAlignment="Stretch"
                                          MinHeight="0">
                            <StackPanel Spacing="6" Margin="15,20">
                                <Button Command="{Binding ShowGeneralSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=general}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="General"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowSecuritySettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=security}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Security"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowThemeSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=theme}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Theme"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowImportExportSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=importexport}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Import / Export"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowAutoFillSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=autofill}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Auto-Fill"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowBackupSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=backup}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Backup"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowAccessibilitySettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=accessibility}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Accessibility"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowAdvancedSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=advanced}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Advanced"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowRubbishBinSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=rubbishbin}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Secured Rubbish Bin"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding OpenSecurityDashboardWindowCommand}"
                                        Classes="liquid-glass settings-tab"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Password Health"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>

                                <Button Command="{Binding ShowSyncSettingsCommand}"
                                        Classes="liquid-glass settings-tab"
                                        Classes.active="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabEqualsConverter}, ConverterParameter=sync}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Height="40"
                                        Padding="0">
                                    <Grid ColumnDefinitions="3,*">
                                        <Border Grid.Column="0" Classes="tab-accent"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="2"
                                                Margin="2,6"
                                                IsVisible="False"/>
                                        <TextBlock Grid.Column="1" Classes="tab-label"
                                                   Text="Sync &amp; Integration"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"/>
                                    </Grid>
                                </Button>
                            </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- Tab Content Area + Issue #21 Save/Discard row.
                             Column 1 becomes a vertical Grid with the scrolling
                             content above a sticky button row at the bottom. -->
                        <Grid Grid.Column="1" RowDefinitions="*,Auto">
                            <!-- Issue #2: bottom of tab content got cut off because
                                 the ScrollViewer's bottom padding wasn't enough to
                                 clear the window edge and the content had no inner
                                 bottom margin to compensate. Pin to Stretch + add
                                 a generous bottom margin on the ContentControl so
                                 even tall tabs scroll past the final input. -->
                            <ScrollViewer Grid.Row="0"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Disabled"
                                         VerticalAlignment="Stretch"
                                         MinHeight="0"
                                         Padding="30,20,20,30">
                                <ContentControl Content="{Binding SelectedSettingsContent}"
                                              HorizontalAlignment="Stretch"
                                              Margin="0,0,20,40"/>
                            </ScrollViewer>

                            <!-- Issue #21: sticky Save / Discard row. Always
                                 visible at the bottom of the tab content area.
                                 Buttons are disabled until at least one staged
                                 change exists (driven by HasUnsavedSettings).
                                 Save is the primary action — accent fill +
                                 stronger weight; Discard is secondary glass.
                                 An amber dot + 'You have unsaved changes' hint
                                 sits to the left so dirty state is legible. -->
                            <Border Grid.Row="1"
                                    Background="{DynamicResource HeaderBackgroundBrush}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="22,12,22,14">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                    <Ellipse Grid.Column="0"
                                             Width="8" Height="8"
                                             VerticalAlignment="Center"
                                             Fill="{DynamicResource WarningBrush}"
                                             IsVisible="{Binding HasUnsavedSettings}"/>
                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Center"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="You have unsaved changes"
                                               IsVisible="{Binding HasUnsavedSettings}"/>
                                    <Button Grid.Column="2"
                                            Content="Discard"
                                            Classes="liquid-glass"
                                            Command="{Binding DiscardSettingsCommand}"
                                            IsEnabled="{Binding HasUnsavedSettings}"
                                            Padding="14,6"/>
                                    <!-- Save is the primary action: accent-tinted
                                         background so it visually leads the eye.
                                         Falls back to plain liquid-glass when no
                                         changes are staged so the button doesn't
                                         look 'live' while inert. -->
                                    <Button Grid.Column="3"
                                            Content="Save"
                                            Classes="liquid-glass settings-save-primary"
                                            Command="{Binding SaveSettingsCommand}"
                                            IsEnabled="{Binding HasUnsavedSettings}"
                                            Padding="22,6"
                                            FontWeight="SemiBold"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
    
</UserControl>
