<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:PhantomVault.UI.Views"
             x:Class="PhantomVault.UI.Views.Overlays.IconManagerOverlay">
    
    <Border Background="{DynamicResource OverlayBackgroundBrush}"
            IsVisible="{Binding IsIconManagerPanelVisible}"
            IsHitTestVisible="{Binding IsIconManagerPanelVisible}">
        <Border.Styles>
            <Style Selector="Border">
                <Setter Property="Opacity" Value="0"/>
            </Style>
            <Style Selector="Border[IsVisible=True]">
                <Style.Animations>
                    <Animation Duration="0:0:0.25" FillMode="Forward" Easing="SineEaseOut">
                        <KeyFrame Cue="0%">
                            <Setter Property="Opacity" Value="0"/>
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="Opacity" Value="1"/>
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
        </Border.Styles>

        <Grid ClipToBounds="True">
            <!-- Transparent area to close panel -->
            <Border Background="Transparent" />

            <!-- Icon Manager Container - Slides in from right -->
            <Border x:Name="IconManagerSlideHost" 
                    HorizontalAlignment="Right"
                    Width="1280"
                    Tag="{Binding IsIconManagerPanelVisible}"
                    RenderTransformOrigin="0.5,0.5"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1,0,0,0"
                    BoxShadow="{DynamicResource SlideOutPanelShadow}">
                <Border.RenderTransform>
                    <TranslateTransform X="1280"/>
                </Border.RenderTransform>
                <Border.Styles>
                    <Style Selector="Border#IconManagerSlideHost[Tag=True]">
                        <Setter Property="Opacity" Value="1"/>
                    </Style>
                    <Style Selector="Border[Tag=False]">
                        <Setter Property="Opacity" Value="0"/>
                    </Style>
                </Border.Styles>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header with Close Button -->
                    <Border Grid.Row="0" 
                            Background="{DynamicResource HeaderBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="20">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="Icon Manager" 
                                           FontSize="18" 
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock Text="Manage custom icons and download icon packs" 
                                           FontSize="12"
                                           Foreground="{DynamicResource MutedTextBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding CloseIconManagerCommand}"
                                    Classes="liquid-glass"
                                    Width="100"
                                    Height="36"
                                    Content="Close"/>
                        </Grid>
                    </Border>

                    <!-- Icon Manager Content -->
                    <ScrollViewer Grid.Row="1" 
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="20">
                        <TextBlock Text="Icon Manager is available as a separate window"
                                   FontSize="16"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
    
</UserControl>
