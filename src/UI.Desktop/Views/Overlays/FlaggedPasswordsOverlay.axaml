<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PhantomVault.UI.Views.Overlays.FlaggedPasswordsOverlay">
    
    <Border Background="{DynamicResource OverlayBackgroundBrush}"
            IsVisible="{Binding IsFlaggedPanelVisible}"
            IsHitTestVisible="{Binding IsFlaggedPanelVisible}">
        <Border.Styles>
            <Style Selector="Border">
                <Setter Property="Opacity" Value="0"/>
            </Style>
            <Style Selector="Border[IsVisible=True]">
                <Style.Animations>
                    <Animation Duration="0:0:0.25" FillMode="Forward" Easing="SineEaseOut">
                        <KeyFrame Cue="0%">
                            <Setter Property="Opacity" Value="0"/>
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="Opacity" Value="1"/>
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
        </Border.Styles>

        <Grid ClipToBounds="True">
            <Border Background="Transparent" />

            <Border x:Name="FlaggedPasswordsSlideHost"
                    HorizontalAlignment="Right"
                    Width="520"
                    Tag="{Binding IsFlaggedPanelVisible}"
                    RenderTransformOrigin="0.5,0.5"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1,0,0,0"
                    BoxShadow="{DynamicResource FlaggedPanelShadow}">
                <Border.RenderTransform>
                    <TranslateTransform X="520"/>
                </Border.RenderTransform>
                <Border.Styles>
                    <Style Selector="Border#FlaggedPasswordsSlideHost[Tag=True]">
                        <Setter Property="RenderTransform">
                            <TranslateTransform X="0"/>
                        </Setter>
                    </Style>
                    <Style Selector="Border#FlaggedPasswordsSlideHost[Tag=False]">
                        <Setter Property="RenderTransform">
                            <TranslateTransform X="520"/>
                        </Setter>
                    </Style>
                </Border.Styles>
                <Border.Transitions>
                    <Transitions>
                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.35" Easing="CubicEaseOut"/>
                    </Transitions>
                </Border.Transitions>

                <Grid RowDefinitions="Auto,Auto,*">
                    <Border Grid.Row="0"
                            Padding="24,20,24,12">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="16">
                            <Border Width="6"
                                    Height="44"
                                    CornerRadius="22"
                                    Background="#33FFAE00"
                                    VerticalAlignment="Center">
                                <TextBlock Text="⚑"
                                           FontSize="{StaticResource Type.H3.Size}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Orientation="Vertical"
                                        Spacing="2"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Flagged Passwords"
                                           FontSize="{StaticResource Type.H3.Size}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Weak or short passwords show up here so you can harden them quickly."
                                           FontSize="{StaticResource Type.Small.Size}"
                                           Foreground="{DynamicResource MutedTextBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <Border Background="#19000000"
                                        CornerRadius="10"
                                        Padding="10,4">
                                    <TextBlock Text="{Binding FlaggedCredentialCount}"
                                               FontSize="{StaticResource Type.Label.Size}"
                                               FontWeight="Bold"/>
                                </Border>
                                <Button Command="{Binding CloseFlaggedPasswordsCommand}"
                                        Classes="liquid-glass"
                                        Width="34"
                                        Height="34"
                                        ToolTip.Tip="Close flagged passwords panel">
                                    <TextBlock Text="✕"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="1"
                               Margin="24,0,24,8"
                               Text="Passwords flagged as Weak or OK are prioritized first."
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"/>

                    <Grid Grid.Row="2" Margin="24,0,24,24">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      IsVisible="{Binding HasFlaggedCredentials}">
                            <ItemsControl ItemsSource="{Binding FlaggedCredentials}" Margin="0,0,0,16">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource ContentBackgroundBrush}"
                                                CornerRadius="{StaticResource Radius.Xl}"
                                                Padding="14"
                                                Margin="0,0,0,12"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                Effect="{x:Null}">
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16" VerticalAlignment="Center">
                                                <!-- Left colour bar -->
                                                <Border Width="6"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Stretch"
                                                        CornerRadius="12,0,0,12"
                                                        Margin="0"
                                                        IsHitTestVisible="False"
                                                        Opacity="{Binding HasGroup, Converter={StaticResource BoolToOpacityConverter}}">
                                                    <Border.Background>
                                                        <MultiBinding Converter="{StaticResource CategoryNameToBrushConverter}">
                                                            <Binding Path="Group"/>
                                                            <Binding Path="$parent[Window].DataContext.Categories"/>
                                                        </MultiBinding>
                                                    </Border.Background>
                                                </Border>

                                                <!-- Icon / avatar -->
                                                <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                                                    <Border Width="46"
                                                            Height="46"
                                                            CornerRadius="{StaticResource Radius.Lg}"
                                                            Background="{Binding IconBackgroundBrush}">
                                                        <Grid>
                                                            <Image Source="{Binding AutoDetectedIconBitmap}"
                                                                   Width="34"
                                                                   Height="34"
                                                                   Stretch="Uniform"
                                                                   IsVisible="{Binding HasAutoDetectedIcon}"/>
                                                            <TextBlock Text="{Binding DisplayIcon}"
                                                                       FontSize="{StaticResource Type.SubHeading.Size}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="White"
                                                                       IsVisible="{Binding HasCustomIcon}"/>
                                                            <TextBlock Text="{Binding IconText}"
                                                                       FontSize="{StaticResource Type.H3.Size}"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="White"
                                                                       IsVisible="{Binding !HasCustomIcon}"/>
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="{StaticResource Type.H4.Size}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Username}"
                                                               FontSize="{StaticResource Type.Label.Size}"
                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Border Background="{Binding PasswordFlagBackground}"
                                                                CornerRadius="{StaticResource Radius.Lg}"
                                                                Padding="10,2">
                                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                                <TextBlock Text="⚑" FontSize="{StaticResource Type.Tiny.Size}"/>
                                                                <TextBlock Text="{Binding PasswordFlagText}"
                                                                           FontSize="{StaticResource Type.Tiny.Size}"
                                                                           FontWeight="SemiBold"/>
                                                            </StackPanel>
                                                        </Border>
                                                        <TextBlock Text="{Binding LastUpdatedUtc, StringFormat='Updated {0:MMM dd, yyyy}'}"
                                                                   FontSize="{StaticResource Type.Tiny.Size}"
                                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="8">
                                                    <Button Command="{Binding DataContext.EditCredentialCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Background="{DynamicResource AccentBrush}"
                                                            Foreground="{DynamicResource ButtonAccentForegroundBrush}"
                                                            Padding="12,4"
                                                            MinWidth="90"
                                                            ToolTip.Tip="Open this credential in the editor">
                                                        <TextBlock Text="Review" FontWeight="SemiBold"/>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.CopyPasswordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Classes="liquid-glass"
                                                            Padding="12,4"
                                                            MinWidth="90"
                                                            ToolTip.Tip="Copy password to clipboard">
                                                        <TextBlock Text="Copy"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="6"
                                    IsVisible="{Binding !HasFlaggedCredentials}">
                            <TextBlock Text="All passwords look great!"
                                       FontSize="{StaticResource Type.H5.Size}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="We will list weaker entries here as soon as we detect them."
                                       FontSize="{StaticResource Type.Small.Size}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
    
</UserControl>
