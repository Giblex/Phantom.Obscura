<views:ThemeAwareWindow xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PhantomVault.UI.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:PhantomVault.UI.Views"
    mc:Ignorable="d" d:DesignWidth="650" d:DesignHeight="700"
    x:Class="PhantomVault.UI.Views.VeraCryptSetupWindow"
        x:DataType="vm:VeraCryptSetupWindowViewModel"
        Title="VeraCrypt Container Setup"
        Width="680" Height="720"
        MinWidth="550" MinHeight="500"
        MaxWidth="800" MaxHeight="850"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
    Background="{DynamicResource WindowBackgroundBrush}" Icon="avares://PhantomVault.UI/Assets/Visuals/Giblex Icons/Parent Icon.ico" FontFamily="Segoe UI">

    <Design.DataContext>
        <vm:VeraCryptSetupWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="0">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" Padding="15,8">
            <StackPanel Spacing="8">
                <TextBlock Text="VeraCrypt Container Setup"
                           FontSize="{StaticResource Type.H2.Size}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           HorizontalAlignment="Center"/>
                
                <TextBlock Text="Create an encrypted container for additional security"
                           FontSize="{StaticResource Type.Label.Size}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
                
                <TextBlock Text="(Optional - can be set up later)"
                           FontSize="{StaticResource Type.Tiny.Size}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content with Tabs -->
        <TabControl Grid.Row="1" Padding="10" Margin="10,5">
            
            <!-- Container Setup Tab -->
            <TabItem Header="Container Setup">
                <ScrollViewer Padding="30,20,30,30" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="25" MaxWidth="500" Margin="0,0,0,120">
                        
                        <!-- Container Size -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Container Size"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    
                    <TextBlock Text="Choose the size for your encrypted container"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,0,0,8"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center">
                        <NumericUpDown Value="{Binding ContainerSizeMB}"
                                       Minimum="10"
                                       Maximum="1048576"
                                       Increment="100"
                                       Width="150"
                                       Height="32"
                                       ToolTip.Tip="Enter the size for your encrypted container in megabytes (MB). Range: 10 MB to 1 TB."/>
                        
                        <TextBlock Text="MB"
                                   VerticalAlignment="Center"
                                   FontSize="{StaticResource Type.Body.Size}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        
                        <TextBlock Text="{Binding ContainerSizeGB, StringFormat='({0})'}"
                                   VerticalAlignment="Center"
                                   FontSize="{StaticResource Type.Label.Size}"
                                   Foreground="{DynamicResource MutedTextBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0" HorizontalAlignment="Center">
                        <Button Content="100 MB" 
                                Command="{Binding SetSizeCommand}"
                                CommandParameter="100"
                                Classes="liquid-glass"
                                Width="75" Height="30"
                                FontSize="{StaticResource Type.Tiny.Size}"/>
                        <Button Content="500 MB"
                                Command="{Binding SetSizeCommand}"
                                CommandParameter="500"
                                Classes="liquid-glass"
                                Width="75" Height="30"
                                FontSize="{StaticResource Type.Tiny.Size}"/>
                        <Button Content="1 GB"
                                Command="{Binding SetSizeCommand}"
                                CommandParameter="1024"
                                Classes="liquid-glass"
                                Width="75" Height="30"
                                FontSize="{StaticResource Type.Tiny.Size}"/>
                        <Button Content="5 GB"
                                Command="{Binding SetSizeCommand}"
                                CommandParameter="5120"
                                Classes="liquid-glass"
                                Width="75" Height="30"
                                FontSize="{StaticResource Type.Tiny.Size}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Container Location -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Container Location"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    
                    <TextBlock Text="Where should the encrypted container be created?"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,0,0,8"/>
                    
                    <Grid ColumnDefinitions="*,Auto" Height="32">
                        <TextBox Grid.Column="0" 
                                 Text="{Binding ContainerPath}"
                                 IsReadOnly="True"
                                 Watermark="Select container location..."
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,10,0"/>
                        
            <Button Grid.Column="1"
                Content="Browse"
                Command="{Binding BrowseLocationCommand}"
                Classes="liquid-glass"
                Width="100"
                Height="32"
                FontWeight="SemiBold"
                ToolTip.Tip="Browse and select where to save the VeraCrypt container file on your USB drive."/>
                    </Grid>
                </StackPanel>

                <!-- Container Password -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Container Password"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>

                    <TextBlock Text="Optional but strongly recommended. Leaving this blank means anyone with the container can open it."
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,0,0,8"/>

                    <StackPanel Spacing="6">
                        <TextBox Text="{Binding ContainerPassword}"
                                 PasswordChar="{Binding ContainerPasswordMaskChar}"
                                 Watermark="Enter container password (leave blank to skip)"
                                 VerticalContentAlignment="Center"
                                 Height="32"/>
                        <CheckBox Content="Show password"
                                  IsChecked="{Binding ShowContainerPassword}"
                                  FontSize="{StaticResource Type.Tiny.Size}"
                                  Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding PasswordError}"
                                   FontSize="{StaticResource Type.Tiny.Size}"
                                   Foreground="{DynamicResource ErrorBrush}"/>
                    </StackPanel>

                    <StackPanel Spacing="6" Margin="0,8,0,0">
                        <TextBox Text="{Binding ConfirmContainerPassword}"
                                 PasswordChar="{Binding ConfirmPasswordMaskChar}"
                                 Watermark="Confirm container password (if used)"
                                 VerticalContentAlignment="Center"
                                 Height="32"/>
                        <CheckBox Content="Show confirmation"
                                  IsChecked="{Binding ShowConfirmContainerPassword}"
                                  FontSize="{StaticResource Type.Tiny.Size}"
                                  Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="{Binding ConfirmPasswordError}"
                                   FontSize="{StaticResource Type.Tiny.Size}"
                                   Foreground="{DynamicResource ErrorBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Encryption Algorithm -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Encryption Algorithm"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    
                    <TextBlock Text="Select the encryption cipher(s) for the container"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,0,0,8"/>
                    
                    <ComboBox ItemsSource="{Binding EncryptionAlgorithms}"
                              SelectedValue="{Binding SelectedEncryption}"
                              Width="300"
                              Height="32"
                              HorizontalAlignment="Left"
                              ToolTip.Tip="Select encryption algorithm for the container. AES is recommended for best performance and security."/>
                    
                    <TextBlock Text="AES is recommended for best performance"
                               FontSize="{StaticResource Type.Tiny.Size}"
                               Foreground="{DynamicResource SuccessBrush}"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Hash Algorithm -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Hash Algorithm"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    
                    <TextBlock Text="Select the hash algorithm for key derivation"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,0,0,8"/>
                    
                    <ComboBox ItemsSource="{Binding HashAlgorithms}"
                              SelectedValue="{Binding SelectedHash}"
                              Width="300"
                              Height="32"
                              HorizontalAlignment="Left"
                              ToolTip.Tip="Select the hash algorithm used for key derivation. SHA-512 provides strong security."/>
                </StackPanel>

                <!-- Filesystem -->
                <StackPanel Spacing="10">
                    <TextBlock Text="Filesystem"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    
                    <TextBlock Text="Choose the filesystem for the container"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,0,0,8"/>
                    
                    <ComboBox ItemsSource="{Binding FilesystemTypes}"
                              SelectedValue="{Binding SelectedFilesystem}"
                              Width="300"
                              Height="32"
                              HorizontalAlignment="Left"
                              ToolTip.Tip="Select the filesystem for the container. FAT for compatibility, NTFS for large files (Windows only), exFAT for cross-platform large files."/>
                    
                    <TextBlock FontSize="{StaticResource Type.Tiny.Size}" Foreground="{DynamicResource MutedTextBrush}" Margin="0,5,0,0">
                        <Run Text="FAT: Best compatibility"/>
                        <LineBreak/>
                        <Run Text="NTFS: Windows only, supports large files"/>
                        <LineBreak/>
                        <Run Text="exFAT: Cross-platform, large files"/>
                    </TextBlock>
                </StackPanel>

                <!-- Progress Section (visible during creation) -->
                <StackPanel Spacing="12" IsVisible="{Binding IsCreating}">
                    <ProgressBar Value="{Binding CreationProgress}"
                                 Minimum="0"
                                 Maximum="100"
                                 Height="8"
                                 Foreground="{DynamicResource AccentBrush}"/>
                    
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="{StaticResource Type.Label.Size}"
                               Foreground="{DynamicResource SuccessBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Status Message (errors/info) -->
                <Border Background="{DynamicResource FooterBackgroundBrush}"
                        Padding="15,12"
                        CornerRadius="{DynamicResource Radius.Md}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource WarningBrush}"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Info Box -->
                <Border Background="{DynamicResource ControlBackgroundBrush}"
                        Padding="15"
                        CornerRadius="{DynamicResource Radius.Md}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="💡 About VeraCrypt"
                                   FontSize="{StaticResource Type.Label.Size}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        
                        <TextBlock FontSize="{StaticResource Type.Tiny.Size}" 
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="16">
                            VeraCrypt creates an encrypted container on your USB drive. This provides:<LineBreak/>
                            • Military-grade encryption<LineBreak/>
                            • Plausible deniability (hidden volumes)<LineBreak/>
                            • Cross-platform compatibility<LineBreak/>
                            • Protection against forensic analysis<LineBreak/>
                            <LineBreak/>
                            You can skip this step and set it up later from Settings.
                        </TextBlock>
                    </StackPanel>
                </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- VeraCrypt Settings Tab -->
            <TabItem Header="VeraCrypt Settings">
                <ScrollViewer Padding="30,20,30,30" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="25" MaxWidth="500">
                        
                        <!-- Integration Settings -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="VeraCrypt Integration"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            
                            <TextBlock Text="Configure how PhantomVault integrates with VeraCrypt"
                                       FontSize="{StaticResource Type.Small.Size}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,0,0,8"/>
                            
                            <CheckBox Content="Enable VeraCrypt Integration"
                                      IsChecked="{Binding IsVeraCryptEnabled}"
                                      ToolTip.Tip="Enable or disable VeraCrypt encryption for this vault"/>
                            
                            <CheckBox Content="Auto-mount container on vault access"
                                      IsChecked="{Binding AutoMountEnabled}"
                                      IsEnabled="{Binding IsVeraCryptEnabled}"
                                      Margin="20,5,0,0"
                                      ToolTip.Tip="Automatically mount the VeraCrypt container when opening the vault"/>
                            
                            <CheckBox Content="Auto-dismount on vault close"
                                      IsChecked="{Binding AutoDismountEnabled}"
                                      IsEnabled="{Binding IsVeraCryptEnabled}"
                                      Margin="20,5,0,0"
                                      ToolTip.Tip="Automatically dismount the container when closing the vault"/>
                        </StackPanel>

                        <!-- VeraCrypt Executable Path -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="VeraCrypt Executable"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            
                            <TextBlock Text="Location of the VeraCrypt executable"
                                       FontSize="{StaticResource Type.Small.Size}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,0,0,8"/>
                            
                            <Grid ColumnDefinitions="*,Auto" Height="32">
                                <TextBox Grid.Column="0" 
                                         Text="{Binding VeraCryptPath}"
                                         IsReadOnly="True"
                                         Watermark="VeraCrypt.exe path..."
                                         VerticalContentAlignment="Center"
                                         Margin="0,0,10,0"/>
                                
                                <Button Grid.Column="1"
                                        Content="Browse"
                                        Command="{Binding BrowseVeraCryptCommand}"
                                        Classes="liquid-glass"
                                        Width="100"
                                        Height="32"
                                        FontWeight="SemiBold"
                                        ToolTip.Tip="Browse to locate VeraCrypt.exe on your system"/>
                            </Grid>
                            
                            <TextBlock Text="Default: C:\Program Files\VeraCrypt\VeraCrypt.exe"
                                       FontSize="{StaticResource Type.Tiny.Size}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- Mount Options -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="Mount Options"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            
                            <TextBlock Text="Advanced mounting preferences"
                                       FontSize="{StaticResource Type.Small.Size}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,0,0,8"/>
                            
                            <CheckBox Content="Mount as removable media"
                                      IsChecked="{Binding MountAsRemovable}"
                                      IsEnabled="{Binding IsVeraCryptEnabled}"
                                      ToolTip.Tip="Mount the container as a removable drive"/>
                            
                            <CheckBox Content="Mount as read-only"
                                      IsChecked="{Binding MountReadOnly}"
                                      IsEnabled="{Binding IsVeraCryptEnabled}"
                                      ToolTip.Tip="Mount the container in read-only mode for extra protection"/>
                            
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                                <TextBlock Text="Preferred Drive Letter:"
                                           VerticalAlignment="Center"
                                           FontSize="{StaticResource Type.Label.Size}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <ComboBox Width="80"
                                          Height="32"
                                          SelectedValue="{Binding PreferredDriveLetter}"
                                          SelectedValueBinding="{Binding Content, RelativeSource={RelativeSource Self}}"
                                          IsEnabled="{Binding IsVeraCryptEnabled}"
                                          ToolTip.Tip="Select preferred drive letter (leave empty for auto)">
                                    <ComboBoxItem Content="Auto"/>
                                    <ComboBoxItem Content="V:"/>
                                    <ComboBoxItem Content="W:"/>
                                    <ComboBoxItem Content="X:"/>
                                    <ComboBoxItem Content="Y:"/>
                                    <ComboBoxItem Content="Z:"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>

                        <!-- Security Options -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="Security Options"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            
                            <TextBlock Text="Additional security features"
                                       FontSize="{StaticResource Type.Small.Size}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,0,0,8"/>
                            
                            <CheckBox Content="Cache password in driver memory"
                                      IsChecked="{Binding CachePassword}"
                                      IsEnabled="{Binding IsVeraCryptEnabled}"
                                      ToolTip.Tip="Cache the password for faster remounting (less secure)"/>
                            
                            <CheckBox Content="Use PIM (Personal Iterations Multiplier)"
                                      IsChecked="{Binding UsePIM}"
                                      IsEnabled="{Binding IsVeraCryptEnabled}"
                                      ToolTip.Tip="Enable PIM for additional security during mounting"/>
                            
                            <CheckBox Content="Use keyfiles"
                                      IsChecked="{Binding UseKeyfiles}"
                                      IsEnabled="{Binding IsVeraCryptEnabled}"
                                      ToolTip.Tip="Require keyfiles in addition to password"/>
                        </StackPanel>

                        <!-- Info Box -->
                        <Border Background="{DynamicResource ControlBackgroundBrush}"
                                Padding="15"
                                CornerRadius="{DynamicResource Radius.Md}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="⚙️ Configuration Tips"
                                           FontSize="{StaticResource Type.Label.Size}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                
                                <TextBlock FontSize="{StaticResource Type.Tiny.Size}" 
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="16">
                                    • Auto-mount makes vault access seamless but requires VeraCrypt installed<LineBreak/>
                                    • Read-only mode prevents accidental modifications<LineBreak/>
                                    • PIM increases security at the cost of mount time<LineBreak/>
                                    • Keyfiles provide an additional authentication factor<LineBreak/>
                                    <LineBreak/>
                                    Changes take effect on next vault access.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Action Buttons -->
        <Border Grid.Row="2" Background="{DynamicResource FooterBackgroundBrush}" Padding="25,10">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Spacing="15">
                
                <!-- Go Back Button -->
                <Button Click="GoBack_Click"
                        Width="140"
                        Height="42"
                        Classes="liquid-glass"
                        FontSize="{StaticResource Type.Body.Size}"
                        IsEnabled="{Binding !IsCreating}"
                        ToolTip.Tip="Return to the previous screen">
                    <TextBlock Text="Go Back" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
                
                <!-- Create Button -->
                <Button Command="{Binding CreateContainerCommand}"
                        Width="140"
                        Height="42"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Classes="liquid-glass primary"
                        IsEnabled="{Binding !IsCreating}"
                        ToolTip.Tip="Create the encrypted VeraCrypt container with the specified settings. This may take several minutes depending on size.">
                    <TextBlock Text="Create" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Skip Button -->
                <Button Command="{Binding SkipCommand}"
                        Width="120"
                        Height="42"
                        Classes="liquid-glass"
                        FontSize="{StaticResource Type.Label.Size}"
                        IsEnabled="{Binding !IsCreating}"
                        ToolTip.Tip="Skip VeraCrypt setup for now. You can configure it later from the Settings page.">
                    <TextBlock Text="Skip" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</views:ThemeAwareWindow>


