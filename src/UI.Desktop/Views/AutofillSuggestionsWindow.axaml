<?xml version="1.0" encoding="utf-8"?>
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PhantomVault.UI.Views.AutofillSuggestionsWindow"
        Title="Auto-Fill Suggestions" 
        Width="420" 
        Height="580"
        MinWidth="380"
        MinHeight="400"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="True">
    
    <Window.Styles>
        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Styles>
    
    <Grid RowDefinitions="Auto,*">
        
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource HeaderBackgroundBrush}" 
                Padding="15,12"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="4">
                <TextBlock Text="Auto-Fill Suggestions" 
                           FontSize="15" 
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="Select credentials or detect new passwords" 
                           FontSize="11" 
                           Foreground="{DynamicResource MutedTextBrush}"/>
            </StackPanel>
        </Border>
        
        <!-- Tabbed Content -->
        <TabControl Grid.Row="1" 
                    Padding="0"
                    Background="{DynamicResource WindowBackgroundBrush}">
            
            <!-- Tab 1: Credential Suggestions -->
            <TabItem Header="⌘ Credentials">
                <Grid RowDefinitions="Auto,*,Auto">
                    
                    <!-- Current Site Info -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            Padding="12,10"
                            Margin="0,0,0,8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Current site:" 
                                       FontSize="10"
                                       Foreground="{DynamicResource MutedTextBrush}"/>
                            <TextBlock Text="github.com" 
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Credentials List -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="8,0">
                        <ItemsControl>
                            <!-- Sample Credentials -->
                            <StackPanel Spacing="6">
                                
                                <!-- Credential Item 1 -->
                                <Border Background="{DynamicResource ContentBackgroundBrush}"
                                        CornerRadius="{StaticResource Radius.Md}"
                                        Padding="12,10"
                                        Cursor="Hand">
                                    <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
                                        </Style>
                                    </Border.Styles>
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0"
                                                Width="32"
                                                Height="32"
                                                CornerRadius="{StaticResource Radius.Xxl}"
                                                Background="{DynamicResource AccentBrush}"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="GH" 
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" 
                                                    VerticalAlignment="Center"
                                                    Spacing="2">
                                            <TextBlock Text="user@example.com" 
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="GitHub Account" 
                                                       FontSize="10"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="⭐"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                                
                                <!-- Credential Item 2 -->
                                <Border Background="{DynamicResource ContentBackgroundBrush}"
                                        CornerRadius="{StaticResource Radius.Md}"
                                        Padding="12,10"
                                        Cursor="Hand">
                                    <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
                                        </Style>
                                    </Border.Styles>
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Border Grid.Column="0"
                                                Width="32"
                                                Height="32"
                                                CornerRadius="{StaticResource Radius.Xxl}"
                                                Background="#4078C0"
                                                Margin="0,0,10,0">
                                            <TextBlock Text="GH" 
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" 
                                                    VerticalAlignment="Center"
                                                    Spacing="2">
                                            <TextBlock Text="work@company.com" 
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="Work GitHub" 
                                                       FontSize="10"
                                                       Foreground="{DynamicResource MutedTextBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                
                                <!-- No Matching Credentials Message -->
                                <Border Background="{DynamicResource ControlBackgroundBrush}"
                                        CornerRadius="{StaticResource Radius.Md}"
                                        Padding="20"
                                        Margin="0,20,0,0"
                                        IsVisible="False">
                                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                                        <TextBlock Text="🔍" 
                                                   FontSize="32"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="No saved credentials for this site" 
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="Enter credentials to save them" 
                                                   FontSize="10"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                
                            </StackPanel>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <!-- Footer Actions -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="12,10">
                        <StackPanel Spacing="8">
                            <Button Content="+ Add New Credential for This Site"
                                    Classes="liquid-glass"
                                    HorizontalAlignment="Stretch"
                                    Height="36"
                                    FontSize="12"/>
                            <Button Content="⚙️ Manage All Credentials"
                                    Classes="liquid-glass"
                                    HorizontalAlignment="Stretch"
                                    Height="32"
                                    FontSize="11"/>
                        </StackPanel>
                    </Border>
                    
                </Grid>
            </TabItem>
            
            <!-- Tab 2: New Password Detection -->
            <TabItem Header="🔔 Detect Changes">
                <Grid RowDefinitions="Auto,*,Auto">
                    
                    <!-- Info Header -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            Padding="12,10"
                            Margin="0,0,0,12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Automatic Password Change Detection" 
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="PhantomVault will automatically detect when you create or change passwords and offer to update your vault." 
                                       FontSize="10"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Detection Content -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="8,0">
                        <StackPanel Spacing="12">
                            
                            <!-- Detection Settings -->
                            <Border Background="{DynamicResource ContentBackgroundBrush}"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Padding="15">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Detection Settings" 
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <ToggleSwitch Content="Auto-detect new passwords"
                                                  IsChecked="True"
                                                  FontSize="11"/>
                                    <ToggleSwitch Content="Auto-detect password changes"
                                                  IsChecked="True"
                                                  FontSize="11"/>
                                    <ToggleSwitch Content="Prompt before saving"
                                                  IsChecked="True"
                                                  FontSize="11"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Recent Detections -->
                            <Border Background="{DynamicResource ContentBackgroundBrush}"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Padding="15">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Recent Detections" 
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    
                                    <!-- Detection Item -->
                                    <Border Background="{DynamicResource WindowBackgroundBrush}"
                                            CornerRadius="{StaticResource Radius.Sm}"
                                            Padding="10"
                                            BorderBrush="{DynamicResource SuccessBrush}"
                                            BorderThickness="1">
                                        <Grid RowDefinitions="Auto,Auto,Auto">
                                            <StackPanel Grid.Row="0" 
                                                        Orientation="Horizontal" 
                                                        Spacing="6">
                                                <TextBlock Text="✓" 
                                                           FontSize="12"
                                                           Foreground="{DynamicResource SuccessBrush}"/>
                                                <TextBlock Text="Password Changed" 
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" 
                                                       Text="github.com • user@example.com" 
                                                       FontSize="10"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="2" 
                                                       Text="Updated 2 minutes ago" 
                                                       FontSize="9"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       Margin="0,2,0,0"/>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- Empty State -->
                                    <Border Background="{DynamicResource WindowBackgroundBrush}"
                                            CornerRadius="{StaticResource Radius.Sm}"
                                            Padding="15"
                                            IsVisible="False">
                                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                                            <TextBlock Text="👁️" 
                                                       FontSize="24"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="No recent detections" 
                                                       FontSize="10"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                            
                            <!-- Quick Update -->
                            <Border Background="{DynamicResource ControlBackgroundBrush}"
                                    CornerRadius="{StaticResource Radius.Md}"
                                    Padding="15"
                                    BorderBrush="{DynamicResource AccentBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="🔄" FontSize="14"/>
                                        <TextBlock Text="Quick Update Credential" 
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="Detected a password change on this page" 
                                               FontSize="10"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                    <ComboBox PlaceholderText="Select credential to update"
                                              Height="32"
                                              FontSize="11">
                                        <ComboBoxItem Content="user@example.com - GitHub Account"/>
                                        <ComboBoxItem Content="work@company.com - Work GitHub"/>
                                    </ComboBox>
                                    <Button Content="Update Selected Credential"
                                            Classes="accent"
                                            Height="32"
                                            FontSize="11"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>
                            
                        </StackPanel>
                    </ScrollViewer>
                    
                    <!-- Footer -->
                    <Border Grid.Row="2"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="12,10">
                        <Button Content="View Detection History"
                                Classes="liquid-glass"
                                HorizontalAlignment="Stretch"
                                Height="32"
                                FontSize="11"/>
                    </Border>
                    
                </Grid>
            </TabItem>
            
        </TabControl>
        
    </Grid>
    
</Window>
