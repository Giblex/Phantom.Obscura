<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- High Contrast theme - WCAG AAA compliant (7:1+ contrast ratios) -->
    <!-- Designed for users with low vision, color blindness, or light sensitivity -->
    <Style>
        <Style.Resources>
            <!-- High contrast backgrounds - Pure black base -->
            <SolidColorBrush x:Key="WindowBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="FooterBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="ContentBackgroundBrush">#000000</SolidColorBrush>

            <!-- High contrast surfaces - White text on black -->
            <SolidColorBrush x:Key="TileGlassBrush">#1A1A1A</SolidColorBrush>
            <SolidColorBrush x:Key="TileGapBrush">#000000</SolidColorBrush>
            <!-- No gradients in high contrast mode - solid color only -->
            <SolidColorBrush x:Key="TileOverlayBrush">#00FFFFFF</SolidColorBrush>

            <!-- High contrast accent - Bright cyan for maximum visibility -->
            <SolidColorBrush x:Key="AccentBrush">#00FFFF</SolidColorBrush>
            <SolidColorBrush x:Key="AccentHoverBrush">#66FFFF</SolidColorBrush>
            <SolidColorBrush x:Key="SecondaryAccentBrush">#00FF00</SolidColorBrush>

            <!-- High contrast text - Pure white on black -->
            <Color x:Key="PrimaryTextColor">#FFFFFF</Color>
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="{DynamicResource PrimaryTextColor}" />
            <SolidColorBrush x:Key="ControlForegroundBrush" Color="{DynamicResource PrimaryTextColor}" />
            <SolidColorBrush x:Key="HeaderTextBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderMutedTextBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="FooterTextBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="FooterMutedTextBrush">#FFFFFF</SolidColorBrush>

            <!-- High contrast buttons - Lighter backgrounds with strong borders for visibility -->
            <SolidColorBrush x:Key="HeaderButtonBackgroundBrush">#4D4D4D</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderButtonHoverBrush">#666666</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderButtonPressedBrush">#808080</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderButtonForegroundBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderButtonBorderBrush">#FFFFFF</SolidColorBrush>
            
            <!-- Button backgrounds - Lighter for better visibility -->
            <SolidColorBrush x:Key="ButtonBackgroundBrush">#4D4D4D</SolidColorBrush>
            <SolidColorBrush x:Key="ButtonBackgroundHoverBrush">#666666</SolidColorBrush>
            <SolidColorBrush x:Key="ButtonBackgroundPressedBrush">#808080</SolidColorBrush>
            <SolidColorBrush x:Key="ButtonForegroundBrush">#FFFFFF</SolidColorBrush>

            <!-- High contrast text hierarchy - All white, no muted variants -->
            <SolidColorBrush x:Key="SecondaryTextBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="MutedTextBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="DisabledTextBrush">#808080</SolidColorBrush>

            <!-- High contrast controls - Solid backgrounds with strong borders -->
            <SolidColorBrush x:Key="ControlBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="ControlBorderBrush">#FFFFFF</SolidColorBrush>

            <!-- Settings panel -->
            <SolidColorBrush x:Key="SettingsPanelBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="SettingsPanelBorderBrush">#FFFFFF</SolidColorBrush>

            <!-- Liquid glass button - High contrast variant -->
            <SolidColorBrush x:Key="LiquidGlassButtonForeground">#FFFFFF</SolidColorBrush>

            <!-- Overlays and utilities -->
            <SolidColorBrush x:Key="OverlayBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="ReadOnlyFieldBackgroundBrush">#1A1A1A</SolidColorBrush>
            <SolidColorBrush x:Key="ReadOnlyFieldForegroundBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="ButtonWhiteBackgroundBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="SeparatorBrush">#FFFFFF</SolidColorBrush>

            <!-- High contrast filters - Solid backgrounds only -->
            <SolidColorBrush x:Key="QuickFilterGlassBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="QuickFilterGlassHoverBrush">#1A1A1A</SolidColorBrush>
            <SolidColorBrush x:Key="QuickFilterGlassActiveBrush">#333333</SolidColorBrush>
            <SolidColorBrush x:Key="QuickFilterGlassActiveHoverBrush">#4D4D4D</SolidColorBrush>
            <SolidColorBrush x:Key="QuickFilterGlassBorderBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="QuickFilterGlassActiveBorderBrush">#00FFFF</SolidColorBrush>

            <!-- High contrast semantic colors - Bright, saturated colors -->
            <SolidColorBrush x:Key="SuccessBrush">#00FF00</SolidColorBrush>
            <SolidColorBrush x:Key="WarningBrush">#FFFF00</SolidColorBrush>
            <SolidColorBrush x:Key="WarningBrushDark">#FFFF00</SolidColorBrush>
            <SolidColorBrush x:Key="WarningBrushDarker">#FFFF00</SolidColorBrush>
            <SolidColorBrush x:Key="WarningIcon">#FFFF00</SolidColorBrush>
            <SolidColorBrush x:Key="ErrorBrush">#FF0000</SolidColorBrush>
            <SolidColorBrush x:Key="SuccessBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="WarningBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="ErrorBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="InfoBackgroundBrush">#000000</SolidColorBrush>
            <FontFamily x:Key="MainFontFamily">Segoe UI</FontFamily>

            <!-- Overlay utilities -->
            <SolidColorBrush x:Key="OverlayBackgroundLightBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="ErrorTextBrush">#FF0000</SolidColorBrush>
            <SolidColorBrush x:Key="SuccessTextBrush">#00FF00</SolidColorBrush>

            <!-- Autofill high contrast -->
            <SolidColorBrush x:Key="AutofillBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillHeaderBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillBorderBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillTextBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillTextSecondaryBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillTextTertiaryBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillTextQuaternaryBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillSuccessBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="KeyboardBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="KeyboardKeyBackgroundBrush">#000000</SolidColorBrush>

            <!-- Spacing Tokens (same as other themes) -->
            <x:Double x:Key="Space.Xs">4</x:Double>
            <x:Double x:Key="Space.Sm">8</x:Double>
            <x:Double x:Key="Space.Md">12</x:Double>
            <x:Double x:Key="Space.Lg">16</x:Double>
            <x:Double x:Key="Space.Xl">20</x:Double>
            <x:Double x:Key="Space.Xxl">24</x:Double>

            <!-- Border Radius Tokens (reduced for high contrast - clearer edges) -->
            <CornerRadius x:Key="Radius.Xs">0</CornerRadius>
            <CornerRadius x:Key="Radius.Sm">0</CornerRadius>
            <CornerRadius x:Key="Radius.Md">2</CornerRadius>
            <CornerRadius x:Key="Radius.Lg">2</CornerRadius>
            <CornerRadius x:Key="Radius.Xl">4</CornerRadius>
            <CornerRadius x:Key="Radius.Pill">999</CornerRadius>

            <!-- Border & Accent Brushes -->
            <SolidColorBrush x:Key="Brush.BorderSoft">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.BorderMedium">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.BorderStrong">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.Accent">#00FFFF</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.AccentHover">#66FFFF</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.FocusRing">#FFFF00</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.DangerHover">#FF0000</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.Danger">#FF0000</SolidColorBrush>

            <!-- Thickness Tokens -->
            <Thickness x:Key="Thickness.CardPadding">16,12,16,12</Thickness>
            <Thickness x:Key="Thickness.ButtonPadding">16,10,16,10</Thickness>
            <SolidColorBrush x:Key="Brush.AccentPressed">#99FFFF</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.Card">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.CardHover">#1A1A1A</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.TextPrimary">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.TextMuted">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.TextOnDark">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.Navy900">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.SurfaceAlt">#1A1A1A</SolidColorBrush>

            <!-- Typography Tokens (same as other themes) -->
            <x:Double x:Key="Type.Display.Size">48</x:Double>
            <x:Double x:Key="Type.H1.Size">32</x:Double>
            <x:Double x:Key="Type.H2.Size">24</x:Double>
            <x:Double x:Key="Type.H3.Size">18</x:Double>
            <x:Double x:Key="Type.H4.Size">16</x:Double>
            <x:Double x:Key="Type.Body.Size">14</x:Double>
            <x:Double x:Key="Type.Label.Size">13</x:Double>
            <x:Double x:Key="Type.Small.Size">12</x:Double>
            <x:Double x:Key="Type.Tiny.Size">11</x:Double>
            <FontWeight x:Key="Type.Weight.Light">Light</FontWeight>
            <FontWeight x:Key="Type.Weight.Medium">Medium</FontWeight>
            <FontWeight x:Key="Type.Weight.SemiBold">SemiBold</FontWeight>

            <!-- Text Selection Colors - High contrast yellow -->
            <SolidColorBrush x:Key="TextSelectionBrush">#FFFF00</SolidColorBrush>
            <SolidColorBrush x:Key="TextCaretBrush">#FFFFFF</SolidColorBrush>

            <!-- Input surfaces - White on black with strong borders -->
            <SolidColorBrush x:Key="InputBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="InputForegroundBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="InputPlaceholderBrush">#808080</SolidColorBrush>

            <!-- Popup/Flyout/Dropdown Brushes - High contrast -->
            <SolidColorBrush x:Key="FlyoutPresenterBackground">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="MenuFlyoutPresenterBackground">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxDropDownBackground">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="PopupBackgroundBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumLowBrush">#000000</SolidColorBrush>
            <SolidColorBrush x:Key="SystemControlForegroundBaseHighBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxItemForeground">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelected">#000000</SolidColorBrush>

            <!-- NO SHADOWS in high contrast mode - visual noise reduction -->
            <Color x:Key="GlobalShadowColor">#00000000</Color>
            <Color x:Key="HeaderAccentColor">#000000</Color>

            <!-- All shadow effects disabled (0 opacity) for high contrast -->
            <DropShadowEffect x:Key="DarkSubtleDropShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0" BlurRadius="0" />
            <DropShadowEffect x:Key="SubtleDropShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0" BlurRadius="0" />
            <DropShadowEffect x:Key="DarkButtonShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0" BlurRadius="0" />
            <DropShadowEffect x:Key="DarkButtonShadowHover" Color="{DynamicResource GlobalShadowColor}" Opacity="0" BlurRadius="0" />
            <DropShadowEffect x:Key="DarkButtonShadowPressed" Color="{DynamicResource GlobalShadowColor}" Opacity="0" BlurRadius="0" />
            <DropShadowEffect x:Key="HoverMenuDropShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0" BlurRadius="0" />
            <DropShadowEffect x:Key="TileActiveShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0" BlurRadius="0" />
            <DropShadowEffect x:Key="TileActiveShadowPressed" Color="{DynamicResource GlobalShadowColor}" Opacity="0" BlurRadius="0" />
            <DropShadowEffect x:Key="FrontPageTileBaseShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0" BlurRadius="0" />
            <DropShadowEffect x:Key="FooterGroundedShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0" BlurRadius="0" />

            <!-- BoxShadow presets disabled -->
            <BoxShadows x:Key="SlideOutPanelShadow">0 0 0 0 #00000000</BoxShadows>
            <BoxShadows x:Key="FlaggedPanelShadow">0 0 0 0 #00000000</BoxShadows>
        </Style.Resources>
    </Style>

    <!-- Base control styles for high contrast -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style Selector="Border.header-surface">
        <Setter Property="TextElement.Foreground" Value="{DynamicResource HeaderTextBrush}" />
    </Style>

    <Style Selector="TextBlock.header-muted">
        <Setter Property="Foreground" Value="{DynamicResource HeaderMutedTextBrush}" />
    </Style>

    <Style Selector="Border.footer-surface">
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FooterTextBrush}" />
    </Style>

    <Style Selector="TextBlock.footer-muted">
        <Setter Property="Foreground" Value="{DynamicResource FooterMutedTextBrush}" />
    </Style>

    <!-- High contrast buttons - Lighter backgrounds with strong borders required -->
    <Style Selector="Button">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Background" Value="#666666" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="BorderBrush" Value="#FFFFFF" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="MinWidth" Value="90" />
        <Setter Property="Effect" Value="{x:Null}" />
    </Style>

    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="#808080" />
        <Setter Property="BorderBrush" Value="#FFFF00" />
        <Setter Property="BorderThickness" Value="3" />
    </Style>

    <Style Selector="Button:pressed">
        <Setter Property="Background" Value="#999999" />
        <Setter Property="BorderBrush" Value="#00FFFF" />
        <Setter Property="BorderThickness" Value="3" />
    </Style>

    <!-- Liquid glass buttons - lighter in high contrast -->
    <Style Selector="Button.liquid-glass">
        <Setter Property="Background" Value="#666666" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="BorderBrush" Value="#FFFFFF" />
        <Setter Property="Effect" Value="{x:Null}" />
    </Style>

    <Style Selector="Button.liquid-glass:pointerover">
        <Setter Property="Background" Value="#808080" />
        <Setter Property="BorderBrush" Value="#FFFF00" />
    </Style>

    <Style Selector="Button.liquid-glass:pressed">
        <Setter Property="Background" Value="#999999" />
        <Setter Property="BorderBrush" Value="#00FFFF" />
    </Style>

    <Style Selector="Button.primary-vault">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Background" Value="#4D4D4D" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="BorderBrush" Value="#FFFFFF" />
        <Setter Property="Effect" Value="{x:Null}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <Style Selector="Button.primary-vault:pointerover">
        <Setter Property="Background" Value="#666666" />
        <Setter Property="BorderBrush" Value="#FFFF00" />
    </Style>

    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="#4D4D4D" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="BorderBrush" Value="#FFFFFF" />
        <Setter Property="Effect" Value="{x:Null}" />
    </Style>

    <Style Selector="Button.secondary:pointerover">
        <Setter Property="Background" Value="#666666" />
        <Setter Property="BorderBrush" Value="#FFFF00" />
        <Setter Property="Effect" Value="{x:Null}" />
    </Style>

    <!-- High contrast list items - Strong borders -->
    <Style Selector="ListBoxItem:pointerover, ListBoxItem:focused">
        <Setter Property="Effect" Value="{x:Null}" />
        <Setter Property="Background" Value="#333333" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="BorderBrush" Value="#FFFF00" />
    </Style>

    <Style Selector="ListBoxItem">
        <Setter Property="Effect" Value="{x:Null}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="BorderBrush" Value="#FFFFFF" />
        <Setter Property="Background" Value="#1A1A1A" />
    </Style>

    <Style Selector="DataGridRow:pointerover, DataGridRow:focused">
        <Setter Property="Effect" Value="{x:Null}" />
        <Setter Property="Background" Value="#333333" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="BorderBrush" Value="#FFFF00" />
    </Style>

    <Style Selector="DataGridRow">
        <Setter Property="Effect" Value="{x:Null}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="BorderBrush" Value="#FFFFFF" />
        <Setter Property="Background" Value="#1A1A1A" />
    </Style>

    <!-- High contrast borders and tiles - Stronger borders everywhere -->
    <Style Selector="Border:pointerover">
        <Setter Property="Effect" Value="{x:Null}" />
        <Setter Property="BorderBrush" Value="#FFFF00" />
        <Setter Property="BorderThickness" Value="3" />
    </Style>

    <Style Selector="Border">
        <Setter Property="Effect" Value="{x:Null}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <!-- MenuFlyout high contrast -->
    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Background" Value="#000000" />
        <Setter Property="BorderBrush" Value="#FFFFFF" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.secondary:pressed">
        <Setter Property="Effect" Value="{x:Null}" />
        <Setter Property="Background" Value="#333333" />
    </Style>

    <!-- High contrast text inputs -->
    <Style Selector="TextBox">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        <Setter Property="BorderBrush" Value="#FFFFFF" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="SelectionBrush" Value="{DynamicResource TextSelectionBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextCaretBrush}" />
    </Style>

    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="#FFFF00" />
        <Setter Property="BorderThickness" Value="3" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="BorderBrush" Value="#FFFFFF" />
        <Setter Property="BorderThickness" Value="3" />
        <Setter Property="Background" Value="#000000" />
        <Setter Property="Foreground" Value="#FFFFFF" />
    </Style>

    <Style Selector="ComboBox:focus">
        <Setter Property="BorderBrush" Value="#FFFF00" />
    </Style>

</Styles>
