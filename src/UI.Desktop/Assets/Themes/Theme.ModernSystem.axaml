<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Modern System Theme - Windows/iOS Style -->
    <!-- Clean, minimal, light with system blue accent -->
    
    <!-- Grey Scale -->
    <Color x:Key="Color.Navy900">#1A1A1A</Color>
    <Color x:Key="Color.Navy800">#2D2D2D</Color>
    <Color x:Key="Color.Navy700">#404040</Color>
    <Color x:Key="Color.Navy600">#525252</Color>
    <Color x:Key="Color.Navy500">#666666</Color>
    <Color x:Key="Color.Navy400">#808080</Color>
    
    <!-- Light Scale -->
    <Color x:Key="Color.LightGrey100">#FFFFFF</Color>
    <Color x:Key="Color.LightGrey200">#F9F9F9</Color>
    <Color x:Key="Color.LightGrey300">#F3F3F3</Color>
    <Color x:Key="Color.LightGrey400">#E5E5E5</Color>
    
    <!-- Text Colors -->
    <Color x:Key="Color.TextPrimary">#1A1A1A</Color>
    <Color x:Key="Color.TextMuted">#666666</Color>
    <Color x:Key="Color.TextOnDark">#FFFFFF</Color>
    <Color x:Key="Color.TextOnLight">#1A1A1A</Color>
    
    <!-- Accent Colors - System Blue -->
    <Color x:Key="Color.Accent">#0078D4</Color>
    <Color x:Key="Color.AccentHover">#1084D9</Color>
    <Color x:Key="Color.AccentDim">#60A5E8</Color>
    
    <!-- Secondary Colors -->
    <Color x:Key="Color.SystemBlue">#0078D4</Color>
    <Color x:Key="Color.SystemGreen">#107C10</Color>
    <Color x:Key="Color.SystemRed">#D13438</Color>
    <Color x:Key="Color.SystemYellow">#FFB900</Color>
    
    <!-- Semantic Colors -->
    <Color x:Key="Color.Success">#107C10</Color>
    <Color x:Key="Color.Warning">#FFB900</Color>
    <Color x:Key="Color.Danger">#D13438</Color>
    <Color x:Key="Color.Info">#0078D4</Color>

    <!-- ═══════════════════════ LEGACY BRUSHES ═══════════════════════ -->
    
    <!-- Main window background - clean white -->
    <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F3F3F3" Offset="0"/>
        <GradientStop Color="#F3F3F3" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Header - system blue gradient -->
    <LinearGradientBrush x:Key="HeaderBackgroundBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#0078D4" Offset="0"/>
        <GradientStop Color="#0067B8" Offset="0.5"/>
        <GradientStop Color="#0078D4" Offset="1"/>
    </LinearGradientBrush>
    
    <SolidColorBrush x:Key="FooterBackgroundBrush" Color="#F3F3F3"/>
    <!-- Content - pure white -->
    <SolidColorBrush x:Key="ContentBackgroundBrush" Color="#FFFFFF"/>
    <!-- Cards - slightly off-white -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <!-- Settings panels - light grey -->
    <SolidColorBrush x:Key="SettingsPanelBackgroundBrush" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="SettingsPanelBorderBrush" Color="#D0D0D0"/>
    <SolidColorBrush x:Key="TileGlassBrush">#EEFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="TileGapBrush" Color="#E5E5E5"/>
    
    <!-- System blue accents -->
    <SolidColorBrush x:Key="AccentBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#1084D9"/>
    <SolidColorBrush x:Key="SecondaryAccentBrush" Color="#60A5E8"/>
    
    <!-- Text colors -->
    <Color x:Key="PrimaryTextColor">#000000</Color>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#000000"/>
    <SolidColorBrush x:Key="ControlForegroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="HeaderTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderMutedTextBrush" Color="#B3DAFF"/>
    <SolidColorBrush x:Key="FooterTextBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="FooterMutedTextBrush" Color="#666666"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#404040"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#666666"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#A0A0A0"/>
    
    <!-- Header buttons -->
    <SolidColorBrush x:Key="HeaderButtonBackgroundBrush" Color="#1084D9"/>
    <SolidColorBrush x:Key="HeaderButtonHoverBrush" Color="#2090E0"/>
    <SolidColorBrush x:Key="HeaderButtonPressedBrush" Color="#0067B8"/>
    <SolidColorBrush x:Key="HeaderButtonForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderButtonBorderBrush" Color="#5560A5E8"/>
    
    <!-- Controls - clean white with grey borders -->
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFF"/>
    <!-- SUBTLER: Barely visible hover (was #F5F5F5) -->
    <SolidColorBrush x:Key="ControlHoverBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="TextSelectionBrush" Color="#60A8DAFF"/>
    <SolidColorBrush x:Key="TextCaretBrush" Color="#000000"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#D1D1D1"/>
    <SolidColorBrush x:Key="OverlayBackgroundBrush" Color="#DD000000"/>
    <SolidColorBrush x:Key="ReadOnlyFieldBackgroundBrush" Color="#F9F9F9"/>
    <SolidColorBrush x:Key="ReadOnlyFieldForegroundBrush" Color="#404040"/>
    <SolidColorBrush x:Key="CategoryPanelBackgroundBrush" Color="#F3F3F3"/>

    <!-- High contrast border (invisible in normal mode, will be visible in high contrast themes) -->
    <SolidColorBrush x:Key="HighContrastBorderBrush" Color="#00000000"/>

    <!-- TextBox/Input Brushes - SUBTLER: Barely visible hover states -->
    <SolidColorBrush x:Key="TextBoxBackgroundBrush" Color="#FFFFFF"/>
    <!-- SUBTLER: Already subtle, keep as is -->
    <SolidColorBrush x:Key="TextBoxBackgroundHoverBrush" Color="#FDFDFD"/>
    <!-- SUBTLER: Barely noticeable focus -->
    <SolidColorBrush x:Key="TextBoxBackgroundFocusedBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="TextBoxBackgroundDisabledBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="TextBoxBorderBrush" Color="#D1D1D1"/>
    <SolidColorBrush x:Key="TextBoxBorderHoverBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="TextBoxBorderFocusedBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="TextBrush" Color="#000000"/>
    
    <!-- Dialog/Window Brushes -->
    <SolidColorBrush x:Key="DialogBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DialogBorderBrush" Color="#E5E5E5"/>
    
    <!-- Button Text Brushes -->
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonAccentForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonSecondaryForegroundBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ButtonDisabledForegroundBrush" Color="#A0A0A0"/>
    
    <!-- Content Area Text -->
    <SolidColorBrush x:Key="ContentTextBrush" Color="#000000"/>
    <SolidColorBrush x:Key="ContentSecondaryTextBrush" Color="#333333"/>
    <SolidColorBrush x:Key="ContentMutedTextBrush" Color="#666666"/>
    <SolidColorBrush x:Key="CardTextBrush" Color="#000000"/>
    <SolidColorBrush x:Key="CardSecondaryTextBrush" Color="#333333"/>
    
    <!-- Input/Form Text -->
    <SolidColorBrush x:Key="InputTextBrush" Color="#000000"/>
    <!-- Lighter placeholder for better hierarchy (PRIORITY 13) -->
    <SolidColorBrush x:Key="InputPlaceholderBrush" Color="#8A9AAA"/>
    <SolidColorBrush x:Key="LabelTextBrush" Color="#000000"/>

    <!-- Popup/Flyout/Dropdown Brushes - clean light backgrounds -->
    <SolidColorBrush x:Key="FlyoutPresenterBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="MenuFlyoutPresenterBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumLowBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SystemControlForegroundBaseHighBrush" Color="#1A1A1A"/>

    <!-- ComboBox item states - SUBTLER: Barely visible highlights -->
    <SolidColorBrush x:Key="ComboBoxItemBackground" Color="#FFFFFF"/>
    <!-- SUBTLER: Barely noticeable hover (was #F3F3F3) -->
    <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#FAFAFA"/>
    <!-- SUBTLER: Subtle pressed/selected (was #E5E5E5) -->
    <SolidColorBrush x:Key="ComboBoxItemBackgroundPressed" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="ComboBoxItemForeground" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ComboBoxItemForegroundPressed" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ComboBoxItemForegroundDisabled" Color="#A0A0A0"/>
    
    <!-- List/Item Text -->
    <SolidColorBrush x:Key="ListItemTextBrush" Color="#000000"/>
    <SolidColorBrush x:Key="ListItemSecondaryTextBrush" Color="#666666"/>
    <SolidColorBrush x:Key="ListItemSelectedTextBrush" Color="#000000"/>
    
    <SolidColorBrush x:Key="ButtonWhiteBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#E5E5E5"/>
    
    <!-- Card separator line (transparent unless high contrast) -->
    <SolidColorBrush x:Key="CardSeparatorBrush" Color="#00000000"/>
    
    <!-- Quick filter -->
    <SolidColorBrush x:Key="QuickFilterGlassBrush" Color="#00000000"/>
    <SolidColorBrush x:Key="QuickFilterGlassHoverBrush" Color="#20FFFFFF"/>
    <SolidColorBrush x:Key="QuickFilterGlassActiveBrush" Color="#40FFFFFF"/>
    <SolidColorBrush x:Key="QuickFilterGlassActiveHoverBrush" Color="#50FFFFFF"/>
    <SolidColorBrush x:Key="QuickFilterGlassBorderBrush" Color="#30FFFFFF"/>
    <SolidColorBrush x:Key="QuickFilterGlassActiveBorderBrush" Color="#45FFFFFF"/>
    
    <!-- Semantic colors -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#107C10"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFB900"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#D13438"/>
    <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="#DFF6DD"/>
    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#FFF4CE"/>
    <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="#FDE7E9"/>
    <SolidColorBrush x:Key="InfoBackgroundBrush" Color="#DEECF9"/>
    
    <FontFamily x:Key="MainFontFamily">Segoe UI</FontFamily>
    
    <!-- MODERNIZED: Shadow color for elevation (Fluent Design 2 / Material 3 style) -->
    <Color x:Key="GlobalShadowColor">#1A1A1A</Color>
    <Color x:Key="HeaderAccentColor">#0078D4</Color>

    <!-- ADDED: Modern elevation with subtle shadows (inspired by Fluent Design 2) -->
    <!-- Elevation Level 1: Subtle lift (cards, panels) -->
    <DropShadowEffect x:Key="DarkSubtleDropShadow" Color="#1A1A1A" Opacity="0.06" BlurRadius="8" OffsetX="0" OffsetY="2"/>
    <DropShadowEffect x:Key="SubtleDropShadow" Color="#1A1A1A" Opacity="0.08" BlurRadius="12" OffsetX="0" OffsetY="2"/>

    <!-- Elevation Level 2: Buttons (resting, hover, pressed) -->
    <DropShadowEffect x:Key="DarkButtonShadow" Color="#1A1A1A" Opacity="0.10" BlurRadius="8" OffsetX="0" OffsetY="1"/>
    <DropShadowEffect x:Key="DarkButtonShadowHover" Color="#1A1A1A" Opacity="0.14" BlurRadius="16" OffsetX="0" OffsetY="4"/>
    <DropShadowEffect x:Key="DarkButtonShadowPressed" Color="#1A1A1A" Opacity="0.08" BlurRadius="4" OffsetX="0" OffsetY="1"/>

    <!-- Elevation Level 3: Menus and dropdowns -->
    <DropShadowEffect x:Key="HoverMenuDropShadow" Color="#1A1A1A" Opacity="0.14" BlurRadius="20" OffsetX="0" OffsetY="8"/>

    <!-- Elevation Level 4: Active tiles (raised state) -->
    <DropShadowEffect x:Key="TileActiveShadow" Color="#1A1A1A" Opacity="0.16" BlurRadius="24" OffsetX="0" OffsetY="8"/>
    <DropShadowEffect x:Key="TileActiveShadowPressed" Color="#1A1A1A" Opacity="0.12" BlurRadius="12" OffsetX="0" OffsetY="4"/>
    <DropShadowEffect x:Key="FrontPageTileBaseShadow" Color="#1A1A1A" Opacity="0.10" BlurRadius="16" OffsetX="0" OffsetY="4"/>

    <!-- Elevation Level 5: Footer grounding (inverted shadow) -->
    <DropShadowEffect x:Key="FooterGroundedShadow" Color="#1A1A1A" Opacity="0.06" BlurRadius="8" OffsetX="0" OffsetY="-2"/>

    <!-- Panel shadows with modern elevation -->
    <BoxShadows x:Key="SlideOutPanelShadow">-20 0 40 -5 #58000000</BoxShadows>
    <BoxShadows x:Key="FlaggedPanelShadow">-16 0 32 -4 #52000000</BoxShadows>
    
    <!-- Clean overlay -->
    <LinearGradientBrush x:Key="TileOverlayBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#100078D4" Offset="0"/>
        <GradientStop Color="#0560A5E8" Offset="0.5"/>
        <GradientStop Color="#00FFFFFF" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
