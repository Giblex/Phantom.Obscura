<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark variant (copied from PhantomTheme.axaml) -->
    <Style>
        <Style.Resources>
            <!-- Deep dark backgrounds for professional contrast -->
            <SolidColorBrush x:Key="WindowBackgroundBrush">#1E2A38</SolidColorBrush>
            <!-- Header/footer backgrounds with clear hierarchy -->
            <SolidColorBrush x:Key="HeaderBackgroundBrush">#1A2535</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderBorderBrush">Transparent</SolidColorBrush>
            <SolidColorBrush x:Key="FooterBackgroundBrush">#141C28</SolidColorBrush>
            <SolidColorBrush x:Key="ContentBackgroundBrush">#151D2A</SolidColorBrush>
            <!-- Dark acrylic-style tile base and overlay used by list/grid entries -->
            <SolidColorBrush x:Key="TileGlassBrush">#AA1F2937</SolidColorBrush>
            <SolidColorBrush x:Key="TileGapBrush">#1E2A38</SolidColorBrush>
            <!-- Micro-highlight reflection edges: slightly offset shades of the window background -->
            <Color x:Key="TileReflectHighlightColor">#4A6278</Color>
            <Color x:Key="TileReflectMidColor">#3D5267</Color>
            <Color x:Key="TileReflectShadowColor">#232F3E</Color>
            <LinearGradientBrush x:Key="TileOverlayBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#33FFFFFF" Offset="0" />
                <GradientStop Color="#00FFFFFF" Offset="1" />
            </LinearGradientBrush>
            <!-- Card background - lighter for better content visibility -->
            <SolidColorBrush x:Key="CardBackgroundBrush">#263344</SolidColorBrush>
            <!-- Surface brush for dashboard/card buttons -->
            <SolidColorBrush x:Key="SurfaceBrush">#1A2434</SolidColorBrush>
            <!-- Slightly duller blues for buttons (subtler, less saturated) -->
            <!-- FIXED: Enhanced accent color hierarchy with 25% brightness increase on hover -->
            <SolidColorBrush x:Key="AccentBrush">#6B8CAE</SolidColorBrush>
            <SolidColorBrush x:Key="AccentHoverBrush">#8FB5DF</SolidColorBrush>
            <SolidColorBrush x:Key="SecondaryAccentBrush">#6FA89F</SolidColorBrush>
            <!-- Canonical primary text color used across brushes -->
            <Color x:Key="PrimaryTextColor">#FFFFFF</Color>
            <SolidColorBrush x:Key="PrimaryTextBrush" Color="{DynamicResource PrimaryTextColor}" />
            <!-- Control foreground reuses the same canonical color to avoid duplication -->
            <SolidColorBrush x:Key="ControlForegroundBrush" Color="{DynamicResource PrimaryTextColor}" />
            <SolidColorBrush x:Key="HeaderTextBrush">#FFFFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderMutedTextBrush">#FFB9C7D6</SolidColorBrush>
            <SolidColorBrush x:Key="FooterTextBrush">#FFFFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="FooterMutedTextBrush">#FFB9C7D6</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderButtonBackgroundBrush">#1C2C3A</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderButtonHoverBrush">#243444</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderButtonPressedBrush">#182838</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderButtonForegroundBrush">#F5F7FA</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderButtonBorderBrush">#551C2C3A</SolidColorBrush>
            <SolidColorBrush x:Key="SecondaryTextBrush">#E0E6ED</SolidColorBrush>
            <!-- Boosted muted text contrast for professional readability -->
            <SolidColorBrush x:Key="MutedTextBrush">#D0D8E0</SolidColorBrush>
            <SolidColorBrush x:Key="DisabledTextBrush">#909AA4</SolidColorBrush>
            <!-- Deep control background for professional depth -->
            <SolidColorBrush x:Key="ControlBackgroundBrush">#1A2434</SolidColorBrush>
            <!-- FIXED: Visible borders for depth perception -->
            <SolidColorBrush x:Key="ControlBorderBrush">#FFFFFF15</SolidColorBrush>
            
            <!-- Settings panel/tile background for dark theme -->
            <SolidColorBrush x:Key="SettingsPanelBackgroundBrush">#1E2A38</SolidColorBrush>
            <SolidColorBrush x:Key="SettingsPanelBorderBrush">#2A3A4E</SolidColorBrush>
            
            <!-- Liquid glass button foreground for dark theme (light text) -->
            <SolidColorBrush x:Key="LiquidGlassButtonForeground">#EAF1FA</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderSvgIconColor">#EAF1FA</SolidColorBrush>

            <!-- ═══ Liquid Glass Token Colors ═══
                 Theme-aware tint colors used by LiquidGlass.axaml gradient brushes.
                 Override these in other themes for different glass tints. -->
            <Color x:Key="Glass.Tint.Light">#D8E8F8</Color>
            <Color x:Key="Glass.Tint.Mid">#8FB5DF</Color>
            <Color x:Key="Glass.Tint.Dark">#6B8CAE</Color>
            <Color x:Key="Glass.Tint.Deepest">#272F43</Color>
            <Color x:Key="Glass.Sheen.Bright">#E8F4FF</Color>
            <Color x:Key="Glass.Sheen.Mid">#C8E0F5</Color>
            <Color x:Key="Glass.Sheen.Soft">#A0C8E8</Color>
            <SolidColorBrush x:Key="Brush.Glass.Border">#306B8CAE</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.Glass.BorderHover">#508FB5DF</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.Glass.BorderPressed">#406B8CAE</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.Glass.BorderFocus">#A8C5E8</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.Glass.EdgeHighlight.Start">#50D8E8F8</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.Glass.EdgeHighlight.Mid">#30B8D5EF</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.Glass.EdgeHighlight.End">#008FB5DF</SolidColorBrush>

            <!-- Glass layer fill defaults (dark) -->
            <RadialGradientBrush x:Key="Brush.Glass.BaseFill" Center="35%,40%" RadiusX="80%" RadiusY="80%">
                <GradientStop Color="#0ED8E8F8" Offset="0"/>
                <GradientStop Color="#0C8FB5DF" Offset="0.5"/>
                <GradientStop Color="#0A6B8CAE" Offset="0.8"/>
                <GradientStop Color="#05272F43" Offset="1"/>
            </RadialGradientBrush>
            <RadialGradientBrush x:Key="Brush.Glass.BaseFillHover" Center="35%,40%" RadiusX="80%" RadiusY="80%">
                <GradientStop Color="#20D8E8F8" Offset="0"/>
                <GradientStop Color="#18A8C5E8" Offset="0.5"/>
                <GradientStop Color="#108FB5DF" Offset="0.8"/>
                <GradientStop Color="#08394D68" Offset="1"/>
            </RadialGradientBrush>
            <RadialGradientBrush x:Key="Brush.Glass.BaseFillPressed" Center="35%,40%" RadiusX="80%" RadiusY="80%">
                <GradientStop Color="#10B8D5EF" Offset="0"/>
                <GradientStop Color="#0C879BBE" Offset="0.5"/>
                <GradientStop Color="#086B8CAE" Offset="0.8"/>
                <GradientStop Color="#04272F43" Offset="1"/>
            </RadialGradientBrush>
            <RadialGradientBrush x:Key="Brush.Glass.BaseFillChecked" Center="35%,40%" RadiusX="80%" RadiusY="80%">
                <GradientStop Color="#40D8E8F8" Offset="0"/>
                <GradientStop Color="#30B8D5EF" Offset="0.5"/>
                <GradientStop Color="#208FB5DF" Offset="0.8"/>
                <GradientStop Color="#10394D68" Offset="1"/>
            </RadialGradientBrush>
            <LinearGradientBrush x:Key="Brush.Glass.InnerShadow" StartPoint="100%,100%" EndPoint="0%,0%">
                <GradientStop Color="#30272F43" Offset="0"/>
                <GradientStop Color="#00272F43" Offset="0.3"/>
            </LinearGradientBrush>
            <RadialGradientBrush x:Key="Brush.Glass.Sheen" Center="30%,25%" RadiusX="60%" RadiusY="50%">
                <GradientStop Color="#38E8F4FF" Offset="0"/>
                <GradientStop Color="#20C8E0F5" Offset="0.2"/>
                <GradientStop Color="#10A0C8E8" Offset="0.5"/>
                <GradientStop Color="#00000000" Offset="1"/>
            </RadialGradientBrush>
            <LinearGradientBrush x:Key="Brush.Glass.EdgeHighlightBorder" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#F6FFFFFF" Offset="0"/>
                <GradientStop Color="#C8F1FBFF" Offset="0.12"/>
                <GradientStop Color="#3962809C" Offset="0.34"/>
                <GradientStop Color="#0F243748" Offset="0.54"/>
                <GradientStop Color="#E8F8FFFF" Offset="0.76"/>
                <GradientStop Color="#11405A70" Offset="0.9"/>
                <GradientStop Color="#031A2B3A" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="Brush.Glass.BottomShadow" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#00000000" Offset="0"/>
                <GradientStop Color="#00000000" Offset="0.5"/>
                <GradientStop Color="#40272F43" Offset="1"/>
            </LinearGradientBrush>
            <SolidColorBrush x:Key="TileHoverBrush">#101F2D</SolidColorBrush>
            <SolidColorBrush x:Key="TilePressedBrush">#1A2A38</SolidColorBrush>
            <Color x:Key="LiquidGlassDropShadow">#45000000</Color>
            <Color x:Key="LiquidGlassDropShadowHover">#38000000</Color>
            <Color x:Key="LiquidGlassDropShadowPressed">#25000000</Color>
            <DropShadowEffect x:Key="LiquidGlassButtonEffect" BlurRadius="20" OffsetX="8" OffsetY="6" Color="#45000000"/>
            <DropShadowEffect x:Key="LiquidGlassButtonEffectHover" BlurRadius="18" OffsetX="5" OffsetY="6" Color="#38000000"/>
            <DropShadowEffect x:Key="LiquidGlassButtonEffectPressed" BlurRadius="8" OffsetX="1" OffsetY="2" Color="#25000000"/>

            <SolidColorBrush x:Key="OverlayBackgroundBrush">#80000000</SolidColorBrush>
            <SolidColorBrush x:Key="ReadOnlyFieldBackgroundBrush">#1A2A38</SolidColorBrush>
            <SolidColorBrush x:Key="ReadOnlyFieldForegroundBrush">#E0E6ED</SolidColorBrush>
            <SolidColorBrush x:Key="ButtonWhiteBackgroundBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="SeparatorBrush">#30FFFFFF</SolidColorBrush>
            
            <!-- Glass-like transparent highlight brushes for sidebar category filters -->
            <SolidColorBrush x:Key="QuickFilterGlassBrush">#00FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="QuickFilterGlassHoverBrush">#20FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="QuickFilterGlassActiveBrush">#40FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="QuickFilterGlassActiveHoverBrush">#50FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="QuickFilterGlassBorderBrush">#30FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="QuickFilterGlassActiveBorderBrush">#45FFFFFF</SolidColorBrush>
            
            <!-- Use a muted pastel green to reduce brightness while keeping meaning -->
            <SolidColorBrush x:Key="SuccessBrush">#B8E6C8</SolidColorBrush>
            <SolidColorBrush x:Key="WarningBrush">#FFC107</SolidColorBrush>
            <SolidColorBrush x:Key="WarningBrushDark">#E65100</SolidColorBrush>
            <SolidColorBrush x:Key="WarningBrushDarker">#BF360C</SolidColorBrush>
            <SolidColorBrush x:Key="WarningIcon">#FF9800</SolidColorBrush>
            <SolidColorBrush x:Key="ErrorBrush">#F48771</SolidColorBrush>
            <SolidColorBrush x:Key="SuccessBackgroundBrush">#1A3D1A</SolidColorBrush>
            <SolidColorBrush x:Key="SuccessBorderBrush">#4CAF50</SolidColorBrush>
            <SolidColorBrush x:Key="WarningBackgroundBrush">#3D2A1A</SolidColorBrush>
            <SolidColorBrush x:Key="WarningBorderBrush">#FF9800</SolidColorBrush>
            <SolidColorBrush x:Key="ErrorBackgroundBrush">#3D1A1A</SolidColorBrush>
            <SolidColorBrush x:Key="ErrorBorderBrush">#F44336</SolidColorBrush>
            <SolidColorBrush x:Key="InfoBackgroundBrush">#1A2A38</SolidColorBrush>
            <FontFamily x:Key="MainFontFamily">Segoe UI Variable, Segoe UI</FontFamily>
            <FontFamily x:Key="MonoFontFamily">Consolas</FontFamily>
            
            <!-- Overlay & Utility Tokens (P9: Overlays) -->
            <SolidColorBrush x:Key="OverlayBackgroundLightBrush">#40000000</SolidColorBrush>
            <SolidColorBrush x:Key="ErrorTextBrush">#CC5555</SolidColorBrush>
            <SolidColorBrush x:Key="SuccessTextBrush">#4CAF50</SolidColorBrush>
            
            <!-- Autofill & Keyboard Tokens (P12: Autofill color standardization) -->
            <SolidColorBrush x:Key="AutofillBackgroundBrush">#2B2B2B</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillHeaderBackgroundBrush">#1E1E1E</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillBorderBrush">#404040</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillTextBrush">#B0B0B0</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillTextSecondaryBrush">#808080</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillTextTertiaryBrush">#707070</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillTextQuaternaryBrush">#606060</SolidColorBrush>
            <SolidColorBrush x:Key="AutofillSuccessBackgroundBrush">#2B3A2E</SolidColorBrush>
            <SolidColorBrush x:Key="KeyboardBackgroundBrush">#2B2B2B</SolidColorBrush>
            <SolidColorBrush x:Key="KeyboardKeyBackgroundBrush">#1E1E1E</SolidColorBrush>
            
            <!-- Spacing Tokens (P10: Spacing standardization) -->
            <x:Double x:Key="Space.Xs">4</x:Double>
            <x:Double x:Key="Space.Sm">8</x:Double>
            <x:Double x:Key="Space.Md">12</x:Double>
            <x:Double x:Key="Space.Lg">16</x:Double>
            <x:Double x:Key="Space.Xl">20</x:Double>
            <x:Double x:Key="Space.Xxl">24</x:Double>
            
            <!-- Border Radius Tokens (P7: Standardization) -->
            <CornerRadius x:Key="Radius.Xs">2</CornerRadius>
            <CornerRadius x:Key="Radius.Sm">4</CornerRadius>
            <CornerRadius x:Key="Radius.Md">6</CornerRadius>
            <CornerRadius x:Key="Radius.Lg">8</CornerRadius>
            <CornerRadius x:Key="Radius.Xl">12</CornerRadius>
            <CornerRadius x:Key="Radius.Pill">999</CornerRadius>
            
            <!-- Border & Accent Brushes (P4-P6: Border consistency & accent application) -->
            <SolidColorBrush x:Key="Brush.BorderSoft">#FFFFFF15</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.BorderMedium">#FFFFFF25</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.BorderStrong">#FFFFFF35</SolidColorBrush>
            <!-- FIXED: Match updated accent colors -->
            <SolidColorBrush x:Key="Brush.Accent">#6B8CAE</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.AccentHover">#8FB5DF</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.FocusRing">#8FB5D6</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.DangerHover">#DC2626</SolidColorBrush>

            <!-- Thickness Tokens -->
            <Thickness x:Key="Thickness.CardPadding">16,12,16,12</Thickness>
            <Thickness x:Key="Thickness.ButtonPadding">16,10,16,10</Thickness>
            <SolidColorBrush x:Key="Brush.AccentPressed">#556C83</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.Card">#1E2A38</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.CardHover">#263344</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.TextPrimary">#FFFFFF</SolidColorBrush>
            <!-- Boosted muted text contrast for professional readability -->
            <SolidColorBrush x:Key="Brush.TextMuted">#D0D8E0</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.TextOnDark">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="Brush.Navy900">#1F2937</SolidColorBrush>
            
            <!-- Typography Tokens (bumped +1px for sharper Skia rendering) -->
            <x:Double x:Key="Type.Display.Size">48</x:Double>
            <x:Double x:Key="Type.H1.Size">32</x:Double>
            <x:Double x:Key="Type.H2.Size">24</x:Double>
            <x:Double x:Key="Type.H3.Size">19</x:Double>
            <x:Double x:Key="Type.H4.Size">17</x:Double>
            <x:Double x:Key="Type.H5.Size">16</x:Double>
            <x:Double x:Key="Type.Body.Size">15</x:Double>
            <x:Double x:Key="Type.Label.Size">14</x:Double>
            <x:Double x:Key="Type.Small.Size">13</x:Double>
            <x:Double x:Key="Type.Tiny.Size">12</x:Double>
            <x:Double x:Key="Type.Micro.Size">11</x:Double>
            <x:Double x:Key="Type.Mini.Size">10</x:Double>
            <!-- Specialty sizes for icons, headings, and empty-state decorations -->
            <x:Double x:Key="Type.EmptyState.Size">80</x:Double>
            <x:Double x:Key="Type.EmptyState.Lg.Size">64</x:Double>
            <x:Double x:Key="Type.IconLg.Size">48</x:Double>
            <x:Double x:Key="Type.Score.Size">42</x:Double>
            <x:Double x:Key="Type.Banner.Size">36</x:Double>
            <x:Double x:Key="Type.IconMd.Size">34</x:Double>
            <x:Double x:Key="Type.XL.Size">28</x:Double>
            <x:Double x:Key="Type.Hero.Size">26</x:Double>
            <x:Double x:Key="Type.SubHeading.Size">22</x:Double>
            <x:Double x:Key="Type.Icon.Size">20</x:Double>
            <FontWeight x:Key="Type.Weight.Light">Light</FontWeight>
            <FontWeight x:Key="Type.Weight.Medium">Medium</FontWeight>
            <FontWeight x:Key="Type.Weight.SemiBold">SemiBold</FontWeight>
            <FontWeight x:Key="Type.Weight.Bold">Bold</FontWeight>
            
            <!-- Text Selection Colors -->
            <!-- Light grey selection for dark mode -->
            <SolidColorBrush x:Key="TextSelectionBrush">#60A0A0A0</SolidColorBrush>
            <SolidColorBrush x:Key="TextCaretBrush">#FFFFFF</SolidColorBrush>

            <!-- Input surface (dark-adapted for dark theme) -->
            <SolidColorBrush x:Key="InputBackgroundBrush">#1E2530</SolidColorBrush>
            <SolidColorBrush x:Key="InputForegroundBrush">#E8ECF1</SolidColorBrush>
            <!-- Lighter placeholder for better hierarchy (PRIORITY 13) -->
            <SolidColorBrush x:Key="InputPlaceholderBrush">#8A9AAA</SolidColorBrush>
            <!-- Subtle highlight for TextBox/Border hover & focus states (theme-adaptive) -->
            <SolidColorBrush x:Key="InputHighlightBrush">#33FFFFFF</SolidColorBrush>
            <!-- Icon tile background for IconManager (theme-adaptive) -->
            <SolidColorBrush x:Key="IconTileBackgroundBrush">#3D4F61</SolidColorBrush>

            <!-- Popup/Flyout/Dropdown Brushes (force off-white dropdowns + dark text) -->
            <SolidColorBrush x:Key="FlyoutPresenterBackground">#F5F7FA</SolidColorBrush>
            <SolidColorBrush x:Key="MenuFlyoutPresenterBackground">#F5F7FA</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxDropDownBackground">#F5F7FA</SolidColorBrush>
            <SolidColorBrush x:Key="PopupBackgroundBrush">#F5F7FA</SolidColorBrush>
            <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumLowBrush">#F5F7FA</SolidColorBrush>
            <SolidColorBrush x:Key="SystemControlForegroundBaseHighBrush">#1F2937</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxItemForeground">#1F2937</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver">#1F2937</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelected">#1F2937</SolidColorBrush>
            <!-- Shadow effects to increase perceived depth on dark theme -->
            <!-- Slightly stronger base shadow so controls read higher on dark surfaces but not overpowering -->
                        <!-- Use a dark-grey shadow color instead of pure black for a softer appearance -->
                        <Color x:Key="GlobalShadowColor">#2B2F33</Color>
                        <!-- Add a header accent color used for the front-page centered tile shadow tint -->
                        <Color x:Key="HeaderAccentColor">#3D4F61</Color>

                        <!-- TEMPORARILY DISABLED: Shadow effects cause RenderTransform animator errors -->
                        <!-- <DropShadowEffect x:Key="DarkSubtleDropShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0.08" BlurRadius="22" />
                        <DropShadowEffect x:Key="SubtleDropShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0.12" BlurRadius="22" />
                        <DropShadowEffect x:Key="DarkButtonShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0.18" BlurRadius="16" />
                        <DropShadowEffect x:Key="DarkButtonShadowHover" Color="{DynamicResource GlobalShadowColor}" Opacity="0.24" BlurRadius="20" />
                        <DropShadowEffect x:Key="DarkButtonShadowPressed" Color="{DynamicResource GlobalShadowColor}" Opacity="0.12" BlurRadius="10" />
                        <DropShadowEffect x:Key="HoverMenuDropShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0.16" BlurRadius="14" />
                        <DropShadowEffect x:Key="TileActiveShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0.20" BlurRadius="32" />
                        <DropShadowEffect x:Key="TileActiveShadowPressed" Color="{DynamicResource GlobalShadowColor}" Opacity="0.14" BlurRadius="16" />
                        <DropShadowEffect x:Key="FrontPageTileBaseShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0.15" BlurRadius="20" />
                        <DropShadowEffect x:Key="FooterGroundedShadow" Color="{DynamicResource GlobalShadowColor}" Opacity="0.18" BlurRadius="10" />
                        <BoxShadows x:Key="SlideOutPanelShadow">-10 0 30 0 #40000000</BoxShadows>
                        <BoxShadows x:Key="FlaggedPanelShadow">-8 0 32 0 #40000000</BoxShadows> -->
        
            <!-- ═══ Dashboard sheet overlay ═══ -->
            <LinearGradientBrush x:Key="DashboardSheetOverlayBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#40182E48" Offset="0"/>
                <GradientStop Color="#38152840" Offset="0.5"/>
                <GradientStop Color="#30182E48" Offset="1"/>
            </LinearGradientBrush>
            <Color x:Key="DashboardSheetAcrylicTint">#1E2A38</Color>
            <Color x:Key="DashboardSheetAcrylicFallback">#18182838</Color>

            <!-- ═══ Dashboard glass panel resources ═══ -->
            <LinearGradientBrush x:Key="DashboardSectionBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#6E243A56" Offset="0"/>
                <GradientStop Color="#60182C44" Offset="0.5"/>
                <GradientStop Color="#58182840" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardSectionHoverBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#7A2A4060" Offset="0"/>
                <GradientStop Color="#6C20364F" Offset="0.5"/>
                <GradientStop Color="#621C2E48" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardSectionBorderBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#55FFFFFF" Offset="0"/>
                <GradientStop Color="#40CFE8FF" Offset="0.35"/>
                <GradientStop Color="#28FFFFFF" Offset="0.7"/>
                <GradientStop Color="#18FFFFFF" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardSectionHoverBorderBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#66FFFFFF" Offset="0"/>
                <GradientStop Color="#50CFE8FF" Offset="0.35"/>
                <GradientStop Color="#34FFFFFF" Offset="0.7"/>
                <GradientStop Color="#22FFFFFF" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardCardBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#6428405C" Offset="0"/>
                <GradientStop Color="#581E334E" Offset="0.5"/>
                <GradientStop Color="#4E182A42" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardCardHoverBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#722E4868" Offset="0"/>
                <GradientStop Color="#6424405A" Offset="0.5"/>
                <GradientStop Color="#58202E50" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardCardPressedBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#5820364E" Offset="0"/>
                <GradientStop Color="#4C1C2E44" Offset="0.5"/>
                <GradientStop Color="#421A2A3C" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardNavBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#60223858" Offset="0"/>
                <GradientStop Color="#541C2E4C" Offset="0.5"/>
                <GradientStop Color="#48182640" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardNavHoverBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#6E283E62" Offset="0"/>
                <GradientStop Color="#6022385A" Offset="0.5"/>
                <GradientStop Color="#541E2E4C" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardNavPressedBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#561C304E" Offset="0"/>
                <GradientStop Color="#4A182840" Offset="0.5"/>
                <GradientStop Color="#3E142038" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardNavPrimaryBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#6C385088" Offset="0"/>
                <GradientStop Color="#60304878" Offset="0.5"/>
                <GradientStop Color="#562A3C68" Offset="1"/>
            </LinearGradientBrush>
            <SolidColorBrush x:Key="DashboardNavPrimaryBorderBrush" Color="#60609CF8"/>
            <LinearGradientBrush x:Key="DashboardPanelBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#5824406A" Offset="0"/>
                <GradientStop Color="#481D3458" Offset="0.5"/>
                <GradientStop Color="#3A172A48" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardPanelBorderBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#55CFE8FF" Offset="0"/>
                <GradientStop Color="#36CFE8FF" Offset="0.5"/>
                <GradientStop Color="#1ECFE8FF" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardTileBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#A8304668" Offset="0"/>
                <GradientStop Color="#98243A58" Offset="0.5"/>
                <GradientStop Color="#881C2E48" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardTileHoverBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#C03A5278" Offset="0"/>
                <GradientStop Color="#B02C4664" Offset="0.5"/>
                <GradientStop Color="#A0223654" Offset="1"/>
            </LinearGradientBrush>
            <Color x:Key="DashboardTileBorderColor">#55FFFFFF</Color>
            <Color x:Key="DashboardTileHoverBorderColor">#66CFE8FF</Color>
            <Color x:Key="DashboardAcrylicTint">#14203A</Color>
            <Color x:Key="DashboardAcrylicFallback">#0C15253A</Color>
</Style.Resources>
    </Style>

    <!-- Keep other styles consistent with dark theme -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>

    <Style Selector="Border.header-surface">
        <Setter Property="TextElement.Foreground" Value="{DynamicResource HeaderTextBrush}" />
    </Style>

    <Style Selector="TextBlock.header-muted">
        <Setter Property="Foreground" Value="{DynamicResource HeaderMutedTextBrush}" />
    </Style>

    <Style Selector="Border.footer-surface">
        <Setter Property="TextElement.Foreground" Value="{DynamicResource FooterTextBrush}" />
    </Style>

    <Style Selector="TextBlock.footer-muted">
        <Setter Property="Foreground" Value="{DynamicResource FooterMutedTextBrush}" />
    </Style>

    <Style Selector="Button">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="MinWidth" Value="90" />
        <!-- TEMPORARILY DISABLED: Shadow effects cause RenderTransform animator errors -->
        <!-- <Setter Property="Effect" Value="{DynamicResource DarkButtonShadow}" /> -->
    </Style>

    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    </Style>

    <!-- Prioritised vault access button style (dull navy) -->
    <Style Selector="Button.primary-vault">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Background" Value="#1F3A56" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <!-- <Setter Property="Effect" Value="{DynamicResource DarkButtonShadow}" /> -->
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    </Style>

    <!-- Provide a base shadow for secondary buttons so they have subtle elevation by default -->
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
        <!-- <Setter Property="Effect" Value="{DynamicResource DarkButtonShadow}" /> -->
    </Style>

    <Style Selector="Button.secondary:pointerover">
        <Setter Property="Background" Value="{DynamicResource ControlBorderBrush}" />
        <!-- <Setter Property="Effect" Value="{DynamicResource HoverMenuDropShadow}" /> -->
    </Style>

    <!-- Make list and grid rows show a subtle elevation on hover in dark theme -->
    <Style Selector="ListBoxItem:pointerover, ListBoxItem:focused">
        <!-- <Setter Property="Effect" Value="{DynamicResource HoverMenuDropShadow}" /> -->
        <Setter Property="Background" Value="{DynamicResource ControlBorderBrush}" />
    </Style>

    <!-- Base elevation for list/grid rows so they appear layered even when not hovered -->
    <Style Selector="ListBoxItem">
        <!-- <Setter Property="Effect" Value="{DynamicResource DarkSubtleDropShadow}" /> -->
    </Style>

    <Style Selector="DataGridRow:pointerover, DataGridRow:focused">
        <!-- <Setter Property="Effect" Value="{DynamicResource HoverMenuDropShadow}" /> -->
        <Setter Property="Background" Value="{DynamicResource ControlBorderBrush}" />
    </Style>

    <!-- Base elevation for data grid rows -->
    <Style Selector="DataGridRow">
        <!-- <Setter Property="Effect" Value="{DynamicResource DarkSubtleDropShadow}" /> -->
    </Style>

    <!-- Ensure standalone Borders (tiles and cards) lift slightly on hover in dark theme -->
    <Style Selector="Border:pointerover">
        <!-- <Setter Property="Effect" Value="{DynamicResource HoverMenuDropShadow}" /> -->
    </Style>

    <!-- Apply a subtle base shadow to Borders so cards/tiles have depth by default -->
    <Style Selector="Border">
        <!-- <Setter Property="Effect" Value="{DynamicResource DarkSubtleDropShadow}" /> -->
    </Style>

    <!-- MenuFlyout Rounded Corners -->
    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Background" Value="#3A4551" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
        <Setter Property="Opacity" Value="0.95" />
    </Style>

    <Style Selector="Button.secondary:pressed">
        <!-- <Setter Property="Effect" Value="{DynamicResource DarkButtonShadowPressed}" /> -->
    </Style>

    <Style Selector="TextBox">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="SelectionBrush" Value="{DynamicResource TextSelectionBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextCaretBrush}" />
    </Style>

    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    </Style>

    <Style Selector="ComboBox /template/ ContentControl#ContentPresenter">
        <Setter Property="Foreground" Value="{DynamicResource InputForegroundBrush}" />
    </Style>

</Styles>
