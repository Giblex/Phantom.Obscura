<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- PhantomVault Custom Theme: Matted Light Navy Blue with Charcoal Grey -->
    
    <Style>
        <Style.Resources>
            <!-- Color Palette -->
            <!-- Main Background: Deep Navy -->
            <SolidColorBrush x:Key="WindowBackgroundBrush">#1E2A38</SolidColorBrush>
            
            <!-- Header Background: Deep teal -->
            <SolidColorBrush x:Key="HeaderBackgroundBrush">#162030</SolidColorBrush>
            <SolidColorBrush x:Key="HeaderBorderBrush">Transparent</SolidColorBrush>
            
            <!-- Footer Background: Darkest navy -->
            <SolidColorBrush x:Key="FooterBackgroundBrush">#141C28</SolidColorBrush>
            
            <!-- Content Background: Deep base surface -->
            <SolidColorBrush x:Key="ContentBackgroundBrush">#1A2535</SolidColorBrush>
            
            <!-- Accent Color: Pastel Duller Blue (#6B8CAE) -->
            <SolidColorBrush x:Key="AccentBrush">#6B8CAE</SolidColorBrush>
            
            <!-- Accent Hover: Slightly Lighter Pastel Blue (#7FA3C3) -->
            <SolidColorBrush x:Key="AccentHoverBrush">#7FA3C3</SolidColorBrush>
            
            <!-- Secondary Accent: Muted Teal (#6FA89F) -->
            <SolidColorBrush x:Key="SecondaryAccentBrush">#6FA89F</SolidColorBrush>
            
            <!-- Text Colors -->
            <SolidColorBrush x:Key="PrimaryTextBrush">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="SecondaryTextBrush">#E0E6ED</SolidColorBrush>
            <SolidColorBrush x:Key="MutedTextBrush">#D0D8E0</SolidColorBrush>
            <SolidColorBrush x:Key="DisabledTextBrush">#7A8590</SolidColorBrush>
            
            <!-- Control Backgrounds -->
            <SolidColorBrush x:Key="ControlBackgroundBrush">#1E2530</SolidColorBrush>
            <!-- IMPROVED: Better contrast border for accessibility (WCAG AA compliant) -->
            <SolidColorBrush x:Key="ControlBorderBrush">#6A8BAF</SolidColorBrush>
            
            <!-- Success/Warning/Error Text Colors -->
            <!-- Changed to a softer pastel/dull green per UX request -->
            <SolidColorBrush x:Key="SuccessBrush">#B8E6C8</SolidColorBrush>
            <SolidColorBrush x:Key="WarningBrush">#FFC107</SolidColorBrush>
            <SolidColorBrush x:Key="ErrorBrush">#F48771</SolidColorBrush>
            
            <!-- Dialog/Info Background Colors -->
            <SolidColorBrush x:Key="SuccessBackgroundBrush">#1A2A38</SolidColorBrush>
            <SolidColorBrush x:Key="WarningBackgroundBrush">#1A2A38</SolidColorBrush>
            <SolidColorBrush x:Key="ErrorBackgroundBrush">#1A2A38</SolidColorBrush>
            <SolidColorBrush x:Key="InfoBackgroundBrush">#1A2A38</SolidColorBrush>
            
            <!-- Font Family -->
            <FontFamily x:Key="MainFontFamily">Segoe UI Variable, Segoe UI</FontFamily>
            
            <!-- Text Selection Colors -->
            <!-- Light grey selection for dark theme -->
            <SolidColorBrush x:Key="TextSelectionBrush">#60A0A0A0</SolidColorBrush>
            <SolidColorBrush x:Key="TextCaretBrush">#FFFFFF</SolidColorBrush>

            <!-- FIXED: Dark input surface for dark theme (was light #F5F7FA) -->
            <SolidColorBrush x:Key="InputBackgroundBrush">#2A3A4E</SolidColorBrush>
            <SolidColorBrush x:Key="InputForegroundBrush">#FFFFFF</SolidColorBrush>
            <!-- IMPROVED: Better contrast placeholder text for dark theme -->
            <SolidColorBrush x:Key="InputPlaceholderBrush">#C5CDD5</SolidColorBrush>

            <!-- ADDED: Dropdown/Flyout brushes for dark theme -->
            <SolidColorBrush x:Key="FlyoutPresenterBackground">#222E3E</SolidColorBrush>
            <SolidColorBrush x:Key="MenuFlyoutPresenterBackground">#222E3E</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxDropDownBackground">#222E3E</SolidColorBrush>
            <SolidColorBrush x:Key="PopupBackgroundBrush">#222E3E</SolidColorBrush>
            <SolidColorBrush x:Key="SystemControlBackgroundChromeMediumLowBrush">#222E3E</SolidColorBrush>
            <SolidColorBrush x:Key="SystemControlForegroundBaseHighBrush">#FFFFFF</SolidColorBrush>

            <!-- ComboBox item states for dark theme - SUBTLER: Barely visible highlights -->
            <SolidColorBrush x:Key="ComboBoxItemBackground">#222E3E</SolidColorBrush>
            <!-- SUBTLER: Barely noticeable hover (was #4A5C6E) -->
            <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver">#283848</SolidColorBrush>
            <!-- SUBTLER: Subtle pressed/selected (was #556D8A) -->
            <SolidColorBrush x:Key="ComboBoxItemBackgroundPressed">#2E4050</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected">#2E4050</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxItemForeground">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxItemForegroundPressed">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelected">#FFFFFF</SolidColorBrush>
            <SolidColorBrush x:Key="ComboBoxItemForegroundDisabled">#7A8590</SolidColorBrush>

            <!-- ADDED: Focus and accessibility colors -->
            <SolidColorBrush x:Key="FocusBorderBrush">#7FA3C3</SolidColorBrush>
            <SolidColorBrush x:Key="FocusGlowBrush">#406B8CAE</SolidColorBrush>
            <x:Double x:Key="FocusBorderThickness">2</x:Double>
        
            <!-- ═══ Dashboard sheet overlay (transparent glass behind dashboard) ═══ -->
            <LinearGradientBrush x:Key="DashboardSheetOverlayBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#68102035" Offset="0"/>
                <GradientStop Color="#600E1C30" Offset="0.5"/>
                <GradientStop Color="#58102035" Offset="1"/>
            </LinearGradientBrush>
            <Color x:Key="DashboardSheetAcrylicTint">#1E2A38</Color>
            <Color x:Key="DashboardSheetAcrylicFallback">#18182838</Color>

            <!-- ═══ Dashboard glass panel resources ═══ -->
            <LinearGradientBrush x:Key="DashboardSectionBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#5C15253A" Offset="0"/>
                <GradientStop Color="#50101E30" Offset="0.5"/>
                <GradientStop Color="#48101B2E" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardSectionHoverBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#6818293F" Offset="0"/>
                <GradientStop Color="#5C142236" Offset="0.5"/>
                <GradientStop Color="#521C2438" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardSectionBorderBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#38FFFFFF" Offset="0"/>
                <GradientStop Color="#28CFE8FF" Offset="0.35"/>
                <GradientStop Color="#18FFFFFF" Offset="0.7"/>
                <GradientStop Color="#10FFFFFF" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardSectionHoverBorderBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#44FFFFFF" Offset="0"/>
                <GradientStop Color="#30CFE8FF" Offset="0.35"/>
                <GradientStop Color="#20FFFFFF" Offset="0.7"/>
                <GradientStop Color="#14FFFFFF" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardCardBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#5420364D" Offset="0"/>
                <GradientStop Color="#4A1A2C3E" Offset="0.5"/>
                <GradientStop Color="#40152232" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardCardHoverBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#62253A55" Offset="0"/>
                <GradientStop Color="#5620334A" Offset="0.5"/>
                <GradientStop Color="#4A1B2D40" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardCardPressedBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#481A2C42" Offset="0"/>
                <GradientStop Color="#4016253A" Offset="0.5"/>
                <GradientStop Color="#3A121F30" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardNavBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#501C3048" Offset="0"/>
                <GradientStop Color="#4616263A" Offset="0.5"/>
                <GradientStop Color="#3C121E30" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardNavHoverBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#5E223650" Offset="0"/>
                <GradientStop Color="#521C2E44" Offset="0.5"/>
                <GradientStop Color="#4818263A" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardNavPressedBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#46162840" Offset="0"/>
                <GradientStop Color="#3E122234" Offset="0.5"/>
                <GradientStop Color="#38101C2C" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardNavPrimaryBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#5C304878" Offset="0"/>
                <GradientStop Color="#52283E68" Offset="0.5"/>
                <GradientStop Color="#48203458" Offset="1"/>
            </LinearGradientBrush>
            <SolidColorBrush x:Key="DashboardNavPrimaryBorderBrush" Color="#50508CF0"/>
            <LinearGradientBrush x:Key="DashboardPanelBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#141A2838" Offset="0"/>
                <GradientStop Color="#0C152030" Offset="0.5"/>
                <GradientStop Color="#08101820" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardPanelBorderBrush" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#1CCFE8FF" Offset="0"/>
                <GradientStop Color="#0CCFE8FF" Offset="0.5"/>
                <GradientStop Color="#06CFE8FF" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardTileBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#6E243A5C" Offset="0"/>
                <GradientStop Color="#5E1C2E4A" Offset="0.5"/>
                <GradientStop Color="#4E162538" Offset="1"/>
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="DashboardTileHoverBg" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#822E4870" Offset="0"/>
                <GradientStop Color="#72223A5C" Offset="0.5"/>
                <GradientStop Color="#621C3048" Offset="1"/>
            </LinearGradientBrush>
            <Color x:Key="DashboardTileBorderColor">#48FFFFFF</Color>
            <Color x:Key="DashboardTileHoverBorderColor">#55CFE8FF</Color>
            <Color x:Key="DashboardAcrylicTint">#14203A</Color>
            <Color x:Key="DashboardAcrylicFallback">#0C15253A</Color>
</Style.Resources>
    </Style>
    
    <!-- Global Text Style -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>
    
    <!-- Button Styles -->
    <Style Selector="Button">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="MinWidth" Value="90" />
    </Style>
    
    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    
    <Style Selector="Button:disabled">
        <Setter Property="Opacity" Value="0.4" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>

    <!-- ADDED: Focus state for accessibility -->
    <Style Selector="Button:focus-visible">
        <Setter Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}" />
        <Setter Property="BorderThickness" Value="{DynamicResource FocusBorderThickness}" />
        <Setter Property="RenderTransform">
            <TransformGroup>
                <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
            </TransformGroup>
        </Setter>
    </Style>
    
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
    </Style>
    
    <Style Selector="Button.secondary:pointerover">
        <Setter Property="Background" Value="{DynamicResource ControlBorderBrush}" />
    </Style>
    
    <Style Selector="Button.secondary:disabled">
        <Setter Property="Opacity" Value="0.3" />
        <Setter Property="Cursor" Value="Arrow" />
    </Style>
    
    <!-- Accent Button Style (liquid glass with accent tint) -->
    <Style Selector="Button.accent">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <Border Name="BaseBorder"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="#70FFFFFF"
                            ClipToBounds="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                <GradientStop Color="#90A855F7" Offset="0"/>
                                <GradientStop Color="#70A855F7" Offset="0.55"/>
                                <GradientStop Color="#60A855F7" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Border Margin="1"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            BorderThickness="1"
                            BorderBrush="#30FFFFFF"
                            IsHitTestVisible="False"/>
                    <Border Height="16"
                            VerticalAlignment="Top"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Opacity="0.85"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                <GradientStop Color="#30FFFFFF" Offset="0"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Margin="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      RecognizesAccessKey="True"/>
                </Panel>
            </ControlTemplate>
        </Setter>
    </Style>
    
    <Style Selector="Button.accent:pointerover /template/ Border#BaseBorder">
        <Setter Property="BorderBrush" Value="#A0FFFFFF"/>
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#A0A855F7" Offset="0"/>
                <GradientStop Color="#80A855F7" Offset="0.55"/>
                <GradientStop Color="#70A855F7" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    
    <Style Selector="Button.accent:pressed">
        <Setter Property="RenderTransform">
            <TranslateTransform Y="1"/>
        </Setter>
    </Style>
    
    <!-- TextBox Styles -->
    <Style Selector="TextBox">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="SelectionBrush" Value="{DynamicResource TextSelectionBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextCaretBrush}" />
    </Style>

    <!-- ADDED: TextBox focus and error states -->
    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource FocusBorderBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="TextBox.error">
        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>
    
    <!-- ComboBox Styles -->
    <Style Selector="ComboBox">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
    </Style>
    
    <!-- CheckBox Styles -->
    <Style Selector="CheckBox">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
    </Style>
    
    <!-- ScrollBar Styles - Fix scrollbar to go all the way down -->
    <Style Selector="ScrollBar">
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
    </Style>
    
    <Style Selector="ScrollBar:vertical">
        <Setter Property="Width" Value="12" />
    </Style>
    
    <Style Selector="ScrollBar:horizontal">
        <Setter Property="Height" Value="12" />
    </Style>
    
    <Style Selector="ScrollBar /template/ RepeatButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="{DynamicResource ControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    
    <Style Selector="ScrollBar /template/ Thumb:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    </Style>
    
    <!-- ScrollViewer Styles -->
    <Style Selector="ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    
    <!-- MenuFlyout Rounded Corners -->
    <Style Selector="MenuFlyoutPresenter">
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    
</Styles>
