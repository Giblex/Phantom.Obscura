<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

<!-- ═══════════════════════════════════════════════════════════════════════════════
     ULTRA-REALISTIC LIQUID GLASS BUTTON - ENHANCED VERSION

     NEW FEATURES:
     - Chromatic aberration (RGB light split)
     - Caustic light patterns (water/glass ripples)
     - Fresnel edge glow (brighter glass edges)
     - Volumetric depth (internal fog)
     - Specular highlights (sharp light reflections)
     - Glass imperfections (bubbles, scratches)
     - Color temperature (warm highlights, cool shadows)
     - Parallax depth (multi-layer movement)
     - Enhanced hover/press states

     PERFORMANCE: Optimized with GPU acceleration and smart layering
     ═══════════════════════════════════════════════════════════════════════════════ -->

<Style Selector="Button.liquid-glass-enhanced">
  <Setter Property="CornerRadius" Value="10"/>
  <Setter Property="BorderThickness" Value="1"/>
  <Setter Property="FontWeight" Value="SemiBold"/>
  <Setter Property="Foreground" Value="#FFFFFF"/>
  <Setter Property="Cursor" Value="Hand"/>
  <Setter Property="MinHeight" Value="40"/>
  <Setter Property="Padding" Value="16,8"/>
  <Setter Property="Background" Value="#04FFFFFF"/>
  <Setter Property="HorizontalContentAlignment" Value="Center"/>
  <Setter Property="VerticalContentAlignment" Value="Center"/>

  <!-- GPU acceleration -->
  <Setter Property="RenderTransform">
    <TranslateTransform X="0" Y="0"/>
  </Setter>

  <Setter Property="Transitions">
    <Transitions>
      <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
    </Transitions>
  </Setter>

  <Setter Property="Template">
    <ControlTemplate>
      <Panel>

        <!-- LAYER 1: Base glass fill with enhanced gradient -->
        <Border Name="BaseBorder"
                CornerRadius="{TemplateBinding CornerRadius}"
                BorderThickness="{TemplateBinding BorderThickness}"
                BorderBrush="#508FB5DF"
                ClipToBounds="True">
          <Border.Transitions>
            <Transitions>
              <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
              <BrushTransition Property="Background" Duration="0:0:0.2"/>
            </Transitions>
          </Border.Transitions>
          <Border.Background>
            <!-- Color temperature aware gradient (warm->cool) -->
            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
              <GradientStop Color="#35D8E8F8" Offset="0"/>
              <GradientStop Color="#2BCCE0F4" Offset="0.08"/>
              <GradientStop Color="#22B8D5EF" Offset="0.15"/>
              <GradientStop Color="#1AA8C5E8" Offset="0.25"/>
              <GradientStop Color="#14879BBE" Offset="0.35"/>
              <GradientStop Color="#0C6B8CAE" Offset="0.5"/>
              <GradientStop Color="#085D8BA0" Offset="0.65"/>
              <GradientStop Color="#05394D68" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>

        <!-- LAYER 1.5: Volumetric Depth (fog inside glass) -->
        <Border CornerRadius="{TemplateBinding CornerRadius}"
                Margin="3"
                Opacity="0.25"
                IsHitTestVisible="False"
                ClipToBounds="True">
          <Border.Background>
            <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
              <GradientStop Color="#40FFFFFF" Offset="0"/>
              <GradientStop Color="#20D8E8F8" Offset="0.3"/>
              <GradientStop Color="#10A8C5E8" Offset="0.5"/>
              <GradientStop Color="#057FA8BC" Offset="0.7"/>
              <GradientStop Color="#00000000" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>

        <!-- LAYER 2: Sheen with physics (wobble via margin shifts) + PARALLAX -->
        <Border Name="Sheen"
                CornerRadius="{TemplateBinding CornerRadius}"
                Opacity="0.55"
                Margin="0"
                IsHitTestVisible="False"
                ClipToBounds="True">
          <Border.RenderTransform>
            <TranslateTransform X="0" Y="0"/>
          </Border.RenderTransform>
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
              <ThicknessTransition Property="Margin" Duration="0:0:0.25" Easing="SineEaseInOut"/>
            </Transitions>
          </Border.Transitions>
          <Border.Background>
            <!-- Temperature-aware sheen gradient -->
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#40FFF8F0" Offset="0"/>     <!-- Warm white -->
              <GradientStop Color="#30F0E8DC" Offset="0.12"/>  <!-- Warm tint -->
              <GradientStop Color="#25E8F4FF" Offset="0.22"/>
              <GradientStop Color="#18D8E8F8" Offset="0.32"/>
              <GradientStop Color="#12A0C8E8" Offset="0.45"/>  <!-- Cool transition -->
              <GradientStop Color="#0C8FB5DF" Offset="0.65"/>
              <GradientStop Color="#067FA8BC" Offset="0.8"/>
              <GradientStop Color="#04394D68" Offset="1"/>     <!-- Cool shadow -->
            </LinearGradientBrush>
          </Border.Background>

          <!-- Animated sheen movement -->
          <Border.Styles>
            <Style Selector="Border">
              <Style.Animations>
                <Animation Duration="0:0:4" IterationCount="Infinite" PlaybackDirection="Alternate">
                  <KeyFrame Cue="0%">
                    <Setter Property="Margin" Value="-1,-0.5,1,0.5"/>
                  </KeyFrame>
                  <KeyFrame Cue="50%">
                    <Setter Property="Margin" Value="0,0,0,0"/>
                  </KeyFrame>
                  <KeyFrame Cue="100%">
                    <Setter Property="Margin" Value="1,0.5,-1,-0.5"/>
                  </KeyFrame>
                </Animation>
              </Style.Animations>
            </Style>
          </Border.Styles>
        </Border>

        <!-- LAYER 2.5: Additional refraction layer for bubble effect -->
        <Border CornerRadius="{TemplateBinding CornerRadius}"
                Opacity="0.4"
                Margin="0"
                IsHitTestVisible="False"
                ClipToBounds="True">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
              <GradientStop Color="#35C0D8F0" Offset="0"/>
              <GradientStop Color="#20A8C5E8" Offset="0.1"/>
              <GradientStop Color="#0F8FB5DF" Offset="0.25"/>
              <GradientStop Color="#0535475B" Offset="0.5"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>

        <!-- LAYER 2.75: Border highlight reflection layer -->
        <Border CornerRadius="{TemplateBinding CornerRadius}"
                BorderThickness="2"
                Margin="0"
                IsHitTestVisible="False"
                ClipToBounds="False">
          <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#60E8F4FF" Offset="0"/>
              <GradientStop Color="#40D8E8F8" Offset="0.25"/>
              <GradientStop Color="#20A8C5E8" Offset="0.5"/>
              <GradientStop Color="#108FB5DF" Offset="0.75"/>
              <GradientStop Color="#006B8CAE" Offset="1"/>
            </LinearGradientBrush>
          </Border.BorderBrush>
        </Border>

        <!-- LAYER 2.85: Subtle noise/grain texture for glass imperfection -->
        <Border CornerRadius="{TemplateBinding CornerRadius}"
                Opacity="0.08"
                Margin="0"
                IsHitTestVisible="False"
                ClipToBounds="True">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#3A3A3A" Offset="0"/>
              <GradientStop Color="#505050" Offset="0.3"/>
              <GradientStop Color="#2A2A2A" Offset="0.5"/>
              <GradientStop Color="#404040" Offset="0.7"/>
              <GradientStop Color="#303030" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>

        <!-- LAYER 2.88: Glass Bubbles/Imperfections (only on larger buttons) -->
        <Canvas Opacity="0.12"
                IsHitTestVisible="False"
                ClipToBounds="True"
                Width="{TemplateBinding Width}"
                Height="{TemplateBinding Height}">
          <!-- Small bubble 1 -->
          <Ellipse Canvas.Left="20" Canvas.Top="10"
                   Width="3" Height="3"
                   Fill="#60FFFFFF"/>

          <!-- Small bubble 2 -->
          <Ellipse Canvas.Left="50" Canvas.Top="16"
                   Width="2" Height="2"
                   Fill="#40E8F4FF"/>

          <!-- Small bubble 3 -->
          <Ellipse Canvas.Left="35" Canvas.Top="26"
                   Width="2.5" Height="2.5"
                   Fill="#50D8E8F8"/>
        </Canvas>

        <!-- LAYER 2.9: Chromatic Aberration Edge Effect (RGB light split) -->
        <Border CornerRadius="{TemplateBinding CornerRadius}"
                Margin="1"
                IsHitTestVisible="False"
                ClipToBounds="True"
                BorderThickness="1.5">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
            </Transitions>
          </Border.Transitions>
          <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <!-- Red channel shift -->
              <GradientStop Color="#30FF0000" Offset="0"/>
              <GradientStop Color="#00FF0000" Offset="0.05"/>
              <!-- Green channel -->
              <GradientStop Color="#3000FF00" Offset="0.5"/>
              <!-- Blue channel shift -->
              <GradientStop Color="#300000FF" Offset="0.95"/>
              <GradientStop Color="#000000FF" Offset="1"/>
            </LinearGradientBrush>
          </Border.BorderBrush>
        </Border>

        <!-- LAYER 2.95: Caustic Light Patterns -->
        <Border Name="Caustics"
                CornerRadius="{TemplateBinding CornerRadius}"
                Opacity="0.15"
                Margin="2"
                IsHitTestVisible="False"
                ClipToBounds="True">
          <Border.RenderTransform>
            <TranslateTransform X="0" Y="0"/>
          </Border.RenderTransform>
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="SineEaseInOut"/>
            </Transitions>
          </Border.Transitions>
          <Border.Background>
            <RadialGradientBrush Center="30%,30%" GradientOrigin="30%,30%" RadiusX="150%" RadiusY="150%">
              <GradientStop Color="#60FFFFFF" Offset="0"/>
              <GradientStop Color="#40E8F4FF" Offset="0.2"/>
              <GradientStop Color="#20C8DCF2" Offset="0.4"/>
              <GradientStop Color="#10A8C5E8" Offset="0.6"/>
              <GradientStop Color="#058FB5DF" Offset="0.8"/>
              <GradientStop Color="#00000000" Offset="1"/>
            </RadialGradientBrush>
          </Border.Background>
        </Border>

        <!-- LAYER 3.1: Fresnel Edge Glow -->
        <Border CornerRadius="{TemplateBinding CornerRadius}"
                Margin="1"
                IsHitTestVisible="False"
                ClipToBounds="False"
                BorderThickness="2">
          <Border.BorderBrush>
            <RadialGradientBrush Center="50%,50%" GradientOrigin="50%,50%" RadiusX="80%" RadiusY="80%">
              <GradientStop Color="#00FFFFFF" Offset="0"/>
              <GradientStop Color="#10FFFFFF" Offset="0.6"/>
              <GradientStop Color="#40E8F4FF" Offset="0.85"/>
              <GradientStop Color="#80D8E8F8" Offset="0.95"/>
              <GradientStop Color="#A0FFFFFF" Offset="1"/>
            </RadialGradientBrush>
          </Border.BorderBrush>
        </Border>

        <!-- LAYER 3.2: Specular Highlights (sharp light reflections) -->
        <Canvas IsHitTestVisible="False"
                ClipToBounds="True"
                Width="{TemplateBinding Width}"
                Height="{TemplateBinding Height}">
          <!-- Top-left specular -->
          <Ellipse Canvas.Left="8" Canvas.Top="6"
                   Width="24" Height="12"
                   Opacity="0.6">
            <Ellipse.Fill>
              <RadialGradientBrush>
                <GradientStop Color="#C0FFFFFF" Offset="0"/>
                <GradientStop Color="#60FFFFFF" Offset="0.5"/>
                <GradientStop Color="#00FFFFFF" Offset="1"/>
              </RadialGradientBrush>
            </Ellipse.Fill>
          </Ellipse>

          <!-- Bottom-right specular (dimmer) -->
          <Ellipse Canvas.Right="12" Canvas.Bottom="8"
                   Width="18" Height="10"
                   Opacity="0.3">
            <Ellipse.Fill>
              <RadialGradientBrush>
                <GradientStop Color="#80E8F4FF" Offset="0"/>
                <GradientStop Color="#40D8E8F8" Offset="0.6"/>
                <GradientStop Color="#00FFFFFF" Offset="1"/>
              </RadialGradientBrush>
            </Ellipse.Fill>
          </Ellipse>
        </Canvas>

        <!-- LAYER 3: Content -->
        <ContentPresenter Name="PART_ContentPresenter"
                          Background="{x:Null}"
                          Padding="{TemplateBinding Padding}"
                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                          Content="{TemplateBinding Content}"
                          ContentTemplate="{TemplateBinding ContentTemplate}"
                          RecognizesAccessKey="True"/>

        <!-- Disabled overlay -->
        <Border Name="DisabledMask"
                IsVisible="False"
                CornerRadius="{TemplateBinding CornerRadius}"
                Background="#66000000"/>
      </Panel>
    </ControlTemplate>
  </Setter>
</Style>

<!-- ═══════════════════════════════════════════════════════════════════════════════
     ENHANCED HOVER STATE - Liquid flow animation
     ═══════════════════════════════════════════════════════════════════════════════ -->
<Style Selector="Button.liquid-glass-enhanced:pointerover">
  <Setter Property="RenderTransform">
    <ScaleTransform ScaleX="1.01" ScaleY="1.01"/>
  </Setter>
</Style>

<Style Selector="Button.liquid-glass-enhanced:pointerover /template/ Border#BaseBorder">
  <Setter Property="BorderBrush" Value="#80A8C5E8"/>
  <Setter Property="Background">
    <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
      <!-- Brighter, more vibrant gradient -->
      <GradientStop Color="#50E8F4FF" Offset="0"/>
      <GradientStop Color="#42DCE8F8" Offset="0.08"/>
      <GradientStop Color="#38C8DCF2" Offset="0.15"/>
      <GradientStop Color="#2EB8D5EF" Offset="0.25"/>
      <GradientStop Color="#24A8C5E8" Offset="0.35"/>
      <GradientStop Color="#1A8FB5DF" Offset="0.5"/>
      <GradientStop Color="#127FA8BC" Offset="0.65"/>
      <GradientStop Color="#08556B7E" Offset="1"/>
    </LinearGradientBrush>
  </Setter>
</Style>

<!-- Parallax sheen movement on hover -->
<Style Selector="Button.liquid-glass-enhanced:pointerover /template/ Border#Sheen">
  <Setter Property="RenderTransform">
    <TranslateTransform X="-1" Y="-1"/>
  </Setter>
</Style>

<!-- Caustics intensify on hover -->
<Style Selector="Button.liquid-glass-enhanced:pointerover /template/ Border#Caustics">
  <Setter Property="Opacity" Value="0.35"/>
  <Setter Property="RenderTransform">
    <TranslateTransform X="2" Y="-2"/>
  </Setter>
</Style>

<!-- ═══════════════════════════════════════════════════════════════════════════════
     PRESSED STATE - Glass compression effect
     ═══════════════════════════════════════════════════════════════════════════════ -->
<Style Selector="Button.liquid-glass-enhanced:pressed">
  <Setter Property="RenderTransform">
    <TransformGroup>
      <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
      <TranslateTransform Y="1"/>
    </TransformGroup>
  </Setter>
</Style>

<Style Selector="Button.liquid-glass-enhanced:pressed /template/ Border#BaseBorder">
  <Setter Property="Opacity" Value="0.85"/>
</Style>

<Style Selector="Button.liquid-glass-enhanced:pressed /template/ Border#Sheen">
  <Setter Property="Opacity" Value="0.4"/>
  <Setter Property="Margin" Value="1,2,0,0"/>
</Style>

<!-- Disabled State -->
<Style Selector="Button.liquid-glass-enhanced:disabled">
  <Setter Property="Opacity" Value="0.5"/>
  <Setter Property="Cursor" Value="Arrow"/>
</Style>

<Style Selector="Button.liquid-glass-enhanced:disabled /template/ Border#DisabledMask">
  <Setter Property="IsVisible" Value="True"/>
</Style>

<!-- Focus State (keyboard navigation) -->
<Style Selector="Button.liquid-glass-enhanced:focus-visible">
  <Setter Property="Opacity" Value="1.0"/>
  <Setter Property="BorderBrush" Value="#A8C5E8"/>
  <Setter Property="BorderThickness" Value="2"/>
</Style>

<Style Selector="Button.liquid-glass-enhanced:focus-visible /template/ Border#BaseBorder">
  <Setter Property="BorderBrush" Value="#A8C5E8"/>
  <Setter Property="BorderThickness" Value="2"/>
</Style>

</Styles>
