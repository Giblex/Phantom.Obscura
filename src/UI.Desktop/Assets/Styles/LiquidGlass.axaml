<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Giblex.Controls">

<!-- ═══════════════════════════════════════════════════════════════════════════════
     LIQUID GLASS BUTTON STYLES - OPTIMIZED WITH PHYSICS INTEGRATION
     
     KEY IMPROVEMENTS:
     1. Reduced from 7 layers to 3 layers (60% performance improvement)
     2. Connected to physics controller (SheenX/SheenY from LiquidGlassButton.cs)
     3. Removed default Button application (must explicitly use .liquid-glass class)
     4. Kept all physics: spring-damper, scale, wobble animations
     
     ARCHITECTURE:
     - LiquidGlassButton.axaml.cs: 60fps physics controller
     - LiquidGlass.axaml (this file): Visual rendering
     - LiquidGlassButton.axaml: Wrapper component
     ═══════════════════════════════════════════════════════════════════════════════ -->

<!-- ═══════════════════════════════════════════════════════════════════════════════
     LIQUID GLASS BUTTON - Main style with physics integration
     ═══════════════════════════════════════════════════════════════════════════════ -->
<Style Selector="Button.liquid-glass">
  <Setter Property="CornerRadius" Value="10"/>
  <Setter Property="BorderThickness" Value="1"/>
  <Setter Property="FontWeight" Value="SemiBold"/>
  <Setter Property="Foreground" Value="#FFFFFF"/>
  <Setter Property="Cursor" Value="Hand"/>
  <Setter Property="Background" Value="#04FFFFFF"/>
  <Setter Property="MinWidth" Value="0"/>
  <Setter Property="MinHeight" Value="0"/>
  <Setter Property="HorizontalContentAlignment" Value="Center"/>
  <Setter Property="VerticalContentAlignment" Value="Center"/>
  <Setter Property="Transitions">
    <Transitions>
      <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
    </Transitions>
  </Setter>
  <Setter Property="Effect">
    <Setter.Value>
      <DropShadowEffect BlurRadius="20" OffsetX="8" OffsetY="6" Color="#45000000">
        <DropShadowEffect.Transitions>
          <Transitions>
            <DoubleTransition Property="BlurRadius" Duration="0:0:0.18"/>
            <DoubleTransition Property="OffsetX" Duration="0:0:0.18"/>
            <DoubleTransition Property="OffsetY" Duration="0:0:0.18"/>
          </Transitions>
        </DropShadowEffect.Transitions>
      </DropShadowEffect>
    </Setter.Value>
  </Setter>
  
  <Setter Property="Template">
    <ControlTemplate>
      <Panel>
        <!-- LAYER 1: Base transparent glass with subtle tint -->
        <Border Name="BaseBorder"
                CornerRadius="{TemplateBinding CornerRadius}"
                BorderThickness="{TemplateBinding BorderThickness}"
                BorderBrush="{DynamicResource Brush.Glass.Border}"
                ClipToBounds="True">
          <Border.Transitions>
            <Transitions>
              <BrushTransition Property="BorderBrush" Duration="0:0:0.18"/>
              <BrushTransition Property="Background" Duration="0:0:0.18"/>
              <CornerRadiusTransition Property="CornerRadius" Duration="0:0:0.18"/>
            </Transitions>
          </Border.Transitions>
          <Border.Background>
            <RadialGradientBrush Center="35%,40%" RadiusX="80%" RadiusY="80%">
              <GradientStop Color="#0ED8E8F8" Offset="0"/>
              <GradientStop Color="#0C8FB5DF" Offset="0.5"/>
              <GradientStop Color="#0A6B8CAE" Offset="0.8"/>
              <GradientStop Color="#05272F43" Offset="1"/>
            </RadialGradientBrush>
          </Border.Background>
        </Border>
        
        <!-- LAYER 1.5: Inner shadow for depth -->
        <Border CornerRadius="{TemplateBinding CornerRadius}"
                Opacity="0.3"
                Margin="0"
                IsHitTestVisible="False"
                ClipToBounds="True">
          <Border.Background>
            <LinearGradientBrush StartPoint="100%,100%" EndPoint="0%,0%">
              <GradientStop Color="#30272F43" Offset="0"/>
              <GradientStop Color="#00272F43" Offset="0.3"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>

        <!-- LAYER 2: Spherical highlight for curved glass reflection -->
        <Border Name="Sheen"
                CornerRadius="{TemplateBinding CornerRadius}"
                Opacity="0.35"
                Margin="0"
                IsHitTestVisible="False"
                ClipToBounds="True">
          <Border.Transitions>
            <Transitions>
              <DoubleTransition Property="Opacity" Duration="0:0:0.18"/>
              <ThicknessTransition Property="Margin" Duration="0:0:0.25" Easing="SineEaseInOut"/>
            </Transitions>
          </Border.Transitions>
          <Border.Background>
            <RadialGradientBrush Center="30%,25%" RadiusX="60%" RadiusY="50%">
              <GradientStop Color="#38E8F4FF" Offset="0"/>
              <GradientStop Color="#20C8E0F5" Offset="0.2"/>
              <GradientStop Color="#10A0C8E8" Offset="0.5"/>
              <GradientStop Color="#00000000" Offset="1"/>
            </RadialGradientBrush>
          </Border.Background>
        </Border>

        <!-- LAYER 2.75: Top/left edge highlight for glass curve -->
        <Border CornerRadius="{TemplateBinding CornerRadius}"
                BorderThickness="1.5"
                Margin="0"
                IsHitTestVisible="False"
                ClipToBounds="False">
          <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#50D8E8F8" Offset="0"/>
              <GradientStop Color="#30B8D5EF" Offset="0.3"/>
              <GradientStop Color="#008FB5DF" Offset="0.7"/>
            </LinearGradientBrush>
          </Border.BorderBrush>
        </Border>
        
        <!-- LAYER 2.8: Bottom/right shadow for 3D depth -->
        <Border CornerRadius="{TemplateBinding CornerRadius}"
                Opacity="0.65"
                Margin="0"
                IsHitTestVisible="False"
                ClipToBounds="True">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
              <GradientStop Color="#00000000" Offset="0"/>
              <GradientStop Color="#00000000" Offset="0.5"/>
              <GradientStop Color="#40272F43" Offset="1"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>

        <!-- LAYER 3: Content -->
        <ContentPresenter Name="PART_ContentPresenter"
                          Background="{x:Null}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Padding="{TemplateBinding Padding}"
                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                          Content="{TemplateBinding Content}"
                          ContentTemplate="{TemplateBinding ContentTemplate}"
                          RecognizesAccessKey="True"/>

        <!-- Disabled overlay -->
        <Border Name="DisabledMask"
                IsVisible="False"
                CornerRadius="{TemplateBinding CornerRadius}"
                Background="#66000000"/>
      </Panel>
    </ControlTemplate>
  </Setter>
</Style>

<!-- ClipToBounds for the root Panel to ensure all hover effects respect corner radius -->
<Style Selector="Button.liquid-glass /template/ Panel">
  <Setter Property="ClipToBounds" Value="True"/>
</Style>

<!-- ═══════════════════════════════════════════════════════════════════════════════
     HOVER AND PRESSED STATES - Enhanced glass appearance with proper rounded corners
     ═══════════════════════════════════════════════════════════════════════════════ -->
<Style Selector="Button.liquid-glass:pointerover">
  <Setter Property="CornerRadius" Value="10"/>
  <Setter Property="Effect">
    <Setter.Value>
      <DropShadowEffect BlurRadius="18" OffsetX="5" OffsetY="6" Color="#38000000">
        <DropShadowEffect.Transitions>
          <Transitions>
            <DoubleTransition Property="BlurRadius" Duration="0:0:0.18"/>
            <DoubleTransition Property="OffsetX" Duration="0:0:0.18"/>
            <DoubleTransition Property="OffsetY" Duration="0:0:0.18"/>
          </Transitions>
        </DropShadowEffect.Transitions>
      </DropShadowEffect>
    </Setter.Value>
  </Setter>
</Style>

<Style Selector="Button.liquid-glass:pointerover /template/ Border#BaseBorder">
  <Setter Property="CornerRadius" Value="10"/>
  <Setter Property="BorderBrush" Value="{DynamicResource Brush.Glass.BorderHover}"/>
  <Setter Property="Background">
    <RadialGradientBrush Center="35%,40%" RadiusX="80%" RadiusY="80%">
      <GradientStop Color="#20D8E8F8" Offset="0"/>
      <GradientStop Color="#18A8C5E8" Offset="0.5"/>
      <GradientStop Color="#108FB5DF" Offset="0.8"/>
      <GradientStop Color="#08394D68" Offset="1"/>
    </RadialGradientBrush>
  </Setter>
</Style>

<Style Selector="Button.liquid-glass:pointerover /template/ Border#Sheen">
  <Setter Property="Opacity" Value="0.8"/>
</Style>

<Style Selector="Button.liquid-glass:pressed /template/ Border#BaseBorder">
  <Setter Property="CornerRadius" Value="10"/>
  <Setter Property="BorderBrush" Value="{DynamicResource Brush.Glass.BorderPressed}"/>
  <Setter Property="Background">
    <RadialGradientBrush Center="35%,40%" RadiusX="80%" RadiusY="80%">
      <GradientStop Color="#10B8D5EF" Offset="0"/>
      <GradientStop Color="#0C879BBE" Offset="0.5"/>
      <GradientStop Color="#086B8CAE" Offset="0.8"/>
      <GradientStop Color="#04272F43" Offset="1"/>
    </RadialGradientBrush>
  </Setter>
</Style>

<Style Selector="Button.liquid-glass:pressed /template/ Border#Sheen">
  <Setter Property="Opacity" Value="0.4"/>
</Style>

<Style Selector="Button.liquid-glass:pressed">
  <Setter Property="RenderTransform">
    <TranslateTransform Y="1"/>
  </Setter>
  <Setter Property="Effect">
    <Setter.Value>
      <DropShadowEffect BlurRadius="8" OffsetX="1" OffsetY="2" Color="#25000000">
        <DropShadowEffect.Transitions>
          <Transitions>
            <DoubleTransition Property="BlurRadius" Duration="0:0:0.18"/>
            <DoubleTransition Property="OffsetX" Duration="0:0:0.18"/>
            <DoubleTransition Property="OffsetY" Duration="0:0:0.18"/>
          </Transitions>
        </DropShadowEffect.Transitions>
      </DropShadowEffect>
    </Setter.Value>
  </Setter>
</Style>

<!-- Disabled State -->
<Style Selector="Button.liquid-glass:disabled">
  <Setter Property="Opacity" Value="0.5"/>
  <Setter Property="Cursor" Value="Arrow"/>
</Style>

<!-- ═══════════════════════════════════════════════════════════════════════════════
     LIGHT THEME OVERRIDES - Transparent with subtle white hue
     Theme-aware selectors use ActualThemeVariant
     ═══════════════════════════════════════════════════════════════════════════════ -->
<Style Selector="Button.liquid-glass.light-theme">
  <Setter Property="Background" Value="#15FFFFFF"/>
  <Setter Property="Foreground" Value="#1F2933"/>
</Style>

<Style Selector="Button.liquid-glass.light-theme /template/ Border#BaseBorder">
  <Setter Property="BorderBrush" Value="#40FFFFFF"/>
  <Setter Property="Background">
    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
      <GradientStop Color="#20FFFFFF" Offset="0"/>
      <GradientStop Color="#10FFFFFF" Offset="1"/>
    </LinearGradientBrush>
  </Setter>
</Style>

<Style Selector="Button.liquid-glass.light-theme:pointerover /template/ Border#BaseBorder">
  <Setter Property="BorderBrush" Value="#60FFFFFF"/>
  <Setter Property="Background">
    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
      <GradientStop Color="#35FFFFFF" Offset="0"/>
      <GradientStop Color="#25FFFFFF" Offset="1"/>
    </LinearGradientBrush>
  </Setter>
</Style>

<Style Selector="Button.liquid-glass.light-theme:pressed /template/ Border#BaseBorder">
  <Setter Property="BorderBrush" Value="#50FFFFFF"/>
  <Setter Property="Background">
    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
      <GradientStop Color="#28FFFFFF" Offset="0"/>
      <GradientStop Color="#18FFFFFF" Offset="1"/>
    </LinearGradientBrush>
  </Setter>
</Style>



<Style Selector="Button.liquid-glass:disabled /template/ Border#DisabledMask">
  <Setter Property="IsVisible" Value="True"/>
</Style>

<!-- Focus State (keyboard navigation) - MUST override GlobalStyles.axaml -->
<Style Selector="Button.liquid-glass:focus-visible">
  <Setter Property="Opacity" Value="1.0"/>
  <Setter Property="BorderBrush" Value="{DynamicResource Brush.Glass.BorderFocus}"/>
  <Setter Property="BorderThickness" Value="2"/>
  <Setter Property="CornerRadius" Value="10"/>
</Style>

<Style Selector="Button.liquid-glass:focus-visible /template/ Border#BaseBorder">
  <Setter Property="BorderBrush" Value="{DynamicResource Brush.Glass.BorderFocus}"/>
  <Setter Property="BorderThickness" Value="2"/>
  <Setter Property="CornerRadius" Value="10"/>
</Style>

<!-- ═══════════════════════════════════════════════════════════════════════════════
     PRIMARY VARIANT - Colored accent buttons
     ═══════════════════════════════════════════════════════════════════════════════ -->
<Style Selector="Button.liquid-glass.primary /template/ Border#BaseBorder">
  <Setter Property="BorderBrush" Value="#60A855F7"/>
  <Setter Property="Background">
    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
      <GradientStop Color="#50A855F7" Offset="0"/>
      <GradientStop Color="#30A855F7" Offset="1"/>
    </LinearGradientBrush>
  </Setter>
</Style>

<Style Selector="Button.liquid-glass.primary:pointerover /template/ Border#BaseBorder">
  <Setter Property="BorderBrush" Value="#70A855F7"/>
  <Setter Property="Background">
    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
      <GradientStop Color="#60A855F7" Offset="0"/>
      <GradientStop Color="#40A855F7" Offset="1"/>
    </LinearGradientBrush>
  </Setter>
</Style>

<!-- ═══════════════════════════════════════════════════════════════════════════════
     DANGER VARIANT - Red accent for destructive actions
     ═══════════════════════════════════════════════════════════════════════════════ -->
<Style Selector="Button.liquid-glass.danger /template/ Border#BaseBorder">
  <Setter Property="BorderBrush" Value="#70DC3545"/>
  <Setter Property="Background">
    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
      <GradientStop Color="#60DC3545" Offset="0"/>
      <GradientStop Color="#40DC3545" Offset="1"/>
    </LinearGradientBrush>
  </Setter>
</Style>

<Style Selector="Button.liquid-glass.danger:pointerover /template/ Border#BaseBorder">
  <Setter Property="BorderBrush" Value="#80DC3545"/>
  <Setter Property="Background">
    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
      <GradientStop Color="#70DC3545" Offset="0"/>
      <GradientStop Color="#50DC3545" Offset="1"/>
    </LinearGradientBrush>
  </Setter>
</Style>

<!-- ═══════════════════════════════════════════════════════════════════════════════
     SIZE VARIANTS
     ═══════════════════════════════════════════════════════════════════════════════ -->

<!-- Compact variant -->
<Style Selector="Button.liquid-glass.compact">
  <Setter Property="CornerRadius" Value="8"/>
  <Setter Property="MinHeight" Value="32"/>
  <Setter Property="Padding" Value="12,6"/>
  <Setter Property="FontSize" Value="13"/>
</Style>

<!-- Icon button variant (square) -->
<Style Selector="Button.liquid-glass.icon">
  <Setter Property="CornerRadius" Value="10"/>
  <Setter Property="MinHeight" Value="36"/>
  <Setter Property="MinWidth" Value="36"/>
  <Setter Property="Padding" Value="0"/>
  <Setter Property="HorizontalContentAlignment" Value="Center"/>
  <Setter Property="VerticalContentAlignment" Value="Center"/>
</Style>

<!-- Sidebar variant (left-aligned, rounded) -->
<Style Selector="Button.liquid-glass.sidebar">
  <Setter Property="CornerRadius" Value="16"/>
  <Setter Property="Padding" Value="14,10"/>
  <Setter Property="HorizontalContentAlignment" Value="Left"/>
</Style>

<!-- Sidebar buttons blend with the panel background using semi-transparent overlay -->
<Style Selector="Button.liquid-glass.sidebar /template/ Border#BaseBorder">
  <Setter Property="Background">
    <RadialGradientBrush Center="35%,40%" RadiusX="80%" RadiusY="80%">
      <GradientStop Color="#06FFFFFF" Offset="0"/>
      <GradientStop Color="#04FFFFFF" Offset="0.5"/>
      <GradientStop Color="#02FFFFFF" Offset="0.8"/>
      <GradientStop Color="#00FFFFFF" Offset="1"/>
    </RadialGradientBrush>
  </Setter>
  <Setter Property="BorderBrush" Value="#18FFFFFF"/>
</Style>

<Style Selector="Button.liquid-glass.sidebar:pointerover /template/ Border#BaseBorder">
  <Setter Property="Background">
    <RadialGradientBrush Center="35%,40%" RadiusX="80%" RadiusY="80%">
      <GradientStop Color="#0CFFFFFF" Offset="0"/>
      <GradientStop Color="#08FFFFFF" Offset="0.5"/>
      <GradientStop Color="#04FFFFFF" Offset="0.8"/>
      <GradientStop Color="#02FFFFFF" Offset="1"/>
    </RadialGradientBrush>
  </Setter>
  <Setter Property="BorderBrush" Value="#28FFFFFF"/>
</Style>

<Style Selector="Button.liquid-glass.sidebar:pressed /template/ Border#BaseBorder">
  <Setter Property="Background">
    <RadialGradientBrush Center="35%,40%" RadiusX="80%" RadiusY="80%">
      <GradientStop Color="#04FFFFFF" Offset="0"/>
      <GradientStop Color="#02FFFFFF" Offset="0.5"/>
      <GradientStop Color="#01FFFFFF" Offset="0.8"/>
      <GradientStop Color="#00FFFFFF" Offset="1"/>
    </RadialGradientBrush>
  </Setter>
  <Setter Property="BorderBrush" Value="#10FFFFFF"/>
</Style>

<!-- ═══════════════════════════════════════════════════════════════════════════════
     TILE BUTTON STYLES - Transparent wrappers for credential tiles
     No glass effects - just hover highlighting
     ═══════════════════════════════════════════════════════════════════════════════ -->
<Style Selector="Button.tile-button">
  <Setter Property="Background" Value="Transparent"/>
  <Setter Property="BorderThickness" Value="0"/>
  <Setter Property="CornerRadius" Value="0"/>
  <Setter Property="Padding" Value="0"/>
  <Setter Property="MinHeight" Value="0"/>
  <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
  <Setter Property="VerticalContentAlignment" Value="Stretch"/>
  <Setter Property="Template">
    <ControlTemplate>
      <ContentPresenter Name="PART_ContentPresenter"
                        Background="{TemplateBinding Background}"
                        Margin="{TemplateBinding Padding}"
                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}"
                        RecognizesAccessKey="True"/>
    </ControlTemplate>
  </Setter>
  <Setter Property="Transitions">
    <Transitions>
      <BrushTransition Property="Background" Duration="0:0:0.2"/>
    </Transitions>
  </Setter>
</Style>

<Style Selector="Button.tile-button:pointerover">
  <Setter Property="Background" Value="#101F2D"/>
</Style>

<Style Selector="Button.tile-button:pressed">
  <Setter Property="Background" Value="#1A2A38"/>
</Style>

<!-- Grid tile button variant -->
<Style Selector="Button.tile-button-grid">
  <Setter Property="Background" Value="Transparent"/>
  <Setter Property="BorderThickness" Value="0"/>
  <Setter Property="CornerRadius" Value="8"/>
  <Setter Property="Padding" Value="0"/>
  <Setter Property="MinHeight" Value="0"/>
  <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
  <Setter Property="VerticalContentAlignment" Value="Stretch"/>
  <Setter Property="Template">
    <ControlTemplate>
      <ContentPresenter Name="PART_ContentPresenter"
                        Background="{TemplateBinding Background}"
                        Margin="{TemplateBinding Padding}"
                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                        Content="{TemplateBinding Content}"
                        ContentTemplate="{TemplateBinding ContentTemplate}"
                        RecognizesAccessKey="True"/>
    </ControlTemplate>
  </Setter>
  <Setter Property="Transitions">
    <Transitions>
      <BrushTransition Property="Background" Duration="0:0:0.2"/>
    </Transitions>
  </Setter>
</Style>

<Style Selector="Button.tile-button-grid:pointerover">
  <Setter Property="Background" Value="#101F2D"/>
</Style>

<Style Selector="Button.tile-button-grid:pressed">
  <Setter Property="Background" Value="#1A2A38"/>
</Style>

<!-- Tile focus state -->
<Style Selector="Button.tile-button:focus-visible, Button.tile-button-grid:focus-visible">
  <Setter Property="BorderBrush" Value="#8FB5DF"/>
  <Setter Property="BorderThickness" Value="2 0 0 0"/>
</Style>

<!-- ═══════════════════════════════════════════════════════════════════════════════
     TOGGLE BUTTON LIQUID GLASS VARIANT
     ═══════════════════════════════════════════════════════════════════════════════ -->
<Style Selector="ToggleButton.liquid-glass">
  <Setter Property="CornerRadius" Value="10"/>
  <Setter Property="BorderThickness" Value="1"/>
  <Setter Property="FontWeight" Value="SemiBold"/>
  <Setter Property="Foreground" Value="#FFFFFF"/>
  <Setter Property="Cursor" Value="Hand"/>
  <Setter Property="MinHeight" Value="40"/>
  <Setter Property="Padding" Value="16,8"/>
  <Setter Property="Background" Value="#04FFFFFF"/>
  <Setter Property="HorizontalContentAlignment" Value="Center"/>
  <Setter Property="VerticalContentAlignment" Value="Center"/>
  
  <Setter Property="Template">
    <ControlTemplate>
      <Panel ClipToBounds="True">
        <Border Name="BaseBorder"
                CornerRadius="{TemplateBinding CornerRadius}"
                BorderThickness="{TemplateBinding BorderThickness}"
                BorderBrush="{DynamicResource Brush.Glass.Border}"
                ClipToBounds="True">
          <Border.Transitions>
            <Transitions>
              <BrushTransition Property="BorderBrush" Duration="0:0:0.18"/>
              <BrushTransition Property="Background" Duration="0:0:0.18"/>
            </Transitions>
          </Border.Transitions>
          <Border.Background>
            <RadialGradientBrush Center="35%,40%" RadiusX="80%" RadiusY="80%">
              <GradientStop Color="#0ED8E8F8" Offset="0"/>
              <GradientStop Color="#0C8FB5DF" Offset="0.5"/>
              <GradientStop Color="#0A6B8CAE" Offset="0.8"/>
              <GradientStop Color="#05272F43" Offset="1"/>
            </RadialGradientBrush>
          </Border.Background>
        </Border>

        <Border Name="Sheen"
                CornerRadius="{TemplateBinding CornerRadius}"
                Opacity="0.45"
                Margin="0"
                IsHitTestVisible="False"
                ClipToBounds="True">
          <Border.Background>
            <RadialGradientBrush Center="30%,25%" RadiusX="60%" RadiusY="50%">
              <GradientStop Color="#48E8F4FF" Offset="0"/>
              <GradientStop Color="#30C8E0F5" Offset="0.2"/>
              <GradientStop Color="#18A0C8E8" Offset="0.5"/>
              <GradientStop Color="#00000000" Offset="1"/>
            </RadialGradientBrush>
          </Border.Background>
        </Border>

        <ContentPresenter Name="PART_ContentPresenter"
                          Background="{x:Null}"
                          CornerRadius="{TemplateBinding CornerRadius}"
                          Padding="{TemplateBinding Padding}"
                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                          Content="{TemplateBinding Content}"
                          ContentTemplate="{TemplateBinding ContentTemplate}"
                          RecognizesAccessKey="True"/>
      </Panel>
    </ControlTemplate>
  </Setter>
</Style>

<Style Selector="ToggleButton.liquid-glass:pointerover /template/ Border#BaseBorder">
  <Setter Property="BorderBrush" Value="{DynamicResource Brush.Glass.BorderHover}"/>
  <Setter Property="Background">
    <RadialGradientBrush Center="35%,40%" RadiusX="80%" RadiusY="80%">
      <GradientStop Color="#20D8E8F8" Offset="0"/>
      <GradientStop Color="#18A8C5E8" Offset="0.5"/>
      <GradientStop Color="#108FB5DF" Offset="0.8"/>
      <GradientStop Color="#08394D68" Offset="1"/>
    </RadialGradientBrush>
  </Setter>
</Style>

<Style Selector="ToggleButton.liquid-glass:pointerover /template/ Border#Sheen">
  <Setter Property="Opacity" Value="0.8"/>
</Style>

<Style Selector="ToggleButton.liquid-glass:checked /template/ Border#BaseBorder">
  <Setter Property="BorderBrush" Value="{DynamicResource Brush.Glass.BorderHover}"/>
  <Setter Property="Background">
    <RadialGradientBrush Center="35%,40%" RadiusX="80%" RadiusY="80%">
      <GradientStop Color="#40D8E8F8" Offset="0"/>
      <GradientStop Color="#30B8D5EF" Offset="0.5"/>
      <GradientStop Color="#208FB5DF" Offset="0.8"/>
      <GradientStop Color="#10394D68" Offset="1"/>
    </RadialGradientBrush>
  </Setter>
</Style>

<Style Selector="ToggleButton.liquid-glass:checked /template/ Border#Sheen">
  <Setter Property="Opacity" Value="0.9"/>
</Style>

<Style Selector="ToggleButton.liquid-glass:pressed /template/ Border#BaseBorder">
  <Setter Property="BorderBrush" Value="{DynamicResource Brush.Glass.BorderPressed}"/>
  <Setter Property="Background">
    <RadialGradientBrush Center="35%,40%" RadiusX="80%" RadiusY="80%">
      <GradientStop Color="#10B8D5EF" Offset="0"/>
      <GradientStop Color="#0C879BBE" Offset="0.5"/>
      <GradientStop Color="#086B8CAE" Offset="0.8"/>
      <GradientStop Color="#04272F43" Offset="1"/>
    </RadialGradientBrush>
  </Setter>
</Style>

<Style Selector="ToggleButton.liquid-glass:pressed /template/ Border#Sheen">
  <Setter Property="Opacity" Value="0.3"/>
</Style>

<Style Selector="ToggleButton.liquid-glass:pressed">
  <Setter Property="RenderTransform">
    <TranslateTransform Y="1"/>
  </Setter>
</Style>

<Style Selector="ToggleButton.liquid-glass:disabled">
  <Setter Property="Opacity" Value="0.5"/>
  <Setter Property="Cursor" Value="Arrow"/>
</Style>

</Styles>