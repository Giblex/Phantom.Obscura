<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Modern Animation Presets -->
    <!-- All animations respect ReduceMotion setting via conditional styling -->

    <Style>
        <Style.Resources>
            <!-- Animation Durations -->
            <x:Double x:Key="Anim.Duration.Instant">0.08</x:Double>
            <x:Double x:Key="Anim.Duration.Fast">0.15</x:Double>
            <x:Double x:Key="Anim.Duration.Normal">0.25</x:Double>
            <x:Double x:Key="Anim.Duration.Slow">0.4</x:Double>
            <x:Double x:Key="Anim.Duration.VerySlow">0.6</x:Double>

            <!-- Reduced Motion Durations (50% faster) -->
            <x:Double x:Key="Anim.Duration.Instant.Reduced">0.04</x:Double>
            <x:Double x:Key="Anim.Duration.Fast.Reduced">0.08</x:Double>
            <x:Double x:Key="Anim.Duration.Normal.Reduced">0.12</x:Double>
            <x:Double x:Key="Anim.Duration.Slow.Reduced">0.2</x:Double>
            <x:Double x:Key="Anim.Duration.VerySlow.Reduced">0.3</x:Double>
        </Style.Resources>
    </Style>

    <!-- ══════════════════════ FADE ANIMATIONS ══════════════════════ -->

    <!-- Fade In -->
    <Style Selector="Control.fade-in">
        <Setter Property="Opacity" Value="0"/>
        <Style.Animations>
            <Animation Duration="0:0:0.3" FillMode="Forward" Easing="SineEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Fade Out -->
    <Style Selector="Control.fade-out">
        <Style.Animations>
            <Animation Duration="0:0:0.2" FillMode="Forward" Easing="SineEaseIn">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="1"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="0"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ══════════════════════ SLIDE ANIMATIONS ══════════════════════ -->

    <!-- Slide In from Bottom -->
    <Style Selector="Control.slide-in-bottom">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="RenderTransform" Value="translateY(20px)"/>
        <Style.Animations>
            <Animation Duration="0:0:0.4" FillMode="Forward" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="(TranslateTransform.Y)" Value="20"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="(TranslateTransform.Y)" Value="0"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Slide In from Top -->
    <Style Selector="Control.slide-in-top">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="RenderTransform" Value="translateY(-20px)"/>
        <Style.Animations>
            <Animation Duration="0:0:0.4" FillMode="Forward" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="(TranslateTransform.Y)" Value="-20"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="(TranslateTransform.Y)" Value="0"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Slide In from Left -->
    <Style Selector="Control.slide-in-left">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="RenderTransform" Value="translateX(-20px)"/>
        <Style.Animations>
            <Animation Duration="0:0:0.35" FillMode="Forward" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="(TranslateTransform.X)" Value="-20"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="(TranslateTransform.X)" Value="0"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Slide In from Right -->
    <Style Selector="Control.slide-in-right">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="RenderTransform" Value="translateX(20px)"/>
        <Style.Animations>
            <Animation Duration="0:0:0.35" FillMode="Forward" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="(TranslateTransform.X)" Value="20"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="(TranslateTransform.X)" Value="0"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ══════════════════════ SCALE ANIMATIONS ══════════════════════ -->

    <!-- Scale Up (gentle entrance) -->
    <Style Selector="Control.scale-up">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="RenderTransform" Value="scale(0.95)"/>
        <Style.Animations>
            <Animation Duration="0:0:0.3" FillMode="Forward" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="(ScaleTransform.ScaleX)" Value="0.95"/>
                    <Setter Property="(ScaleTransform.ScaleY)" Value="0.95"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="(ScaleTransform.ScaleX)" Value="1"/>
                    <Setter Property="(ScaleTransform.ScaleY)" Value="1"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Pop In (bouncy entrance) -->
    <Style Selector="Control.pop-in">
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="RenderTransform" Value="scale(0.8)"/>
        <Style.Animations>
            <Animation Duration="0:0:0.5" FillMode="Forward" Easing="BackEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="(ScaleTransform.ScaleX)" Value="0.8"/>
                    <Setter Property="(ScaleTransform.ScaleY)" Value="0.8"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="(ScaleTransform.ScaleX)" Value="1"/>
                    <Setter Property="(ScaleTransform.ScaleY)" Value="1"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ══════════════════════ STAGGERED LIST ANIMATIONS ══════════════════════ -->

    <!-- Stagger delays for sequential animations -->
    <Style Selector="Control.stagger-1">
        <Style.Animations>
            <Animation Delay="0:0:0.05" Duration="0:0:0.4" FillMode="Forward" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="(TranslateTransform.Y)" Value="10"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="(TranslateTransform.Y)" Value="0"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Control.stagger-2">
        <Style.Animations>
            <Animation Delay="0:0:0.1" Duration="0:0:0.4" FillMode="Forward" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="(TranslateTransform.Y)" Value="10"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="(TranslateTransform.Y)" Value="0"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Control.stagger-3">
        <Style.Animations>
            <Animation Delay="0:0:0.15" Duration="0:0:0.4" FillMode="Forward" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="(TranslateTransform.Y)" Value="10"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="(TranslateTransform.Y)" Value="0"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- ══════════════════════ HOVER ANIMATIONS ══════════════════════ -->

    <!-- Smooth lift on hover -->
    <Style Selector="Control.hoverable:pointerover">
        <Setter Property="(TranslateTransform.Y)" Value="-2"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>

    <!-- Gentle scale on hover -->
    <Style Selector="Control.scalable:pointerover">
        <Setter Property="(ScaleTransform.ScaleX)" Value="1.02"/>
        <Setter Property="(ScaleTransform.ScaleY)" Value="1.02"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>

</Styles>
