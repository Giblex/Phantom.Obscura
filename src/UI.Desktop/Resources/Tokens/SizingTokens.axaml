<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Tile sizing tokens - Adjust these to change all tiles uniformly -->
    <x:Double x:Key="TileWidth">420</x:Double>
    <x:Double x:Key="TileHeight">100</x:Double>
    <x:Double x:Key="GridTileWidth">252</x:Double>
    <x:Double x:Key="GridTileHeight">96</x:Double>
    
</ResourceDictionary>

