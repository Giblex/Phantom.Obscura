<Styles xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Quick filter toggle buttons - liquid glass effect sidebar buttons -->
    <Style Selector="ToggleButton.quick-filter">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Height" Value="44" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Panel>
                        <!-- Base body with glass gradient -->
                        <Border Name="BaseBorder"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="#40FFFFFF"
                                ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#30FFFFFF" Offset="0"/>
                                    <GradientStop Color="#18FFFFFF" Offset="0.55"/>
                                    <GradientStop Color="#10FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        
                        <!-- Inner rim highlight -->
                        <Border Margin="1"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BorderThickness="1"
                                BorderBrush="#10FFFFFF"
                                Opacity="0.95"
                                IsHitTestVisible="False"/>
                        
                        <!-- Liquid sheen effect -->
                        <Border Name="Sheen"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0.90"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                    <GradientStop Color="#18FFFFFF" Offset="0"/>
                                    <GradientStop Color="#08FFFFFF" Offset="0.38"/>
                                    <GradientStop Color="#00FFFFFF" Offset="0.75"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        
                        <!-- Specular top highlight -->
                        <Border Height="16"
                                VerticalAlignment="Top"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0.80"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#18FFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        
                        <!-- Content -->
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          RecognizesAccessKey="True"/>
                    </Panel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style Selector="ToggleButton.quick-filter:pointerover /template/ Border#BaseBorder">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderBrush" Value="#60FFFFFF"/>
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#40FFFFFF" Offset="0"/>
                <GradientStop Color="#28FFFFFF" Offset="0.55"/>
                <GradientStop Color="#20FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>

    <Style Selector="ToggleButton.quick-filter:checked /template/ Border#BaseBorder">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#40004258" Offset="0"/>
                <GradientStop Color="#30004258" Offset="0.55"/>
                <GradientStop Color="#25004258" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>

    <Style Selector="ToggleButton.quick-filter:checked:pointerover /template/ Border#BaseBorder">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#40004258" Offset="0"/>
                <GradientStop Color="#2C004258" Offset="0.55"/>
                <GradientStop Color="#24004258" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>

    <!-- Category filter toggle buttons - liquid glass effect, slightly shorter -->
    <Style Selector="ToggleButton.category-filter">
        <Setter Property="FontFamily" Value="{DynamicResource MainFontFamily}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Height" Value="38" />
        <Setter Property="Cursor" Value="Hand" />
        <!-- Issue #17: 8 → 12 across base + hover/checked overrides so dropdown
             toggle and list-item corners read visibly rounded. -->
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Panel>
                        <!-- Issue #10/#18: category list items were nearly invisible
                             at rest. Use a stronger rest background gradient so they
                             read as solid 'present' tiles while keeping the glass
                             border feel from QuickFilterGlassBorderBrush. -->
                        <Border Name="BaseBorder"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{DynamicResource QuickFilterGlassBorderBrush}"
                                ClipToBounds="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                    <GradientStop Color="#1AFFFFFF" Offset="0"/>
                                    <GradientStop Color="#10FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        
                        <!-- Content -->
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          RecognizesAccessKey="True"/>
                    </Panel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Issue #18: category-filter hover/checked were near-black overlays which
         read flat and too dim. Switch to white-alpha + cyan glass border so
         the categories tone up slightly and have liquid-glass border feel. -->
    <Style Selector="ToggleButton.category-filter:pointerover /template/ Border#BaseBorder">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="{DynamicResource QuickFilterGlassBorderBrush}"/>
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#20FFFFFF" Offset="0"/>
                <GradientStop Color="#14FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>

    <Style Selector="ToggleButton.category-filter:checked /template/ Border#BaseBorder">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="{DynamicResource QuickFilterGlassActiveBorderBrush}"/>
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#2CFFFFFF" Offset="0"/>
                <GradientStop Color="#1CFFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>

    <Style Selector="ToggleButton.category-filter:checked:pointerover /template/ Border#BaseBorder">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BorderBrush" Value="{DynamicResource QuickFilterGlassActiveBorderBrush}"/>
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#38FFFFFF" Offset="0"/>
                <GradientStop Color="#24FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    
</Styles>
