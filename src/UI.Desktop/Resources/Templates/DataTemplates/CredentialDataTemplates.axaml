<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Giblex.Controls;assembly=PhantomVault.UI"
                    xmlns:dcontrols="clr-namespace:PhantomVault.UI.Desktop.Controls;assembly=PhantomVault.UI"
                    xmlns:vm="clr-namespace:PhantomVault.UI.ViewModels;assembly=PhantomVault.UI">
    
    <!-- Category Banner/Header Template for grouped list -->
    <DataTemplate x:Key="CategoryHeaderTemplate" DataType="vm:ListItemWrapper">
        <Border CornerRadius="{StaticResource Radius.Lg}"
                BorderThickness="0"
                Padding="16,12"
                Margin="0,8,0,0"
                HorizontalAlignment="Stretch"
                ClipToBounds="True">
            <Border.Background>
                <SolidColorBrush Color="{Binding CategoryColor, FallbackValue=#444444}" Opacity="0.85"/>
            </Border.Background>
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Category color accent bar -->
                <Border Grid.Column="0" 
                        Width="5" 
                        CornerRadius="2.5"
                        Margin="0,0,12,0"
                        VerticalAlignment="Stretch">
                    <Border.Background>
                        <SolidColorBrush Color="#000000" Opacity="0.25"/>
                    </Border.Background>
                </Border>
                
                <!-- Category name -->
                <TextBlock Grid.Column="1"
                           Text="{Binding CategoryName}"
                           FontSize="{StaticResource Type.Body.Size}"
                           FontWeight="Bold"
                           Foreground="#FF1A1A2E"
                           VerticalAlignment="Center"/>
                
                <!-- Item count -->
                <Border Grid.Column="2"
                        CornerRadius="10"
                        Padding="8,3"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush Color="#000000" Opacity="0.15"/>
                    </Border.Background>
                    <TextBlock Text="{Binding CategoryItemCount}"
                               FontSize="{StaticResource Type.Small.Size}"
                               FontWeight="SemiBold"
                               Foreground="#FF1A1A2E"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </DataTemplate>
    
    <!-- List View Credential Tile Template -->
    <DataTemplate x:Key="CredentialListTileTemplate">
        <!-- Each Credential Card (List) -->
        <Button Command="{Binding $parent[Window].DataContext.TileClickCommand}"
                CommandParameter="{Binding}"
                Background="Transparent"
                BorderThickness="0"
                Padding="0"
                Margin="0"
                Classes="tile-button"
                HorizontalAlignment="Stretch"
                VerticalContentAlignment="Center"
                MinHeight="96"
                Height="96"
                AutomationProperties.Name="{Binding Title}">
            <Border x:Name="ListTileBorder"
                    BorderBrush="{DynamicResource HeaderButtonBorderBrush}"
                    Background="{DynamicResource ContentBackgroundBrush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="16,12"
                    HorizontalAlignment="Stretch"
                    MinHeight="96"
                    VerticalAlignment="Center"
                    ClipToBounds="True">
                <Border.Styles>
                    <Style Selector="Button.tile-button:pointerover Border#ListTileBorder">
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        <Setter Property="BoxShadow" Value="0 2 8 0 #18000000"/>
                    </Style>
                    <Style Selector="Button.tile-button:pointerover Border#ListTileHighlightOverlay">
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Opacity" Value="0.10"/>
                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    </Style>
                    <Style Selector="Button.tile-button:pressed Border#ListTileBorder">
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        <Setter Property="BoxShadow" Value="0 1 4 0 #12000000"/>
                    </Style>
                    <Style Selector="Button.tile-button:pressed Border#ListTileHighlightOverlay">
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Opacity" Value="0.16"/>
                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    </Style>
                </Border.Styles>

                <Grid Classes="tile-entrance">

                    
                    <!-- Category color bar on the left edge (hidden when sorted by category) -->
                    <Border Width="6" HorizontalAlignment="Left" VerticalAlignment="Stretch" CornerRadius="0" Margin="0" IsHitTestVisible="False"
                            Opacity="{Binding HasGroup, Converter={StaticResource BoolToOpacityConverter}}"
                            IsVisible="{Binding !$parent[Window].DataContext.IsSortedByCategory}">
                        <Border.Background>
                            <MultiBinding Converter="{StaticResource CategoryNameToBrushConverter}">
                                <Binding Path="Group"/>
                                <Binding Path="$parent[Window].DataContext.Categories"/>
                            </MultiBinding>
                        </Border.Background>
                    </Border>
                    
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Icon Column -->
                        <Grid Grid.Column="0" Margin="12,0,16,0" VerticalAlignment="Center">
                            <Border Background="{Binding IconBackgroundBrush}" Width="72" Height="72" CornerRadius="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid>
                                    <Image Source="{Binding AutoDetectedIconBitmap}" Width="64" Height="64" Stretch="Uniform" IsVisible="{Binding HasAutoDetectedIcon}"/>
                                    <StackPanel IsVisible="{Binding !HasAutoDetectedIcon}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayIcon}" FontSize="{StaticResource Type.H2.Size}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" IsVisible="{Binding HasCustomIcon}"/>
                                        <TextBlock Text="{Binding IconText}" FontSize="{StaticResource Type.H3.Size}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Content Column -->
                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="4" VerticalAlignment="Center" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock FontSize="{StaticResource Type.H3.Size}" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" MaxLines="1">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource PrivacyMaskConverter}">
                                            <Binding Path="Title"/>
                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <!-- Non-interactive favorite indicator for list tiles -->
                                <dcontrols:SvgIcon IconName="Assets/SVG/Favourites.svg" Width="14" Height="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   IconColor="{Binding FavoriteIconBrush}"
                                                   Opacity="{Binding FavoriteIconOpacity}"/>
                            </StackPanel>

                            <!-- TOTP Code Display (visible only for TOTP entries) -->
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" IsVisible="{Binding IsTotpEntry}">
                                <Border Background="{DynamicResource ControlBackgroundBrush}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,6">
                                    <TextBlock Text="{Binding CurrentTotpCode}"
                                               FontSize="{StaticResource Type.H2.Size}"
                                               FontFamily="Consolas,monospace"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               LetterSpacing="2"/>
                                </Border>
                                <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotpSecondsRemaining, StringFormat='{}{0}s remaining'}"
                                               FontSize="{StaticResource Type.Small.Size}"
                                               Foreground="{DynamicResource MutedTextBrush}"/>
                                    <ProgressBar Value="{Binding TotpProgressPercent}"
                                                 Maximum="100"
                                                 Width="80"
                                                 Height="4"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 Background="{DynamicResource ControlBackgroundBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Entry-type aware detail lines (hidden for TOTP) -->
                            <StackPanel Orientation="Vertical" Spacing="2" IsVisible="{Binding !IsTotpEntry}">
                                <TextBlock FontSize="{StaticResource Type.H5.Size}" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" MaxLines="1">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="DetailLine1">
                                            <Binding Path="DetailLine1"/>
                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="{StaticResource Type.Body.Size}" Foreground="{DynamicResource MutedTextBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" MaxLines="1" IsVisible="{Binding HasDetailLine2}">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="DetailLine2">
                                            <Binding Path="DetailLine2"/>
                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- Quick Action Buttons (visible on hover) -->
                        <StackPanel Grid.Column="2" 
                                    Orientation="Horizontal" 
                                    Spacing="6" 
                                    VerticalAlignment="Center"
                                    Margin="6,0,0,0"
                                    x:Name="QuickActionsPanel"
                                    Opacity="0">
                            <StackPanel.Styles>
                                <Style Selector="Button:pointerover StackPanel#QuickActionsPanel">
                                    <Setter Property="Opacity" Value="1"/>
                                </Style>
                                <Style Selector="Border:pointerover StackPanel#QuickActionsPanel">
                                    <Setter Property="Opacity" Value="1"/>
                                </Style>
                            </StackPanel.Styles>
                            <StackPanel.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                                </Transitions>
                            </StackPanel.Transitions>
                            
                            <!-- Copy Username -->
                            <Button Command="{Binding $parent[Window].DataContext.CopyUsernameCommand}"
                                    CommandParameter="{Binding}"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="{StaticResource Radius.Sm}"
                                    Padding="0"
                                    ToolTip.Tip="Copy username">
                                <TextBlock Text="👤"
                                           FontSize="{StaticResource Type.Body.Size}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                            
                            <!-- Copy Password -->
                            <controls:LiquidGlassButton Command="{Binding $parent[Window].DataContext.CopyPasswordCommand}"
                                    CommandParameter="{Binding}"
                                    WidthOverride="34"
                                    HeightOverride="34"
                                    CornerRadiusValue="8"
                                    PaddingOverride="0"
                                    ToolTipText="Copy password">
                                <controls:LiquidGlassButton.ButtonContent>
                                    <TextBlock Text="🔑"
                                               FontSize="{StaticResource Type.Body.Size}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </controls:LiquidGlassButton.ButtonContent>
                            </controls:LiquidGlassButton>
                            
                            <!-- Edit Button -->
                            <Button Command="{Binding $parent[Window].DataContext.EditCredentialCommand}"
                                    CommandParameter="{Binding}"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="{StaticResource Radius.Sm}"
                                    Padding="0"
                                    ToolTip.Tip="Edit">
                                <TextBlock Text="✏️"
                                           FontSize="{StaticResource Type.Small.Size}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border x:Name="ListTileHighlightOverlay"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Background="Transparent"
                            CornerRadius="0"
                            Opacity="0"
                            IsHitTestVisible="False"/>
                </Grid>
            </Border>
        </Button>
    </DataTemplate>
    
    <!-- Grid View Credential Tile Template -->
    <DataTemplate x:Key="CredentialGridTileTemplate">
        <Grid Margin="6,4,6,8" HorizontalAlignment="Stretch" Classes="tile-entrance">
            <Button Command="{Binding $parent[Window].DataContext.TileClickCommand}"
                    CommandParameter="{Binding}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Classes="tile-button-grid">
                <Border x:Name="GridTileBorder"
                        MinWidth="{StaticResource GridTileWidth}"
                        Height="{StaticResource GridTileHeight}"
                        Padding="0"
                        CornerRadius="{StaticResource Radius.Xl}"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        BorderThickness="1"
                        ClipToBounds="False"
                        BoxShadow="0 2 8 0 #18000000">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="{DynamicResource ControlBorderColor}"/>
                    </Border.BorderBrush>
                    <Border.Styles>
                        <Style Selector="Button.tile-button-grid:pointerover Border#GridTileBorder">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="BoxShadow" Value="0 4 12 0 #22000000"/>
                        </Style>
                        <Style Selector="Button.tile-button-grid:pointerover Border#GridTileHighlightOverlay">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Opacity" Value="0.12"/>
                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                        </Style>
                        <Style Selector="Button.tile-button-grid:pressed Border#GridTileBorder">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="BoxShadow" Value="0 1 4 0 #12000000"/>
                        </Style>
                        <Style Selector="Button.tile-button-grid:pressed Border#GridTileHighlightOverlay">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="Opacity" Value="0.18"/>
                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                        </Style>
                    </Border.Styles>
                    <Grid>
                        <!-- Category color bar stretching across entire top -->
                        <Border Height="6"
                            Grid.ColumnSpan="2"
                            Grid.RowSpan="2"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"
                            CornerRadius="{StaticResource Radius.Xl},{StaticResource Radius.Xl},0,0"
                                Margin="0"
                                IsHitTestVisible="False"
                                Opacity="{Binding HasGroup, Converter={StaticResource BoolToOpacityConverter}}">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource CategoryNameToBrushConverter}">
                                    <Binding Path="Group"/>
                                    <Binding Path="$parent[Window].DataContext.Categories"/>
                                </MultiBinding>
                            </Border.Background>
                        </Border>
                        
                        <Border Background="Transparent"
                            Grid.ColumnSpan="2"
                            Grid.RowSpan="2"
                                CornerRadius="{StaticResource Radius.Xl}"
                                IsHitTestVisible="False"
                                Margin="0,6,0,0"
                                Opacity="0"/>
                        
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="16"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Icon with better padding -->
                        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="12,14,10,0">
                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="20"
                                    Background="{Binding IconBackgroundBrush}">
                                <Grid>
                                    <Image Source="{Binding AutoDetectedIconBitmap}"
                                           Width="34"
                                           Height="34"
                                           Stretch="Uniform"
                                           IsVisible="{Binding HasAutoDetectedIcon}"/>
                                    <TextBlock Text="{Binding IconText}"
                                               FontSize="{StaticResource Type.H4.Size}"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding !HasAutoDetectedIcon}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                        
                        <!-- Content with proper margins to prevent cutoff -->
                        <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Spacing="2" Margin="0,14,12,0">
                            <TextBlock FontSize="{StaticResource Type.Label.Size}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1">
                                <TextBlock.Effect>
                                    <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"
                                             Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                </TextBlock.Effect>
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource PrivacyMaskConverter}">
                                        <Binding Path="Title"/>
                                        <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="{StaticResource Type.Tiny.Size}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1">
                                <TextBlock.Effect>
                                    <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"
                                             Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                </TextBlock.Effect>
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource PrivacyMaskConverter}"
                                                  ConverterParameter="DetailLine1">
                                        <Binding Path="DetailLine1"/>
                                        <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        
                        <Rectangle Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   Height="2"
                                   Opacity="0.0"
                                   Fill="Transparent"/>
                        <Rectangle Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   Height="1"
                                   Fill="{DynamicResource ControlBorderBrush}"
                                   Opacity="0.0"
                                   VerticalAlignment="Bottom"/>

                        <Border x:Name="GridTileHighlightOverlay"
                                Grid.ColumnSpan="2"
                                Grid.RowSpan="2"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Background="Transparent"
                                CornerRadius="{StaticResource Radius.Xl}"
                                Opacity="0"
                                IsHitTestVisible="False"/>
                    </Grid>
                </Border>
            </Button>

            <!-- Action Buttons Overlay (Hidden by default, shown on hover) -->
            <Border Width="48"
                    Height="{StaticResource GridTileHeight}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="-36,0,0,0"
                    Background="Transparent"
                    IsHitTestVisible="False">
                <Canvas IsHitTestVisible="True">
                    <Border Canvas.Top="-18"
                            Canvas.Right="0"
                            CornerRadius="{StaticResource Radius.Lg}"
                            Padding="0"
                            Width="48"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Effect="{x:Null}"
                            Opacity="0">
                        <Grid Width="48" Margin="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <controls:LiquidGlassButton Grid.Row="0"
                                    Command="{Binding $parent[Window].DataContext.CopyPasswordCommand}"
                                    CommandParameter="{Binding}"
                                    WidthOverride="22"
                                    HeightOverride="22"
                                    CornerRadiusValue="6"
                                    PaddingOverride="0"
                                    HorizontalAlignment="Center"
                                    Margin="0,2,0,0">
                                <controls:LiquidGlassButton.ButtonContent>
                                    <TextBlock Text="⧉" FontSize="{StaticResource Type.Tiny.Size}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </controls:LiquidGlassButton.ButtonContent>
                            </controls:LiquidGlassButton>
                            
                            <controls:LiquidGlassButton Grid.Row="1"
                                    Command="{Binding $parent[Window].DataContext.EditCredentialCommand}"
                                    CommandParameter="{Binding}"
                                    WidthOverride="22"
                                    HeightOverride="22"
                                    CornerRadiusValue="6"
                                    PaddingOverride="0"
                                    HorizontalAlignment="Center"
                                    Margin="0,6,0,0">
                                <controls:LiquidGlassButton.ButtonContent>
                                    <TextBlock Text="✎" FontSize="{StaticResource Type.Tiny.Size}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </controls:LiquidGlassButton.ButtonContent>
                            </controls:LiquidGlassButton>
                            
                            <controls:LiquidGlassButton Grid.Row="2"
                                    Command="{Binding $parent[Window].DataContext.DeleteCredentialCommand}"
                                    CommandParameter="{Binding}"
                                    WidthOverride="22"
                                    HeightOverride="22"
                                    CornerRadiusValue="6"
                                    PaddingOverride="0"
                                    HorizontalAlignment="Center"
                                    Margin="0,6,0,0">
                                <controls:LiquidGlassButton.ButtonContent>
                                    <TextBlock Text="🗑" FontSize="{StaticResource Type.Tiny.Size}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </controls:LiquidGlassButton.ButtonContent>
                            </controls:LiquidGlassButton>
                            
                            <controls:LiquidGlassButton Grid.Row="3"
                                    Command="{Binding $parent[Window].DataContext.ToggleFavoriteCommand}"
                                    CommandParameter="{Binding}"
                                    WidthOverride="22"
                                    HeightOverride="22"
                                    CornerRadiusValue="6"
                                    PaddingOverride="0"
                                    HorizontalAlignment="Center"
                                    Margin="0,6,0,0">
                                <controls:LiquidGlassButton.ButtonContent>
                                    <dcontrols:SvgIcon IconName="Assets/SVG/Favourites.svg" Width="12" Height="12"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       IconColor="{Binding FavoriteIconBrush}"
                                                       Opacity="{Binding FavoriteIconOpacity}"/>
                                </controls:LiquidGlassButton.ButtonContent>
                            </controls:LiquidGlassButton>
                        </Grid>
                    </Border>
                </Canvas>
            </Border>
        </Grid>
    </DataTemplate>

    <!-- Template for ListItemWrapper - shows either category header or credential -->
    <DataTemplate x:Key="GroupedListItemTemplate" DataType="vm:ListItemWrapper">
        <ContentControl>
            <ContentControl.Styles>
                <Style Selector="ContentControl">
                    <Setter Property="Content" Value="{Binding}"/>
                </Style>
            </ContentControl.Styles>
            
            <Grid>
                <!-- Category Header (shown when IsCategoryHeader is true) -->
                <Border IsVisible="{Binding IsCategoryHeader}"
                        CornerRadius="{StaticResource Radius.Lg}"
                        BorderThickness="0"
                        Padding="16,12"
                        Margin="4,12,4,2"
                        HorizontalAlignment="Stretch"
                        ClipToBounds="True">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding CategoryColor, FallbackValue=#444444}" Opacity="0.85"/>
                    </Border.Background>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Category color accent bar -->
                        <Border Grid.Column="0"
                                Width="5"
                                CornerRadius="2.5"
                                Margin="0,0,12,0"
                                VerticalAlignment="Stretch">
                            <Border.Background>
                                <SolidColorBrush Color="#000000" Opacity="0.25"/>
                            </Border.Background>
                        </Border>

                        <!-- Category name -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CategoryName}"
                                   FontSize="{StaticResource Type.H5.Size}"
                                   FontWeight="Bold"
                                   Foreground="#FF1A1A2E"
                                   VerticalAlignment="Center"/>
                        
                        <!-- Item count badge -->
                        <Border Grid.Column="2"
                                CornerRadius="10"
                                Padding="10,3"
                                VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="#000000" Opacity="0.15"/>
                            </Border.Background>
                            <TextBlock Text="{Binding CategoryItemCount, StringFormat='{}{0} items'}"
                                       FontSize="{StaticResource Type.Small.Size}"
                                       FontWeight="SemiBold"
                                       Foreground="#FF1A1A2E"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- Credential tile (shown when IsCategoryHeader is false) -->
                <ContentControl IsVisible="{Binding !IsCategoryHeader}"
                                Content="{Binding Credential}"
                                ContentTemplate="{StaticResource CredentialListTileTemplate}"/>
            </Grid>
        </ContentControl>
    </DataTemplate>
    
</ResourceDictionary>
