<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Giblex.Controls;assembly=PhantomVault.UI"
                    xmlns:vm="clr-namespace:PhantomVault.UI.ViewModels;assembly=PhantomVault.UI">
    
    <!-- Category Banner/Header Template for grouped list -->
    <DataTemplate x:Key="CategoryHeaderTemplate" DataType="vm:ListItemWrapper">
        <Border Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12"
                Margin="0,8,0,0"
                HorizontalAlignment="Stretch">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Category color indicator -->
                <Border Grid.Column="0" 
                        Width="6" 
                        Height="28"
                        CornerRadius="{StaticResource Radius.Xs}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <SolidColorBrush Color="{Binding CategoryColor, FallbackValue=#888888}"/>
                    </Border.Background>
                </Border>
                
                <!-- Category name -->
                <TextBlock Grid.Column="1"
                           Text="{Binding CategoryName}"
                           FontSize="{StaticResource Type.Body.Size}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           VerticalAlignment="Center"/>
                
                <!-- Item count -->
                <Border Grid.Column="2"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        CornerRadius="10"
                        Padding="8,2"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding CategoryItemCount}"
                               FontSize="{StaticResource Type.Small.Size}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </DataTemplate>
    
    <!-- List View Credential Tile Template -->
    <DataTemplate x:Key="CredentialListTileTemplate">
        <!-- Each Credential Card (List) -->
        <Button Command="{Binding $parent[Window].DataContext.TileClickCommand}"
                CommandParameter="{Binding}"
                Background="Transparent"
                BorderThickness="0"
                Padding="0"
                Margin="0"
                Classes="tile-button"
                HorizontalAlignment="Stretch"
                VerticalContentAlignment="Center"
                MinHeight="96"
                Height="96"
                AutomationProperties.Name="{Binding Title}">
            <Border BorderBrush="{DynamicResource CardSeparatorBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="0"
                    Padding="16,12"
                    HorizontalAlignment="Stretch"
                    MinHeight="96"
                    VerticalAlignment="Center"
                    ClipToBounds="True">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="#18FFFFFF" Offset="0"/>
                        <GradientStop Color="#08FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid Classes="tile-entrance">
                    <!-- Material sheen overlay below content -->
                    <Border Background="{DynamicResource TileOverlayBrush}" CornerRadius="0" IsHitTestVisible="False"/>
                    
                    <!-- Category color bar on the left edge -->
                    <Border Width="6" HorizontalAlignment="Left" VerticalAlignment="Stretch" CornerRadius="0" Margin="0" IsHitTestVisible="False" Opacity="{Binding HasGroup, Converter={StaticResource BoolToOpacityConverter}}">
                        <Border.Background>
                            <MultiBinding Converter="{StaticResource CategoryNameToBrushConverter}">
                                <Binding Path="Group"/>
                                <Binding Path="$parent[Window].DataContext.Categories"/>
                            </MultiBinding>
                        </Border.Background>
                    </Border>
                    
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Icon Column -->
                        <Grid Grid.Column="0" Margin="12,0,16,0" VerticalAlignment="Center">
                            <Border Background="{Binding IconBackgroundBrush}" Width="72" Height="72" CornerRadius="36" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid>
                                    <Image Source="{Binding AutoDetectedIconBitmap}" Width="64" Height="64" Stretch="Uniform" IsVisible="{Binding HasAutoDetectedIcon}"/>
                                    <StackPanel IsVisible="{Binding !HasAutoDetectedIcon}" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayIcon}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" IsVisible="{Binding HasCustomIcon}"/>
                                        <TextBlock Text="{Binding IconText}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Content Column -->
                        <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="4" VerticalAlignment="Center" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock FontSize="{StaticResource Type.H3.Size}" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" MaxLines="1">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource PrivacyMaskConverter}">
                                            <Binding Path="Title"/>
                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <!-- Non-interactive favorite indicator for list tiles -->
                                <TextBlock Text="{Binding FavoriteIcon}" FontSize="{StaticResource Type.Body.Size}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- TOTP Code Display (visible only for TOTP entries) -->
                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" IsVisible="{Binding IsTotpEntry}">
                                <Border Background="{DynamicResource ControlBackgroundBrush}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,6">
                                    <TextBlock Text="{Binding CurrentTotpCode}"
                                               FontSize="24"
                                               FontFamily="Consolas,monospace"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               LetterSpacing="2"/>
                                </Border>
                                <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TotpSecondsRemaining, StringFormat='{}{0}s remaining'}"
                                               FontSize="12"
                                               Foreground="{DynamicResource MutedTextBrush}"/>
                                    <ProgressBar Value="{Binding TotpProgressPercent}"
                                                 Maximum="100"
                                                 Width="80"
                                                 Height="4"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 Background="{DynamicResource ControlBackgroundBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Entry-type aware detail lines (hidden for TOTP) -->
                            <StackPanel Orientation="Vertical" Spacing="2" IsVisible="{Binding !IsTotpEntry}">
                                <TextBlock FontSize="15" Foreground="{DynamicResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" MaxLines="1">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="DetailLine1">
                                            <Binding Path="DetailLine1"/>
                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="{StaticResource Type.Body.Size}" Foreground="{DynamicResource MutedTextBrush}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" MaxLines="1" IsVisible="{Binding HasDetailLine2}">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource PrivacyMaskConverter}" ConverterParameter="DetailLine2">
                                            <Binding Path="DetailLine2"/>
                                            <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- Quick Action Buttons (visible on hover) -->
                        <StackPanel Grid.Column="2" 
                                    Orientation="Horizontal" 
                                    Spacing="6" 
                                    VerticalAlignment="Center"
                                    Margin="6,0,0,0"
                                    x:Name="QuickActionsPanel"
                                    Opacity="0">
                            <StackPanel.Styles>
                                <Style Selector="Button:pointerover StackPanel#QuickActionsPanel">
                                    <Setter Property="Opacity" Value="1"/>
                                </Style>
                                <Style Selector="Border:pointerover StackPanel#QuickActionsPanel">
                                    <Setter Property="Opacity" Value="1"/>
                                </Style>
                            </StackPanel.Styles>
                            <StackPanel.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                                </Transitions>
                            </StackPanel.Transitions>
                            
                            <!-- Copy Username -->
                            <Button Command="{Binding $parent[Window].DataContext.CopyUsernameCommand}"
                                    CommandParameter="{Binding}"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="{StaticResource Radius.Sm}"
                                    Padding="0"
                                    ToolTip.Tip="Copy username">
                                <TextBlock Text="👤"
                                           FontSize="{StaticResource Type.Body.Size}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                            
                            <!-- Copy Password -->
                            <controls:LiquidGlassButton Command="{Binding $parent[Window].DataContext.CopyPasswordCommand}"
                                    CommandParameter="{Binding}"
                                    WidthOverride="34"
                                    HeightOverride="34"
                                    CornerRadiusValue="8"
                                    PaddingOverride="0"
                                    ToolTipText="Copy password">
                                <controls:LiquidGlassButton.ButtonContent>
                                    <TextBlock Text="🔑"
                                               FontSize="{StaticResource Type.Body.Size}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </controls:LiquidGlassButton.ButtonContent>
                            </controls:LiquidGlassButton>
                            
                            <!-- Edit Button -->
                            <Button Command="{Binding $parent[Window].DataContext.EditCredentialCommand}"
                                    CommandParameter="{Binding}"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1"
                                    Width="32"
                                    Height="32"
                                    CornerRadius="{StaticResource Radius.Sm}"
                                    Padding="0"
                                    ToolTip.Tip="Edit">
                                <TextBlock Text="✏️"
                                           FontSize="{StaticResource Type.Small.Size}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Button>
    </DataTemplate>
    
    <!-- Grid View Credential Tile Template -->
    <DataTemplate x:Key="CredentialGridTileTemplate">
        <Grid Margin="6" HorizontalAlignment="Center" Width="{StaticResource GridTileWidth}" Classes="tile-entrance">
            <Button Command="{Binding $parent[Window].DataContext.TileClickCommand}"
                    CommandParameter="{Binding}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border Width="{StaticResource GridTileWidth}"
                        Height="{StaticResource GridTileHeight}"
                        Padding="0"
                        CornerRadius="{StaticResource Radius.Xl}"
                        Background="{DynamicResource TileGlassBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        ClipToBounds="True"
                        BoxShadow="0 4 12 0 #20000000"
                        Effect="{x:Null}">
                    <Grid>
                        <!-- Category color bar stretching across entire top -->
                        <Border Height="6"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"
                                CornerRadius="0"
                                Margin="0"
                                IsHitTestVisible="False"
                                Opacity="{Binding HasGroup, Converter={StaticResource BoolToOpacityConverter}}">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource CategoryNameToBrushConverter}">
                                    <Binding Path="Group"/>
                                    <Binding Path="$parent[Window].DataContext.Categories"/>
                                </MultiBinding>
                            </Border.Background>
                        </Border>
                        
                        <Border Background="{DynamicResource TileOverlayBrush}"
                                CornerRadius="{StaticResource Radius.Xl}"
                                IsHitTestVisible="False"
                                Margin="0,6,0,0"/>
                        
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="16"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Icon with better padding -->
                        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="10,12,8,0">
                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="20"
                                    Background="{Binding IconBackgroundBrush}">
                                <Grid>
                                    <Image Source="{Binding AutoDetectedIconBitmap}"
                                           Width="34"
                                           Height="34"
                                           Stretch="Uniform"
                                           IsVisible="{Binding HasAutoDetectedIcon}"/>
                                    <TextBlock Text="{Binding IconText}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding !HasAutoDetectedIcon}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                        
                        <!-- Content with proper margins to prevent cutoff -->
                        <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Spacing="2" Margin="0,12,10,0">
                            <TextBlock FontSize="13"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1">
                                <TextBlock.Effect>
                                    <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"
                                             Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                </TextBlock.Effect>
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource PrivacyMaskConverter}">
                                        <Binding Path="Title"/>
                                        <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1">
                                <TextBlock.Effect>
                                    <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"
                                             Converter="{StaticResource PrivacyBlurEffectConverter}"/>
                                </TextBlock.Effect>
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource PrivacyMaskConverter}"
                                                  ConverterParameter="DetailLine1">
                                        <Binding Path="DetailLine1"/>
                                        <Binding Path="$parent[Window].DataContext.PrivacyModeEnabled"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        
                        <Rectangle Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   Height="2"
                                   Opacity="0.0"
                                   Fill="Transparent"/>
                        <Rectangle Grid.Row="1"
                                   Grid.ColumnSpan="2"
                                   Height="1"
                                   Fill="{DynamicResource ControlBorderBrush}"
                                   Opacity="0.0"
                                   VerticalAlignment="Bottom"/>
                    </Grid>
                </Border>
            </Button>

            <!-- Action Buttons Overlay (Hidden by default, shown on hover) -->
            <Border Width="48"
                    Height="{StaticResource GridTileHeight}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="-36,0,0,0"
                    Background="Transparent"
                    IsHitTestVisible="False">
                <Canvas IsHitTestVisible="True">
                    <Border Canvas.Top="-18"
                            Canvas.Right="0"
                            CornerRadius="{StaticResource Radius.Lg}"
                            Padding="0"
                            Width="48"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Effect="{x:Null}"
                            Opacity="0">
                        <Grid Width="48" Margin="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <controls:LiquidGlassButton Grid.Row="0"
                                    Command="{Binding $parent[Window].DataContext.CopyPasswordCommand}"
                                    CommandParameter="{Binding}"
                                    WidthOverride="22"
                                    HeightOverride="22"
                                    CornerRadiusValue="6"
                                    PaddingOverride="0"
                                    HorizontalAlignment="Center"
                                    Margin="0,2,0,0">
                                <controls:LiquidGlassButton.ButtonContent>
                                    <TextBlock Text="⧉" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </controls:LiquidGlassButton.ButtonContent>
                            </controls:LiquidGlassButton>
                            
                            <controls:LiquidGlassButton Grid.Row="1"
                                    Command="{Binding $parent[Window].DataContext.EditCredentialCommand}"
                                    CommandParameter="{Binding}"
                                    WidthOverride="22"
                                    HeightOverride="22"
                                    CornerRadiusValue="6"
                                    PaddingOverride="0"
                                    HorizontalAlignment="Center"
                                    Margin="0,6,0,0">
                                <controls:LiquidGlassButton.ButtonContent>
                                    <TextBlock Text="✎" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </controls:LiquidGlassButton.ButtonContent>
                            </controls:LiquidGlassButton>
                            
                            <controls:LiquidGlassButton Grid.Row="2"
                                    Command="{Binding $parent[Window].DataContext.DeleteCredentialCommand}"
                                    CommandParameter="{Binding}"
                                    WidthOverride="22"
                                    HeightOverride="22"
                                    CornerRadiusValue="6"
                                    PaddingOverride="0"
                                    HorizontalAlignment="Center"
                                    Margin="0,6,0,0">
                                <controls:LiquidGlassButton.ButtonContent>
                                    <TextBlock Text="🗑" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </controls:LiquidGlassButton.ButtonContent>
                            </controls:LiquidGlassButton>
                            
                            <controls:LiquidGlassButton Grid.Row="3"
                                    Command="{Binding $parent[Window].DataContext.ToggleFavoriteCommand}"
                                    CommandParameter="{Binding}"
                                    WidthOverride="22"
                                    HeightOverride="22"
                                    CornerRadiusValue="6"
                                    PaddingOverride="0"
                                    HorizontalAlignment="Center"
                                    Margin="0,6,0,0">
                                <controls:LiquidGlassButton.ButtonContent>
                                    <TextBlock Text="{Binding FavoriteIcon}" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </controls:LiquidGlassButton.ButtonContent>
                            </controls:LiquidGlassButton>
                        </Grid>
                    </Border>
                </Canvas>
            </Border>
        </Grid>
    </DataTemplate>

    <!-- Template for ListItemWrapper - shows either category header or credential -->
    <DataTemplate x:Key="GroupedListItemTemplate" DataType="vm:ListItemWrapper">
        <ContentControl>
            <ContentControl.Styles>
                <Style Selector="ContentControl">
                    <Setter Property="Content" Value="{Binding}"/>
                </Style>
            </ContentControl.Styles>
            
            <Grid>
                <!-- Category Header (shown when IsCategoryHeader is true) -->
                <Border IsVisible="{Binding IsCategoryHeader}"
                        Background="{DynamicResource WindowBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="16,12"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Stretch">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Category color indicator -->
                        <Border Grid.Column="0" 
                                Width="6" 
                                Height="28"
                                CornerRadius="{StaticResource Radius.Xs}"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding CategoryColor, FallbackValue=#888888}"/>
                            </Border.Background>
                        </Border>
                        
                        <!-- Category name -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CategoryName}"
                                   FontSize="{StaticResource Type.Body.Size}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center"/>
                        
                        <!-- Item count -->
                        <Border Grid.Column="2"
                                Background="{DynamicResource ControlBackgroundBrush}"
                                CornerRadius="10"
                                Padding="8,2"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding CategoryItemCount}"
                                       FontSize="{StaticResource Type.Small.Size}"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
                
                <!-- Credential tile (shown when IsCategoryHeader is false) -->
                <ContentControl IsVisible="{Binding !IsCategoryHeader}"
                                Content="{Binding Credential}"
                                ContentTemplate="{StaticResource CredentialListTileTemplate}"/>
            </Grid>
        </ContentControl>
    </DataTemplate>
    
</ResourceDictionary>
