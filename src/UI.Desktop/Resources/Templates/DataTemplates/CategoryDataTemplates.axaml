<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Category Item Template (Sidebar) -->
    <DataTemplate x:Key="CategoryItemTemplate">
        <!-- Sidebar refinement: list items are borderless; only the parent
             CATEGORIES drop-menu toggle keeps a border. Corners + left text
             inset match the ENTRY TYPES list items for full consistency. -->
        <ToggleButton Command="{Binding $parent[Window].DataContext.SelectCategoryCommand}"
                      CommandParameter="{Binding Name}"
                      Classes="sidebar-filter-item-toggle category-filter"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Left"
                      Height="36"
                      CornerRadius="14"
                      BorderBrush="Transparent"
                      BorderThickness="0"
                      IsChecked="{Binding IsActive, Mode=TwoWay}"
                      Tag="{Binding TileColor}"
                      AutomationProperties.Name="{Binding Name, StringFormat='Category: {0} ({1} items)'}"
                      Margin="6,2">
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="6,0,0,0">
                <!-- Category color bar (slightly inset) -->
                <Border Width="8" Height="22" CornerRadius="4" VerticalAlignment="Center">
                    <Border.Background>
                        <Binding Path="TileColor" Converter="{StaticResource HexToBrushConverter}"/>
                    </Border.Background>
                </Border>
                <TextBlock Text="{Binding Name}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="{Binding Count}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0"/>
            </StackPanel>
        </ToggleButton>
    </DataTemplate>
    
</ResourceDictionary>
