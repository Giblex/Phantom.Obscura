<?xml version="1.0" encoding="utf-8"?>
<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PhantomVault.UI.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <!-- Localization Resources (English by default) -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PhantomVault.UI/Resources/Strings.en-US.axaml"/>
                <ResourceInclude Source="avares://Phantom.UI.Shared/Icons/VectorIcons.axaml"/>
                <!-- To enable Spanish, uncomment: -->
                <!-- <ResourceInclude Source="avares://PhantomVault.UI/Resources/Strings.es-ES.axaml"/> -->
            </ResourceDictionary.MergedDictionaries>
            <!-- Monospace font (theme-independent, must be StaticResource-resolvable) -->
            <FontFamily x:Key="MonoFontFamily">Consolas</FontFamily>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
    <!-- Fluent theme base -->
    <FluentTheme />

        <!-- PhantomTheme is loaded dynamically by ThemeManagerService -->
        
        <!-- Liquid Glass Button Style -->
        <StyleInclude Source="avares://PhantomVault.UI/Assets/Styles/LiquidGlass.axaml" />

        <!-- Modern Animation Library -->
        <StyleInclude Source="avares://PhantomVault.UI/Assets/Animations/ModernAnimations.axaml" />

        <!-- Enhanced Animations (MFA cards, credential list, copy feedback, password strength) -->
        <!-- Safe to enable: broken RotateTransform/ScaleTransform animators were removed; -->
        <!-- remaining styles use TransformOperationsTransition (string form) + Style.Animations -->
        <!-- which both work correctly on Avalonia 11.3.11. -->
        <StyleInclude Source="avares://PhantomVault.UI/Styles/Animations.axaml" />

        <!-- Global UI Styles (buttons, cards, typography) -->
        <StyleInclude Source="avares://PhantomVault.UI/Assets/Styles/GlobalStyles.axaml" />

        <!--
            Note: a previous version added <Style Selector="Control:focus"> that
            faded Opacity to 0.18 on focused controls, which actively dimmed
            inputs while the user was typing. It was removed. Focus indication
            is now provided per-control by FluentTheme + LiquidGlass styles,
            which is where BorderBrush/Background live (Control itself does not
            expose those properties, so a global Control:focus style cannot
            animate them either).
        -->

        <!-- Smooth scrolling for all ScrollViewers -->
        <Style Selector="ScrollViewer">
            <Setter Property="AllowAutoHide" Value="True"/>
        </Style>

        <!-- Shared window entrance animation (opt-in via 'animated-window' class) -->
        <Style Selector="Window.animated-window">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="Window.animated-window[IsVisible=True]:not(.reduce-motion)">
            <Style.Animations>
                <Animation Duration="0:0:0.35" FillMode="Forward" Easing="0.16,1,0.3,1">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <!-- Reduce-motion: snap to fully-opaque without animation. -->
        <Style Selector="Window.animated-window.reduce-motion[IsVisible=True]">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <!-- Shared overlay fade (apply class 'overlay-fade' to Border overlays) -->
        <Style Selector="Border.overlay-fade">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="Window:not(.reduce-motion) Border.overlay-fade[IsVisible=True]">
            <Style.Animations>
                <Animation Duration="0:0:0.20" FillMode="Forward" Easing="SineEaseOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <!-- Reduce-motion: snap visible without animating. -->
        <Style Selector="Window.reduce-motion Border.overlay-fade[IsVisible=True]">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <!-- Quick fade utility (apply 'fade-toggle' class on lightweight controls) -->
        <Style Selector="Control.fade-toggle">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="Window:not(.reduce-motion) Control.fade-toggle[IsVisible=True]">
            <Style.Animations>
                <Animation Duration="0:0:0.16" FillMode="Forward" Easing="SineEaseOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Window.reduce-motion Control.fade-toggle[IsVisible=True]">
            <Setter Property="Opacity" Value="1"/>
        </Style>

    </Application.Styles>

    <Application.Resources>
        <!-- Shared aqua acrylic material for liquid glass accents -->
    <ExperimentalAcrylicMaterial x:Key="LiquidAcrylic"
                     TintColor="#9FD8FF"
                                     TintOpacity="0.18"
                                     MaterialOpacity="0.38"
                                     FallbackColor="#66FFFFFF"/>
    </Application.Resources>
</Application>
