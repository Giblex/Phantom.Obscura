<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PhantomVault.UI.Desktop.Controls"
             x:Class="PhantomVault.UI.Desktop.Controls.ToastNotification"
             Width="380"
             MaxHeight="120">

    <UserControl.Styles>
        <Style Selector="Border.toast">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BoxShadow" Value="0 8 24 0 #40000000"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform" Value="translateY(-20px)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.toast.show">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="RenderTransform" Value="translateY(0)"/>
        </Style>

        <Style Selector="Border.toast.success">
            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
        </Style>

        <Style Selector="Border.toast.error">
            <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
        </Style>

        <Style Selector="Border.toast.warning">
            <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
        </Style>

        <Style Selector="Border.toast.info">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>
    </UserControl.Styles>

    <Border x:Name="ToastBorder" Classes="toast">
        <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">

            <!-- Icon -->
            <controls:SvgIcon x:Name="ToastIcon"
                              Grid.Column="0"
                              Grid.RowSpan="2"
                              Width="24"
                              Height="24"
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              IconColor="{DynamicResource AccentBrush}"/>

            <!-- Title -->
            <TextBlock x:Name="TitleText"
                       Grid.Column="1"
                       Grid.Row="0"
                       FontWeight="SemiBold"
                       FontSize="14"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       TextWrapping="NoWrap"
                       TextTrimming="CharacterEllipsis"/>

            <!-- Message -->
            <TextBlock x:Name="MessageText"
                       Grid.Column="1"
                       Grid.Row="1"
                       FontSize="13"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       TextWrapping="Wrap"
                       MaxLines="2"
                       TextTrimming="CharacterEllipsis"
                       Margin="0,4,0,0"/>

            <!-- Close Button -->
            <Button x:Name="CloseButton"
                    Grid.Column="2"
                    Grid.RowSpan="2"
                    Width="24"
                    Height="24"
                    Padding="0"
                    Margin="12,0,0,0"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    BorderThickness="0"
                    Classes="icon-button">
                <controls:SvgIcon Preset="X"
                                  Width="16"
                                  Height="16"
                                  IconColor="{DynamicResource MutedTextBrush}"/>
            </Button>

        </Grid>
    </Border>

</UserControl>
