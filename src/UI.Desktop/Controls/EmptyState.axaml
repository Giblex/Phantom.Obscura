<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PhantomVault.UI.Desktop.Controls"
             x:Class="PhantomVault.UI.Desktop.Controls.EmptyState">

    <UserControl.Styles>
        <Style Selector="Border.empty-state">
            <Setter Property="Padding" Value="48"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.empty-title">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,16,0,8"/>
        </Style>

        <Style Selector="TextBlock.empty-description">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="MaxWidth" Value="400"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="22"/>
        </Style>

        <Style Selector="Button.empty-action">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,24,0,0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Styles>

    <Border Classes="empty-state">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="0">

            <!-- Illustration (SVG or simple shapes) -->
            <Panel Width="200" Height="200" Margin="0,0,0,8">
                <!-- Vault illustration -->
                <Canvas x:Name="IllustrationCanvas">
                    <!-- Background circle -->
                    <Ellipse Width="180" Height="180"
                             Canvas.Left="10" Canvas.Top="10"
                             Fill="#15FFFFFF"
                             Opacity="0.4"/>

                    <!-- Vault icon - simplified representation -->
                    <Path Fill="{DynamicResource AccentBrush}"
                          Opacity="0.7"
                          Canvas.Left="60" Canvas.Top="50"
                          Data="M40,0 L40,10 L0,10 L0,80 L80,80 L80,10 L40,10 L40,0 Z M40,30 A15,15 0 1,1 40,60 A15,15 0 1,1 40,30 Z M40,38 L40,52 M32,45 L48,45"/>

                    <!-- Lock icon overlay -->
                    <Path Fill="{DynamicResource AccentBrush}"
                          Opacity="0.5"
                          Canvas.Left="100" Canvas.Top="120"
                          Data="M24,17 L24,11 A11,11 0 0,0 2,11 L2,17 M0,17 L26,17 L26,40 L0,40 Z"/>

                    <!-- Sparkles for empty state charm -->
                    <Ellipse Width="6" Height="6"
                             Canvas.Left="30" Canvas.Top="30"
                             Fill="{DynamicResource SuccessBrush}"
                             Opacity="0.6">
                        <Ellipse.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Styles>
                            <Style Selector="Ellipse">
                                <Style.Animations>
                                    <Animation Duration="0:0:2" IterationCount="Infinite">
                                        <KeyFrame Cue="0%">
                                            <Setter Property="Opacity" Value="0.3"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="50%">
                                            <Setter Property="Opacity" Value="0.8"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="100%">
                                            <Setter Property="Opacity" Value="0.3"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </Ellipse.Styles>
                    </Ellipse>

                    <Ellipse Width="6" Height="6"
                             Canvas.Left="150" Canvas.Top="50"
                             Fill="{DynamicResource AccentBrush}"
                             Opacity="0.5">
                        <Ellipse.Styles>
                            <Style Selector="Ellipse">
                                <Style.Animations>
                                    <Animation Duration="0:0:2.5" IterationCount="Infinite" Delay="0:0:0.5">
                                        <KeyFrame Cue="0%">
                                            <Setter Property="Opacity" Value="0.2"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="50%">
                                            <Setter Property="Opacity" Value="0.7"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="100%">
                                            <Setter Property="Opacity" Value="0.2"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </Ellipse.Styles>
                    </Ellipse>

                </Canvas>
            </Panel>

            <!-- Title -->
            <TextBlock x:Name="TitleText"
                       Classes="empty-title"
                       Text="No credentials yet"/>

            <!-- Description -->
            <TextBlock x:Name="DescriptionText"
                       Classes="empty-description"
                       Text="Get started by adding your first credential. Click the button below to create one."/>

            <!-- Action Button -->
            <Button x:Name="ActionButton"
                    Classes="empty-action"
                    Content="Add Your First Credential"
                    IsVisible="True"/>

        </StackPanel>
    </Border>

</UserControl>
