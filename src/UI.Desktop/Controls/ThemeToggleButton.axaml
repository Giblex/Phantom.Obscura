<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PhantomVault.UI.Desktop.Controls"
             x:Class="PhantomVault.UI.Desktop.Controls.ThemeToggleButton">

    <UserControl.Styles>
        <!-- Theme toggle button style -->
        <Style Selector="ToggleButton.theme-toggle">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="ToggleButton.theme-toggle:checked">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <!-- Thumb (sliding circle) -->
        <Style Selector="Border.toggle-thumb">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="BoxShadow" Value="0 2 4 0 #40000000"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="ToggleButton.theme-toggle:checked Border.toggle-thumb">
            <Setter Property="RenderTransform" Value="translateX(24px)"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Orientation="Horizontal" Spacing="12">
        <ToggleButton x:Name="ThemeToggle"
                      Classes="theme-toggle"
                      IsChecked="{Binding IsDarkMode, Mode=TwoWay}"
                      ToolTip.Tip="Toggle light/dark theme">
            <Panel>
                <!-- Thumb -->
                <Border Classes="toggle-thumb">
                    <controls:SvgIcon x:Name="ThemeIcon"
                                      IconName="Assets/SVG/Current/Visible eye.svg"
                                      Width="12" Height="12"
                                      IconColor="{DynamicResource AccentBrush}"/>
                </Border>
            </Panel>
        </ToggleButton>

        <TextBlock Text="{Binding ThemeLabel}"
                   FontSize="{StaticResource Type.Label.Size}"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   VerticalAlignment="Center"
                   IsVisible="False"/>
    </StackPanel>

</UserControl>
