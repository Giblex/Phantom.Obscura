<?xml version="1.0" encoding="utf-8"?>
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:PhantomVault.UI.Desktop.Controls"
             x:Class="PhantomVault.UI.Desktop.Controls.SecurityDashboard">

    <UserControl.Styles>
        <!-- Stat card -->
        <Style Selector="Border.stat-card">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="TextBlock.stat-number">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <Style Selector="TextBlock.stat-label">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
    </UserControl.Styles>

    <StackPanel Spacing="18" Margin="0">
        <!-- Main Security Score Card with Open Button -->
        <Border CornerRadius="14" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" Padding="20,16">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="Security Score" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="{Binding SecurityScore}" FontSize="44" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1" VerticalAlignment="Center" Classes="liquid-glass" Padding="14,32"
                            Command="{Binding OpenSecurityDashboardWindowCommand}"
                            ToolTip.Tip="Open full security dashboard">
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="📊" FontSize="24" TextAlignment="Center"/>
                            <TextBlock Text="Full" FontSize="12" TextAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="Report" FontSize="12" TextAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <ProgressBar Value="{Binding SecurityScore}" Maximum="100" Height="8" CornerRadius="4" Background="{DynamicResource DividerBrush}" Foreground="{DynamicResource AccentBrush}"/>
                
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="✓" Foreground="{DynamicResource SuccessBrush}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TwoFactorEnabledCount}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="2FA" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="⚠" Foreground="{DynamicResource WarningBrush}"/>
                        <TextBlock Text="{Binding WeakCredentials.Count}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="weak" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="✕" Foreground="{DynamicResource ErrorBrush}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding BreachedPasswordCount}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="breached" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Quick Stats Grid -->
        <UniformGrid Columns="2">
            <Border Classes="stat-card" Margin="0,0,5,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding TotalCount}" Classes="stat-number"/>
                    <TextBlock Text="Total" Classes="stat-label"/>
                </StackPanel>
            </Border>

            <Border Classes="stat-card" Margin="5,0,0,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding ExpiringCredentialCount}" Classes="stat-number" Foreground="{DynamicResource WarningBrush}"/>
                    <TextBlock Text="Expiring Soon" Classes="stat-label"/>
                </StackPanel>
            </Border>

            <Border Classes="stat-card" Margin="0,5,5,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding ReusedPasswordCount}" Classes="stat-number" Foreground="{DynamicResource WarningBrush}"/>
                    <TextBlock Text="Reused" Classes="stat-label"/>
                </StackPanel>
            </Border>

            <Border Classes="stat-card" Margin="5,5,0,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding BreachedPasswordCount}" Classes="stat-number" Foreground="{DynamicResource ErrorBrush}"/>
                    <TextBlock Text="Breached" Classes="stat-label"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Footer Info -->
        <StackPanel Spacing="6" Margin="0,8,0,4">
            <TextBlock Text="{Binding LastBreachCheckTime}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" TextAlignment="Center"/>
            <TextBlock Text="Click 'Full Report' for comprehensive analysis" FontSize="10" Foreground="{DynamicResource MutedTextBrush}" TextAlignment="Center" FontStyle="Italic"/>
        </StackPanel>
    </StackPanel>
</UserControl>
