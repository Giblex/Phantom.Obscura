<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="120"
             x:Class="PhantomVault.UI.Controls.PasswordCaptureToast">

    <UserControl.Styles>
        <Style Selector="Button.toast-action">
            <Setter Property="Background" Value="#5865F2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        
        <Style Selector="Button.toast-action:pointerover">
            <Setter Property="Background" Value="#4752C4"/>
        </Style>
        
        <Style Selector="Button.toast-cancel">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        
        <Style Selector="Button.toast-cancel:pointerover">
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource AutofillSuccessBackgroundBrush}" 
            BorderBrush="{DynamicResource SuccessBrush}" 
            BorderThickness="2"
            CornerRadius="{StaticResource Radius.Lg}"
            Padding="16"
            BoxShadow="0 4 12 #40000000">
        <Grid RowDefinitions="Auto,Auto">
            <!-- Message -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
                <Border Grid.Column="0" 
                       Width="32" Height="32"
                       Background="{DynamicResource SuccessBrush}"
                       CornerRadius="{StaticResource Radius.Xxl}"
                       Margin="0,0,12,0">
                    <TextBlock Text="⌘" 
                              FontSize="{StaticResource Type.H3.Size}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                </Border>
                
                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock Name="TitleText"
                              Text="New Password Detected" 
                              FontWeight="Bold" 
                              FontSize="{StaticResource Type.Body.Size}"
                              Foreground="{DynamicResource AutofillTextBrush}"/>
                    <TextBlock Name="MessageText"
                              FontSize="{StaticResource Type.Small.Size}"
                              Foreground="{DynamicResource AutofillTextBrush}"
                              TextWrapping="Wrap"/>
                </StackPanel>
                
                <Button Grid.Column="2" 
                       Name="CloseButton"
                       Content="✕" 
                       Background="Transparent"
                       Foreground="{DynamicResource AutofillTextBrush}"
                       BorderThickness="0"
                       Padding="4"
                       FontSize="{StaticResource Type.H4.Size}"
                       Cursor="Hand"
                       VerticalAlignment="Top"/>
            </Grid>

            <!-- Action buttons -->
            <StackPanel Grid.Row="1" 
                       Orientation="Horizontal" 
                       HorizontalAlignment="Right" 
                       Spacing="8">
                <Button Name="IgnoreButton"
                       Content="Ignore" 
                       Classes="toast-cancel"/>
                
                <Button Name="ActionButton"
                       Classes="toast-action"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
