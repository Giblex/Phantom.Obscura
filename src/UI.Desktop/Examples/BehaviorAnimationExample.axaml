<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
             xmlns:behaviors="clr-namespace:PhantomVault.UI.Behaviors"
             x:Class="PhantomVault.UI.Examples.BehaviorAnimationExample">

    <!--
    This is an example file demonstrating behavior-based animations.
    Copy these examples to your actual views and customize as needed.
    -->

    <ScrollViewer>
        <StackPanel Spacing="32" Margin="40">

            <!-- ═══════════════════════════════════════════════════════ -->
            <!--                   ENTRANCE ANIMATIONS                    -->
            <!-- ═══════════════════════════════════════════════════════ -->

            <TextBlock Text="Entrance Animations" FontSize="24" FontWeight="Bold" />

            <!-- Example 1: Fade In -->
            <Border Background="#2C2C2C" CornerRadius="8" Padding="20">
                <i:Interaction.Behaviors>
                    <behaviors:FadeInBehavior Duration="0.3" />
                </i:Interaction.Behaviors>
                <TextBlock Text="I fade in smoothly" FontSize="16" />
            </Border>

            <!-- Example 2: Slide In from Bottom -->
            <Border Background="#2C2C2C" CornerRadius="8" Padding="20">
                <i:Interaction.Behaviors>
                    <behaviors:SlideInBehavior Direction="Bottom" Distance="30" />
                </i:Interaction.Behaviors>
                <TextBlock Text="I slide up from bottom" FontSize="16" />
            </Border>

            <!-- Example 3: Scale In (Gentle) -->
            <Border Background="#2C2C2C" CornerRadius="8" Padding="20">
                <i:Interaction.Behaviors>
                    <behaviors:ScaleInBehavior FromScale="0.95" />
                </i:Interaction.Behaviors>
                <TextBlock Text="I scale up gently" FontSize="16" />
            </Border>

            <!-- Example 4: Pop In (Bouncy) -->
            <Border Background="#2C2C2C" CornerRadius="8" Padding="20">
                <i:Interaction.Behaviors>
                    <behaviors:ScaleInBehavior FromScale="0.8" UseBounce="True" />
                </i:Interaction.Behaviors>
                <TextBlock Text="I pop in with bounce!" FontSize="16" />
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!--                   STAGGERED ANIMATIONS                   -->
            <!-- ═══════════════════════════════════════════════════════ -->

            <TextBlock Text="Staggered List Animation" FontSize="24" FontWeight="Bold" Margin="0,40,0,0" />

            <StackPanel Spacing="12">
                <Border Background="#2C2C2C" CornerRadius="6" Padding="16">
                    <i:Interaction.Behaviors>
                        <behaviors:SlideInBehavior Direction="Left" Delay="0.0" />
                    </i:Interaction.Behaviors>
                    <TextBlock Text="List Item 1" />
                </Border>

                <Border Background="#2C2C2C" CornerRadius="6" Padding="16">
                    <i:Interaction.Behaviors>
                        <behaviors:SlideInBehavior Direction="Left" Delay="0.05" />
                    </i:Interaction.Behaviors>
                    <TextBlock Text="List Item 2" />
                </Border>

                <Border Background="#2C2C2C" CornerRadius="6" Padding="16">
                    <i:Interaction.Behaviors>
                        <behaviors:SlideInBehavior Direction="Left" Delay="0.1" />
                    </i:Interaction.Behaviors>
                    <TextBlock Text="List Item 3" />
                </Border>

                <Border Background="#2C2C2C" CornerRadius="6" Padding="16">
                    <i:Interaction.Behaviors>
                        <behaviors:SlideInBehavior Direction="Left" Delay="0.15" />
                    </i:Interaction.Behaviors>
                    <TextBlock Text="List Item 4" />
                </Border>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!--                    HOVER ANIMATIONS                      -->
            <!-- ═══════════════════════════════════════════════════════ -->

            <TextBlock Text="Hover Effects" FontSize="24" FontWeight="Bold" Margin="0,40,0,0" />

            <!-- Example 5: Hover Lift -->
            <Border Background="#2C2C2C" CornerRadius="8" Padding="20">
                <i:Interaction.Behaviors>
                    <behaviors:FadeInBehavior />
                    <behaviors:HoverLiftBehavior LiftDistance="-4" />
                </i:Interaction.Behaviors>
                <TextBlock Text="Hover me - I lift upward!" FontSize="16" />
            </Border>

            <!-- Example 6: Hover Scale -->
            <Border Background="#2C2C2C" CornerRadius="8" Padding="20">
                <i:Interaction.Behaviors>
                    <behaviors:FadeInBehavior />
                    <behaviors:HoverScaleBehavior HoverScale="1.05" />
                </i:Interaction.Behaviors>
                <TextBlock Text="Hover me - I scale up!" FontSize="16" />
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!--                  COMBINED ANIMATIONS                     -->
            <!-- ═══════════════════════════════════════════════════════ -->

            <TextBlock Text="Combined Animations" FontSize="24" FontWeight="Bold" Margin="0,40,0,0" />

            <!-- Example 7: Feature Card (Slide + Hover Lift) -->
            <Border Background="#2C2C2C" CornerRadius="12" Padding="24">
                <i:Interaction.Behaviors>
                    <behaviors:SlideInBehavior Direction="Bottom" Distance="30" />
                    <behaviors:HoverLiftBehavior LiftDistance="-6" />
                </i:Interaction.Behaviors>

                <StackPanel Spacing="12">
                    <TextBlock Text="Feature Card" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="Slides in from bottom, then lifts on hover" Opacity="0.7" />
                    <Button Content="Learn More" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- Example 8: Modal Dialog Simulation -->
            <Border Background="#CC000000" CornerRadius="8" Padding="40">
                <i:Interaction.Behaviors>
                    <behaviors:FadeInBehavior Duration="0.2" />
                </i:Interaction.Behaviors>

                <Border Background="#1E1E1E" CornerRadius="12" Padding="32" MaxWidth="400">
                    <i:Interaction.Behaviors>
                        <behaviors:ScaleInBehavior FromScale="0.9" Delay="0.1" />
                    </i:Interaction.Behaviors>

                    <StackPanel Spacing="20">
                        <TextBlock Text="Confirm Action" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="This dialog fades in backdrop + scales content" TextWrapping="Wrap" Opacity="0.8" />
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                            <Button Content="Cancel" />
                            <Button Content="Confirm" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Example 9: Success Notification -->
            <Border Background="#10B981" CornerRadius="8" Padding="16" MaxWidth="300">
                <i:Interaction.Behaviors>
                    <behaviors:ScaleInBehavior FromScale="0.8" UseBounce="True" />
                    <behaviors:SlideInBehavior Direction="Bottom" Distance="40" />
                </i:Interaction.Behaviors>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Path Data="M9,16.2L4.8,12l-1.4,1.4L9,19L21,7l-1.4-1.4L9,16.2z"
                          Fill="White"
                          Width="24"
                          Height="24"
                          Stretch="Uniform" />
                    <TextBlock Text="Saved successfully!"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="White" />
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!--                  CARD GRID EXAMPLE                       -->
            <!-- ═══════════════════════════════════════════════════════ -->

            <TextBlock Text="Card Grid with Stagger + Hover" FontSize="24" FontWeight="Bold" Margin="0,40,0,0" />

            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" Margin="0,0,0,40">
                <!-- Card 1 -->
                <Border Grid.Row="0" Grid.Column="0"
                        Background="#2C2C2C"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,12,12">
                    <i:Interaction.Behaviors>
                        <behaviors:ScaleInBehavior Delay="0.0" />
                        <behaviors:HoverLiftBehavior LiftDistance="-4" />
                    </i:Interaction.Behaviors>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Card 1" FontWeight="SemiBold" />
                        <TextBlock Text="Stagger delay: 0s" Opacity="0.7" FontSize="12" />
                    </StackPanel>
                </Border>

                <!-- Card 2 -->
                <Border Grid.Row="0" Grid.Column="1"
                        Background="#2C2C2C"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,12,12">
                    <i:Interaction.Behaviors>
                        <behaviors:ScaleInBehavior Delay="0.05" />
                        <behaviors:HoverLiftBehavior LiftDistance="-4" />
                    </i:Interaction.Behaviors>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Card 2" FontWeight="SemiBold" />
                        <TextBlock Text="Stagger delay: 0.05s" Opacity="0.7" FontSize="12" />
                    </StackPanel>
                </Border>

                <!-- Card 3 -->
                <Border Grid.Row="0" Grid.Column="2"
                        Background="#2C2C2C"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,0,12">
                    <i:Interaction.Behaviors>
                        <behaviors:ScaleInBehavior Delay="0.1" />
                        <behaviors:HoverLiftBehavior LiftDistance="-4" />
                    </i:Interaction.Behaviors>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Card 3" FontWeight="SemiBold" />
                        <TextBlock Text="Stagger delay: 0.1s" Opacity="0.7" FontSize="12" />
                    </StackPanel>
                </Border>

                <!-- Card 4 -->
                <Border Grid.Row="1" Grid.Column="0"
                        Background="#2C2C2C"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,12,0">
                    <i:Interaction.Behaviors>
                        <behaviors:ScaleInBehavior Delay="0.15" />
                        <behaviors:HoverLiftBehavior LiftDistance="-4" />
                    </i:Interaction.Behaviors>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Card 4" FontWeight="SemiBold" />
                        <TextBlock Text="Stagger delay: 0.15s" Opacity="0.7" FontSize="12" />
                    </StackPanel>
                </Border>

                <!-- Card 5 -->
                <Border Grid.Row="1" Grid.Column="1"
                        Background="#2C2C2C"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,12,0">
                    <i:Interaction.Behaviors>
                        <behaviors:ScaleInBehavior Delay="0.2" />
                        <behaviors:HoverLiftBehavior LiftDistance="-4" />
                    </i:Interaction.Behaviors>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Card 5" FontWeight="SemiBold" />
                        <TextBlock Text="Stagger delay: 0.2s" Opacity="0.7" FontSize="12" />
                    </StackPanel>
                </Border>

                <!-- Card 6 -->
                <Border Grid.Row="1" Grid.Column="2"
                        Background="#2C2C2C"
                        CornerRadius="8"
                        Padding="20">
                    <i:Interaction.Behaviors>
                        <behaviors:ScaleInBehavior Delay="0.25" />
                        <behaviors:HoverLiftBehavior LiftDistance="-4" />
                    </i:Interaction.Behaviors>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Card 6" FontWeight="SemiBold" />
                        <TextBlock Text="Stagger delay: 0.25s" Opacity="0.7" FontSize="12" />
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>

</UserControl>
