<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:PhantomVault.Android"
             xmlns:conv="clr-namespace:PhantomVault.Android.Converters"
             x:Class="PhantomVault.Android.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters available app-wide as StaticResource -->
            <conv:EntryTypeIconConverter x:Key="EntryTypeIconConverter" />
            <conv:NotNullBoolConverter x:Key="NotNullBoolConverter" />
            <conv:NotNullOrEmptyBoolConverter x:Key="NotNullOrEmptyBoolConverter" />
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
            <conv:BoolToTextConverter x:Key="BoolToTextConverter" />
            <conv:BusyTextConverter x:Key="BusyTextConverter" />
            <conv:BoolToEyeIconConverter x:Key="BoolToEyeIconConverter" />
            <conv:PasswordMaskConverter x:Key="PasswordMaskConverter" />
            <conv:BoolToTitleConverter x:Key="BoolToTitleConverter" />
            <conv:BoolToSuccessColorConverter x:Key="BoolToSuccessColorConverter" />
            <conv:StringToBoolConverter x:Key="StringToBoolConverter" />
            <conv:BoolToColorConverter x:Key="BoolToColorConverter" />
            <conv:TypeFilterChipBgConverter x:Key="TypeFilterChipBgConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
