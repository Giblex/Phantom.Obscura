<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PhantomVault.Android.Pages.PasswordGeneratorPage"
             Title="Password Generator"
             BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- Generated password display -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="14" Padding="18" BorderColor="{StaticResource Primary}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding GeneratedPassword}"
                           FontFamily="OpenSansSemibold"
                           FontSize="18"
                           TextColor="{StaticResource Primary}"
                           LineBreakMode="CharacterWrap"
                           HorizontalTextAlignment="Center" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Button Grid.Column="0"
                                Text="🔁 Regenerate"
                                Command="{Binding GenerateCommand}"
                                BackgroundColor="{StaticResource ButtonSecondary}"
                                TextColor="{StaticResource PrimaryText}"
                                FontSize="14" HeightRequest="44" CornerRadius="10" />
                        <Button Grid.Column="1"
                                Text="{Binding PasswordCopied, Converter={StaticResource BoolToTitleConverter}, ConverterParameter='✓ Copied!|Copy'}"
                                Command="{Binding CopyCommand}"
                                BackgroundColor="{Binding PasswordCopied, Converter={StaticResource BoolToSuccessColorConverter}}"
                                TextColor="{StaticResource PrimaryText}"
                                FontSize="14" HeightRequest="44" CornerRadius="10" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Length -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16" BorderColor="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Length" FontSize="14" TextColor="{StaticResource PrimaryText}" VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding Length}"
                               FontFamily="OpenSansSemibold"
                               FontSize="16"
                               TextColor="{StaticResource Primary}"
                               VerticalOptions="Center" />
                    </Grid>
                    <Slider Minimum="8" Maximum="64"
                            Value="{Binding Length}"
                            ThumbColor="{StaticResource Primary}"
                            MinimumTrackColor="{StaticResource Primary}"
                            MaximumTrackColor="{StaticResource InputBorder}" />
                </VerticalStackLayout>
            </Frame>

            <!-- Character classes -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16" BorderColor="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Character Classes" FontSize="14" TextColor="{StaticResource SecondaryText}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Uppercase (A-Z)" FontSize="15" TextColor="{StaticResource PrimaryText}" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding UseUppercase}" OnColor="{StaticResource Primary}" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Divider}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Lowercase (a-z)" FontSize="15" TextColor="{StaticResource PrimaryText}" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding UseLowercase}" OnColor="{StaticResource Primary}" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Divider}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Digits (0-9)" FontSize="15" TextColor="{StaticResource PrimaryText}" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding UseDigits}" OnColor="{StaticResource Primary}" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource Divider}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Symbols (!@#…)" FontSize="15" TextColor="{StaticResource PrimaryText}" VerticalOptions="Center" />
                        <Switch Grid.Column="1" IsToggled="{Binding UseSymbols}" OnColor="{StaticResource Primary}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
