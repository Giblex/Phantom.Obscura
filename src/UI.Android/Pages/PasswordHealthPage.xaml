<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PhantomVault.Android.Pages.PasswordHealthPage"
             Title="Password Health"
             BackgroundColor="{StaticResource Background}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Analyse" Command="{Binding AnalyseCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- Status message -->
            <Label Text="{Binding StatusMessage}"
                   FontSize="14" TextColor="{StaticResource SecondaryText}"
                   HorizontalOptions="Center"
                   IsVisible="{Binding StatusMessage, Converter={StaticResource NotNullOrEmptyBoolConverter}}" />

            <!-- Summary card -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="14" Padding="18"
                   BorderColor="{StaticResource CardBorder}"
                   IsVisible="{Binding HasResults}">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,*" RowSpacing="4" ColumnSpacing="8">

                    <Label Grid.Row="0" Grid.Column="0" Text="{Binding Report.WeakCount}" FontFamily="OpenSansSemibold"
                           FontSize="28" TextColor="{StaticResource Danger}" HorizontalOptions="Center" />
                    <Label Grid.Row="1" Grid.Column="0" Text="Weak" FontSize="12"
                           TextColor="{StaticResource SecondaryText}" HorizontalOptions="Center" />

                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding Report.ReusedCount}" FontFamily="OpenSansSemibold"
                           FontSize="28" TextColor="{StaticResource Warning}" HorizontalOptions="Center" />
                    <Label Grid.Row="1" Grid.Column="1" Text="Reused" FontSize="12"
                           TextColor="{StaticResource SecondaryText}" HorizontalOptions="Center" />

                    <Label Grid.Row="0" Grid.Column="2" Text="{Binding Report.OldCount}" FontFamily="OpenSansSemibold"
                           FontSize="28" TextColor="{StaticResource Info}" HorizontalOptions="Center" />
                    <Label Grid.Row="1" Grid.Column="2" Text="Old" FontSize="12"
                           TextColor="{StaticResource SecondaryText}" HorizontalOptions="Center" />

                </Grid>
            </Frame>

            <!-- Average entropy -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   BorderColor="{StaticResource CardBorder}"
                   IsVisible="{Binding HasResults}">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Average Entropy" FontSize="15" TextColor="{StaticResource PrimaryText}" VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding Report.AverageEntropy, StringFormat='{0:F1} bits'}"
                           FontFamily="OpenSansSemibold" FontSize="15"
                           TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                </Grid>
            </Frame>

            <!-- Weak passwords -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   BorderColor="{StaticResource Danger}"
                   IsVisible="{Binding WeakTitles.Count, Converter={StaticResource StringToBoolConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="⚠ Weak Passwords" FontFamily="OpenSansSemibold" FontSize="14"
                           TextColor="{StaticResource Danger}" />
                    <CollectionView ItemsSource="{Binding WeakTitles}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}" FontSize="14" TextColor="{StaticResource PrimaryText}" Padding="0,2" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Reused passwords -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   BorderColor="{StaticResource Warning}"
                   IsVisible="{Binding ReusedTitles.Count, Converter={StaticResource StringToBoolConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="♻ Reused Passwords" FontFamily="OpenSansSemibold" FontSize="14"
                           TextColor="{StaticResource Warning}" />
                    <CollectionView ItemsSource="{Binding ReusedTitles}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}" FontSize="14" TextColor="{StaticResource PrimaryText}" Padding="0,2" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Old passwords -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   BorderColor="{StaticResource Info}"
                   IsVisible="{Binding OldTitles.Count, Converter={StaticResource StringToBoolConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="🕐 Old Passwords (&gt;1 year)" FontFamily="OpenSansSemibold" FontSize="14"
                           TextColor="{StaticResource Info}" />
                    <CollectionView ItemsSource="{Binding OldTitles}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}" FontSize="14" TextColor="{StaticResource PrimaryText}" Padding="0,2" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <!-- Empty state -->
            <VerticalStackLayout Spacing="12" HorizontalOptions="Center" Margin="0,32,0,0"
                                 IsVisible="{Binding HasResults, Converter={StaticResource InverseBoolConverter}}">
                <Label Text="🛡" FontSize="48" HorizontalOptions="Center" />
                <Label Text="Tap Analyse to check your password health"
                       FontSize="15" TextColor="{StaticResource SecondaryText}"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                <Button Text="Analyse Now" Command="{Binding AnalyseCommand}"
                        BackgroundColor="{StaticResource Primary}" TextColor="#0A0A0A"
                        FontFamily="OpenSansSemibold" HeightRequest="48" CornerRadius="12"
                        Padding="32,0" HorizontalOptions="Center" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
