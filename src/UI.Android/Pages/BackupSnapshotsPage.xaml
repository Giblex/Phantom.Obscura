<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PhantomVault.Android.ViewModels"
             x:Class="PhantomVault.Android.Pages.BackupSnapshotsPage"
             Title="Backup Snapshots"
             BackgroundColor="{StaticResource Background}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="＋" Command="{Binding CreateSnapshotCommand}" />
        <ToolbarItem Text="↺" Command="{Binding RefreshCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Status -->
        <Label Grid.Row="0" Text="{Binding StatusMessage}" FontSize="13"
               TextColor="{StaticResource SecondaryText}" HorizontalOptions="Center"
               Margin="16,8" IsVisible="{Binding StatusMessage, Converter={StaticResource NotNullOrEmptyBoolConverter}}" />

        <!-- Summary -->
        <Frame Grid.Row="1" Margin="16,4" Padding="14,10"
               BackgroundColor="{StaticResource Surface}" CornerRadius="12"
               BorderColor="{StaticResource CardBorder}">
            <Grid ColumnDefinitions="*,*">
                <VerticalStackLayout HorizontalOptions="Center">
                    <Label Text="{Binding SnapshotCount}" FontFamily="OpenSansSemibold"
                           FontSize="22" TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
                    <Label Text="Snapshots" FontSize="11" TextColor="{StaticResource SecondaryText}" HorizontalOptions="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                    <Label Text="{Binding TotalSize}" FontFamily="OpenSansSemibold"
                           FontSize="14" TextColor="{StaticResource PrimaryText}" HorizontalOptions="Center" />
                    <Label Text="Total Size" FontSize="11" TextColor="{StaticResource SecondaryText}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Frame>

        <!-- Snapshot list -->
        <CollectionView Grid.Row="2" ItemsSource="{Binding Snapshots}"
                        Margin="16,0" EmptyView="No backup snapshots found.">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:BackupSnapshotItem">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete" BackgroundColor="#8B2222"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteSnapshotCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Frame Margin="0,4" Padding="14,12"
                               BackgroundColor="{StaticResource Surface}"
                               BorderColor="{StaticResource CardBorder}" CornerRadius="10">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="💾" FontSize="24" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="{Binding FileName}" FontFamily="OpenSansSemibold"
                                           FontSize="14" TextColor="{StaticResource PrimaryText}" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding CreatedDate}" FontSize="12"
                                           TextColor="{StaticResource SecondaryText}" />
                                    <Label Text="{Binding SizeFormatted}" FontSize="11"
                                           TextColor="{StaticResource SecondaryText}" />
                                </VerticalStackLayout>
                                <Button Grid.Column="2" Text="Restore"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RestoreSnapshotCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#1A3A2A" TextColor="#2ECC71"
                                        FontSize="12" CornerRadius="8" Padding="10,6" VerticalOptions="Center" />
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
