<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PhantomVault.Android.ViewModels"
             xmlns:models="clr-namespace:PhantomVault.Core.Models;assembly=PhantomVault.Core"
             x:Class="PhantomVault.Android.Pages.CategoryPage"
             Title="Categories"
             BackgroundColor="{StaticResource Background}">

    <CollectionView ItemsSource="{Binding Groups}"
                    EmptyView="No categories yet. Add a category to a credential by editing it.">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="vm:CategoryGroup">
                <Frame Margin="12,4" Padding="0"
                       BackgroundColor="{StaticResource Surface}"
                       BorderColor="{StaticResource CardBorder}"
                       CornerRadius="12">
                    <VerticalStackLayout>
                        <!-- Category header -->
                        <Grid ColumnDefinitions="*,Auto" Padding="16,12">
                            <VerticalStackLayout>
                                <Label Text="{Binding Name}"
                                       FontFamily="OpenSansSemibold" FontSize="16"
                                       TextColor="{StaticResource PrimaryText}" />
                                <Label Text="{Binding Count, StringFormat='{0} credential(s)'}"
                                       FontSize="12" TextColor="{StaticResource SecondaryText}" />
                            </VerticalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{StaticResource Divider}" />

                        <!-- Credential list within category -->
                        <CollectionView ItemsSource="{Binding Credentials}" Margin="0,4,0,4">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Credential">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,8" ColumnSpacing="12">
                                        <Label Grid.Column="0"
                                               Text="{Binding EntryType, Converter={StaticResource EntryTypeIconConverter}}"
                                               FontSize="20" VerticalOptions="Center" />
                                        <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                            <Label Text="{Binding Title}"
                                                   FontFamily="OpenSansSemibold" FontSize="14"
                                                   TextColor="{StaticResource PrimaryText}" />
                                            <Label Text="{Binding Username}"
                                                   FontSize="12" TextColor="{StaticResource SecondaryText}" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="2" Text="›"
                                                BackgroundColor="Transparent"
                                                TextColor="{StaticResource SecondaryText}"
                                                FontSize="20" Padding="8,0"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenCredentialCommand}"
                                                CommandParameter="{Binding .}" />
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
