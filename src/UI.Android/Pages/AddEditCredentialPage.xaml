<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PhantomVault.Android.ViewModels"
             x:Class="PhantomVault.Android.Pages.AddEditCredentialPage"
             Title="{Binding IsEditMode, Converter={StaticResource BoolToTitleConverter},
                             ConverterParameter='Edit Credential|New Credential'}"
             BackgroundColor="{StaticResource Background}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Save" Command="{Binding SaveCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Error message -->
            <Frame IsVisible="{Binding ErrorMessage, Converter={StaticResource NotNullBoolConverter}}"
                   BackgroundColor="#3D1515" BorderColor="#8B2222" CornerRadius="8" Padding="12">
                <Label Text="{Binding ErrorMessage}" TextColor="#FF6B6B" FontSize="14" />
            </Frame>

            <!-- Entry type picker -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Type" FontSize="12" TextColor="{StaticResource SecondaryText}" />
                    <Picker ItemsSource="{Binding AllEntryTypes}"
                            SelectedItem="{Binding SelectedEntryType}"
                            TextColor="{StaticResource PrimaryText}"
                            BackgroundColor="Transparent"
                            FontSize="15" />
                </VerticalStackLayout>
            </Frame>

            <!-- Title -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Title *" FontSize="12" TextColor="{StaticResource SecondaryText}" />
                    <Entry Text="{Binding Credential.Title}"
                           Placeholder="e.g. GitHub, Netflix…"
                           PlaceholderColor="{StaticResource SecondaryText}"
                           TextColor="{StaticResource PrimaryText}"
                           BackgroundColor="Transparent" FontSize="15" />
                </VerticalStackLayout>
            </Frame>

            <!-- Username (shown for Password and similar types) -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Username / Email" FontSize="12" TextColor="{StaticResource SecondaryText}" />
                    <Entry Text="{Binding Credential.Username}"
                           Placeholder="username or email"
                           PlaceholderColor="{StaticResource SecondaryText}"
                           TextColor="{StaticResource PrimaryText}"
                           BackgroundColor="Transparent" FontSize="15"
                           Keyboard="Email" />
                </VerticalStackLayout>
            </Frame>

            <!-- Password with generate button -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Password" FontSize="12"
                               TextColor="{StaticResource SecondaryText}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Generate"
                                Command="{Binding GeneratePasswordCommand}"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Primary}"
                                FontSize="12" Padding="0" HeightRequest="28" />
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Entry Grid.Column="0"
                               Text="{Binding Credential.Password}"
                               IsPassword="{Binding PasswordVisible, Converter={StaticResource InverseBoolConverter}}"
                               Placeholder="password"
                               PlaceholderColor="{StaticResource SecondaryText}"
                               TextColor="{StaticResource PrimaryText}"
                               BackgroundColor="Transparent" FontSize="15" />
                        <Button Grid.Column="1"
                                Text="{Binding PasswordVisible, Converter={StaticResource BoolToEyeIconConverter}}"
                                Command="{Binding TogglePasswordVisibilityCommand}"
                                BackgroundColor="{StaticResource ButtonSecondary}"
                                TextColor="{StaticResource PrimaryText}"
                                FontSize="16" HeightRequest="36" WidthRequest="40" CornerRadius="8" Padding="0" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- URL -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Website / URL" FontSize="12" TextColor="{StaticResource SecondaryText}" />
                    <Entry Text="{Binding Credential.Url}"
                           Placeholder="https://example.com"
                           PlaceholderColor="{StaticResource SecondaryText}"
                           TextColor="{StaticResource PrimaryText}"
                           BackgroundColor="Transparent" FontSize="15"
                           Keyboard="Url" />
                </VerticalStackLayout>
            </Frame>

            <!-- Notes -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Notes" FontSize="12" TextColor="{StaticResource SecondaryText}" />
                    <Editor Text="{Binding Credential.Notes}"
                            Placeholder="Optional notes…"
                            PlaceholderColor="{StaticResource SecondaryText}"
                            TextColor="{StaticResource PrimaryText}"
                            BackgroundColor="Transparent"
                            AutoSize="TextChanges"
                            MinimumHeightRequest="80"
                            FontSize="14" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
