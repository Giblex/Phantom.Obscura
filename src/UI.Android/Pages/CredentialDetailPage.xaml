<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PhantomVault.Android.ViewModels"
             x:Class="PhantomVault.Android.Pages.CredentialDetailPage"
             Title="{Binding Credential.Title}"
             BackgroundColor="{StaticResource Background}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit" Command="{Binding EditCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <!-- Header card -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="14" Padding="18">
                <Grid ColumnDefinitions="56,*" ColumnSpacing="16">
                    <Frame Grid.Column="0" CornerRadius="14" BackgroundColor="{StaticResource IconBackground}"
                           Padding="0" WidthRequest="52" HeightRequest="52">
                        <Label Text="{Binding Credential.EntryType, Converter={StaticResource EntryTypeIconConverter}}"
                               FontSize="26" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Frame>
                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                        <Label Text="{Binding Credential.Title}"
                               FontFamily="OpenSansSemibold" FontSize="18"
                               TextColor="{StaticResource PrimaryText}" />
                        <Label Text="{Binding Credential.Url}"
                               FontSize="12" TextColor="{StaticResource Primary}"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                </Grid>
            </Frame>

            <!-- Username row -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   IsVisible="{Binding Credential.Username, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Username" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                        <Label Text="{Binding Credential.Username}"
                               FontFamily="OpenSansSemibold" FontSize="15"
                               TextColor="{StaticResource PrimaryText}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1" Text="Copy" Command="{Binding CopyUsernameCommand}"
                            BackgroundColor="{StaticResource ButtonSecondary}"
                            TextColor="{StaticResource PrimaryText}"
                            FontSize="13" HeightRequest="36" CornerRadius="8" Padding="12,0" />
                </Grid>
            </Frame>

            <!-- Password row -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   IsVisible="{Binding Credential.Password, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="Password" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                        <Label Text="{Binding Credential.Password, Converter={StaticResource PasswordMaskConverter}}"
                               FontFamily="OpenSansSemibold" FontSize="15"
                               TextColor="{StaticResource PrimaryText}"
                               x:Name="PasswordLabel" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="{Binding PasswordVisible, Converter={StaticResource BoolToEyeIconConverter}}"
                            Command="{Binding TogglePasswordVisibilityCommand}"
                            BackgroundColor="{StaticResource ButtonSecondary}"
                            TextColor="{StaticResource PrimaryText}"
                            FontSize="16" HeightRequest="36" WidthRequest="40" CornerRadius="8" Padding="0" />
                    <Button Grid.Column="2" Text="Copy" Command="{Binding CopyPasswordCommand}"
                            BackgroundColor="{StaticResource ButtonSecondary}"
                            TextColor="{StaticResource PrimaryText}"
                            FontSize="13" HeightRequest="36" CornerRadius="8" Padding="12,0" />
                </Grid>
            </Frame>

            <!-- TOTP row -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   IsVisible="{Binding TotpCode, Converter={StaticResource NotNullBoolConverter}}">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="One-Time Code" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                        <Label Text="{Binding TotpCode}"
                               FontFamily="OpenSansSemibold" FontSize="24"
                               TextColor="{StaticResource Primary}"
                               CharacterSpacing="6" />
                        <Label Text="{Binding TotpSecondsRemaining, StringFormat='Refreshes in {0}s'}"
                               FontSize="11" TextColor="{StaticResource SecondaryText}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="2" Text="Copy" Command="{Binding CopyTotpCommand}"
                            BackgroundColor="{StaticResource ButtonSecondary}"
                            TextColor="{StaticResource PrimaryText}"
                            FontSize="13" HeightRequest="36" CornerRadius="8" Padding="12,0" />
                </Grid>
            </Frame>

            <!-- Notes -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   IsVisible="{Binding Credential.Notes, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Notes" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                    <Label Text="{Binding Credential.Notes}"
                           FontSize="14" TextColor="{StaticResource PrimaryText}" />
                </VerticalStackLayout>
            </Frame>

            <!-- ── WiFi fields ─────────────────────────────────────────────── -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   IsVisible="{Binding Credential.WiFiSSID, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="WiFi Network" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout>
                            <Label Text="SSID" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                            <Label Text="{Binding Credential.WiFiSSID}" FontFamily="OpenSansSemibold"
                                   FontSize="15" TextColor="{StaticResource PrimaryText}" />
                        </VerticalStackLayout>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto"
                          IsVisible="{Binding Credential.WiFiSecurityType, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                        <VerticalStackLayout>
                            <Label Text="Security" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                            <Label Text="{Binding Credential.WiFiSecurityType}"
                                   FontSize="14" TextColor="{StaticResource PrimaryText}" />
                        </VerticalStackLayout>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"
                          IsVisible="{Binding Credential.WiFiPassword, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                        <VerticalStackLayout>
                            <Label Text="WiFi Password" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                            <Label Text="{Binding Credential.WiFiPassword, Converter={StaticResource PasswordMaskConverter}}"
                                   FontFamily="OpenSansSemibold" FontSize="15" TextColor="{StaticResource PrimaryText}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="2" Text="Copy"
                                BackgroundColor="{StaticResource ButtonSecondary}"
                                TextColor="{StaticResource PrimaryText}"
                                FontSize="13" HeightRequest="36" CornerRadius="8" Padding="12,0"
                                Clicked="OnCopyWifiPasswordTapped" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- ── Credit Card fields ─────────────────────────────────────── -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   IsVisible="{Binding Credential.CardNumber, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Credit / Debit Card" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout>
                            <Label Text="Card Number" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                            <Label Text="{Binding Credential.CardNumber, Converter={StaticResource PasswordMaskConverter}}"
                                   FontFamily="OpenSansSemibold" FontSize="15"
                                   TextColor="{StaticResource PrimaryText}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Copy"
                                BackgroundColor="{StaticResource ButtonSecondary}"
                                TextColor="{StaticResource PrimaryText}"
                                FontSize="13" HeightRequest="36" CornerRadius="8" Padding="12,0"
                                Clicked="OnCopyCardNumberTapped" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout IsVisible="{Binding Credential.CardholderName, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                            <Label Text="Cardholder" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                            <Label Text="{Binding Credential.CardholderName}"
                                   FontSize="14" TextColor="{StaticResource PrimaryText}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1">
                            <Label Text="Expiry" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                            <Label FontSize="14" TextColor="{StaticResource PrimaryText}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Credential.CardExpiryMonth}" />
                                        <Span Text="/" />
                                        <Span Text="{Binding Credential.CardExpiryYear}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto"
                          IsVisible="{Binding Credential.CardCVV, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                        <VerticalStackLayout>
                            <Label Text="CVV" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                            <Label Text="•••" FontFamily="OpenSansSemibold"
                                   FontSize="15" TextColor="{StaticResource PrimaryText}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Copy"
                                BackgroundColor="{StaticResource ButtonSecondary}"
                                TextColor="{StaticResource PrimaryText}"
                                FontSize="13" HeightRequest="36" CornerRadius="8" Padding="12,0"
                                Clicked="OnCopyCvvTapped" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- ── Bank Account fields ────────────────────────────────────── -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   IsVisible="{Binding Credential.BankName, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Bank Account" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                    <Label Text="{Binding Credential.BankName}" FontFamily="OpenSansSemibold"
                           FontSize="16" TextColor="{StaticResource PrimaryText}" />
                    <Grid ColumnDefinitions="*,Auto"
                          IsVisible="{Binding Credential.BankAccountNumber, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                        <VerticalStackLayout>
                            <Label Text="Account Number" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                            <Label Text="{Binding Credential.BankAccountNumber, Converter={StaticResource PasswordMaskConverter}}"
                                   FontSize="14" TextColor="{StaticResource PrimaryText}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Copy"
                                BackgroundColor="{StaticResource ButtonSecondary}"
                                TextColor="{StaticResource PrimaryText}"
                                FontSize="13" HeightRequest="36" CornerRadius="8" Padding="12,0"
                                Clicked="OnCopyBankAccountTapped" />
                    </Grid>
                    <VerticalStackLayout
                        IsVisible="{Binding Credential.BankIBAN, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                        <Label Text="IBAN" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                        <Label Text="{Binding Credential.BankIBAN}"
                               FontSize="13" TextColor="{StaticResource PrimaryText}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout
                        IsVisible="{Binding Credential.BankSWIFT, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                        <Label Text="SWIFT / BIC" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                        <Label Text="{Binding Credential.BankSWIFT}"
                               FontSize="13" TextColor="{StaticResource PrimaryText}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- ── Identity fields ────────────────────────────────────────── -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   IsVisible="{Binding Credential.IdNumber, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Identity Document" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                    <Label Text="{Binding Credential.IdDocumentType}"
                           FontFamily="OpenSansSemibold" FontSize="15" TextColor="{StaticResource PrimaryText}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout>
                            <Label Text="ID Number" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                            <Label Text="{Binding Credential.IdNumber}"
                                   FontSize="14" TextColor="{StaticResource PrimaryText}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1"
                            IsVisible="{Binding Credential.IdIssuingCountry, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                            <Label Text="Country" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                            <Label Text="{Binding Credential.IdIssuingCountry}"
                                   FontSize="14" TextColor="{StaticResource PrimaryText}" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- ── API Key fields ─────────────────────────────────────────── -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   IsVisible="{Binding Credential.ApiKeyValue, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="API Key" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Credential.ApiKeyValue, Converter={StaticResource PasswordMaskConverter}}"
                               FontFamily="OpenSansSemibold" FontSize="14"
                               TextColor="{StaticResource PrimaryText}" />
                        <Button Grid.Column="1" Text="Copy"
                                BackgroundColor="{StaticResource ButtonSecondary}"
                                TextColor="{StaticResource PrimaryText}"
                                FontSize="13" HeightRequest="36" CornerRadius="8" Padding="12,0"
                                Clicked="OnCopyApiKeyTapped" />
                    </Grid>
                    <VerticalStackLayout
                        IsVisible="{Binding Credential.ApiEndpoint, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                        <Label Text="Endpoint" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                        <Label Text="{Binding Credential.ApiEndpoint}"
                               FontSize="13" TextColor="{StaticResource Primary}"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                    <VerticalStackLayout
                        IsVisible="{Binding Credential.ApiEnvironment, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                        <Label Text="Environment" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                        <Label Text="{Binding Credential.ApiEnvironment}"
                               FontSize="13" TextColor="{StaticResource PrimaryText}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- ── Contact fields ─────────────────────────────────────────── -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   IsVisible="{Binding Credential.ContactFullName, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                <VerticalStackLayout Spacing="6">
                    <Label Text="Contact" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                    <Label Text="{Binding Credential.ContactFullName}"
                           FontFamily="OpenSansSemibold" FontSize="16" TextColor="{StaticResource PrimaryText}" />
                    <Label Text="{Binding Credential.ContactEmail}" FontSize="13"
                           TextColor="{StaticResource Primary}"
                           IsVisible="{Binding Credential.ContactEmail, Converter={StaticResource NotNullOrEmptyBoolConverter}}" />
                    <Label Text="{Binding Credential.ContactPhone}" FontSize="13"
                           TextColor="{StaticResource PrimaryText}"
                           IsVisible="{Binding Credential.ContactPhone, Converter={StaticResource NotNullOrEmptyBoolConverter}}" />
                    <Label Text="{Binding Credential.ContactCompany}" FontSize="13"
                           TextColor="{StaticResource SecondaryText}"
                           IsVisible="{Binding Credential.ContactCompany, Converter={StaticResource NotNullOrEmptyBoolConverter}}" />
                </VerticalStackLayout>
            </Frame>

            <!-- ── PIN Code fields ────────────────────────────────────────── -->
            <Frame BackgroundColor="{StaticResource Surface}" CornerRadius="12" Padding="16"
                   IsVisible="{Binding Credential.PinLabel, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="PIN Code" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                    <Label Text="{Binding Credential.PinLabel}"
                           FontFamily="OpenSansSemibold" FontSize="15" TextColor="{StaticResource PrimaryText}" />
                    <Grid ColumnDefinitions="*,Auto"
                          IsVisible="{Binding Credential.PinValue, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                        <VerticalStackLayout>
                            <Label Text="PIN" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                            <Label Text="••••" FontFamily="OpenSansSemibold"
                                   FontSize="18" TextColor="{StaticResource PrimaryText}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Copy"
                                BackgroundColor="{StaticResource ButtonSecondary}"
                                TextColor="{StaticResource PrimaryText}"
                                FontSize="13" HeightRequest="36" CornerRadius="8" Padding="12,0"
                                Clicked="OnCopyPinTapped" />
                    </Grid>
                    <VerticalStackLayout
                        IsVisible="{Binding Credential.PinIssuer, Converter={StaticResource NotNullOrEmptyBoolConverter}}">
                        <Label Text="Issuer" FontSize="11" TextColor="{StaticResource SecondaryText}" />
                        <Label Text="{Binding Credential.PinIssuer}"
                               FontSize="13" TextColor="{StaticResource PrimaryText}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <!-- Status message -->
            <Label Text="{Binding StatusMessage}"
                   FontSize="13" TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center"
                   IsVisible="{Binding StatusMessage, Converter={StaticResource NotNullBoolConverter}}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
